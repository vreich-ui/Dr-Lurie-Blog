---
import Layout from '~/layouts/PageLayout.astro';

import type { MetaData } from '~/types';

export interface Props {
  frontmatter: {
    title?: string;
  };
}

const { frontmatter } = Astro.props;

const metadata: MetaData = {
  title: frontmatter?.title,
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-[720px] px-4 py-16 sm:px-6 lg:py-20">
    <h1 class="font-serif text-4xl font-bold leading-tighter tracking-tighter md:text-5xl">{frontmatter.title}</h1>
    <div class="editorial-prose dl-mt-m dl-gap-m">
      <slot />
    </div>
  </section>
</Layout>
