---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const publicGitHubRepoUrl = import.meta.env.PUBLIC_GITHUB_REPOSITORY_URL ?? '';
const publicGitHubBranch = import.meta.env.PUBLIC_GITHUB_BRANCH ?? 'main';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="admin-page mx-auto max-w-[900px] px-4 py-10 sm:px-6 sm:py-14"
    data-admin-shell
    data-clerk-publishable-key={clerkPublishableKey}
    data-public-github-branch={publicGitHubBranch}
    data-public-github-repo-url={publicGitHubRepoUrl}
    hidden
  >
    <header
      class="admin-header mb-8 flex flex-col gap-4 border-b border-gray-200 pb-6 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800"
    >
      <div>
        <p id="publish-mode" class="admin-kicker text-sm font-semibold uppercase tracking-[0.18em] text-accent">
          Publishing workspace
        </p>
        <h1 class="mt-2 font-heading text-4xl font-bold tracking-tight text-default sm:text-5xl">{pageTitle}</h1>
      </div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <section class="admin-card" aria-label="Publishing form" data-auth-gated hidden>
      <form id="publish-form" class="admin-form">
        <div class="json-import-card" aria-labelledby="json-import-heading">
          <div class="json-import-header">
            <div>
              <h2 id="json-import-heading">Import JSON</h2>
              <p class="hint">Paste article JSON or upload a single <code>.json</code> file to populate this form.</p>
            </div>
            <label class="json-upload-button" for="json-upload">
              <Icon name="tabler:upload" class="json-upload-icon" aria-hidden="true" />
              <span>Upload JSON</span>
            </label>
            <input id="json-upload" class="visually-hidden" type="file" accept=".json" />
          </div>
          <textarea
            id="json-import"
            class="json-import-input"
            rows="6"
            placeholder='{
  "record_type": "content_source",
  "schema_version": "content_source.v1",
  "content": { "title": "Article title" },
  "publication": {
    "publish_payload": {
      "slug": "article-slug",
      "content": "Markdown content"
    }
  },
  "sources": { "source_list": ["Source citation"] }
}'
          ></textarea>
          <div class="json-import-actions">
            <button id="load-json" class="btn-secondary btn-sm" type="button">Load JSON</button>
            <span id="json-upload-name" class="json-upload-name" aria-live="polite"></span>
          </div>
          <p id="json-import-status" class="json-import-status" aria-live="polite"></p>
        </div>

        <div class="field">
          <label for="title">Title</label>
          <input id="title" name="title" type="text" autocomplete="off" />
        </div>

        <div class="field">
          <label for="slug">Slug</label>
          <input
            id="slug"
            name="slug"
            type="text"
            autocomplete="off"
            placeholder="article-slug"
            aria-describedby="slug-edit-hint"
          />
          <p id="slug-edit-hint" class="hint" aria-live="polite" hidden></p>
        </div>

        <div class="field">
          <label for="excerpt">Excerpt</label>
          <textarea
            id="excerpt"
            name="excerpt"
            rows="3"
            maxlength="300"
            placeholder="Short list-card and topic summary copy."></textarea>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="publish-date">Publish date</label>
            <input id="publish-date" name="publishDate" type="datetime-local" />
          </div>

          <div class="field">
            <label for="author">Author</label>
            <input id="author" name="author" type="text" autocomplete="off" placeholder="Dr. Lurié" />
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="category">Category</label>
            <input id="category" name="category" type="text" autocomplete="off" placeholder="Aging skin" />
          </div>

          <div class="field">
            <label for="tags">Tags</label>
            <input id="tags" name="tags" type="text" autocomplete="off" placeholder="barrier function, lipids" />
          </div>
        </div>

        <div class="field checkbox-field">
          <input id="draft" name="draft" type="checkbox" />
          <label for="draft">Save as draft</label>
        </div>

        <div class="field">
          <label for="content">Markdown content</label>
          <textarea id="content" name="content" placeholder="Paste article content here. Markdown is supported."
          ></textarea>
        </div>

        <div class="field">
          <label for="sources">Sources</label>
          <textarea
            id="sources"
            name="sources"
            class="sources-input"
            rows="4"
            placeholder="One source per line, or comma-separated citations."></textarea>
          <p class="hint">Imported <code>sources[]</code> are stored as one citation per line.</p>
        </div>

        <div class="field">
          <label for="image-upload">Image upload</label>
          <input id="image-upload" type="file" multiple accept="image/*" />
          <p class="hint">
            Selected images will be committed with the article under <code>src/assets/images/uploads/</code>.
          </p>
          <ul id="image-list" class="image-list" aria-live="polite"></ul>
        </div>

        <div class="field">
          <label for="featured-image">Featured image</label>
          <select id="featured-image" name="featuredImage">
            <option value="">Select an uploaded image</option>
          </select>
          <input id="existing-featured-image-path" name="existingFeaturedImagePath" type="hidden" />
        </div>

        <div class="field">
          <label for="video-link">Optional video link</label>
          <input id="video-link" name="videoLink" type="url" placeholder="https://example.com/video" />
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="cta-link">Optional CTA link</label>
            <input id="cta-link" name="ctaLink" type="url" placeholder="https://example.com/call-to-action" />
          </div>

          <div class="field">
            <label for="cta-text">Optional CTA text</label>
            <input id="cta-text" name="ctaText" type="text" placeholder="Learn more" />
          </div>
        </div>

        <div class="field">
          <label for="seo-description">Optional SEO description</label>
          <input id="seo-description" name="seoDescription" type="text" maxlength="180" />
        </div>

        <div class="field checkbox-field">
          <input id="overwrite-slug" name="overwrite" type="checkbox" />
          <label for="overwrite-slug">Overwrite an existing article with this slug</label>
        </div>

        <div class="actions">
          <button id="save-draft" class="btn-secondary" type="button">Save Draft</button>
          <button id="preview" class="btn-secondary" type="button">Preview</button>
          <button id="publish" class="btn-primary publish-button" type="button">Publish Article</button>
        </div>
        <p id="status" class="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="admin-card admin-panel" aria-labelledby="preview-heading" data-auth-gated hidden>
      <h2 id="preview-heading">Preview</h2>
      <div class="preview-box">
        <h3 id="preview-title">Untitled article</h3>
        <p>
          Featured image path:
          <span id="preview-featured-image" class="preview-image-path">None selected</span>
        </p>
        <div id="markdown-preview" class="markdown-preview">Preview will appear here.</div>
      </div>
    </section>

    <section class="admin-card admin-panel" aria-labelledby="publish-output-heading" data-auth-gated hidden>
      <h2 id="publish-output-heading">Publish output</h2>
      <p>
        Suggested destination: <span id="suggested-location" class="suggestion">src/data/post/slug.md</span>
      </p>
      <button id="copy-output" class="btn-secondary btn-sm copy-button" type="button">Copy Markdown backup</button>
      <textarea id="output-markdown" class="output-markdown" readonly></textarea>
      <p class="publish-message">
        Publish commits the article to GitHub. This Markdown is a backup preview of what will be saved.
      </p>
    </section>

    <div id="toast" class="toast" aria-live="polite" hidden></div>
  </section>
</Layout>

<style>
  .admin-page {
    color: var(--aw-color-text-default);
  }

  .auth-status {
    margin: -1rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .toast {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    max-width: min(28rem, calc(100vw - 2rem));
    border: 1px solid rgb(22 163 74 / 30%);
    border-radius: 1rem;
    background: rgb(240 253 244 / 96%);
    box-shadow: 0 1rem 2.5rem rgb(15 23 42 / 16%);
    color: rgb(22 101 52);
    padding: 0.9rem 1rem;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .toast a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .toast-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.45rem;
  }

  :global(.dark) .toast {
    border-color: rgb(34 197 94 / 32%);
    background: rgb(20 83 45 / 94%);
    color: rgb(220 252 231);
  }

  .admin-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 84%);
    box-shadow: 0 1.5rem 4rem rgb(15 23 42 / 6%);
    padding: 1.5rem;
  }

  :global(.dark) .admin-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
    box-shadow: none;
  }

  .json-import-card {
    margin-bottom: 1.3rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 1.1rem;
    padding: 1rem;
    background: var(--aw-color-bg-surface);
  }

  :global(.dark) .json-import-card {
    border-color: rgb(30 41 59);
    background: rgb(2 6 23 / 42%);
  }

  .json-import-header,
  .json-import-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .json-import-header {
    margin-bottom: 0.85rem;
  }

  .json-import-card h2 {
    margin: 0;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: 1.15rem;
    font-weight: 800;
  }

  .json-import-input {
    min-height: 9rem;
    max-height: 13rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.92rem;
  }

  .sources-input {
    min-height: 7.5rem;
  }

  .json-upload-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: auto;
    margin: 0;
    border: 1px solid rgb(209 213 219);
    border-radius: 999px;
    padding: 0.62rem 0.9rem;
    color: var(--aw-color-text-heading);
    background: var(--aw-color-bg-page);
    cursor: pointer;
    font-size: 0.92rem;
    white-space: nowrap;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
  }

  .json-upload-button:hover,
  .json-upload-button:focus-within {
    border-color: var(--aw-color-accent);
    box-shadow: 0 0 0 3px rgb(94 140 138 / 14%);
    color: var(--aw-color-accent);
  }

  .json-upload-icon {
    width: 1.05rem;
    height: 1.05rem;
  }

  .json-import-actions {
    margin-top: 0.7rem;
  }

  .json-upload-name {
    color: var(--aw-color-text-muted);
    font-size: 0.88rem;
    overflow-wrap: anywhere;
  }

  .json-import-status {
    min-height: 1.3em;
    margin: 0.65rem 0 0;
    color: var(--aw-color-text-muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .json-import-status.is-error {
    color: var(--aw-color-accent);
  }

  .json-import-status.is-success {
    color: var(--aw-color-secondary);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
    padding: 0;
  }

  .admin-panel {
    margin-top: 1.5rem;
  }

  .admin-panel h2 {
    margin: 0 0 0.9rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .field {
    margin-bottom: 1.15rem;
  }

  .field-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .field-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  label,
  .field-title {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--aw-color-text-heading);
    font-weight: 700;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.85rem;
    padding: 0.78rem 0.9rem;
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-page);
    font: inherit;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  :global(.dark) input,
  :global(.dark) select,
  :global(.dark) textarea {
    border-color: rgb(51 65 85);
    background: rgb(2 6 23 / 70%);
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--aw-color-accent);
    box-shadow: 0 0 0 3px rgb(94 140 138 / 18%);
    outline: none;
  }

  input.is-error {
    border-color: var(--aw-color-accent);
    background: rgb(254 242 242 / 72%);
  }

  input.is-error:focus {
    box-shadow: 0 0 0 3px rgb(190 58 58 / 18%);
  }

  :global(.dark) input.is-error {
    background: rgb(127 29 29 / 18%);
  }

  textarea {
    min-height: 420px;
    resize: vertical;
    line-height: 1.6;
  }

  .json-import-input,
  .sources-input,
  #excerpt {
    min-height: auto;
  }

  .hint {
    margin: 0.45rem 0 0;
    color: var(--aw-color-text-muted);
    font-size: 0.92rem;
  }

  .hint.is-error {
    color: var(--aw-color-accent);
    font-weight: 700;
  }

  .image-list {
    display: grid;
    gap: 0.6rem;
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
  }

  .image-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 0.75rem;
    background: var(--aw-color-bg-surface);
  }

  :global(.dark) .image-list li {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
  }

  .filename,
  .preview-image-path,
  .suggestion {
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  .filename {
    font-size: 0.9rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .publish-button {
    box-shadow: 0 0.9rem 1.8rem rgb(46 111 149 / 20%);
  }

  .copy-button {
    margin-bottom: 0.8rem;
  }

  .preview-box,
  .output-box {
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 1rem;
    background: var(--aw-color-bg-page);
  }

  :global(.dark) .preview-box,
  :global(.dark) .output-box {
    border-color: rgb(30 41 59);
  }

  .preview-box h3 {
    margin: 0 0 0.75rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
  }

  .markdown-preview {
    margin-top: 1rem;
    line-height: 1.7;
  }

  .markdown-preview h1,
  .markdown-preview h2,
  .markdown-preview h3 {
    margin: 1rem 0 0.5rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
  }

  .markdown-preview p {
    margin: 0 0 0.8rem;
  }

  .markdown-preview code {
    border-radius: 0.4rem;
    padding: 0.12rem 0.32rem;
    background: var(--aw-color-bg-surface);
  }

  .output-markdown {
    min-height: 260px;
    margin-top: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.9rem;
  }

  .publish-message {
    margin: 0.85rem 0 0;
    color: var(--aw-color-secondary);
    font-weight: 800;
  }

  .checkbox-field {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .checkbox-field input {
    width: auto;
    margin-top: 0.25rem;
  }

  .checkbox-field label {
    margin-bottom: 0;
  }

  .status {
    min-height: 1.3em;
    margin: 0.9rem 0 0;
    color: var(--aw-color-accent);
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .admin-page {
      padding-top: 1.5rem;
      padding-bottom: 2.5rem;
    }

    .admin-card {
      border-radius: 1.1rem;
      padding: 1rem;
    }

    .image-list li {
      align-items: stretch;
      flex-direction: column;
    }

    .json-import-header,
    .json-import-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .json-upload-button,
    .json-import-actions > button {
      width: 100%;
    }

    .actions > button {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (() => {
    const draftKey = 'dr-lurie-admin-draft';
    const fields = {
      title: document.querySelector('#title'),
      slug: document.querySelector('#slug'),
      slugHint: document.querySelector('#slug-edit-hint'),
      excerpt: document.querySelector('#excerpt'),
      publishDate: document.querySelector('#publish-date'),
      author: document.querySelector('#author'),
      category: document.querySelector('#category'),
      tags: document.querySelector('#tags'),
      sources: document.querySelector('#sources'),
      jsonImport: document.querySelector('#json-import'),
      jsonUpload: document.querySelector('#json-upload'),
      jsonUploadName: document.querySelector('#json-upload-name'),
      jsonImportStatus: document.querySelector('#json-import-status'),
      draft: document.querySelector('#draft'),
      content: document.querySelector('#content'),
      imageUpload: document.querySelector('#image-upload'),
      imageList: document.querySelector('#image-list'),
      featuredImage: document.querySelector('#featured-image'),
      existingFeaturedImagePath: document.querySelector('#existing-featured-image-path'),
      videoLink: document.querySelector('#video-link'),
      ctaLink: document.querySelector('#cta-link'),
      ctaText: document.querySelector('#cta-text'),
      seoDescription: document.querySelector('#seo-description'),
      overwrite: document.querySelector('#overwrite-slug'),
      status: document.querySelector('#status'),
      previewTitle: document.querySelector('#preview-title'),
      previewFeaturedImage: document.querySelector('#preview-featured-image'),
      markdownPreview: document.querySelector('#markdown-preview'),
      suggestedLocation: document.querySelector('#suggested-location'),
      outputMarkdown: document.querySelector('#output-markdown'),
      publish: document.querySelector('#publish'),
      publishMode: document.querySelector('#publish-mode'),
      toast: document.querySelector('#toast'),
    };

    let imageNames = [];
    let selectedFiles = [];
    let imagePreviewUrls = [];
    let imageUploadMessage = '';
    let imageUploadMessageIsError = false;
    let isAdmin = false;
    let editArticleLoaded = false;

    const adminPage = document.querySelector('.admin-page');
    const clerkPublishableKey = adminPage?.dataset.clerkPublishableKey || '';
    const publicGitHubBranch = adminPage?.dataset.publicGithubBranch || 'main';
    const publicGitHubRepoUrl = adminPage?.dataset.publicGithubRepoUrl || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
    const slugPattern = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
    const slugInvalidMessage = 'Slug must contain lowercase letters, numbers, and hyphens (a-z0-9-).';
    const allowedImageTypes = new Set(['image/png', 'image/jpeg', 'image/webp']);
    const maxImageFileSizeBytes = 0.5 * 1024 * 1024;
    const maxImageCount = 10;
    const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
    const adminShell = document.querySelector('[data-admin-shell]');
    const authStatus = document.querySelector('[data-auth-status]');
    let clerkLoadPromise;
    let toastTimer;

    const getEditSlug = () => slugify(new URLSearchParams(window.location.search).get('edit') || '');

    const isEditMode = () => Boolean(getEditSlug());

    const getSlugEditHint = () =>
      isEditMode() ? `Slug is locked in edit mode. Updates overwrite src/data/post/${getEditSlug()}.md in place.` : '';

    const renderSlugHint = (isInvalid) => {
      const editHint = getSlugEditHint();
      fields.slugHint.textContent = isInvalid ? slugInvalidMessage : editHint;
      fields.slugHint.hidden = !isInvalid && !editHint;
      fields.slugHint.classList.toggle('is-error', isInvalid);
    };

    const validateSlug = ({ announce = false } = {}) => {
      const slug = fields.slug.value.trim();
      const isInvalid = Boolean(slug) && !slugPattern.test(slug);
      fields.slug.classList.toggle('is-error', isInvalid);
      fields.slug.setAttribute('aria-invalid', String(isInvalid));
      renderSlugHint(isInvalid);

      if (isInvalid && announce) setStatus(slugInvalidMessage, false);
      return !isInvalid;
    };

    const updatePublishButtonState = () => {
      fields.publish.disabled = !isAdmin || !validateSlug();
    };

    const setEditorModeCopy = (mode) => {
      const editing = mode === 'edit';
      fields.publishMode.textContent = editing ? 'Editing article' : 'Publishing workspace';
      fields.publish.textContent = editing ? 'Update Article' : 'Publish Article';
      fields.overwrite.checked = editing || fields.overwrite.checked;
      fields.slug.disabled = editing;
      validateSlug();
    };

    const setGatedContentVisible = (visible) => {
      gatedContent.forEach((element) => {
        element.hidden = !visible;
      });
    };

    const loadClerkScript = () =>
      new Promise((resolve, reject) => {
        if (window.Clerk) {
          console.info('Clerk script loaded');
          resolve();
          return;
        }

        const resolveWhenClerkExists = () => {
          if (!window.Clerk) {
            reject(new Error('Clerk authentication could not be initialized.'));
            return;
          }

          console.info('Clerk script loaded');
          resolve();
        };

        const existingScript = document.querySelector(
          `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
        );
        if (existingScript) {
          existingScript.addEventListener('load', resolveWhenClerkExists, { once: true });
          existingScript.addEventListener(
            'error',
            (event) => {
              console.error('ClerkJS script failed to load from existing script tag.', event);
              reject(new Error('Clerk authentication could not be loaded.'));
            },
            { once: true }
          );
          return;
        }

        const script = document.createElement('script');
        script.src = clerkJsScriptSrc;
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.type = 'text/javascript';
        script.dataset.drLurieClerkjs = 'true';
        script.dataset.clerkPublishableKey = clerkPublishableKey;
        script.addEventListener('load', resolveWhenClerkExists, { once: true });
        script.addEventListener(
          'error',
          (event) => {
            console.error('ClerkJS script failed to load.', event);
            reject(new Error('Clerk authentication could not be loaded.'));
          },
          { once: true }
        );
        document.head.append(script);
      });

    const getClerk = async () => {
      if (!clerkPublishableKey) {
        throw new Error('Publishing authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.');
      }

      clerkLoadPromise ||= (async () => {
        await loadClerkScript();

        if (!window.Clerk) {
          throw new Error('Clerk authentication could not be initialized.');
        }

        const clerk = window.Clerk;
        await clerk.load();
        console.info('Clerk initialized', {
          status: clerk.status,
          isSignedIn: Boolean(clerk.isSignedIn),
        });
        return clerk;
      })();

      return clerkLoadPromise;
    };

    const setAdminShellVisible = (visible) => {
      if (adminShell) adminShell.hidden = !visible;
    };

    const redirectToHome = () => {
      window.location.replace('/');
    };

    const authStatusMessages = {
      checking: 'Checking admin access…',
      'signed-out': 'Sign in to view admin tools.',
      forbidden: 'Access denied (not an admin).',
      error: 'Admin auth failed. Please refresh or contact support.',
      'signed-in': '',
    };

    const setAuthStatus = (message) => {
      if (authStatus) authStatus.textContent = message;
    };

    const setAuthState = (state) => {
      isAdmin = state === 'signed-in';
      setAuthStatus(authStatusMessages[state] || '');
      setAdminShellVisible(isAdmin);
      updatePublishButtonState();
      setGatedContentVisible(isAdmin);

      if (!isAdmin && state !== 'checking') redirectToHome();
    };

    const getAdminStateForClerk = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };

      const token = await clerk.session.getToken();
      if (!token) return { authenticated: true, isAdmin: false, error: 'Could not retrieve a Clerk session token.' };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response
        .json()
        .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
    };

    const renderAuthState = async (clerk) => {
      const signedIn = Boolean(clerk.isSignedIn && clerk.session);
      console.info('Clerk signed-in state', { isSignedIn: signedIn });

      if (signedIn) {
        const adminState = await getAdminStateForClerk(clerk);

        if (adminState.isAdmin) {
          setAuthState('signed-in');
          await initializeEditMode(clerk);
          return;
        }

        setAuthState('forbidden');
        return;
      }

      setAuthState('signed-out');
    };

    const initializeClerkAuth = async () => {
      setAuthState('checking');

      try {
        const clerk = await getClerk();
        await renderAuthState(clerk);

        if (typeof clerk.addListener === 'function') {
          clerk.addListener(() => {
            renderAuthState(clerk).catch((error) => {
              console.error('Clerk authentication refresh failed.', error);
            });
          });
        }
      } catch (error) {
        console.error('Clerk authentication initialization failed.', error);
        const message = error instanceof Error ? error.message : 'Clerk authentication could not be initialized.';
        setAuthState('error');
        setStatus(message, false);
      }
    };

    const getClerkSessionToken = async () => {
      const clerk = await getClerk();
      if (!clerk.isSignedIn || !clerk.session) {
        throw new Error('Authenticate with Clerk before publishing.');
      }

      if (!isAdmin) {
        throw new Error('This account is not authorized to publish articles.');
      }

      const token = await clerk.session.getToken();

      if (!token) {
        throw new Error('Could not retrieve a Clerk session token.');
      }

      return token;
    };

    const escapeHtml = (value) =>
      String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const escapeYaml = (value) => String(value).replaceAll('\\', '\\\\').replaceAll('"', '\\"');

    const formatDateTimeLocal = (date) => {
      const offset = date.getTimezoneOffset();
      const localDate = new Date(date.getTime() - offset * 60000);
      return localDate.toISOString().slice(0, 16);
    };

    const getPublishDate = () => (fields.publishDate.value ? new Date(fields.publishDate.value) : new Date());

    const parseTags = (value) =>
      String(value)
        .split(',')
        .map((tag) => tag.trim())
        .filter(Boolean);

    const parseSources = (value) =>
      String(value)
        .split(/\n|,/)
        .map((source) => source.trim())
        .filter(Boolean);

    const isSimpleImportObject = (value) =>
      Boolean(
        value &&
          typeof value === 'object' &&
          !Array.isArray(value) &&
          Object.values(value).every((item) => item == null || ['string', 'number', 'boolean'].includes(typeof item))
      );

    const formatImportedSource = (source) => {
      if (typeof source === 'string') return source.trim();
      if (!isSimpleImportObject(source)) return '';

      return Object.entries(source)
        .map(([key, value]) => {
          if (value == null || String(value).trim() === '') return '';
          return `${key}: ${String(value).trim()}`;
        })
        .filter(Boolean)
        .join('; ');
    };

    const formatImportedList = (value) => value.map(formatImportedSource).filter(Boolean).join('\n');

    const slugify = (value) =>
      String(value)
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');

    const sanitizeFilename = (value) =>
      String(value)
        .split(/[\\/]/)
        .pop()
        .toLowerCase()
        .replace(/[^a-z0-9._-]+/g, '-')
        .replace(/^-+|-+$/g, '') || 'upload';

    const getCurrentSlug = () =>
      isEditMode()
        ? getEditSlug()
        : slugify(fields.slug.value || fields.title.value || 'untitled-article') || 'untitled-article';

    const getUploadPath = (filename) => `~/assets/images/uploads/${getCurrentSlug()}/${filename}`;

    const getFeaturedImagePath = () => {
      const value = fields.featuredImage.value.trim();
      if (!value) return '';
      if (value.startsWith('~/assets/images/uploads/') || value.startsWith('https://')) return value;
      return getUploadPath(value);
    };

    const getDraft = () => ({
      title: fields.title.value,
      slug: fields.slug.value,
      excerpt: fields.excerpt.value,
      publishDate: fields.publishDate.value,
      author: fields.author.value,
      category: fields.category.value,
      tags: fields.tags.value,
      draft: fields.draft.checked,
      content: fields.content.value,
      sources: fields.sources.value,
      imageNames,
      featuredImage: fields.featuredImage.value,
      existingFeaturedImagePath: fields.existingFeaturedImagePath.value,
      videoLink: fields.videoLink.value,
      ctaLink: fields.ctaLink.value,
      ctaText: fields.ctaText.value,
      seoDescription: fields.seoDescription.value,
      overwrite: fields.overwrite.checked,
    });

    const getCheckedOutWorkflowDraft = () => {
      const params = new URLSearchParams(window.location.search);
      const requestId = params.get('request_id') || sessionStorage.getItem('dr-lurie-workflow-request-id') || '';
      const lockToken = params.get('lock_token') || sessionStorage.getItem('dr-lurie-workflow-lock-token') || '';

      return { requestId: requestId.trim(), lockToken: lockToken.trim() };
    };

    const buildContentSourceDraft = () => {
      const { slug, markdown } = buildMarkdown();
      const featuredImage = getFeaturedImagePath();
      const title = fields.title.value.trim();
      const author = fields.author.value.trim();
      const tags = parseTags(fields.tags.value);
      const publishDate = getPublishDate().toISOString();
      const payload = {
        slug,
        title,
        markdown,
        content: fields.content.value,
        publishDate,
        author,
        tags,
        draft: true,
        overwrite: fields.overwrite.checked,
        ...(fields.excerpt.value.trim()
          ? { excerpt: fields.excerpt.value.trim(), description: fields.excerpt.value.trim() }
          : {}),
        ...(fields.category.value.trim() ? { category: fields.category.value.trim() } : {}),
        ...(fields.seoDescription.value.trim() ? { seoDescription: fields.seoDescription.value.trim() } : {}),
        ...(featuredImage ? { featuredImage } : {}),
        ...(fields.existingFeaturedImagePath.value.trim()
          ? { existingFeaturedImagePath: fields.existingFeaturedImagePath.value.trim() }
          : {}),
        ...(fields.videoLink.value.trim() ? { videoLink: fields.videoLink.value.trim() } : {}),
        ...(fields.ctaLink.value.trim() ? { ctaLink: fields.ctaLink.value.trim() } : {}),
        ...(fields.ctaText.value.trim() ? { ctaText: fields.ctaText.value.trim() } : {}),
        metadata: {
          form_schema: 'admin_publish_form.v1',
          raw_sources: parseSources(fields.sources.value),
          uploaded_image_names: imageNames,
        },
      };

      return {
        record_type: 'content_source',
        schema_version: 'content_source.v1',
        content: {
          schema_version: 'content_blocks.v1',
          title,
          ...(fields.excerpt.value.trim()
            ? { deck: fields.excerpt.value.trim(), description: fields.excerpt.value.trim() }
            : {}),
          blocks: fields.content.value.trim()
            ? [
                {
                  block_id: 'admin-draft-markdown',
                  block_type: 'markdown',
                  payload: { markdown: fields.content.value },
                  section_id: 'body',
                },
              ]
            : [],
        },
        taxonomy: {
          schema_version: 'taxonomy.v1',
          tags,
        },
        seo: {
          schema_version: 'seo.v1',
          ...(fields.title.value.trim() ? { meta_title: fields.title.value.trim() } : {}),
          ...(fields.seoDescription.value.trim() ? { meta_description: fields.seoDescription.value.trim() } : {}),
        },
        editorial: {
          schema_version: 'editorial.v1',
          draft_markdown: fields.content.value,
        },
        publication: {
          schema_version: 'publication.v1',
          publication_status: 'draft',
          publish_payload: payload,
        },
        workflow: {
          schema_version: 'content_workflow.v1',
          current_agent: 'draft',
          next_agent: 'final_article',
          handoff_notes: 'Admin JSON draft saved from the publishing form.',
        },
        versioning: {
          schema_version: 'versioning.v1',
          record_version: 1,
        },
      };
    };

    const setStatus = (message, autoClear = true) => {
      fields.status.textContent = message;
      if (message && autoClear) {
        window.setTimeout(() => {
          if (fields.status.textContent === message) fields.status.textContent = '';
        }, 2500);
      }
    };

    const getPublicGitHubRepoUrl = () => {
      if (!publicGitHubRepoUrl) return '';

      try {
        const url = new URL(publicGitHubRepoUrl);
        return url.hostname === 'github.com'
          ? url
              .toString()
              .replace(/\.git\/?$/, '')
              .replace(/\/$/, '')
          : '';
      } catch {
        return '';
      }
    };

    const getGitHubToastLinks = ({ articlePath, commit }) => {
      const repoUrl = getPublicGitHubRepoUrl();
      if (!repoUrl) return [];

      const links = [];
      const safeArticlePath = String(articlePath || '').replace(/^\/+/, '');
      const safeCommit = String(commit || '').trim();
      const safeBranch = String(publicGitHubBranch || 'main').trim();
      const fileRef = safeCommit || safeBranch;

      if (safeArticlePath) {
        links.push({
          href: `${repoUrl}/blob/${encodeURIComponent(fileRef)}/${safeArticlePath.split('/').map(encodeURIComponent).join('/')}`,
          label: 'View article on GitHub',
        });
      }

      if (safeCommit) {
        links.push({
          href: `${repoUrl}/commit/${encodeURIComponent(safeCommit)}`,
          label: 'View commit',
        });
      }

      return links;
    };

    const showToast = (message, links = []) => {
      if (!fields.toast) return;

      window.clearTimeout(toastTimer);
      fields.toast.replaceChildren();
      const messageElement = document.createElement('div');
      messageElement.textContent = message;
      fields.toast.append(messageElement);

      if (links.length) {
        const linksElement = document.createElement('div');
        linksElement.className = 'toast-links';
        links.forEach((link) => {
          const anchor = document.createElement('a');
          anchor.href = link.href;
          anchor.textContent = link.label;
          anchor.target = '_blank';
          anchor.rel = 'noopener noreferrer';
          linksElement.append(anchor);
        });
        fields.toast.append(linksElement);
      }

      fields.toast.hidden = false;
      toastTimer = window.setTimeout(() => {
        fields.toast.hidden = true;
        fields.toast.replaceChildren();
      }, 4000);
    };

    const setJsonImportStatus = (message, isError = false, mirrorGlobal = true) => {
      fields.jsonImportStatus.textContent = message;
      fields.jsonImportStatus.classList.toggle('is-error', Boolean(message && isError));
      fields.jsonImportStatus.classList.toggle('is-success', Boolean(message && !isError));

      if (mirrorGlobal) setStatus(message, !isError);
    };

    const copyText = async (text, successMessage) => {
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
        setStatus(successMessage);
      } catch {
        fields.outputMarkdown.value = text;
        fields.outputMarkdown.focus();
        fields.outputMarkdown.select();
        setStatus('Clipboard unavailable. Text selected for manual copy.');
      }
    };

    const formatFileSize = (bytes) => {
      if (!Number.isFinite(bytes) || bytes < 0) return 'Unknown size';
      if (bytes >= 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
      return `${Math.max(1, Math.round(bytes / 1024))} KB`;
    };

    const revokeImagePreviews = () => {
      imagePreviewUrls.forEach((url) => URL.revokeObjectURL(url));
      imagePreviewUrls = [];
    };

    const syncImageInputFiles = () => {
      if (typeof DataTransfer !== 'function') return;

      const dataTransfer = new DataTransfer();
      selectedFiles.forEach((file) => dataTransfer.items.add(file));
      fields.imageUpload.files = dataTransfer.files;
    };

    const setImageUploadMessage = (message, isError = false) => {
      imageUploadMessage = message;
      imageUploadMessageIsError = isError;
    };

    const validateImageFiles = (files) => {
      const validFiles = [];
      const errors = [];

      files.forEach((file) => {
        if (validFiles.length >= maxImageCount) {
          errors.push(`${file.name} was skipped because only ${maxImageCount} images can be uploaded at once.`);
          return;
        }

        if (!allowedImageTypes.has(file.type)) {
          errors.push(`${file.name} was skipped because ${file.type || 'its file type'} is not supported.`);
          return;
        }

        if (file.size > maxImageFileSizeBytes) {
          errors.push(
            `${file.name} was skipped because ${formatFileSize(file.size)} exceeds the ${formatFileSize(
              maxImageFileSizeBytes
            )} limit.`
          );
          return;
        }

        validFiles.push(file);
      });

      return { validFiles, errors };
    };

    const removeSelectedImage = (index) => {
      const previousFeaturedImage = fields.featuredImage.value;
      selectedFiles.splice(index, 1);
      imageNames = selectedFiles.map((file) => sanitizeFilename(file.name));
      syncImageInputFiles();
      setImageUploadMessage(
        imageNames.length ? `Removed image. ${imageNames.length} selected.` : 'Removed image.',
        false
      );
      renderImages();
      if (previousFeaturedImage && imageNames.includes(previousFeaturedImage)) {
        fields.featuredImage.value = previousFeaturedImage;
      }
      updatePreview();
      updatePublishOutput();
    };

    const renderImages = () => {
      const previousFeaturedImage = fields.featuredImage.value;
      fields.imageList.innerHTML = '';
      fields.featuredImage.innerHTML = '<option value="">Select an uploaded image</option>';
      revokeImagePreviews();

      if (imageUploadMessage) {
        const messageItem = document.createElement('li');
        messageItem.setAttribute('role', 'status');
        messageItem.style.color = imageUploadMessageIsError ? 'var(--aw-color-accent)' : 'var(--aw-color-secondary)';
        messageItem.style.fontWeight = '700';
        messageItem.textContent = imageUploadMessage;
        fields.imageList.append(messageItem);
      }

      imageNames.forEach((name, index) => {
        const file = selectedFiles[index];
        const option = document.createElement('option');
        option.value = name;
        option.textContent = name;
        fields.featuredImage.append(option);

        const item = document.createElement('li');
        const details = document.createElement('span');
        const filename = document.createElement('span');
        const meta = document.createElement('span');
        const actions = document.createElement('span');
        const copyButton = document.createElement('button');
        const removeButton = document.createElement('button');

        details.style.display = 'flex';
        details.style.alignItems = 'center';
        details.style.gap = '0.75rem';
        details.style.minWidth = '0';
        filename.className = 'filename';
        filename.textContent = name;
        meta.textContent = file ? `${formatFileSize(file.size)} • ${file.type || 'unknown type'}` : 'Saved upload';
        meta.style.display = 'block';
        meta.style.color = 'var(--aw-color-text-muted)';
        meta.style.fontSize = '0.85rem';
        actions.style.display = 'flex';
        actions.style.flexWrap = 'wrap';
        actions.style.gap = '0.5rem';

        if (file) {
          const previewUrl = URL.createObjectURL(file);
          const thumbnail = document.createElement('img');
          imagePreviewUrls.push(previewUrl);
          thumbnail.src = previewUrl;
          thumbnail.alt = `Preview of ${name}`;
          thumbnail.loading = 'lazy';
          thumbnail.style.width = '4rem';
          thumbnail.style.height = '4rem';
          thumbnail.style.flex = '0 0 auto';
          thumbnail.style.borderRadius = '0.75rem';
          thumbnail.style.objectFit = 'cover';
          details.append(thumbnail);
        }

        const text = document.createElement('span');
        text.append(filename, meta);
        details.append(text);

        copyButton.className = 'btn-secondary btn-sm copy-button';
        copyButton.type = 'button';
        copyButton.textContent = 'Copy Markdown';
        copyButton.addEventListener('click', () => {
          copyText(`![Alt text](${getUploadPath(name)})`, `Copied Markdown for ${name}.`);
        });

        removeButton.className = 'btn-secondary btn-sm';
        removeButton.type = 'button';
        removeButton.textContent = 'Remove';
        removeButton.addEventListener('click', () => removeSelectedImage(index));

        actions.append(copyButton, removeButton);
        item.append(details, actions);
        fields.imageList.append(item);
      });

      if (previousFeaturedImage && imageNames.includes(previousFeaturedImage)) {
        fields.featuredImage.value = previousFeaturedImage;
      }
    };

    const renderMarkdownPreview = (markdown) => {
      if (!markdown.trim()) return 'Preview will appear here.';

      return markdown
        .split(/\n{2,}/)
        .map((block) => {
          const text = block.trim();
          if (!text) return '';
          if (text.startsWith('### ')) return `<h3>${escapeHtml(text.slice(4))}</h3>`;
          if (text.startsWith('## ')) return `<h2>${escapeHtml(text.slice(3))}</h2>`;
          if (text.startsWith('# ')) return `<h1>${escapeHtml(text.slice(2))}</h1>`;
          if (text.startsWith('![')) return `<p><code>${escapeHtml(text)}</code></p>`;

          const inline = escapeHtml(text)
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.*?)\*/g, '<em>$1</em>')
            .replace(/`([^`]+)`/g, '<code>$1</code>')
            .replace(/\n/g, '<br />');
          return `<p>${inline}</p>`;
        })
        .join('');
    };

    const updatePreview = () => {
      const featuredPath = getFeaturedImagePath();
      fields.previewTitle.textContent = fields.title.value || 'Untitled article';
      fields.previewFeaturedImage.textContent = featuredPath || 'None selected';
      fields.markdownPreview.innerHTML = renderMarkdownPreview(fields.content.value);
    };

    const buildMarkdown = () => {
      const slug = getCurrentSlug();
      const featuredPath = getFeaturedImagePath();
      const tags = parseTags(fields.tags.value);
      const sources = parseSources(fields.sources.value);
      const publishDate = getPublishDate().toISOString();
      const frontmatter = [
        '---',
        `title: "${escapeYaml(fields.title.value || 'Untitled article')}"`,
        `publishDate: ${publishDate}`,
        ...(fields.draft.checked ? ['draft: true'] : []),
        ...(fields.excerpt.value ? [`excerpt: "${escapeYaml(fields.excerpt.value)}"`] : []),
        ...(featuredPath ? [`image: "${escapeYaml(featuredPath)}"`] : []),
        ...(fields.videoLink.value ? [`video: "${escapeYaml(fields.videoLink.value)}"`] : []),
        ...(fields.ctaLink.value ? [`ctaLink: "${escapeYaml(fields.ctaLink.value)}"`] : []),
        ...(fields.ctaText.value ? [`ctaText: "${escapeYaml(fields.ctaText.value)}"`] : []),
        ...(fields.category.value ? [`category: "${escapeYaml(fields.category.value)}"`] : []),
        ...(tags.length ? ['tags:', ...tags.map((tag) => `  - "${escapeYaml(tag)}"`)] : []),
        ...(fields.author.value ? [`author: "${escapeYaml(fields.author.value)}"`] : []),
        ...(sources.length ? ['sources:', ...sources.map((source) => `  - "${escapeYaml(source)}"`)] : []),
        ...(fields.seoDescription.value
          ? ['metadata:', `  description: "${escapeYaml(fields.seoDescription.value)}"`]
          : []),
        '---',
        '',
      ];

      return {
        slug,
        markdown: `${frontmatter.join('\n')}${fields.content.value.trim()}\n`,
      };
    };

    const updatePublishOutput = () => {
      const { slug, markdown } = buildMarkdown();
      fields.suggestedLocation.textContent = `src/data/post/${slug}.md`;
      fields.outputMarkdown.value = markdown;
    };

    const saveLocalRecoveryDraft = () => {
      try {
        localStorage.setItem(draftKey, JSON.stringify(getDraft()));
        return true;
      } catch (error) {
        console.warn('Local recovery draft could not be saved.', error);
        return false;
      }
    };

    const clearLocalCheckoutState = () => {
      sessionStorage.removeItem('dr-lurie-workflow-request-id');
      sessionStorage.removeItem('dr-lurie-workflow-lock-token');
      localStorage.removeItem(draftKey);
    };

    const saveDraft = async () => {
      const saveButton = document.querySelector('#save-draft');
      const computedSlug = slugify(fields.slug.value || fields.title.value);
      const hasMinimumFields = Boolean(fields.title.value.trim() && computedSlug && fields.author.value.trim());

      if (!hasMinimumFields) {
        setStatus('Title, slug, and author are required to save JSON draft.', false);
        return;
      }

      const confirmed = window.confirm('Save draft JSON to Blobs and return to Admin Dashboard?');
      if (!confirmed) return;

      saveButton.disabled = true;
      setStatus('Saving JSON draft to Blobs…', false);

      try {
        const clerkToken = await getClerkSessionToken();
        const { requestId, lockToken } = getCheckedOutWorkflowDraft();
        const response = await fetch('/.netlify/functions/admin-save-json-draft', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${clerkToken}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            ...(requestId ? { request_id: requestId } : {}),
            ...(lockToken ? { lock_token: lockToken } : {}),
            input: buildContentSourceDraft(),
          }),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || `JSON draft could not be saved (${response.status}).`);
        }

        clearLocalCheckoutState();
        window.location.href = '/admin';
      } catch (error) {
        console.error('JSON draft save failed.', error);
        const recoverySaved = saveLocalRecoveryDraft();
        const message = error instanceof Error ? error.message : 'JSON draft could not be saved.';
        setStatus(
          recoverySaved
            ? `${message} A local recovery draft was saved, but JSON was not saved to Blobs.`
            : `${message} JSON was not saved to Blobs and local recovery failed.`,
          false
        );
      } finally {
        saveButton.disabled = false;
      }
    };

    const loadDraft = () => {
      const saved = localStorage.getItem(draftKey);
      if (!saved) return;

      try {
        const draft = JSON.parse(saved);
        fields.title.value = draft.title || '';
        fields.slug.value = draft.slug || '';
        fields.excerpt.value = draft.excerpt || '';
        fields.publishDate.value = draft.publishDate || formatDateTimeLocal(new Date());
        fields.author.value = draft.author || '';
        fields.category.value = draft.category || '';
        fields.tags.value = draft.tags || '';
        fields.draft.checked = Boolean(draft.draft);
        fields.content.value = draft.content || '';
        fields.sources.value = draft.sources || '';
        fields.videoLink.value = draft.videoLink || '';
        fields.ctaLink.value = draft.ctaLink || '';
        fields.ctaText.value = draft.ctaText || '';
        fields.seoDescription.value = draft.seoDescription || '';
        fields.overwrite.checked = Boolean(draft.overwrite);
        imageNames = Array.isArray(draft.imageNames) ? draft.imageNames : [];
        renderImages();
        fields.existingFeaturedImagePath.value = draft.existingFeaturedImagePath || '';
        if (draft.existingFeaturedImagePath) ensureFeaturedImageOption(draft.existingFeaturedImagePath);
        fields.featuredImage.value = draft.featuredImage || draft.existingFeaturedImagePath || '';
      } catch {
        localStorage.removeItem(draftKey);
      }
    };

    const ensureFeaturedImageOption = (value) => {
      if (!value || Array.from(fields.featuredImage.options).some((option) => option.value === value)) return;

      const option = document.createElement('option');
      option.value = value;
      option.textContent = value;
      fields.featuredImage.append(option);
    };

    const formatEditPublishDate = (value) => {
      if (!value) return formatDateTimeLocal(new Date());

      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? formatDateTimeLocal(new Date()) : formatDateTimeLocal(date);
    };

    const populateArticleForEdit = (article) => {
      fields.title.value = article.title || '';
      fields.slug.value = getEditSlug() || article.slug || '';
      fields.excerpt.value = article.excerpt || '';
      fields.publishDate.value = formatEditPublishDate(article.publishDate);
      fields.author.value = article.author || '';
      fields.category.value = article.category || '';
      fields.tags.value = Array.isArray(article.tags) ? article.tags.join(', ') : article.tags || '';
      fields.draft.checked = Boolean(article.draft);
      fields.content.value = article.content || '';
      fields.sources.value = Array.isArray(article.sources) ? article.sources.join('\n') : article.sources || '';
      fields.videoLink.value = article.videoLink || article.video || '';
      fields.ctaLink.value = article.ctaLink || '';
      fields.ctaText.value = article.ctaText || '';
      fields.seoDescription.value = article.seoDescription || article.metadata?.description || '';
      fields.overwrite.checked = true;
      fields.existingFeaturedImagePath.value = article.image || article.featuredImage || '';
      selectedFiles = [];
      imageNames = [];
      renderImages();
      if (fields.existingFeaturedImagePath.value) {
        ensureFeaturedImageOption(fields.existingFeaturedImagePath.value);
        fields.featuredImage.value = fields.existingFeaturedImagePath.value;
      }
      updatePreview();
      updatePublishOutput();
    };

    const initializeEditMode = async (clerk) => {
      const editSlug = getEditSlug();
      if (!editSlug || editArticleLoaded) return;

      editArticleLoaded = true;
      setEditorModeCopy('edit');
      setStatus(`Loading ${editSlug} for editing…`, false);

      try {
        const token = await clerk.session.getToken();
        if (!token) throw new Error('Could not retrieve a Clerk session token.');

        const response = await fetch(`/.netlify/functions/get-article-for-edit?slug=${encodeURIComponent(editSlug)}`, {
          method: 'GET',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || `Could not load article for editing (${response.status}).`);
        }

        populateArticleForEdit(result.article || result);
        setStatus(
          `Editing ${editSlug}. Slug is locked; publishing will update src/data/post/${editSlug}.md in place.`,
          false
        );
      } catch (error) {
        editArticleLoaded = false;
        setStatus(error instanceof Error ? error.message : 'Article could not be loaded for editing.', false);
      }
    };

    const getDuplicateTopLevelKeys = (text) => {
      const duplicates = [];
      const seen = new Set();
      let depth = 0;
      let inString = false;
      let escaped = false;
      let keyStart = -1;
      let expectingKey = false;
      let possibleKey = false;
      let afterKey = false;
      let currentKey = '';

      for (let index = 0; index < text.length; index += 1) {
        const char = text[index];

        if (inString) {
          if (escaped) {
            escaped = false;
          } else if (char === '\\') {
            escaped = true;
          } else if (char === '"') {
            inString = false;
            if (depth === 1 && possibleKey) {
              currentKey = text.slice(keyStart, index);
              possibleKey = false;
              afterKey = true;
            }
          }
          continue;
        }

        if (char === '"') {
          inString = true;
          keyStart = index + 1;
          possibleKey = depth === 1 && expectingKey;
          continue;
        }

        if (/\s/.test(char)) continue;

        if (char === '{') {
          depth += 1;
          expectingKey = depth === 1;
          afterKey = false;
          continue;
        }

        if (char === '}') {
          depth -= 1;
          expectingKey = false;
          afterKey = false;
          continue;
        }

        if (char === '[') {
          depth += 1;
          expectingKey = false;
          afterKey = false;
          continue;
        }

        if (char === ']') {
          depth -= 1;
          expectingKey = false;
          afterKey = false;
          continue;
        }

        if (depth === 1 && afterKey && char === ':') {
          if (seen.has(currentKey) && !duplicates.includes(currentKey)) duplicates.push(currentKey);
          seen.add(currentKey);
          expectingKey = false;
          afterKey = false;
          continue;
        }

        if (depth === 1 && char === ',') {
          expectingKey = true;
          afterKey = false;
        }
      }

      return duplicates;
    };

    const baselineContentSourceSchemaVersion = 'content_source.v1';
    const contentSourceV1Error = 'Import JSON must use content_source.v1.';
    let currentContentSourceSchemaVersionPromise;

    const isPlainObject = (value) => Boolean(value && typeof value === 'object' && !Array.isArray(value));

    const hasOwn = (object, key) => Object.prototype.hasOwnProperty.call(object, key);

    const getPathValue = (object, path) => {
      let current = object;

      for (const key of path) {
        if (!isPlainObject(current) || !hasOwn(current, key)) return { exists: false, value: undefined };
        current = current[key];
      }

      return { exists: true, value: current };
    };

    const getFirstImportPathValue = (object, paths) => {
      for (const path of paths) {
        const result = getPathValue(object, path);
        if (result.exists) return result;
      }

      return { exists: false, value: undefined };
    };

    const getCurrentContentSourceSchemaVersion = async () => {
      currentContentSourceSchemaVersionPromise ||= (async () => {
        const response = await fetch('/mcp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ jsonrpc: '2.0', id: 'admin-publish-schema-version', method: 'tools/list' }),
        });

        if (!response.ok) {
          throw new Error('Could not verify the current content_source schema version.');
        }

        const body = await response.json();
        const tools = Array.isArray(body?.result?.tools) ? body.result.tools : [];
        const createRequestTool = tools.find((tool) => tool?.name === 'save_json_blob_create_request');
        const schemaVersion =
          createRequestTool?.inputSchema?.properties?.input?.properties?.schema_version?.const ||
          createRequestTool?.inputSchema?.properties?.input?.properties?.schema_version?.enum?.[0];

        if (typeof schemaVersion !== 'string' || !schemaVersion.trim()) {
          throw new Error('Could not verify the current content_source schema version.');
        }

        return schemaVersion.trim();
      })().catch((error) => {
        currentContentSourceSchemaVersionPromise = undefined;
        throw error;
      });

      return currentContentSourceSchemaVersionPromise;
    };

    const getUnsupportedSchemaMessage = (currentSchemaVersion) =>
      currentSchemaVersion === baselineContentSourceSchemaVersion
        ? contentSourceV1Error
        : `Import JSON must use ${baselineContentSourceSchemaVersion} or ${currentSchemaVersion}.`;

    const getAllowedContentSourceSchemaVersions = (currentSchemaVersion) =>
      new Set([baselineContentSourceSchemaVersion, currentSchemaVersion].filter(Boolean));

    const assertOptionalObject = (object, pathLabel, path) => {
      const result = getPathValue(object, path);
      if (result.exists && !isPlainObject(result.value)) {
        throw new Error(`JSON field "${pathLabel}" must be an object.`);
      }
    };

    const assertOptionalTextPath = (object, pathLabel, paths) => {
      const result = getFirstImportPathValue(object, paths);
      if (result.exists && result.value != null && typeof result.value !== 'string') {
        throw new Error(`JSON field "${pathLabel}" must be a string.`);
      }
    };

    const assertOptionalStringArrayPath = (object, pathLabel, paths) => {
      const result = getFirstImportPathValue(object, paths);
      if (!result.exists || result.value == null) return;

      if (!Array.isArray(result.value)) {
        throw new Error(`JSON field "${pathLabel}" must be an array.`);
      }

      if (result.value.some((item) => typeof item !== 'string')) {
        throw new Error(`JSON field "${pathLabel}" must contain only strings.`);
      }
    };

    const assertOptionalSourceListPath = (object) => {
      const result = getPathValue(object, ['sources', 'source_list']);
      if (!result.exists || result.value == null) return;

      if (!Array.isArray(result.value)) {
        throw new Error('JSON field "sources.source_list" must be an array.');
      }

      const hasInvalidItem = result.value.some((item) => typeof item !== 'string' && !isSimpleImportObject(item));
      if (hasInvalidItem) {
        throw new Error('JSON field "sources.source_list" must contain only strings or simple objects.');
      }
    };

    const normalizeContentSourceImportWrapper = (data, currentSchemaVersion) => {
      if (!isPlainObject(data)) {
        throw new Error(
          'JSON import must be a single top-level object. Arrays or multiple article objects are not supported.'
        );
      }

      const candidate = isPlainObject(data.input) ? data.input : data;
      const allowedSchemaVersions = getAllowedContentSourceSchemaVersions(currentSchemaVersion);
      if (candidate.record_type !== 'content_source' || !allowedSchemaVersions.has(candidate.schema_version)) {
        throw new Error(getUnsupportedSchemaMessage(currentSchemaVersion));
      }

      [
        ['content', ['content']],
        ['publication', ['publication']],
        ['publication.publish_payload', ['publication', 'publish_payload']],
        ['editorial', ['editorial']],
        ['seo', ['seo']],
        ['taxonomy', ['taxonomy']],
        ['sources', ['sources']],
      ].forEach(([pathLabel, path]) => assertOptionalObject(candidate, pathLabel, path));

      assertOptionalTextPath(candidate, 'publication.publish_payload.title or content.title', [
        ['publication', 'publish_payload', 'title'],
        ['content', 'title'],
      ]);
      assertOptionalTextPath(candidate, 'publication.publish_payload.slug', [
        ['publication', 'publish_payload', 'slug'],
      ]);
      assertOptionalTextPath(candidate, 'publication.publish_payload.author', [
        ['publication', 'publish_payload', 'author'],
      ]);
      assertOptionalTextPath(candidate, 'publication.publish_payload.excerpt or content.deck', [
        ['publication', 'publish_payload', 'excerpt'],
        ['content', 'deck'],
      ]);
      assertOptionalTextPath(candidate, 'publication.publish_payload.seoDescription or seo.meta_description', [
        ['publication', 'publish_payload', 'seoDescription'],
        ['seo', 'meta_description'],
      ]);
      assertOptionalTextPath(
        candidate,
        'publication.publish_payload.content, publication.publish_payload.markdown, or editorial.draft_markdown',
        [
          ['publication', 'publish_payload', 'content'],
          ['publication', 'publish_payload', 'markdown'],
          ['editorial', 'draft_markdown'],
        ]
      );
      assertOptionalStringArrayPath(candidate, 'publication.publish_payload.tags or taxonomy.tags', [
        ['publication', 'publish_payload', 'tags'],
        ['taxonomy', 'tags'],
      ]);
      assertOptionalSourceListPath(candidate);

      return candidate;
    };

    const normalizeTextImportField = (contentSource, paths) => {
      const result = getFirstImportPathValue(contentSource, paths);
      return {
        exists: result.exists,
        value: result.exists && result.value != null ? result.value : '',
      };
    };

    const normalizeContentSourceImportToFormData = (contentSource, currentSchemaVersion) => {
      const title = normalizeTextImportField(contentSource, [
        ['publication', 'publish_payload', 'title'],
        ['content', 'title'],
      ]);
      const slug = normalizeTextImportField(contentSource, [['publication', 'publish_payload', 'slug']]);
      const computedSlug = slugify(slug.value || title.value);
      const author = normalizeTextImportField(contentSource, [['publication', 'publish_payload', 'author']]);
      const excerpt = normalizeTextImportField(contentSource, [
        ['publication', 'publish_payload', 'excerpt'],
        ['content', 'deck'],
      ]);
      const seoDescription = normalizeTextImportField(contentSource, [
        ['publication', 'publish_payload', 'seoDescription'],
        ['seo', 'meta_description'],
      ]);
      const content = normalizeTextImportField(contentSource, [
        ['publication', 'publish_payload', 'content'],
        ['publication', 'publish_payload', 'markdown'],
        ['editorial', 'draft_markdown'],
      ]);
      const importedTags = getFirstImportPathValue(contentSource, [
        ['publication', 'publish_payload', 'tags'],
        ['taxonomy', 'tags'],
      ]);
      const importedSources = getPathValue(contentSource, ['sources', 'source_list']);

      return {
        schemaVersion: contentSource.schema_version,
        currentSchemaVersion,
        title,
        slug: {
          exists: slug.exists || Boolean(computedSlug),
          value: computedSlug,
        },
        author,
        excerpt,
        seoDescription,
        content,
        tags: {
          exists: importedTags.exists,
          value: Array.isArray(importedTags.value)
            ? importedTags.value
                .map((tag) => tag.trim())
                .filter(Boolean)
                .join(', ')
            : '',
        },
        sources: {
          exists: importedSources.exists,
          value: Array.isArray(importedSources.value) ? formatImportedList(importedSources.value) : '',
        },
      };
    };

    const validateContentSourceImportFormData = (formData) => {
      const allowedSchemaVersions = getAllowedContentSourceSchemaVersions(formData.currentSchemaVersion);
      if (!allowedSchemaVersions.has(formData.schemaVersion)) {
        throw new Error(getUnsupportedSchemaMessage(formData.currentSchemaVersion));
      }

      if (!formData.title.exists || !formData.title.value.trim()) {
        throw new Error('Import JSON must include a non-empty title.');
      }

      if (!formData.slug.exists || !formData.slug.value.trim()) {
        throw new Error('Import JSON must include a slug or enough title text to compute one.');
      }

      if (!formData.author.exists || !formData.author.value.trim()) {
        throw new Error('Import JSON must include a non-empty publication.publish_payload.author.');
      }
    };

    const parseContentSourceImportFormData = async (data) => {
      const currentSchemaVersion = await getCurrentContentSourceSchemaVersion();
      const contentSource = normalizeContentSourceImportWrapper(data, currentSchemaVersion);
      const formData = normalizeContentSourceImportToFormData(contentSource, currentSchemaVersion);
      validateContentSourceImportFormData(formData);
      return formData;
    };

    const applyContentSourceImportFormData = (formData) => {
      if (formData.title.exists) fields.title.value = formData.title.value;
      if (formData.slug.exists) fields.slug.value = formData.slug.value;
      if (formData.author.exists) fields.author.value = formData.author.value;
      if (formData.excerpt.exists) fields.excerpt.value = formData.excerpt.value;
      if (formData.seoDescription.exists) fields.seoDescription.value = formData.seoDescription.value;
      if (formData.content.exists) fields.content.value = formData.content.value;
      if (formData.tags.exists) fields.tags.value = formData.tags.value;
      if (formData.sources.exists) fields.sources.value = formData.sources.value;

      updatePreview();
      updatePublishOutput();
    };

    const getImportJsonObjectText = (text) => {
      const trimmed = text.trim();
      const fencedJson = trimmed.match(/```(?:json)?\s*([\s\S]*?)\s*```/i);
      const candidate = fencedJson ? fencedJson[1].trim() : trimmed;
      const objectStart = candidate.indexOf('{');

      if (objectStart === -1) {
        throw new Error('JSON import must include one top-level object.');
      }

      if (candidate.slice(0, objectStart).trim()) {
        throw new Error('Remove any text before the JSON object and try again.');
      }

      let depth = 0;
      let inString = false;
      let escaped = false;
      let objectEnd = -1;

      for (let index = objectStart; index < candidate.length; index += 1) {
        const char = candidate[index];

        if (inString) {
          if (escaped) {
            escaped = false;
          } else if (char === '\\') {
            escaped = true;
          } else if (char === '"') {
            inString = false;
          }
          continue;
        }

        if (char === '"') {
          inString = true;
          continue;
        }

        if (char === '{' || char === '[') depth += 1;
        if (char === '}' || char === ']') depth -= 1;

        if (depth === 0) {
          objectEnd = index;
          break;
        }
      }

      if (objectEnd === -1) {
        throw new Error('JSON import has an incomplete top-level object.');
      }

      const trailingText = candidate.slice(objectEnd + 1).trim();
      if (trailingText) {
        throw new Error(
          'JSON import must contain only one top-level object. Remove duplicate objects or trailing text.'
        );
      }

      return candidate.slice(objectStart, objectEnd + 1);
    };

    const failJsonImport = (message) => {
      setJsonImportStatus(message, true);
      window.alert(message);
    };

    const loadJsonImport = async (rawValue = fields.jsonImport.value) => {
      const rawJson = rawValue.trim();
      if (!rawJson) {
        failJsonImport('Paste JSON or choose a .json file before loading.');
        return false;
      }

      try {
        const objectJson = getImportJsonObjectText(rawJson);
        const duplicates = getDuplicateTopLevelKeys(objectJson);
        if (duplicates.length) {
          throw new Error(
            `JSON import has duplicate top-level field${duplicates.length === 1 ? '' : 's'}: ${duplicates.join(', ')}.`
          );
        }

        const data = JSON.parse(objectJson);
        const formData = await parseContentSourceImportFormData(data);
        applyContentSourceImportFormData(formData);
        setJsonImportStatus(`${formData.schemaVersion} JSON loaded into the publishing form.`);
        return true;
      } catch (error) {
        const message = error instanceof Error ? error.message : 'JSON import could not be parsed.';
        const isSyntaxError = error instanceof SyntaxError;
        failJsonImport(isSyntaxError ? `Invalid JSON. ${message}` : message);
        return false;
      }
    };

    const readJsonFile = (file) =>
      new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.addEventListener('load', () => resolve(String(reader.result || '')));
        reader.addEventListener('error', () => reject(reader.error || new Error('JSON file could not be read.')));
        reader.readAsText(file);
      });

    fields.title.addEventListener('input', () => {
      if (!fields.slug.value.trim()) fields.slug.value = slugify(fields.title.value);
      updatePublishButtonState();
    });

    ['input', 'change'].forEach((eventName) => {
      fields.slug.addEventListener(eventName, () => {
        validateSlug({ announce: true });
        updatePublishButtonState();
      });
    });

    fields.jsonUpload.addEventListener('change', async () => {
      const [file] = Array.from(fields.jsonUpload.files || []);
      if (!file) return;

      fields.jsonUploadName.textContent = file.name;
      if (!file.name.toLowerCase().endsWith('.json')) {
        failJsonImport('Choose a .json file for import.');
        fields.jsonUpload.value = '';
        return;
      }

      try {
        const rawJson = await readJsonFile(file);
        const loaded = await loadJsonImport(rawJson);
        if (loaded) fields.jsonImport.value = rawJson;
      } catch (error) {
        failJsonImport(error instanceof Error ? error.message : 'JSON file could not be read.');
      }
    });

    document.querySelector('#load-json').addEventListener('click', () => {
      loadJsonImport();
    });

    fields.imageUpload.addEventListener('change', () => {
      const previousFeaturedImage = fields.featuredImage.value;
      const { validFiles, errors } = validateImageFiles(Array.from(fields.imageUpload.files || []));
      selectedFiles = validFiles;
      imageNames = selectedFiles.map((file) => sanitizeFilename(file.name));
      syncImageInputFiles();
      setImageUploadMessage(
        errors.length
          ? errors.join(' ')
          : imageNames.length
            ? `${imageNames.length} image${imageNames.length === 1 ? '' : 's'} ready to upload.`
            : '',
        errors.length > 0
      );
      renderImages();
      if (previousFeaturedImage && !imageNames.includes(previousFeaturedImage))
        ensureFeaturedImageOption(previousFeaturedImage);
      if (previousFeaturedImage) fields.featuredImage.value = previousFeaturedImage;
      updatePreview();
      updatePublishOutput();
    });

    document.querySelector('#save-draft').addEventListener('click', saveDraft);
    document.querySelector('#preview').addEventListener('click', () => {
      updatePreview();
      setStatus('Preview updated.');
    });
    const fileToBase64 = (file) =>
      new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.addEventListener('load', () => {
          const result = String(reader.result || '');
          resolve(result.includes(',') ? result.split(',').pop() : result);
        });
        reader.addEventListener('error', () => reject(reader.error));
        reader.readAsDataURL(file);
      });

    const publishArticle = async () => {
      updatePreview();
      updatePublishOutput();

      const { slug } = buildMarkdown();
      if (!validateSlug({ announce: true })) {
        updatePublishButtonState();
        return;
      }

      if (!fields.title.value.trim() || !slug || !fields.content.value.trim()) {
        setStatus('Title, slug, and Markdown content are required before publishing.', false);
        return;
      }

      const publishButton = document.querySelector('#publish');
      publishButton.disabled = true;
      setStatus('Checking Clerk session…', false);

      try {
        const clerkToken = await getClerkSessionToken();
        setStatus('Publishing article to GitHub…', false);

        const files = await Promise.all(
          selectedFiles.map(async (file) => ({
            base64: await fileToBase64(file),
            name: sanitizeFilename(file.name),
            type: file.type,
          }))
        );
        const response = await fetch('/.netlify/functions/publish-article', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${clerkToken}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            title: fields.title.value,
            slug,
            excerpt: fields.excerpt.value,
            publishDate: getPublishDate().toISOString(),
            author: fields.author.value,
            category: fields.category.value,
            tags: parseTags(fields.tags.value),
            draft: fields.draft.checked,
            content: fields.content.value,
            markdown: fields.outputMarkdown.value,
            sources: parseSources(fields.sources.value),
            featuredImage: fields.featuredImage.value,
            existingFeaturedImagePath: fields.existingFeaturedImagePath.value,
            seoDescription: fields.seoDescription.value,
            videoLink: fields.videoLink.value,
            ctaLink: fields.ctaLink.value,
            ctaText: fields.ctaText.value,
            overwrite: fields.overwrite.checked,
            files,
          }),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          const message = result.error || `Publish failed with status ${response.status}.`;
          setStatus(response.status === 409 ? `${message} Check overwrite to replace it.` : message, false);
          return;
        }

        const publishedPath = result.articlePath || result.path || `src/data/post/${slug}.md`;
        const commit = String(result.commit || '').trim();
        const shortCommit = commit.slice(0, 7);
        const commitText = shortCommit ? ` in commit ${shortCommit}` : '';
        const toastMessage = `Published ${publishedPath}.${commit ? ` Commit: ${commit}` : ''}`;
        setStatus(
          isEditMode() ? `Updated ${publishedPath} in place${commitText}.` : `Published ${publishedPath}${commitText}.`,
          false
        );
        showToast(toastMessage, getGitHubToastLinks({ articlePath: publishedPath, commit }));
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'Article could not be published.', false);
      } finally {
        updatePublishButtonState();
      }
    };

    fields.publish.addEventListener('click', publishArticle);
    document.querySelector('#copy-output').addEventListener('click', () => {
      updatePublishOutput();
      copyText(fields.outputMarkdown.value, 'Publish Markdown copied.');
    });

    ['input', 'change'].forEach((eventName) => {
      document.querySelector('#publish-form').addEventListener(eventName, () => {
        updatePreview();
        updatePublishOutput();
      });
    });

    if (!fields.publishDate.value) fields.publishDate.value = formatDateTimeLocal(new Date());
    setEditorModeCopy(isEditMode() ? 'edit' : 'publish');
    if (!isEditMode()) loadDraft();
    updatePublishButtonState();
    updatePreview();
    updatePublishOutput();
    initializeClerkAuth();
  })();
</script>
