---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const metadata = {
  title: pageTitle,
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <section
    class="admin-page mx-auto max-w-[900px] px-4 py-8 sm:px-6 sm:py-12"
    data-admin-shell
    hidden
  >
    <header class="admin-top-bar">
      <div>
        <p class="admin-kicker">Article Editor</p>
        <h1 class="admin-top-bar-title">{pageTitle}</h1>
      </div>
      <div class="top-bar-actions">
        <a class="btn-secondary btn-sm" href="/admin/drafts">All drafts</a>
        <button id="btn-publish" class="btn-primary btn-sm" type="button" disabled>Publish</button>
      </div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <div class="publish-workspace" data-auth-gated>
      <AdminNav activePath="/admin/publish" />

      <!-- ── Lock status bar ─────────────────────────────────── -->
      <div id="lock-bar" class="lock-bar" hidden>
        <span id="lock-icon" aria-hidden="true"></span>
        <span id="lock-label" class="lock-label"></span>
        <button id="btn-force-release" class="btn-tertiary btn-xs" type="button" hidden>Force release</button>
        <button id="btn-done-editing" class="btn-secondary btn-xs" type="button" hidden>Done editing</button>
      </div>

      <!-- ── No-draft state ──────────────────────────────────── -->
      <div id="no-draft" class="admin-card text-center py-10" hidden>
        <p class="text-lg font-bold mb-2">No draft selected</p>
        <p class="text-sm text-muted mb-6">Open a draft from the list to start editing.</p>
        <a class="btn-primary" href="/admin/drafts">Open draft list</a>
      </div>

      <!-- ── Loading state ──────────────────────────────────── -->
      <p id="load-status" class="load-status" aria-live="polite" hidden></p>

      <!-- ── Article view ───────────────────────────────────── -->
      <article id="article-view" class="article-view" hidden>
        <!-- Article metadata (display-only; editable at publish time) -->
        <header class="article-meta-header">
          <h1 id="article-title" class="article-preview-title"></h1>
          <p id="article-excerpt" class="article-preview-excerpt"></p>
        </header>

        <!-- Rendered nodes -->
        <div id="nodes-container" class="nodes-container editorial-prose"></div>
      </article>

      <!-- ── Publish settings panel ─────────────────────────── -->
      <aside id="publish-panel" class="admin-card publish-panel" hidden>
        <h2 class="card-section-title">Publish settings</h2>

        <div class="field">
          <label for="pub-title">Title</label>
          <input id="pub-title" name="title" type="text" class="title-input" autocomplete="off" />
        </div>
        <div class="field">
          <label for="pub-excerpt">Excerpt</label>
          <textarea id="pub-excerpt" name="excerpt" rows="3" maxlength="300"></textarea>
        </div>
        <div class="field-grid">
          <div class="field">
            <label for="pub-category">Category</label>
            <input id="pub-category" name="category" type="text" autocomplete="off" />
          </div>
          <div class="field">
            <label for="pub-tags">Tags</label>
            <input id="pub-tags" name="tags" type="text" autocomplete="off" placeholder="comma-separated" />
          </div>
        </div>
        <div class="field">
          <label for="pub-seo">SEO description</label>
          <input id="pub-seo" name="seoDescription" type="text" maxlength="180" autocomplete="off" />
        </div>
        <div class="field">
          <label for="pub-slug">Slug</label>
          <input id="pub-slug" name="slug" type="text" autocomplete="off" />
        </div>

        <div class="publish-actions mt-4">
          <button id="btn-publish-confirm" class="btn-primary w-full" type="button">Publish to site</button>
          <p id="publish-status" class="publish-status" aria-live="polite"></p>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .admin-page { color: var(--aw-color-text-default); }

  .admin-top-bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(229 231 235);
  }
  :global(.dark) .admin-top-bar { border-color: rgb(30 41 59); }

  .admin-kicker {
    margin: 0 0 0.25rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .admin-top-bar-title { margin: 0; font-size: 1.5rem; font-weight: 800; }

  .top-bar-actions { display: flex; gap: 0.75rem; align-items: center; flex-shrink: 0; }

  .auth-status { margin: -0.5rem 0 1rem; color: var(--aw-color-text-muted); font-size: 0.9rem; font-weight: 700; }

  .publish-workspace { display: flex; flex-direction: column; gap: 1.5rem; }

  /* Lock bar */
  .lock-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    background: rgb(245 158 11 / 8%);
    border: 1px solid rgb(245 158 11 / 30%);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .lock-bar[data-locked-by-agent] {
    background: rgb(239 68 68 / 6%);
    border-color: rgb(239 68 68 / 30%);
    color: rgb(185 28 28);
  }
  :global(.dark) .lock-bar[data-locked-by-agent] { color: rgb(252 165 165); }
  .lock-bar[data-held] {
    background: rgb(16 185 129 / 6%);
    border-color: rgb(16 185 129 / 30%);
    color: rgb(6 95 70);
  }
  :global(.dark) .lock-bar[data-held] { color: rgb(110 231 183); }
  .lock-label { flex: 1; }

  /* Load status */
  .load-status { padding: 2rem; text-align: center; color: var(--aw-color-text-muted); font-weight: 700; }

  /* Article view */
  .article-view { display: flex; flex-direction: column; gap: 1.5rem; }
  .article-meta-header { margin-bottom: 0.5rem; }
  .article-preview-title { font-family: var(--aw-font-heading, inherit); font-size: clamp(1.8rem, 5vw, 2.6rem); font-weight: 800; margin: 0 0 0.5rem; line-height: 1.1; }
  .article-preview-excerpt { color: var(--aw-color-text-muted); font-size: 0.95rem; font-style: italic; margin: 0; }

  /* Nodes container */
  .nodes-container { display: flex; flex-direction: column; gap: 2rem; }

  /* Node wrapper — node action toolbar appears on hover */
  :global(.dl-node-wrapper) {
    position: relative;
    border-radius: 0.75rem;
    transition: box-shadow 0.15s;
  }
  :global(.dl-node-wrapper:hover) { box-shadow: 0 0 0 2px rgb(94 140 138 / 30%); }
  :global(.dl-node-wrapper[data-editing]) { box-shadow: 0 0 0 2px var(--aw-color-accent); }

  /* Node toolbar (pen + AI buttons) */
  :global(.dl-node-toolbar) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    gap: 0.3rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }
  :global(.dl-node-wrapper:hover .dl-node-toolbar),
  :global(.dl-node-wrapper[data-editing] .dl-node-toolbar) {
    opacity: 1;
    pointer-events: auto;
  }
  :global(.dl-node-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid rgb(209 213 219);
    background: rgb(255 255 255 / 0.9);
    font-size: 0.85rem;
    cursor: pointer;
    box-shadow: 0 1px 3px rgb(0 0 0 / 10%);
    transition: background 0.1s;
  }
  :global(.dark) :global(.dl-node-btn) { background: rgb(30 41 59 / 0.9); border-color: rgb(51 65 85); }
  :global(.dl-node-btn:hover) { background: var(--aw-color-accent); color: white; border-color: transparent; }
  :global(.dl-node-btn[title="Ask AI"]:hover) { background: rgb(124 58 237); }

  /* TipTap editor chrome */
  :global(.dl-node-editor) { margin: -0.25rem; }
  :global(.dl-editor-content .ProseMirror) { outline: none; }
  :global(.dl-editor-content .ProseMirror p) { margin: 0 0 0.75em; }
  :global(.dl-editor-content .ProseMirror h2) { font-size: 1.4rem; font-weight: 700; margin: 0 0 0.5em; }
  :global(.dl-editor-content .ProseMirror h3) { font-size: 1.15rem; font-weight: 600; margin: 0 0 0.5em; }
  :global(.dl-editor-content .ProseMirror a) { text-decoration: underline; color: var(--aw-color-accent); }

  /* Admin card */
  .admin-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.9);
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgb(15 23 42 / 4%);
  }
  :global(.dark) .admin-card { border-color: rgb(30 41 59); background: rgb(15 23 42 / 0.7); }
  .card-section-title { font-size: 1rem; font-weight: 800; margin: 0 0 1rem; }

  /* Publish panel */
  .publish-panel .field { margin-bottom: 0.75rem; }
  .publish-panel label { display: block; font-size: 0.8rem; font-weight: 700; margin-bottom: 0.25rem; }
  .publish-panel input, .publish-panel textarea {
    width: 100%;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.5rem;
    padding: 0.45rem 0.65rem;
    font-size: 0.9rem;
    background: white;
    color: inherit;
  }
  :global(.dark) .publish-panel input,
  :global(.dark) .publish-panel textarea { border-color: rgb(51 65 85); background: rgb(15 23 42 / 0.5); }
  .publish-panel .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .publish-status { min-height: 1.4em; font-size: 0.85rem; font-weight: 700; margin-top: 0.5rem; }
  .publish-status.is-error { color: var(--aw-color-accent); }

  /* Buttons */
  .btn-primary, .btn-secondary, .btn-tertiary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary {
    padding: 0.72rem 1.25rem;
    border: 1px solid rgb(94 140 138 / 55%);
    background: rgb(94 140 138 / 18%);
    color: var(--aw-color-text-heading);
  }
  .btn-secondary { padding: 0.72rem 1.25rem; border: 1px solid rgb(209 213 219); color: var(--aw-color-text-heading); background: transparent; }
  .btn-tertiary { padding: 0.3rem 0.65rem; border: 1px solid rgb(209 213 219); color: var(--aw-color-text-muted); background: transparent; font-size: 0.8rem; }
  .btn-sm { padding: 0.45rem 0.9rem; font-size: 0.85rem; }
  .btn-xs { padding: 0.25rem 0.5rem; font-size: 0.75rem; }
  button:disabled { opacity: 0.45; cursor: not-allowed; }
  .w-full { width: 100%; }
  .mt-4 { margin-top: 1rem; }
</style>

<script>
  import { currentUser, getAccessToken, handleOAuthCallback } from '~/utils/goTrueClient';
  import { LockManager } from '~/lib/admin/lock-manager';
  import { renderNode, wrapNode } from '~/lib/admin/node-renderer';
  import { NodeEditor } from '~/lib/admin/node-editor';
  import { askAiForNode, renderSuggestionOverlay, showInstructionPopover } from '~/lib/admin/ai-suggestion';
  import type { ArticleBodyNode } from '~/schema/article-content-v1';

  // ─── constants ──────────────────────────────────────────────────────────────
  const DRAFT_ENDPOINT = '/.netlify/functions/admin-get-json-draft';
  const UPDATE_NODE_ENDPOINT = '/.netlify/functions/admin-update-node';

  // ─── page init ──────────────────────────────────────────────────────────────
  const init = () => {
    const page = document.querySelector<HTMLElement>('.admin-page');
    if (!page || page.dataset.publishInitialized === 'true') return;
    page.dataset.publishInitialized = 'true';

    const params = new URLSearchParams(window.location.search);
    const draftId = params.get('draftId') ?? params.get('requestId') ?? '';

    // DOM refs
    const els = {
      authStatus: document.querySelector<HTMLElement>('[data-auth-status]'),
      gated: Array.from(document.querySelectorAll<HTMLElement>('[data-auth-gated]')),
      lockBar: document.querySelector<HTMLElement>('#lock-bar')!,
      lockIcon: document.querySelector<HTMLElement>('#lock-icon')!,
      lockLabel: document.querySelector<HTMLElement>('#lock-label')!,
      btnForceRelease: document.querySelector<HTMLButtonElement>('#btn-force-release')!,
      btnDoneEditing: document.querySelector<HTMLButtonElement>('#btn-done-editing')!,
      noDraft: document.querySelector<HTMLElement>('#no-draft')!,
      loadStatus: document.querySelector<HTMLElement>('#load-status')!,
      articleView: document.querySelector<HTMLElement>('#article-view')!,
      articleTitle: document.querySelector<HTMLElement>('#article-title')!,
      articleExcerpt: document.querySelector<HTMLElement>('#article-excerpt')!,
      nodesContainer: document.querySelector<HTMLElement>('#nodes-container')!,
      publishPanel: document.querySelector<HTMLElement>('#publish-panel')!,
      btnPublish: document.querySelector<HTMLButtonElement>('#btn-publish')!,
      btnPublishConfirm: document.querySelector<HTMLButtonElement>('#btn-publish-confirm')!,
      publishStatus: document.querySelector<HTMLElement>('#publish-status')!,
      pubTitle: document.querySelector<HTMLInputElement>('#pub-title')!,
      pubExcerpt: document.querySelector<HTMLTextAreaElement>('#pub-excerpt')!,
      pubCategory: document.querySelector<HTMLInputElement>('#pub-category')!,
      pubTags: document.querySelector<HTMLInputElement>('#pub-tags')!,
      pubSeo: document.querySelector<HTMLInputElement>('#pub-seo')!,
      pubSlug: document.querySelector<HTMLInputElement>('#pub-slug')!,
    };

    // ── State ──────────────────────────────────────────────────────────────────
    let lockManager: LockManager | null = null;
    let activeEditor: NodeEditor | null = null;
    let activeNodeWrapper: HTMLElement | null = null;
    let currentNodes: ArticleBodyNode[] = [];
    const currentRequestId = draftId;

    const getToken = async (): Promise<string> => {
      const token = await getAccessToken();
      if (!token) throw new Error('Not authenticated');
      return token;
    };

    // ── Auth shell (same pattern as existing admin pages) ─────────────────────
    const setAuthStatus = (msg: string) => { if (els.authStatus) els.authStatus.textContent = msg; };
    const setGated = (visible: boolean) => els.gated.forEach((el) => { el.hidden = !visible; });
    const setPageVisible = (visible: boolean) => { if (page) page.hidden = !visible; };

    const authState = (state: 'checking' | 'signed-out' | 'forbidden' | 'error' | 'signed-in') => {
      const msgs: Record<string, string> = {
        checking: 'Checking admin access…', 'signed-out': 'Sign in to view admin tools.',
        forbidden: 'Access denied.', error: 'Auth failed. Refresh or contact support.', 'signed-in': '',
      };
      setAuthStatus(msgs[state] ?? '');
      setPageVisible(state === 'signed-in');
      setGated(state === 'signed-in');
      if (!['checking', 'signed-in'].includes(state)) window.location.replace('/');
    };

    // ── Lock bar ──────────────────────────────────────────────────────────────
    const updateLockBar = (state: { held: boolean; agentLock?: { owner_label: string; expires_at: string }; lockToken?: string; expires_at?: string }) => {
      els.lockBar.hidden = false;
      delete els.lockBar.dataset.lockedByAgent;
      delete els.lockBar.dataset.held;

      if (state.held) {
        els.lockBar.dataset.held = 'true';
        els.lockIcon.textContent = '🔓';
        els.lockLabel.textContent = 'You hold the edit lock';
        els.btnDoneEditing.hidden = false;
        els.btnForceRelease.hidden = true;
      } else if (state.agentLock) {
        els.lockBar.dataset.lockedByAgent = 'true';
        els.lockIcon.textContent = '🔒';
        const exp = new Date(state.agentLock.expires_at);
        const expStr = Number.isFinite(exp.getTime())
          ? `expires ${exp.toLocaleTimeString()}`
          : 'expiry unknown';
        els.lockLabel.textContent = `Agent editing: ${state.agentLock.owner_label} (${expStr})`;
        els.btnDoneEditing.hidden = true;
        els.btnForceRelease.hidden = false;
      } else {
        els.lockIcon.textContent = '✏️';
        els.lockLabel.textContent = 'Click any block to start editing';
        els.btnDoneEditing.hidden = true;
        els.btnForceRelease.hidden = true;
      }
    };

    // ── Lock actions ──────────────────────────────────────────────────────────
    const acquireLock = async (): Promise<boolean> => {
      if (!lockManager) return false;
      const token = await lockManager.checkout();
      return token !== null;
    };

    els.btnDoneEditing.addEventListener('click', async () => {
      closeActiveEditor(false);
      if (lockManager) await lockManager.checkin();
    });

    els.btnForceRelease.addEventListener('click', async () => {
      if (!lockManager) return;
      if (!confirm('Force-release the agent lock? The agent may be mid-edit.')) return;
      await lockManager.forceRelease();
    });

    // ── Node rendering ────────────────────────────────────────────────────────
    const renderArticle = (nodes: ArticleBodyNode[]) => {
      currentNodes = nodes;
      els.nodesContainer.innerHTML = '';

      for (const node of nodes) {
        if (node.visibility && node.visibility !== 'public') continue;

        const rendered = renderNode(node);
        const wrapper = wrapNode(node, rendered);

        // Toolbar overlay
        const toolbar = document.createElement('div');
        toolbar.className = 'dl-node-toolbar';

        const editBtn = document.createElement('button');
        editBtn.className = 'dl-node-btn';
        editBtn.title = 'Edit';
        editBtn.textContent = '✏️';
        editBtn.addEventListener('click', () => onEditClick(node, wrapper));

        const aiBtn = document.createElement('button');
        aiBtn.className = 'dl-node-btn';
        aiBtn.title = 'Ask AI';
        aiBtn.textContent = '✨';
        aiBtn.addEventListener('click', () => onAskAiClick(node, wrapper));

        toolbar.append(editBtn, aiBtn);
        wrapper.append(toolbar);

        // Selection detection on read-only node (not during edit)
        wrapper.addEventListener('mouseup', () => {
          if (wrapper.dataset.editing) return;
          const sel = window.getSelection();
          if (sel && sel.rangeCount > 0 && !sel.isCollapsed && wrapper.contains(sel.anchorNode)) {
            aiBtn.classList.add('ring-2', 'ring-purple-400');
          } else {
            aiBtn.classList.remove('ring-2', 'ring-purple-400');
          }
        });

        els.nodesContainer.append(wrapper);
      }
    };

    // ── Editor open/close ─────────────────────────────────────────────────────
    const closeActiveEditor = (save: boolean) => {
      if (!activeEditor || !activeNodeWrapper) return;
      if (!save) activeEditor.unmount();
      activeNodeWrapper.removeAttribute('data-editing');
      activeEditor = null;
      activeNodeWrapper = null;
    };

    const onEditClick = async (node: ArticleBodyNode, wrapper: HTMLElement) => {
      // If already editing this node, ignore
      if (wrapper.dataset.editing) return;

      // Close any other open editor (without save)
      closeActiveEditor(false);

      // Ensure we hold the lock before entering edit mode
      if (!lockManager?.currentToken) {
        updateLockBar({ held: false }); // show status before attempt
        const acquired = await acquireLock();
        if (!acquired) {
          // Lock is held by agent; lock bar already updated via onStateChange
          return;
        }
      }

      wrapper.dataset.editing = 'true';
      activeNodeWrapper = wrapper;
      activeEditor = new NodeEditor();

      activeEditor.mount(node, wrapper, {
        onSave: async (updatedFields) => {
          await saveNodeUpdate(node.id, updatedFields, wrapper, node);
          closeActiveEditor(false);
        },
        onCancel: () => closeActiveEditor(false),
      });
    };

    // ── AI ask flow ───────────────────────────────────────────────────────────
    const onAskAiClick = (node: ArticleBodyNode, wrapper: HTMLElement) => {
      if (!currentRequestId) return;

      // Capture selection from either TipTap (if in edit mode) or the browser selection
      let selectedText: string | undefined;
      if (wrapper.dataset.editing && activeEditor) {
        const sel = activeEditor.getSelectionText();
        if (sel) selectedText = sel;
      } else {
        const browserSel = window.getSelection();
        if (browserSel && !browserSel.isCollapsed && wrapper.contains(browserSel.anchorNode)) {
          selectedText = browserSel.toString().trim() || undefined;
        }
      }

      showInstructionPopover(
        wrapper,
        selectedText,
        async (instruction) => {
          const spinnerEl = Object.assign(document.createElement('div'), {
            className: 'absolute inset-0 z-20 flex items-center justify-center rounded-xl bg-white/80 dark:bg-slate-900/80 text-sm font-bold',
            textContent: 'Asking AI…',
          });
          wrapper.style.position = 'relative';
          wrapper.append(spinnerEl);

          let token: string;
          try { token = await getToken(); }
          catch { spinnerEl.remove(); return; }

          const result = await askAiForNode({ requestId: currentRequestId, nodeId: node.id, selectedText, instruction, clerkToken: token });
          spinnerEl.remove();

          if (!result.ok) {
            alert(`AI request failed: ${result.error}`);
            return;
          }

          renderSuggestionOverlay(
            wrapper,
            node.public,
            result.suggestion,
            async (fields) => {
              // Accept: acquire lock if needed, then save
              if (!lockManager?.currentToken) {
                const acquired = await acquireLock();
                if (!acquired) { alert('Could not acquire edit lock to apply suggestion.'); return; }
              }
              await saveNodeUpdate(node.id, fields, wrapper, node);
            },
            () => {} // Discard — do nothing
          );
        },
        () => {}
      );
    };

    // ── Node save ─────────────────────────────────────────────────────────────
    const saveNodeUpdate = async (
      nodeId: string,
      updatedFields: Partial<ArticleBodyNode['public']>,
      wrapper: HTMLElement,
      originalNode: ArticleBodyNode
    ) => {
      const lockToken = lockManager?.currentToken;
      if (!lockToken) { alert('Edit lock not held. Please retry.'); return; }

      let token: string;
      try { token = await getToken(); }
      catch { alert('Authentication error. Please refresh.'); return; }

      const res = await fetch(UPDATE_NODE_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ requestId: currentRequestId, lockToken, nodeId, updatedPublicFields: updatedFields }),
      });

      const json = await res.json().catch(() => ({ ok: false, error: 'Parse error' }));
      if (!res.ok || !json.ok) {
        alert(`Save failed: ${json.error ?? 'Unknown error'}`);
        return;
      }

      // Refresh the rendered node in-place
      const updatedNode: ArticleBodyNode = { ...originalNode, public: { ...originalNode.public, ...updatedFields } };
      const nodeIndex = currentNodes.findIndex((n) => n.id === nodeId);
      if (nodeIndex !== -1) currentNodes[nodeIndex] = updatedNode;

      const newRendered = renderNode(updatedNode);
      // Replace content inside wrapper (keep toolbar)
      const toolbar = wrapper.querySelector('.dl-node-toolbar');
      wrapper.innerHTML = '';
      wrapper.append(newRendered);
      if (toolbar) wrapper.append(toolbar);
    };

    // ── Load draft ────────────────────────────────────────────────────────────
    const loadDraft = async (token: string) => {
      if (!draftId) {
        els.noDraft.hidden = false;
        return;
      }

      els.loadStatus.hidden = false;
      els.loadStatus.textContent = 'Loading article…';

      try {
        const res = await fetch(`${DRAFT_ENDPOINT}?draftId=${encodeURIComponent(draftId)}`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const json = await res.json().catch(() => ({ ok: false }));
        if (!res.ok || !json.ok) {
          els.loadStatus.textContent = json.error ?? `Load failed (${res.status})`;
          return;
        }

        const input = json.input as Record<string, unknown>;
        const content = (input.content ?? {}) as Record<string, unknown>;

        const title = String(content.title ?? json.draft?.title ?? 'Untitled');
        const excerpt = String((content.deck ?? json.draft?.excerpt ?? '') as string);

        // Populate metadata fields
        els.articleTitle.textContent = title;
        els.articleExcerpt.textContent = excerpt;
        els.pubTitle.value = title;
        els.pubExcerpt.value = excerpt;
        const taxonomy = (input.taxonomy ?? {}) as Record<string, unknown>;
        els.pubTags.value = Array.isArray(taxonomy.tags) ? taxonomy.tags.join(', ') : '';
        const seo = (input.seo ?? {}) as Record<string, unknown>;
        els.pubSeo.value = String(seo.meta_description ?? '');
        const ids = (input.ids ?? {}) as Record<string, unknown>;
        const slug = String(ids.content_id ?? (input as Record<string,unknown>).slug ?? '');
        els.pubSlug.value = slug;

        const articleBody = content.article_body as { nodes?: ArticleBodyNode[] } | undefined;
        if (articleBody?.nodes?.length) {
          renderArticle(articleBody.nodes);
          els.articleView.hidden = false;
          els.publishPanel.hidden = false;
          els.btnPublish.disabled = false;
        } else {
          els.loadStatus.textContent = 'This draft has no article body nodes yet.';
          els.loadStatus.hidden = false;
          return;
        }

        // Init lock manager
        lockManager = new LockManager(currentRequestId, getToken);
        lockManager.setOnStateChange((state) => updateLockBar(state as Parameters<typeof updateLockBar>[0]));
        lockManager.attachUnloadHandler();

        // Check initial lock state (no-op if unlocked)
        const lockStatus = await lockManager.status();
        updateLockBar(lockStatus as Parameters<typeof updateLockBar>[0]);

        els.loadStatus.hidden = true;
      } catch (err) {
        els.loadStatus.textContent = err instanceof Error ? err.message : 'Failed to load draft.';
      }
    };

    // ── Publish ───────────────────────────────────────────────────────────────
    const showPublishPanel = () => {
      els.publishPanel.scrollIntoView({ behavior: 'smooth' });
    };

    els.btnPublish.addEventListener('click', showPublishPanel);

    els.btnPublishConfirm.addEventListener('click', async () => {
      if (!currentRequestId) return;
      els.btnPublishConfirm.disabled = true;
      els.publishStatus.textContent = 'Publishing…';
      els.publishStatus.className = 'publish-status';

      let token: string;
      try { token = await getToken(); }
      catch { els.publishStatus.textContent = 'Auth error'; els.publishStatus.className = 'publish-status is-error'; els.btnPublishConfirm.disabled = false; return; }

      const lockToken = lockManager?.currentToken;

      try {
        const body = {
          action: 'set_published_time',
          request_id: currentRequestId,
          lock_token: lockToken,
          published_time: new Date().toISOString(),
          article_body: currentNodes.length ? { schema_version: 'article_body.v1', nodes: currentNodes } : undefined,
        };

        const res = await fetch('/.netlify/functions/save-json-blob', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-publish-key': '', Authorization: `Bearer ${token}` },
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error ?? `HTTP ${res.status}`);
        }

        if (lockManager) await lockManager.checkin();
        els.publishStatus.textContent = '✓ Publish recorded. Trigger a deploy to go live.';
        els.btnPublishConfirm.disabled = false;
      } catch (err) {
        els.publishStatus.textContent = err instanceof Error ? err.message : 'Publish failed.';
        els.publishStatus.className = 'publish-status is-error';
        els.btnPublishConfirm.disabled = false;
      }
    });

    // ── Auth bootstrap ────────────────────────────────────────────────────────
    authState('checking');

    (async () => {
      try {
        await handleOAuthCallback().catch(() => {});
        const user = currentUser();
        if (!user) { authState('signed-out'); return; }

        const authToken = await getAccessToken();
        if (!authToken) { authState('error'); return; }

        const stateRes = await fetch('/.netlify/functions/admin-auth-state', {
          headers: { Authorization: `Bearer ${authToken}`, 'Content-Type': 'application/json' },
        }).catch(() => null);
        const stateJson = await stateRes?.json().catch(() => null);
        if (!stateJson?.isAdmin) { authState('forbidden'); return; }

        authState('signed-in');
        await loadDraft(authToken);

        document.addEventListener('dr-lurie:logout', () => authState('signed-out'));
        document.addEventListener('dr-lurie:login', async () => {
          const t = await getAccessToken();
          if (!t) { authState('error'); return; }
          authState('signed-in');
        });
      } catch {
        authState('error');
      }
    })();
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>
