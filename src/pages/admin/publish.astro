---
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="admin-page mx-auto max-w-[900px] px-4 py-10 sm:px-6 sm:py-14"
    data-clerk-publishable-key={clerkPublishableKey}
  >
    <header class="admin-header mb-8 flex flex-col gap-4 border-b border-gray-200 pb-6 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800">
      <div>
        <p class="admin-kicker text-sm font-semibold uppercase tracking-[0.18em] text-accent">Publishing workspace</p>
        <h1 class="mt-2 font-heading text-4xl font-bold tracking-tight text-default sm:text-5xl">{pageTitle}</h1>
      </div>
      <div class="admin-auth" aria-live="polite">
        <span id="auth-status" class="auth-status">Checking sign-in…</span>
        <button id="sign-in" class="btn-primary btn-sm auth-button" type="button" hidden>Sign in</button>
        <button id="sign-out" class="btn-secondary btn-sm auth-button" type="button" hidden>Sign out</button>
      </div>
    </header>

    <section id="auth-panel" class="admin-card auth-panel" aria-label="Admin authentication" aria-live="polite">
      <div id="auth-loading" class="auth-loading" role="status">
        <span class="auth-spinner" aria-hidden="true"></span>
        <p>Checking sign-in…</p>
      </div>
      <p id="auth-help" class="hint">Checking Clerk authentication before showing the publishing workspace.</p>
      <button id="auth-panel-sign-in" class="btn-primary auth-panel-button" type="button" hidden>Sign in with Clerk</button>
    </section>

    <section class="admin-card admin-panel ai-publisher-panel" aria-labelledby="ai-publisher-heading" data-auth-gated hidden>
      <div class="panel-heading-row">
        <div>
          <p class="admin-kicker text-sm font-semibold uppercase tracking-[0.18em] text-accent">Agent publishing</p>
          <h2 id="ai-publisher-heading">AI Article Publisher</h2>
        </div>
        <span class="endpoint-pill">/.netlify/functions/run-publisher-agent</span>
      </div>
      <p class="hint ai-panel-intro">
        Run the server-side OpenAI publishing agent with already-approved Markdown. No publish secrets are exposed in this browser form.
      </p>

      <!-- Future ChatKit widget integration should mount alongside this form and write approved article data into these fields. -->
      <form id="ai-publisher-form" class="admin-form ai-publisher-form">
        <div class="field">
          <label for="ai-title">Title</label>
          <input id="ai-title" name="title" type="text" autocomplete="off" required />
        </div>

        <div class="field">
          <label for="ai-slug">Slug <span class="optional-label">optional</span></label>
          <input id="ai-slug" name="slug" type="text" autocomplete="off" placeholder="article-slug" />
          <p class="hint">Leave blank to let the publishing agent derive a slug from the title.</p>
        </div>

        <div class="field">
          <label for="ai-markdown">Markdown</label>
          <textarea
            id="ai-markdown"
            name="markdown"
            class="agent-markdown"
            placeholder="Paste the complete article Markdown, including Astro frontmatter."
            required
          ></textarea>
        </div>

        <div class="field checkbox-field">
          <input id="ai-overwrite" name="overwrite" type="checkbox" />
          <label for="ai-overwrite">Overwrite an existing article with this slug</label>
        </div>

        <div class="actions">
          <button id="ai-test-payload" class="btn-secondary" type="button">Test payload</button>
          <button id="ai-publish" class="btn-primary publish-button" type="submit">Run publishing agent</button>
        </div>
      </form>

      <div id="ai-publisher-result" class="agent-result" aria-live="polite" hidden></div>
    </section>

    <section class="admin-card" aria-label="Publishing form" data-auth-gated hidden>
      <form id="publish-form" class="admin-form">
        <div class="field">
          <label for="title">Title</label>
          <input id="title" name="title" type="text" autocomplete="off" />
        </div>

        <div class="field">
          <label for="slug">Slug</label>
          <input id="slug" name="slug" type="text" autocomplete="off" placeholder="article-slug" />
        </div>

        <div class="field">
          <label for="excerpt">Excerpt</label>
          <textarea
            id="excerpt"
            name="excerpt"
            rows="3"
            maxlength="300"
            placeholder="Short list-card and topic summary copy."
          ></textarea>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="publish-date">Publish date</label>
            <input id="publish-date" name="publishDate" type="datetime-local" />
          </div>

          <div class="field">
            <label for="author">Author</label>
            <input id="author" name="author" type="text" autocomplete="off" placeholder="Dr. Lurié" />
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="category">Category</label>
            <input id="category" name="category" type="text" autocomplete="off" placeholder="Aging skin" />
          </div>

          <div class="field">
            <label for="tags">Tags</label>
            <input id="tags" name="tags" type="text" autocomplete="off" placeholder="barrier function, lipids" />
          </div>
        </div>

        <div class="field checkbox-field">
          <input id="draft" name="draft" type="checkbox" />
          <label for="draft">Save as draft</label>
        </div>

        <div class="field">
          <label for="content">Markdown content</label>
          <textarea id="content" name="content" placeholder="Paste article content here. Markdown is supported."></textarea>
        </div>

        <div class="field">
          <label for="image-upload">Image upload</label>
          <input id="image-upload" type="file" multiple accept="image/*" />
          <p class="hint">
            Selected images will be committed with the article under <code>src/assets/images/uploads/</code>.
          </p>
          <ul id="image-list" class="image-list" aria-live="polite"></ul>
        </div>

        <div class="field">
          <label for="featured-image">Featured image</label>
          <select id="featured-image" name="featuredImage">
            <option value="">Select an uploaded image</option>
          </select>
        </div>

        <div class="field">
          <label for="video-link">Optional video link</label>
          <input id="video-link" name="videoLink" type="url" placeholder="https://example.com/video" />
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="cta-link">Optional CTA link</label>
            <input id="cta-link" name="ctaLink" type="url" placeholder="https://example.com/call-to-action" />
          </div>

          <div class="field">
            <label for="cta-text">Optional CTA text</label>
            <input id="cta-text" name="ctaText" type="text" placeholder="Learn more" />
          </div>
        </div>

        <div class="field">
          <label for="seo-description">Optional SEO description</label>
          <input id="seo-description" name="seoDescription" type="text" maxlength="180" />
        </div>

        <div class="field checkbox-field">
          <input id="overwrite-slug" name="overwrite" type="checkbox" />
          <label for="overwrite-slug">Overwrite an existing article with this slug</label>
        </div>

        <div class="actions">
          <button id="save-draft" class="btn-secondary" type="button">Save Draft</button>
          <button id="preview" class="btn-secondary" type="button">Preview</button>
          <button id="publish" class="btn-primary publish-button" type="button">Publish</button>
        </div>
        <p id="status" class="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="admin-card admin-panel" aria-labelledby="preview-heading" data-auth-gated hidden>
      <h2 id="preview-heading">Preview</h2>
      <div class="preview-box">
        <h3 id="preview-title">Untitled article</h3>
        <p>
          Featured image path:
          <span id="preview-featured-image" class="preview-image-path">None selected</span>
        </p>
        <div id="markdown-preview" class="markdown-preview">Preview will appear here.</div>
      </div>
    </section>

    <section class="admin-card admin-panel" aria-labelledby="publish-output-heading" data-auth-gated hidden>
      <h2 id="publish-output-heading">Publish output</h2>
      <p>
        Suggested destination: <span id="suggested-location" class="suggestion">src/data/post/slug.md</span>
      </p>
      <button id="copy-output" class="btn-secondary btn-sm copy-button" type="button">Copy Markdown backup</button>
      <textarea id="output-markdown" class="output-markdown" readonly></textarea>
      <p class="publish-message">Publish commits the article to GitHub. This Markdown is a backup preview of what will be saved.</p>
    </section>
  </section>
</Layout>

<style>
  .admin-page {
    color: var(--aw-color-text-default);
  }

  .admin-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 84%);
    box-shadow: 0 1.5rem 4rem rgb(15 23 42 / 6%);
    padding: 1.5rem;
  }

  :global(.dark) .admin-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
    box-shadow: none;
  }

  .admin-panel {
    margin-top: 1.5rem;
  }

  .auth-panel {
    margin-bottom: 1.5rem;
  }

  .auth-loading {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    padding: 2.5rem 1rem;
    color: var(--aw-color-text-muted);
    text-align: center;
    font-weight: 700;
  }

  .auth-loading p {
    margin: 0;
  }

  .auth-spinner {
    width: 2rem;
    height: 2rem;
    border: 3px solid rgb(209 213 219);
    border-top-color: var(--aw-color-accent);
    border-radius: 999px;
    animation: auth-spin 900ms linear infinite;
  }

  @keyframes auth-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .auth-panel-button {
    margin-top: 1rem;
  }

  .admin-auth {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
  }

  .auth-status {
    border: 1px solid rgb(229 231 235);
    border-radius: 999px;
    padding: 0.55rem 0.8rem;
    background: var(--aw-color-bg-surface);
    color: var(--aw-color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .auth-status[data-state='signed-in'] {
    border-color: rgb(22 163 74 / 30%);
    color: rgb(22 101 52);
    background: rgb(220 252 231 / 78%);
  }

  .auth-status[data-state='signed-out'],
  .auth-status[data-state='error'] {
    border-color: rgb(220 38 38 / 25%);
    color: rgb(153 27 27);
    background: rgb(254 226 226 / 72%);
  }

  :global(.dark) .auth-status {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
  }

  :global(.dark) .auth-status[data-state='signed-in'] {
    border-color: rgb(34 197 94 / 28%);
    color: rgb(187 247 208);
    background: rgb(20 83 45 / 35%);
  }

  :global(.dark) .auth-status[data-state='signed-out'],
  :global(.dark) .auth-status[data-state='error'] {
    border-color: rgb(248 113 113 / 28%);
    color: rgb(254 202 202);
    background: rgb(127 29 29 / 35%);
  }

  .admin-panel h2 {
    margin: 0 0 0.9rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .panel-heading-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .panel-heading-row h2 {
    margin-bottom: 0;
  }

  .endpoint-pill {
    border: 1px solid rgb(94 140 138 / 30%);
    border-radius: 999px;
    padding: 0.45rem 0.7rem;
    background: rgb(94 140 138 / 10%);
    color: var(--aw-color-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.78rem;
    font-weight: 800;
    overflow-wrap: anywhere;
  }

  .ai-panel-intro {
    margin-bottom: 1.2rem;
  }

  .optional-label {
    color: var(--aw-color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .agent-markdown {
    min-height: 300px;
  }

  .agent-result {
    margin-top: 1.25rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 1rem;
    background: var(--aw-color-bg-page);
  }

  .agent-result[data-state='loading'] {
    border-color: rgb(94 140 138 / 35%);
  }

  .agent-result[data-state='success'] {
    border-color: rgb(22 163 74 / 30%);
    background: rgb(240 253 244 / 75%);
  }

  .agent-result[data-state='error'] {
    border-color: rgb(220 38 38 / 25%);
    background: rgb(254 242 242 / 72%);
  }

  :global(.dark) .agent-result {
    border-color: rgb(30 41 59);
    background: rgb(2 6 23 / 70%);
  }

  :global(.dark) .agent-result[data-state='success'] {
    border-color: rgb(34 197 94 / 28%);
    background: rgb(20 83 45 / 25%);
  }

  :global(.dark) .agent-result[data-state='error'] {
    border-color: rgb(248 113 113 / 28%);
    background: rgb(127 29 29 / 25%);
  }

  .agent-result h3 {
    margin: 0 0 0.75rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: 1.15rem;
    font-weight: 800;
  }

  .agent-result dl {
    display: grid;
    gap: 0.65rem;
    margin: 0;
  }

  .agent-result dt {
    color: var(--aw-color-text-muted);
    font-size: 0.84rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .agent-result dd {
    margin: 0;
    overflow-wrap: anywhere;
    font-weight: 700;
  }

  .agent-error-hint {
    margin: 0.75rem 0 0;
    color: rgb(153 27 27);
    font-weight: 800;
  }

  :global(.dark) .agent-error-hint {
    color: rgb(254 202 202);
  }

  .agent-json {
    margin: 0.85rem 0 0;
    max-height: 320px;
    overflow: auto;
    border-radius: 0.75rem;
    padding: 0.85rem;
    background: rgb(15 23 42);
    color: rgb(226 232 240);
    font-size: 0.82rem;
    white-space: pre-wrap;
  }

  .field {
    margin-bottom: 1.15rem;
  }

  .field-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .field-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  label,
  .field-title {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--aw-color-text-heading);
    font-weight: 700;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.85rem;
    padding: 0.78rem 0.9rem;
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-page);
    font: inherit;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  :global(.dark) input,
  :global(.dark) select,
  :global(.dark) textarea {
    border-color: rgb(51 65 85);
    background: rgb(2 6 23 / 70%);
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--aw-color-accent);
    box-shadow: 0 0 0 3px rgb(94 140 138 / 18%);
    outline: none;
  }

  textarea {
    min-height: 420px;
    resize: vertical;
    line-height: 1.6;
  }

  .hint {
    margin: 0.45rem 0 0;
    color: var(--aw-color-text-muted);
    font-size: 0.92rem;
  }

  .image-list {
    display: grid;
    gap: 0.6rem;
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
  }

  .image-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 0.75rem;
    background: var(--aw-color-bg-surface);
  }

  :global(.dark) .image-list li {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
  }

  .filename,
  .preview-image-path,
  .suggestion {
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  .filename {
    font-size: 0.9rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .publish-button {
    box-shadow: 0 0.9rem 1.8rem rgb(46 111 149 / 20%);
  }

  .copy-button {
    margin-bottom: 0.8rem;
  }

  .preview-box,
  .output-box {
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 1rem;
    background: var(--aw-color-bg-page);
  }

  :global(.dark) .preview-box,
  :global(.dark) .output-box {
    border-color: rgb(30 41 59);
  }

  .preview-box h3 {
    margin: 0 0 0.75rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
  }

  .markdown-preview {
    margin-top: 1rem;
    line-height: 1.7;
  }

  .markdown-preview h1,
  .markdown-preview h2,
  .markdown-preview h3 {
    margin: 1rem 0 0.5rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
  }

  .markdown-preview p {
    margin: 0 0 0.8rem;
  }

  .markdown-preview code {
    border-radius: 0.4rem;
    padding: 0.12rem 0.32rem;
    background: var(--aw-color-bg-surface);
  }

  .output-markdown {
    min-height: 260px;
    margin-top: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.9rem;
  }

  .publish-message {
    margin: 0.85rem 0 0;
    color: var(--aw-color-secondary);
    font-weight: 800;
  }

  .checkbox-field {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .checkbox-field input {
    width: auto;
    margin-top: 0.25rem;
  }

  .checkbox-field label {
    margin-bottom: 0;
  }

  .status {
    min-height: 1.3em;
    margin: 0.9rem 0 0;
    color: var(--aw-color-accent);
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .admin-page {
      padding-top: 1.5rem;
      padding-bottom: 2.5rem;
    }

    .admin-card {
      border-radius: 1.1rem;
      padding: 1rem;
    }

    .image-list li {
      align-items: stretch;
      flex-direction: column;
    }

    .actions > button,
    .admin-auth,
    .auth-button {
      width: 100%;
    }

    .admin-auth {
      align-items: stretch;
    }

    .auth-status {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script is:inline>
  const draftKey = 'dr-lurie-admin-draft';
  const fields = {
    title: document.querySelector('#title'),
    slug: document.querySelector('#slug'),
    excerpt: document.querySelector('#excerpt'),
    publishDate: document.querySelector('#publish-date'),
    author: document.querySelector('#author'),
    category: document.querySelector('#category'),
    tags: document.querySelector('#tags'),
    draft: document.querySelector('#draft'),
    content: document.querySelector('#content'),
    imageUpload: document.querySelector('#image-upload'),
    imageList: document.querySelector('#image-list'),
    featuredImage: document.querySelector('#featured-image'),
    videoLink: document.querySelector('#video-link'),
    ctaLink: document.querySelector('#cta-link'),
    ctaText: document.querySelector('#cta-text'),
    seoDescription: document.querySelector('#seo-description'),
    overwrite: document.querySelector('#overwrite-slug'),
    status: document.querySelector('#status'),
    previewTitle: document.querySelector('#preview-title'),
    previewFeaturedImage: document.querySelector('#preview-featured-image'),
    markdownPreview: document.querySelector('#markdown-preview'),
    suggestedLocation: document.querySelector('#suggested-location'),
    outputMarkdown: document.querySelector('#output-markdown'),
    authStatus: document.querySelector('#auth-status'),
    signIn: document.querySelector('#sign-in'),
    signOut: document.querySelector('#sign-out'),
    publish: document.querySelector('#publish'),
    aiForm: document.querySelector('#ai-publisher-form'),
    aiTitle: document.querySelector('#ai-title'),
    aiSlug: document.querySelector('#ai-slug'),
    aiMarkdown: document.querySelector('#ai-markdown'),
    aiOverwrite: document.querySelector('#ai-overwrite'),
    aiPublish: document.querySelector('#ai-publish'),
    aiTestPayload: document.querySelector('#ai-test-payload'),
    aiResult: document.querySelector('#ai-publisher-result'),
    authPanel: document.querySelector('#auth-panel'),
    authHelp: document.querySelector('#auth-help'),
    panelSignIn: document.querySelector('#auth-panel-sign-in'),
  };

  let imageNames = [];
  let selectedFiles = [];
  let isSignedIn = false;

  const adminPage = document.querySelector('.admin-page');
  const clerkPublishableKey = adminPage?.dataset.clerkPublishableKey || '';
  const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
  const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
  let clerkLoadPromise;

  const setGatedContentVisible = (visible) => {
    gatedContent.forEach((element) => {
      element.hidden = !visible;
    });
  };

  const setAuthLoadingVisible = (visible) => {
    const loading = document.querySelector('#auth-loading');
    if (loading) loading.hidden = !visible;
  };

  const loadClerkScript = () =>
    new Promise((resolve, reject) => {
      if (window.Clerk) {
        console.info('Clerk script loaded');
        resolve();
        return;
      }

      const resolveWhenClerkExists = () => {
        if (!window.Clerk) {
          reject(new Error('Clerk authentication could not be initialized.'));
          return;
        }

        console.info('Clerk script loaded');
        resolve();
      };

      const existingScript = document.querySelector(
        `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
      );
      if (existingScript) {
        existingScript.addEventListener('load', resolveWhenClerkExists, { once: true });
        existingScript.addEventListener(
          'error',
          (event) => {
            console.error('ClerkJS script failed to load from existing script tag.', event);
            reject(new Error('Clerk authentication could not be loaded.'));
          },
          { once: true }
        );
        return;
      }

      const script = document.createElement('script');
      script.src = clerkJsScriptSrc;
      script.async = true;
      script.crossOrigin = 'anonymous';
      script.type = 'text/javascript';
      script.dataset.drLurieClerkjs = 'true';
      script.dataset.clerkPublishableKey = clerkPublishableKey;
      script.addEventListener('load', resolveWhenClerkExists, { once: true });
      script.addEventListener(
        'error',
        (event) => {
          console.error('ClerkJS script failed to load.', event);
          reject(new Error('Clerk authentication could not be loaded.'));
        },
        { once: true }
      );
      document.head.append(script);
    });

  const getClerk = async () => {
    if (!clerkPublishableKey) {
      throw new Error(
        'Publishing authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.'
      );
    }

    clerkLoadPromise ||= (async () => {
      await loadClerkScript();

      if (!window.Clerk) {
        throw new Error('Clerk authentication could not be initialized.');
      }

      const clerk = window.Clerk;
      await clerk.load();
      console.info('Clerk initialized', {
        status: clerk.status,
        isSignedIn: Boolean(clerk.isSignedIn),
      });
      return clerk;
    })();

    return clerkLoadPromise;
  };

  const getSignedInLabel = (clerk) => {
    const email = clerk.user?.primaryEmailAddress?.emailAddress;
    const name = clerk.user?.fullName || clerk.user?.firstName;
    return email || name || 'Clerk user';
  };

  const showSignedOutPanel = () => {
    fields.authPanel.hidden = false;
    fields.authHelp.textContent = 'Sign in with Clerk to access the publishing workspace.';
    setAuthLoadingVisible(false);
  };

  const hideAuthPanel = () => {
    fields.authPanel.hidden = true;
    setAuthLoadingVisible(false);
  };

  const setAuthState = (state, message) => {
    fields.authStatus.textContent = message;
    fields.authStatus.dataset.state = state;
    isSignedIn = state === 'signed-in';
    fields.signIn.hidden = isSignedIn || state === 'checking' || state === 'error';
    fields.panelSignIn.hidden = fields.signIn.hidden;
    fields.signOut.hidden = !isSignedIn;
    fields.publish.disabled = !isSignedIn;
    fields.aiPublish.disabled = !isSignedIn;
    setGatedContentVisible(isSignedIn);

    if (state === 'checking') {
      fields.authPanel.hidden = false;
      fields.authHelp.textContent = 'Checking Clerk authentication before showing the publishing workspace.';
      setAuthLoadingVisible(true);
    }
  };

  const renderAuthState = (clerk) => {
    const signedIn = Boolean(clerk.isSignedIn && clerk.session);
    console.info('Clerk signed-in state', { isSignedIn: signedIn });

    if (signedIn) {
      setAuthState('signed-in', `Signed in as ${getSignedInLabel(clerk)}`);
      hideAuthPanel();
      return;
    }

    setAuthState('signed-out', 'Signed out — sign in to publish');
    showSignedOutPanel();
  };

  const initializeClerkAuth = async () => {
    setAuthState('checking', 'Checking sign-in…');

    try {
      const clerk = await getClerk();
      renderAuthState(clerk);

      if (typeof clerk.addListener === 'function') {
        clerk.addListener(() => renderAuthState(clerk));
      }
    } catch (error) {
      console.error('Clerk authentication initialization failed.', error);
      const message = error instanceof Error ? error.message : 'Clerk authentication could not be initialized.';
      setAuthState('error', message);
      fields.authPanel.hidden = false;
      fields.authHelp.textContent = message;
      setAuthLoadingVisible(false);
      setStatus(message, false);
    }
  };

  const getClerkSessionToken = async () => {
    const clerk = await getClerk();
    renderAuthState(clerk);

    if (!clerk.isSignedIn || !clerk.session) {
      throw new Error('Sign in with Clerk before publishing.');
    }

    const token = await clerk.session.getToken();

    if (!token) {
      throw new Error('Could not retrieve a Clerk session token.');
    }

    return token;
  };

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const escapeYaml = (value) => String(value).replaceAll('\\', '\\\\').replaceAll('"', '\\"');

  const formatDateTimeLocal = (date) => {
    const offset = date.getTimezoneOffset();
    const localDate = new Date(date.getTime() - offset * 60000);
    return localDate.toISOString().slice(0, 16);
  };

  const getPublishDate = () => (fields.publishDate.value ? new Date(fields.publishDate.value) : new Date());

  const parseTags = (value) =>
    String(value)
      .split(',')
      .map((tag) => tag.trim())
      .filter(Boolean);

  const slugify = (value) =>
    String(value)
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');

  const sanitizeFilename = (value) =>
    String(value)
      .split(/[\\/]/)
      .pop()
      .toLowerCase()
      .replace(/[^a-z0-9._-]+/g, '-')
      .replace(/^-+|-+$/g, '') || 'upload';

  const getCurrentSlug = () => slugify(fields.slug.value || fields.title.value || 'untitled-article') || 'untitled-article';

  const getUploadPath = (filename) => `~/assets/images/uploads/${getCurrentSlug()}/${filename}`;

  const getFeaturedImagePath = () => (fields.featuredImage.value ? getUploadPath(fields.featuredImage.value) : '');

  const getDraft = () => ({
    title: fields.title.value,
    slug: fields.slug.value,
    excerpt: fields.excerpt.value,
    publishDate: fields.publishDate.value,
    author: fields.author.value,
    category: fields.category.value,
    tags: fields.tags.value,
    draft: fields.draft.checked,
    content: fields.content.value,
    imageNames,
    featuredImage: fields.featuredImage.value,
    videoLink: fields.videoLink.value,
    ctaLink: fields.ctaLink.value,
    ctaText: fields.ctaText.value,
    seoDescription: fields.seoDescription.value,
    overwrite: fields.overwrite.checked,
  });

  const setStatus = (message, autoClear = true) => {
    fields.status.textContent = message;
    if (message && autoClear) {
      window.setTimeout(() => {
        if (fields.status.textContent === message) fields.status.textContent = '';
      }, 2500);
    }
  };

  const copyText = async (text, successMessage) => {
    if (!text) return;

    try {
      await navigator.clipboard.writeText(text);
      setStatus(successMessage);
    } catch (error) {
      fields.outputMarkdown.value = text;
      fields.outputMarkdown.focus();
      fields.outputMarkdown.select();
      setStatus('Clipboard unavailable. Text selected for manual copy.');
    }
  };

  const renderImages = () => {
    fields.imageList.innerHTML = '';
    fields.featuredImage.innerHTML = '<option value="">Select an uploaded image</option>';

    imageNames.forEach((name) => {
      const option = document.createElement('option');
      option.value = name;
      option.textContent = name;
      fields.featuredImage.append(option);

      const item = document.createElement('li');
      const filename = document.createElement('span');
      const copyButton = document.createElement('button');

      filename.className = 'filename';
      filename.textContent = name;
      copyButton.className = 'btn-secondary btn-sm copy-button';
      copyButton.type = 'button';
      copyButton.textContent = 'Copy Markdown';
      copyButton.addEventListener('click', () => {
        copyText(`![Alt text](${getUploadPath(name)})`, `Copied Markdown for ${name}.`);
      });

      item.append(filename, copyButton);
      fields.imageList.append(item);
    });
  };

  const renderMarkdownPreview = (markdown) => {
    if (!markdown.trim()) return 'Preview will appear here.';

    return markdown
      .split(/\n{2,}/)
      .map((block) => {
        const text = block.trim();
        if (!text) return '';
        if (text.startsWith('### ')) return `<h3>${escapeHtml(text.slice(4))}</h3>`;
        if (text.startsWith('## ')) return `<h2>${escapeHtml(text.slice(3))}</h2>`;
        if (text.startsWith('# ')) return `<h1>${escapeHtml(text.slice(2))}</h1>`;
        if (text.startsWith('![')) return `<p><code>${escapeHtml(text)}</code></p>`;

        const inline = escapeHtml(text)
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.*?)\*/g, '<em>$1</em>')
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/\n/g, '<br />');
        return `<p>${inline}</p>`;
      })
      .join('');
  };

  const updatePreview = () => {
    const featuredPath = getFeaturedImagePath();
    fields.previewTitle.textContent = fields.title.value || 'Untitled article';
    fields.previewFeaturedImage.textContent = featuredPath || 'None selected';
    fields.markdownPreview.innerHTML = renderMarkdownPreview(fields.content.value);
  };

  const buildMarkdown = () => {
    const slug = getCurrentSlug();
    const featuredPath = getFeaturedImagePath();
    const tags = parseTags(fields.tags.value);
    const publishDate = getPublishDate().toISOString();
    const frontmatter = [
      '---',
      `title: "${escapeYaml(fields.title.value || 'Untitled article')}"`,
      `publishDate: ${publishDate}`,
      ...(fields.draft.checked ? ['draft: true'] : []),
      ...(fields.excerpt.value ? [`excerpt: "${escapeYaml(fields.excerpt.value)}"`] : []),
      ...(featuredPath ? [`image: "${escapeYaml(featuredPath)}"`] : []),
      ...(fields.videoLink.value ? [`video: "${escapeYaml(fields.videoLink.value)}"`] : []),
      ...(fields.ctaLink.value ? [`ctaLink: "${escapeYaml(fields.ctaLink.value)}"`] : []),
      ...(fields.ctaText.value ? [`ctaText: "${escapeYaml(fields.ctaText.value)}"`] : []),
      ...(fields.category.value ? [`category: "${escapeYaml(fields.category.value)}"`] : []),
      ...(tags.length ? ['tags:', ...tags.map((tag) => `  - "${escapeYaml(tag)}"`)] : []),
      ...(fields.author.value ? [`author: "${escapeYaml(fields.author.value)}"`] : []),
      ...(fields.seoDescription.value
        ? ['metadata:', `  description: "${escapeYaml(fields.seoDescription.value)}"`]
        : []),
      '---',
      '',
    ];

    return {
      slug,
      markdown: `${frontmatter.join('\n')}${fields.content.value.trim()}\n`,
    };
  };

  const updatePublishOutput = () => {
    const { slug, markdown } = buildMarkdown();
    fields.suggestedLocation.textContent = `src/data/post/${slug}.md`;
    fields.outputMarkdown.value = markdown;
  };

  const saveDraft = () => {
    localStorage.setItem(draftKey, JSON.stringify(getDraft()));
    setStatus('Draft saved.');
  };

  const loadDraft = () => {
    const saved = localStorage.getItem(draftKey);
    if (!saved) return;

    try {
      const draft = JSON.parse(saved);
      fields.title.value = draft.title || '';
      fields.slug.value = draft.slug || '';
      fields.excerpt.value = draft.excerpt || '';
      fields.publishDate.value = draft.publishDate || formatDateTimeLocal(new Date());
      fields.author.value = draft.author || '';
      fields.category.value = draft.category || '';
      fields.tags.value = draft.tags || '';
      fields.draft.checked = Boolean(draft.draft);
      fields.content.value = draft.content || '';
      fields.videoLink.value = draft.videoLink || '';
      fields.ctaLink.value = draft.ctaLink || '';
      fields.ctaText.value = draft.ctaText || '';
      fields.seoDescription.value = draft.seoDescription || '';
      fields.overwrite.checked = Boolean(draft.overwrite);
      imageNames = Array.isArray(draft.imageNames) ? draft.imageNames : [];
      renderImages();
      fields.featuredImage.value = draft.featuredImage || '';
    } catch (error) {
      localStorage.removeItem(draftKey);
    }
  };

  fields.title.addEventListener('input', () => {
    if (!fields.slug.value.trim()) fields.slug.value = slugify(fields.title.value);
  });

  fields.imageUpload.addEventListener('change', () => {
    selectedFiles = Array.from(fields.imageUpload.files || []);
    imageNames = selectedFiles.map((file) => sanitizeFilename(file.name));
    const previousFeaturedImage = fields.featuredImage.value;
    renderImages();
    if (imageNames.includes(previousFeaturedImage)) fields.featuredImage.value = previousFeaturedImage;
    updatePreview();
    updatePublishOutput();
  });

  document.querySelector('#save-draft').addEventListener('click', saveDraft);
  document.querySelector('#preview').addEventListener('click', () => {
    updatePreview();
    setStatus('Preview updated.');
  });
  const fileToBase64 = (file) =>
    new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.addEventListener('load', () => {
        const result = String(reader.result || '');
        resolve(result.includes(',') ? result.split(',').pop() : result);
      });
      reader.addEventListener('error', () => reject(reader.error));
      reader.readAsDataURL(file);
    });

  const publisherAgentEndpoint = '/.netlify/functions/run-publisher-agent';

  const renderAgentJson = (value) => `<pre class="agent-json">${escapeHtml(JSON.stringify(value, null, 2))}</pre>`;

  const toAgentResultObject = (value, fallbackMessage) => {
    if (value && typeof value === 'object' && !Array.isArray(value)) return value;

    return {
      message: typeof value === 'string' && value ? value : fallbackMessage,
    };
  };

  const setAgentResult = (state, html) => {
    fields.aiResult.hidden = false;
    fields.aiResult.dataset.state = state;
    fields.aiResult.innerHTML = html;
  };

  const getAgentPayload = () => ({
    title: fields.aiTitle.value.trim(),
    slug: fields.aiSlug.value.trim(),
    markdown: fields.aiMarkdown.value.trim(),
    overwrite: fields.aiOverwrite.checked,
    images: [],
  });

  const fillAgentTestPayload = () => {
    fields.aiTitle.value = 'OpenAI Agent Smoke Test';
    fields.aiSlug.value = 'openai-agent-smoke-test';
    fields.aiOverwrite.checked = false;
    fields.aiMarkdown.value = `---
title: "OpenAI Agent Smoke Test"
publishDate: ${new Date().toISOString()}
excerpt: "Smoke-test article published through the OpenAI agent workflow."
category: "Publishing"
tags:
  - "openai agent"
  - "smoke test"
author: "Dr. Lurié"
---

# OpenAI Agent Smoke Test

This is a short smoke-test article for the browser-based AI Article Publisher.

If this article appears on the site, the Clerk-gated admin UI successfully posted to the server-side publishing agent.
`;
    setAgentResult('loading', '<h3>Test payload loaded</h3><p class="hint">Review the Markdown, then run the publishing agent.</p>');
  };

  const isDuplicateError = (status, result) => {
    const combined = `${result?.error || ''} ${result?.message || ''}`.toLowerCase();
    return status === 409 || combined.includes('already exists') || combined.includes('duplicate');
  };

  const renderAgentSuccess = (result) => {
    const rows = [
      ['success', String(result.success === true || result.ok === true)],
      ['articlePath', result.articlePath || result.path || 'Not returned'],
      ['commit', result.commit || 'Not returned'],
      ['message', result.message || 'Published successfully.'],
      ...(result.deployStatus ? [['deployStatus', result.deployStatus]] : []),
    ];

    setAgentResult(
      'success',
      `<h3>Publishing agent succeeded</h3><dl>${rows
        .map(([label, value]) => `<div><dt>${escapeHtml(label)}</dt><dd>${escapeHtml(value)}</dd></div>`)
        .join('')}</dl>${renderAgentJson(result)}`
    );
  };

  const renderAgentError = (status, result) => {
    const duplicateHint = isDuplicateError(status, result)
      ? '<p class="agent-error-hint">This looks like a duplicate article. Enable overwrite and submit again if you intend to replace it.</p>'
      : '';
    const errorBody = Object.keys(result || {}).length ? result : { error: `Publisher agent failed with status ${status}.` };

    setAgentResult(
      'error',
      `<h3>Publishing agent failed</h3>${duplicateHint}${renderAgentJson(errorBody)}`
    );
  };

  const runPublishingAgent = async (event) => {
    event.preventDefault();

    const payload = getAgentPayload();
    if (!payload.title || !payload.markdown) {
      renderAgentError(400, { error: 'Title and Markdown are required before running the publishing agent.' });
      return;
    }

    fields.aiPublish.disabled = true;
    setAgentResult('loading', '<h3>Running publishing agent…</h3><p class="hint">Checking Clerk session and sending the approved article payload.</p>');

    try {
      const clerkToken = await getClerkSessionToken();
      const response = await fetch(publisherAgentEndpoint, {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${clerkToken}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });
      const parsedResult = await response.json().catch(() => ({}));
      const result = toAgentResultObject(parsedResult, `Publisher agent returned status ${response.status}.`);

      if (!response.ok || result.success === false || result.ok === false) {
        renderAgentError(response.status, result);
        return;
      }

      renderAgentSuccess({
        ...result,
        success: result.success ?? result.ok ?? true,
      });
    } catch (error) {
      renderAgentError(0, { error: error instanceof Error ? error.message : 'Publisher agent could not be reached.' });
    } finally {
      fields.aiPublish.disabled = !isSignedIn;
    }
  };

  const publishArticle = async () => {
    updatePreview();
    updatePublishOutput();

    const { slug } = buildMarkdown();
    if (!fields.title.value.trim() || !slug || !fields.content.value.trim()) {
      setStatus('Title, slug, and Markdown content are required before publishing.', false);
      return;
    }

    const publishButton = document.querySelector('#publish');
    publishButton.disabled = true;
    setStatus('Checking Clerk session…', false);

    try {
      const clerkToken = await getClerkSessionToken();
      setStatus('Publishing article to GitHub…', false);

      const files = await Promise.all(
        selectedFiles.map(async (file) => ({
          base64: await fileToBase64(file),
          name: sanitizeFilename(file.name),
          type: file.type,
        }))
      );
      const response = await fetch('/.netlify/functions/publish-article', {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${clerkToken}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          title: fields.title.value,
          slug,
          excerpt: fields.excerpt.value,
          publishDate: getPublishDate().toISOString(),
          author: fields.author.value,
          category: fields.category.value,
          tags: parseTags(fields.tags.value),
          draft: fields.draft.checked,
          content: fields.content.value,
          featuredImage: fields.featuredImage.value,
          seoDescription: fields.seoDescription.value,
          videoLink: fields.videoLink.value,
          ctaLink: fields.ctaLink.value,
          ctaText: fields.ctaText.value,
          overwrite: fields.overwrite.checked,
          files,
        }),
      });
      const result = await response.json().catch(() => ({}));

      if (!response.ok) {
        const message = result.error || `Publish failed with status ${response.status}.`;
        setStatus(response.status === 409 ? `${message} Check overwrite to replace it.` : message, false);
        return;
      }

      setStatus(
        `Published ${result.articlePath || result.path || `src/data/post/${slug}.md`} in commit ${String(result.commit || '').slice(0, 7)}.`,
        false
      );
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Article could not be published.', false);
    } finally {
      publishButton.disabled = !isSignedIn;
    }
  };

  const redirectToHostedSignIn = async (clerk) => {
    if (typeof clerk.redirectToSignIn !== 'function') {
      throw new Error('Clerk hosted sign-in redirect is unavailable.');
    }

    await clerk.redirectToSignIn({ redirectUrl: window.location.href });
  };

  const openSignIn = async () => {
    setAuthState('checking', 'Opening Clerk sign-in…');

    try {
      const clerk = await getClerk();

      if (typeof clerk.openSignIn === 'function') {
        try {
          await clerk.openSignIn();
          renderAuthState(clerk);
          return;
        } catch (error) {
          console.error('Clerk openSignIn failed. Redirecting to Clerk-hosted sign-in.', error);
        }
      }

      await redirectToHostedSignIn(clerk);
    } catch (error) {
      console.error('Clerk sign-in failed.', error);
      const message = error instanceof Error ? error.message : 'Clerk sign-in could not be opened.';
      setAuthState('error', message);
      fields.authPanel.hidden = false;
      fields.authHelp.textContent = message;
      setAuthLoadingVisible(false);
      setStatus(message, false);
    }
  };

  fields.signIn.addEventListener('click', openSignIn);
  fields.panelSignIn.addEventListener('click', openSignIn);

  fields.signOut.addEventListener('click', async () => {
    setAuthState('checking', 'Signing out…');

    try {
      const clerk = await getClerk();
      await clerk.signOut();
      renderAuthState(clerk);
    } catch (error) {
      console.error('Clerk sign-out failed.', error);
      const message = error instanceof Error ? error.message : 'Clerk sign-out failed.';
      setAuthState('error', message);
      fields.authPanel.hidden = false;
      fields.authHelp.textContent = message;
      setAuthLoadingVisible(false);
      setStatus(message, false);
    }
  });

  fields.aiForm.addEventListener('submit', runPublishingAgent);
  fields.aiTestPayload.addEventListener('click', fillAgentTestPayload);
  fields.publish.addEventListener('click', publishArticle);
  document.querySelector('#copy-output').addEventListener('click', () => {
    updatePublishOutput();
    copyText(fields.outputMarkdown.value, 'Publish Markdown copied.');
  });

  ['input', 'change'].forEach((eventName) => {
    document.querySelector('#publish-form').addEventListener(eventName, () => {
      updatePreview();
      updatePublishOutput();
    });
  });

  if (!fields.publishDate.value) fields.publishDate.value = formatDateTimeLocal(new Date());
  loadDraft();
  updatePreview();
  updatePublishOutput();
  initializeClerkAuth();
</script>
