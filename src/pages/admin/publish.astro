---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const metadata = {
  title: pageTitle,
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <section class="admin-page mx-auto max-w-[1280px] px-4 py-8 sm:px-6 sm:py-12" data-admin-shell hidden>
    <header class="admin-top-bar">
      <div>
        <p class="admin-kicker">Article Editor</p>
        <h1 class="admin-top-bar-title">{pageTitle}</h1>
      </div>
      <div class="top-bar-actions"></div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <div class="publish-workspace" data-auth-gated>
      <!-- ── Article workspace — always rendered, children toggled by JS ── -->
      <div id="article-workspace" class="publish-layout">
        <!-- ── Left column: article content ──────────────────── -->
        <div class="publish-main">
          <!-- ── Loading state ────────────────────────────────── -->
          <p id="load-status" class="load-status" aria-live="polite" hidden></p>

          <!-- ── Article header (title + excerpt) — hidden until draft loaded ── -->
          <section id="article-header-card" class="article-header-card" aria-label="Article title and excerpt" hidden>
            <button
              id="btn-header-history"
              class="dl-icon-btn is-history article-header-history-btn"
              type="button"
              aria-label="View title/excerpt save history"
              title="Title & excerpt history"
            >
              <Icon name="tabler:history" class="icon-sm" aria-hidden="true" />
            </button>
            <div class="field">
              <label for="pub-title" class="sr-only">Title</label>
              <textarea
                id="pub-title"
                name="title"
                rows="2"
                class="article-title-input"
                placeholder="Article title…"
                autocomplete="off"
                spellcheck="true"></textarea>
              <p class="field-error" id="err-title" role="alert" hidden></p>
            </div>
            <div class="field">
              <label for="pub-excerpt" class="sr-only">Excerpt / deck</label>
              <textarea
                id="pub-excerpt"
                name="excerpt"
                rows="2"
                maxlength="300"
                class="article-excerpt-input"
                placeholder="Short excerpt shown in listings…"></textarea>
              <p class="field-error" id="err-excerpt" role="alert" hidden></p>
            </div>
          </section>

          <!-- ── Article body (read mode + per-block editing) — hidden until draft loaded ── -->
          <article id="article-view" class="article-view" hidden>
            <div id="nodes-container" class="nodes-container editorial-prose"></div>
          </article>
        </div>

        <!-- ── Right column: sticky inspector panel ─────────── -->
        <aside id="inspector-panel" class="inspector-panel" aria-label="Article settings">
          <div id="dock-marker" class="dock-marker" aria-hidden="true"></div>
          <!-- ── Empty state (no draft loaded) ────────────── -->
          <div id="inspector-empty" class="inspector-empty-card">
            <p class="inspector-empty-label">No draft selected</p>
            <button id="btn-open-draft-list-inspector" class="btn-secondary btn-xs" type="button">Open draft</button>
          </div>

          <!-- ── Active content (shown once a draft loads) ──── -->
          <div id="inspector-content" hidden>
            <!-- ── Lock row ─────────────────────────────────── -->
            <div id="lock-bar" class="lock-row" hidden>
              <span id="lock-icon" class="lock-row-icon" aria-hidden="true"></span>
              <span id="lock-label" class="lock-label"></span>
              <button
                id="btn-force-release"
                class="btn-icon-lock"
                type="button"
                hidden
                aria-label="Force release agent lock"
                title="Force release agent lock"
              >
                <Icon name="tabler:x" class="icon-sm" aria-hidden="true" />
              </button>
              <button
                id="btn-done-editing"
                class="btn-icon-lock"
                type="button"
                hidden
                aria-label="Done editing"
                title="Done editing"
              >
                <Icon name="tabler:check" class="icon-sm" aria-hidden="true" />
              </button>
            </div>

            <!-- ── General section (Author, Date, Category) ─── -->
            <section id="general-editor" class="inspector-section" aria-label="General settings">
              <button
                id="btn-general-toggle"
                class="inspector-section-head inspector-section-toggle"
                type="button"
                aria-expanded="false"
                aria-controls="general-form"
              >
                <div class="inspector-section-head-text">
                  <span class="inspector-section-title">
                    General
                    <span id="general-dirty-dot" class="dirty-indicator" hidden></span>
                  </span>
                  <span id="general-summary" class="section-summary-text"></span>
                </div>
                <Icon name="tabler:chevron-down" class="toggle-caret icon-sm" aria-hidden="true" />
              </button>
              <div id="general-form" class="meta-form" hidden>
                <div class="setup-grid">
                  <div class="field">
                    <label for="pub-author" class="field-label">Author</label>
                    <input id="pub-author" name="author" type="text" autocomplete="off" placeholder="Dr. Lurie" />
                  </div>
                  <div class="field">
                    <label for="pub-date" class="field-label">Publish date</label>
                    <input id="pub-date" name="publishDate" type="date" />
                  </div>
                  <div class="field field-full">
                    <label for="pub-category-input" class="field-label">Category</label>
                    <div id="pub-category-container" class="tag-input-container is-single">
                      <div id="pub-category-chips" class="tag-pills"></div>
                      <input
                        id="pub-category-input"
                        type="text"
                        autocomplete="off"
                        placeholder="Select or create…"
                        class="tag-text-input"
                      />
                      <div
                        id="pub-category-suggestions"
                        class="tag-suggestions"
                        hidden
                        role="listbox"
                        aria-label="Category suggestions"
                      >
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <!-- ── Metadata section (Tags, SEO, Path) ─────────── -->
            <section id="meta-editor" class="inspector-section" aria-label="Metadata">
              <button
                id="btn-meta-toggle"
                class="inspector-section-head inspector-section-toggle"
                type="button"
                aria-expanded="false"
                aria-controls="meta-form"
              >
                <div class="inspector-section-head-text">
                  <span class="inspector-section-title">
                    Metadata
                    <span id="meta-dirty-dot" class="dirty-indicator" hidden></span>
                  </span>
                  <span id="meta-summary" class="section-summary-text"></span>
                </div>
                <Icon name="tabler:chevron-down" class="toggle-caret icon-sm" aria-hidden="true" />
              </button>
              <div id="meta-form" class="meta-form" hidden>
                <div class="setup-grid">
                  <div class="field field-full">
                    <label for="pub-tags-input" class="field-label">Tags</label>
                    <div id="pub-tags-container" class="tag-input-container">
                      <div id="pub-tags-pills" class="tag-pills"></div>
                      <input
                        id="pub-tags-input"
                        type="text"
                        autocomplete="off"
                        placeholder="Add tag…"
                        class="tag-text-input"
                      />
                      <div
                        id="pub-tags-suggestions"
                        class="tag-suggestions"
                        hidden
                        role="listbox"
                        aria-label="Tag suggestions"
                      >
                      </div>
                    </div>
                  </div>
                  <div class="field field-full">
                    <label for="pub-seo" class="field-label">
                      SEO description <span class="char-counter" id="seo-char-count"></span>
                    </label>
                    <input id="pub-seo" name="seoDescription" type="text" maxlength="180" autocomplete="off" />
                  </div>
                  <div class="field field-full">
                    <label for="pub-article-path" class="field-label"
                      >Article path <span class="field-label-hint">— generated</span></label
                    >
                    <div class="article-path-row">
                      <input
                        id="pub-article-path"
                        name="articlePath"
                        type="text"
                        readonly
                        class="article-path-field"
                        tabindex="-1"
                        aria-readonly="true"
                        placeholder="Enter a title to generate path…"
                      />
                      <button
                        id="btn-copy-path"
                        class="btn-icon-xs"
                        type="button"
                        aria-label="Copy article path"
                        title="Copy article path"
                      >
                        <Icon name="tabler:copy" class="icon-sm" aria-hidden="true" />
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <!-- ── Shared save row ────────────────────────────── -->
            <div class="meta-save-row">
              <button id="btn-save-meta" class="btn-secondary btn-sm" type="button">Save</button>
              <button
                id="btn-meta-undo"
                class="btn-link meta-undo-btn"
                type="button"
                hidden
                aria-label="Undo last metadata save">Undo</button
              >
              <p id="meta-status" class="meta-status-inline" aria-live="polite"></p>
            </div>

            <!-- ── Readiness + publish ───────────────────────── -->
            <div id="readiness-strip" class="readiness-strip">
              <div class="readiness-strip-main">
                <span id="readiness-label" class="readiness-pill" aria-live="polite"></span>
                <button id="readiness-toggle" class="readiness-toggle btn-link" type="button" aria-expanded="false">
                  Details
                </button>
              </div>
              <div id="readiness-chips" class="readiness-chips"></div>
              <div id="readiness-audit" class="readiness-audit" hidden>
                <div id="readiness-groups" class="readiness-groups"></div>
              </div>
              <div class="inspector-publish-row">
                <button id="btn-publish" class="btn-primary btn-sm" type="button" disabled>Publish</button>
                <p id="publish-status" class="publish-status" aria-live="polite"></p>
              </div>
            </div>
          </div><!-- /inspector-content -->
        </aside>
      </div><!-- /article-workspace -->
    </div>
  </section>

  <!-- ── Icon templates (pre-rendered at build time, cloned by JS at runtime) ── -->
  <div id="icon-templates" aria-hidden="true" style="display:none">
    <span data-icon="pencil"><Icon name="tabler:pencil" aria-hidden="true" /></span>
    <span data-icon="sparkles"><Icon name="tabler:sparkles" aria-hidden="true" /></span>
    <span data-icon="history"><Icon name="tabler:history" aria-hidden="true" /></span>
    <span data-icon="bold"><Icon name="tabler:bold" aria-hidden="true" /></span>
    <span data-icon="italic"><Icon name="tabler:italic" aria-hidden="true" /></span>
    <span data-icon="h-2"><Icon name="tabler:h-2" aria-hidden="true" /></span>
    <span data-icon="h-3"><Icon name="tabler:h-3" aria-hidden="true" /></span>
    <span data-icon="link"><Icon name="tabler:link" aria-hidden="true" /></span>
    <span data-icon="list"><Icon name="tabler:list" aria-hidden="true" /></span>
    <span data-icon="list-numbers"><Icon name="tabler:list-numbers" aria-hidden="true" /></span>
    <span data-icon="arrow-back-up"><Icon name="tabler:arrow-back-up" aria-hidden="true" /></span>
    <span data-icon="arrow-forward-up"><Icon name="tabler:arrow-forward-up" aria-hidden="true" /></span>
    <span data-icon="rotate-clockwise"><Icon name="tabler:rotate-clockwise" aria-hidden="true" /></span>
    <span data-icon="x"><Icon name="tabler:x" aria-hidden="true" /></span>
    <span data-icon="copy"><Icon name="tabler:copy" aria-hidden="true" /></span>
    <span data-icon="lock"><Icon name="tabler:lock" aria-hidden="true" /></span>
    <span data-icon="lock-open"><Icon name="tabler:lock-open" aria-hidden="true" /></span>
    <span data-icon="chevron-down"><Icon name="tabler:chevron-down" aria-hidden="true" /></span>
  </div>

  <!-- ── Draft picker modal ────────────────────────────────────────────────── -->
  <div id="draft-picker-modal" class="modal-backdrop" aria-hidden="true">
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="draft-picker-title">
      <div class="modal-header">
        <h2 id="draft-picker-title" class="modal-title">Open JSON draft</h2>
        <button id="btn-modal-close" class="modal-close-btn" type="button" aria-label="Close draft picker">✕</button>
      </div>
      <p class="modal-helper">Choose a JSON workflow record from Netlify Blobs.</p>
      <div class="modal-toolbar">
        <input
          id="draft-picker-search"
          type="search"
          class="modal-search"
          placeholder="Filter by title, author, or ID…"
          autocomplete="off"
        />
        <button id="btn-modal-refresh" class="btn-secondary btn-sm" type="button">Refresh</button>
      </div>
      <p id="modal-status" class="modal-status" aria-live="polite" role="status"></p>
      <div id="draft-picker-list" class="draft-picker-list"></div>
      <div id="draft-picker-empty" class="draft-picker-empty" hidden>
        <p>No JSON drafts found.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .admin-page {
    color: var(--aw-color-text-default);
  }

  .admin-top-bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(229 231 235);
  }
  :global(.dark) .admin-top-bar {
    border-color: rgb(30 41 59);
  }

  .admin-kicker {
    margin: 0 0 0.25rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .admin-top-bar-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .top-bar-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
  }

  .auth-status {
    margin: -0.5rem 0 1rem;
    color: var(--aw-color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .publish-workspace {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Inspector content — unified floating panel, single border/shadow */
  #inspector-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
    border: 1px solid rgb(229 231 235);
    border-radius: 0.75rem;
    background: rgb(255 255 255 / 0.92);
    box-shadow: 0 1px 6px rgb(15 23 42 / 5%);
    overflow: hidden;
  }
  :global(.dark) #inspector-content {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.75);
    box-shadow: none;
  }
  /* Hairline divider between every pair of consecutive visible children */
  #inspector-content > :not([hidden]) + :not([hidden]) {
    border-top: 1px solid rgb(229 231 235 / 70%);
  }
  :global(.dark) #inspector-content > :not([hidden]) + :not([hidden]) {
    border-top-color: rgb(30 41 59 / 80%);
  }

  /* Section summary — single-line compact text, shown when section is collapsed */
  .section-summary-text {
    display: block;
    margin: 0;
    font-size: 0.78rem;
    color: var(--aw-color-text-default);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.4;
  }
  .section-summary-text.is-empty {
    color: var(--aw-color-text-muted);
    font-style: italic;
  }

  /* Shared save row below both inspector sections */
  .meta-save-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.45rem 0.7rem;
  }

  /* Lock row — slim one-liner, no individual card chrome */
  .lock-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.7rem;
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--aw-color-text-muted);
    flex-shrink: 0;
    background: transparent;
  }
  .lock-row[data-locked-by-agent] {
    color: rgb(185 28 28);
    background: rgb(239 68 68 / 5%);
  }
  :global(.dark) .lock-row[data-locked-by-agent] {
    color: rgb(252 165 165);
    background: rgb(239 68 68 / 8%);
  }
  .lock-row[data-held] {
    color: rgb(6 95 70);
    background: rgb(16 185 129 / 5%);
  }
  :global(.dark) .lock-row[data-held] {
    color: rgb(110 231 183);
    background: rgb(16 185 129 / 8%);
  }
  .lock-row-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
    opacity: 0.75;
  }
  .lock-label {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Load status */
  .load-status {
    padding: 2rem;
    text-align: center;
    color: var(--aw-color-text-muted);
    font-weight: 700;
  }

  /* ── Admin card base ────────────────────────────────────────────────────────── */
  .admin-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.9);
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgb(15 23 42 / 4%);
  }
  :global(.dark) .admin-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.7);
  }

  /* ── Inspector section — no individual card chrome (lives inside unified panel) ── */
  .inspector-section {
    padding: 0.6rem 0.7rem 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: transparent;
  }

  /* Row containing toggle button + optional icon buttons (e.g. Metadata + history btn) */
  .inspector-section-head-row {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* The clickable section header toggle — fills its row */
  .inspector-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    min-height: 1.6rem;
  }

  /* When the head IS the toggle button */
  button.inspector-section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    min-height: 1.6rem;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    flex: 1;
    min-width: 0;
  }
  button.inspector-section-toggle:hover .inspector-section-title {
    color: var(--aw-color-text-default);
  }

  .inspector-section-head-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
    flex: 1;
  }

  /* Chevron caret — rotates when section is expanded */
  .toggle-caret {
    flex-shrink: 0;
    color: var(--aw-color-text-muted);
    opacity: 0.6;
    transition: transform 0.15s ease;
  }
  button.inspector-section-toggle[aria-expanded='true'] .toggle-caret {
    transform: rotate(180deg);
    opacity: 0.85;
  }

  .inspector-section-title {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .inspector-section-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  /* Collapsed form wrapper */
  .meta-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  /* display:flex would override [hidden]{display:none} — both are (0,1,0) specificity.
     Adding the attribute selector raises this rule to (0,2,0) so hidden wins. */
  .meta-form[hidden] {
    display: none !important;
  }

  /* Inline status next to section title actions */
  .meta-status-inline {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--aw-color-text-muted);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 6rem;
  }
  .meta-status-inline.is-error {
    color: rgb(239 68 68);
  }
  .meta-status-inline.is-ok {
    color: rgb(22 163 74);
  }

  /* Dirty-state dot */
  .dirty-indicator {
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: rgb(245 158 11);
    flex-shrink: 0;
  }

  /* ── Icon-only lock action buttons (Force release, Done editing) ──────────── */
  .btn-icon-lock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 0.3rem;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    opacity: 0.65;
    transition:
      opacity 0.1s,
      background 0.1s;
  }
  .btn-icon-lock:hover {
    opacity: 1;
    background: rgb(209 213 219 / 40%);
  }

  /* ── Small button variants for inspector actions ───────────────────────────── */
  .btn-ghost-xs {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.5rem;
    border-radius: 0.35rem;
    border: 1px solid rgb(209 213 219);
    background: transparent;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    cursor: pointer;
    line-height: 1.25;
    white-space: nowrap;
  }
  .btn-ghost-xs:hover {
    background: rgb(229 231 235 / 50%);
    color: var(--aw-color-text-heading);
  }
  :global(.dark) .btn-ghost-xs {
    border-color: rgb(51 65 85);
  }
  :global(.dark) .btn-ghost-xs:hover {
    background: rgb(51 65 85 / 50%);
  }

  .btn-icon-xs {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 0.35rem;
    border: 1px solid rgb(209 213 219);
    background: transparent;
    color: var(--aw-color-text-muted);
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
  }
  .btn-icon-xs:hover {
    background: rgb(209 213 219 / 40%);
    color: var(--aw-color-text-heading);
  }
  :global(.dark) .btn-icon-xs {
    border-color: rgb(51 65 85);
  }
  :global(.dark) .btn-icon-xs:hover {
    background: rgb(51 65 85 / 50%);
  }

  /* ── Inspector empty state card ─────────────────────────────────────────────── */
  .inspector-empty-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 0.75rem;
    background: rgb(249 250 251 / 0.7);
    padding: 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    text-align: center;
  }
  :global(.dark) .inspector-empty-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.35);
  }
  .inspector-empty-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--aw-color-text-muted);
    margin: 0;
  }

  /* ── Article path row (field + copy button) ─────────────────────────────────── */
  .article-path-row {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .article-path-row .article-path-field {
    flex: 1;
    min-width: 0;
  }

  /* ── Admin setup module (kept for any other uses) ──────────────────────────── */
  .admin-setup-module {
    border: 1px solid rgb(229 231 235 / 80%);
    border-radius: 1rem;
    background: rgb(249 250 251 / 0.7);
    padding: 0.9rem 1.1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  :global(.dark) .admin-setup-module {
    border-color: rgb(30 41 59 / 70%);
    background: rgb(15 23 42 / 0.35);
  }

  .setup-module-label {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
    opacity: 0.7;
  }

  .setup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem 0.75rem;
  }
  .field-full {
    grid-column: 1 / -1;
  }
  /* Inspector is always narrow — collapse to 1-col within it */
  .inspector-section .setup-grid,
  .inspector-panel .setup-grid {
    grid-template-columns: 1fr;
  }
  .inspector-section .field-full,
  .inspector-panel .field-full {
    grid-column: 1;
  }
  @media (max-width: 540px) {
    .setup-grid {
      grid-template-columns: 1fr;
    }
    .field-full {
      grid-column: 1;
    }
  }

  /* ── Fields ─────────────────────────────────────────────────────────────────── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .field-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .field-label-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.68rem;
    opacity: 0.7;
  }

  .char-counter {
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--aw-color-text-muted);
    letter-spacing: 0;
    text-transform: none;
    float: right;
  }

  .field-error {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(239 68 68);
  }
  :global(.dark) .field-error {
    color: rgb(252 165 165);
  }

  /* Setup module inputs — consistent compact style */
  .admin-setup-module input:not(.article-path-field),
  .admin-setup-module input[type='date'],
  .inspector-section input:not(.article-path-field),
  .inspector-section input[type='date'] {
    border: 1px solid rgb(209 213 219);
    border-radius: 0.4rem;
    padding: 0.3rem 0.5rem;
    font-size: 0.82rem;
    background: white;
    color: inherit;
    width: 100%;
    line-height: 1.4;
  }
  .admin-setup-module input:focus,
  .inspector-section input:focus {
    outline: none;
    border-color: var(--aw-color-accent);
    box-shadow: 0 0 0 2px rgb(94 140 138 / 15%);
  }
  :global(.dark) .admin-setup-module input:not(.article-path-field),
  :global(.dark) .admin-setup-module input[type='date'],
  :global(.dark) .inspector-section input:not(.article-path-field),
  :global(.dark) .inspector-section input[type='date'] {
    border-color: rgb(51 65 85);
    background: rgb(15 23 42 / 0.5);
  }

  /* Generated article path — read-only, monospace, greyed */
  .article-path-field {
    border: 1px solid rgb(209 213 219);
    border-radius: 0.4rem;
    padding: 0.35rem 0.55rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    background: rgb(248 250 252);
    color: var(--aw-color-text-muted);
    cursor: default;
    width: 100%;
    user-select: all;
  }
  :global(.dark) .article-path-field {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.3);
    color: rgb(100 116 139);
  }

  .meta-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }

  .meta-status {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    min-height: 1.2em;
  }
  .meta-status.is-error {
    color: rgb(239 68 68);
  }
  .meta-status.is-ok {
    color: rgb(22 163 74);
  }

  /* ── "+N more" chip for readiness ──────────────────────────────────────────── */
  :global(.readiness-chip-more) {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    border: 1px solid rgb(209 213 219);
    background: transparent;
    color: var(--aw-color-text-muted);
    cursor: pointer;
    line-height: 1.3;
  }
  :global(.readiness-chip-more:hover) {
    background: rgb(209 213 219 / 35%);
    color: var(--aw-color-text-heading);
  }
  :global(.dark) :global(.readiness-chip-more) {
    border-color: rgb(51 65 85);
  }

  /* ── Readiness strip — no individual card chrome ─────────────────────────────── */
  .readiness-strip {
    padding: 0.55rem 0.7rem 0.7rem;
    font-size: 0.83rem;
    background: transparent;
  }

  .readiness-strip-main {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .readiness-toggle {
    font-size: 0.73rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    line-height: 1;
  }
  .readiness-toggle:hover {
    color: var(--aw-color-text-default);
  }

  .readiness-audit {
    margin-top: 0.65rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgb(229 231 235);
  }
  :global(.dark) .readiness-audit {
    border-top-color: rgb(30 41 59);
  }

  .readiness-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 900;
  }
  .readiness-pill.is-missing {
    background: rgb(239 68 68 / 10%);
    color: rgb(185 28 28);
  }
  :global(.dark) .readiness-pill.is-missing {
    color: rgb(252 165 165);
  }
  .readiness-pill.is-warning {
    background: rgb(245 158 11 / 12%);
    color: rgb(146 64 14);
  }
  :global(.dark) .readiness-pill.is-warning {
    color: rgb(253 230 138);
  }
  .readiness-pill.is-ready {
    background: rgb(34 197 94 / 12%);
    color: rgb(22 101 52);
  }
  :global(.dark) .readiness-pill.is-ready {
    color: rgb(187 247 208);
  }

  .readiness-groups {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.readiness-group) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.readiness-group-label) {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--aw-color-text-muted);
    margin: 0;
  }

  :global(.readiness-criteria-list) {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  :global(.readiness-criterion) {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  :global(.criterion-pill) {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 900;
    width: 1em;
    text-align: center;
  }
  :global(.criterion-pill.complete) {
    color: rgb(22 163 74);
  }
  :global(.criterion-pill.warning) {
    color: rgb(217 119 6);
  }
  :global(.criterion-pill.missing) {
    color: rgb(220 38 38);
  }
  :global(.criterion-pill.optional) {
    color: var(--aw-color-text-muted);
  }

  :global(.criterion-text) {
    font-weight: 600;
  }
  :global(.criterion-message) {
    color: var(--aw-color-text-muted);
    font-size: 0.73rem;
  }
  :global(.criterion-message::before) {
    content: '— ';
  }

  .publish-status {
    min-height: 1.2em;
    font-size: 0.82rem;
    font-weight: 700;
    margin-top: 0.4rem;
  }
  .publish-status.is-error {
    color: rgb(220 38 38);
  }
  .publish-status.is-ok {
    color: rgb(22 163 74);
  }

  /* ── Article header card (title + excerpt) ─ editorial, no card chrome ───────── */
  .article-header-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 1rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  /* Screenreader-only utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* History button: only appears on hover of the card */
  .article-header-history-btn {
    position: absolute;
    top: 0;
    right: 0.5rem;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 2;
  }
  .article-header-card:hover .article-header-history-btn,
  .article-header-card:focus-within .article-header-history-btn {
    opacity: 1;
  }

  /* Title: textarea matching published article h1 */
  .article-title-input {
    font-family: var(--aw-font-serif, Georgia, 'Times New Roman', serif);
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--aw-color-text-heading);
    padding: 0.1rem 0;
    width: 100%;
    resize: none;
    overflow: hidden;
    display: block;
    min-height: 3rem;
  }
  .article-title-input:focus {
    outline: none;
    border-bottom-color: rgb(94 140 138 / 35%);
  }
  .article-title-input::placeholder {
    color: var(--aw-color-text-muted);
    font-weight: 400;
    font-size: 1.8rem;
    opacity: 0.4;
  }

  /* Excerpt styled as article deck, matching published italic deck */
  .article-excerpt-input {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--aw-color-text-muted);
    border: none;
    border-bottom: 1px solid transparent;
    background: transparent;
    padding: 0.1rem 0;
    width: 100%;
    resize: none;
    line-height: 1.55;
  }
  .article-excerpt-input:focus {
    outline: none;
    border-bottom-color: rgb(94 140 138 / 35%);
  }
  .article-excerpt-input::placeholder {
    color: var(--aw-color-text-muted);
    opacity: 0.5;
  }

  /* ── Article body ─────────────────────────────────────────────────────────── */
  .article-view {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    padding: 0 1rem;
  }

  .nodes-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Node wrapper */
  :global(.dl-node-wrapper) {
    position: relative;
    border-radius: 0.75rem;
    transition: box-shadow 0.15s;
  }
  :global(.dl-node-wrapper:hover),
  :global(.dl-node-wrapper.is-dock-attached) {
    box-shadow: 0 0 0 2px rgb(94 140 138 / 25%);
  }
  :global(.dl-node-wrapper[data-editing]) {
    box-shadow: 0 0 0 2px rgb(220 38 38 / 55%);
  }
  :global(.dl-node-wrapper.is-dock-dirty) {
    box-shadow: 0 0 0 2px rgb(217 119 6 / 40%);
  }

  /* Icon helpers */
  .icon-sm {
    width: 1em;
    height: 1em;
    display: block;
  }

  /* Module label row (label + history icon) — legacy, kept for any other modules */
  .module-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  /* Icon-only buttons (dl-icon-btn): history / future actions */
  :global(.dl-icon-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    border: 1px solid rgb(209 213 219);
    background: transparent;
    color: var(--aw-color-text-muted, #6b7280);
    cursor: pointer;
    transition:
      background 0.1s,
      border-color 0.1s,
      color 0.1s;
    flex-shrink: 0;
  }
  :global(.dl-icon-btn:hover) {
    background: rgb(209 213 219 / 40%);
    border-color: rgb(156 163 175);
    color: var(--aw-color-text-heading);
  }
  :global(.dl-icon-btn.is-history:hover) {
    background: rgb(59 130 246 / 10%);
    border-color: rgb(59 130 246 / 50%);
    color: rgb(37 99 235);
  }
  :global(.dark) :global(.dl-icon-btn.is-history:hover) {
    color: rgb(147 197 253);
  }

  /* History icon button flush to top-right of article-header-card */
  .article-header-history-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
  }

  /* Meta undo button */
  .meta-undo-btn {
    font-size: 0.75rem;
    padding: 0;
    margin-left: 0.5rem;
    text-decoration: underline;
    color: var(--aw-color-text-muted, #6b7280);
    background: none;
    border: none;
    cursor: pointer;
  }
  .meta-undo-btn:hover {
    color: var(--aw-color-text-heading);
  }

  /* Persistent node badge — always visible at bottom-left of each block */
  :global(.dl-node-badge) {
    position: absolute;
    bottom: 0.3rem;
    left: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.65rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    color: var(--aw-color-text-muted, #6b7280);
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
    z-index: 5;
    line-height: 1;
  }
  :global(.dl-node-wrapper:hover .dl-node-badge),
  :global(.dl-node-wrapper[data-editing] .dl-node-badge),
  :global(.dl-node-badge.has-saved) {
    opacity: 1;
    pointer-events: auto;
  }
  :global(.dl-node-badge-saved) {
    display: none;
    color: rgb(22 163 74);
    font-family: inherit;
  }
  :global(.dl-node-badge.has-saved .dl-node-badge-saved) {
    display: inline;
  }
  :global(.dl-node-badge-undo) {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0 0.1rem;
    font-size: inherit;
    font-family: inherit;
    cursor: pointer;
    color: var(--aw-color-text-muted, #6b7280);
    width: 1.1em;
    height: 1.1em;
  }
  :global(.dl-node-badge.has-saved .dl-node-badge-undo) {
    display: inline-flex;
  }
  :global(.dl-node-badge-undo:hover) {
    color: var(--aw-color-text-heading);
  }

  /* Lock state — another agent holds the lock: visually disable all edit controls */
  :global(#article-workspace[data-lock='agent'] .dl-node-btn),
  :global(#article-workspace[data-lock='agent'] #btn-save-meta),
  :global(#article-workspace[data-lock='agent'] #btn-meta-undo),
  :global(#article-workspace[data-lock='agent'] .dl-node-badge-undo),
  :global(#article-workspace[data-lock='agent'] .dl-history-restore) {
    pointer-events: none !important;
    opacity: 0.35 !important;
    cursor: not-allowed !important;
  }

  /* Mutual exclusivity — manual editor open: disable AI on all blocks */
  :global(#nodes-container[data-mode='editing'] .dl-node-btn.is-ai) {
    pointer-events: none;
    opacity: 0.35;
  }

  /* Mutual exclusivity — AI open: disable edit/ai on all blocks */
  :global(#nodes-container[data-mode='ai'] .dl-node-btn:not(.is-history)) {
    pointer-events: none;
    opacity: 0.35;
  }

  /* History button disabled state */
  :global(.dl-node-btn.is-history:disabled),
  :global(.dl-icon-btn.is-history:disabled) {
    opacity: 0.3;
    pointer-events: none;
  }

  /* History popover */
  :global(.dl-history-popover) {
    position: absolute;
    z-index: 60;
    right: 0;
    top: calc(100% + 0.25rem);
    min-width: 18rem;
    max-width: min(24rem, calc(100vw - 2rem));
    background: rgb(255 255 255);
    border: 1px solid rgb(229 231 235);
    border-radius: 0.875rem;
    box-shadow:
      0 4px 24px rgb(0 0 0 / 10%),
      0 1px 4px rgb(0 0 0 / 6%);
    overflow: hidden;
  }
  :global(.dark) :global(.dl-history-popover) {
    background: rgb(15 23 42);
    border-color: rgb(30 41 59);
  }
  :global(.dl-history-popover-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.75rem 0.5rem;
    border-bottom: 1px solid rgb(229 231 235);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--aw-color-text-muted, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  :global(.dark) :global(.dl-history-popover-header) {
    border-color: rgb(30 41 59);
  }
  :global(.dl-history-popover-close) {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    line-height: 1;
    color: inherit;
    padding: 0.1rem 0.25rem;
    border-radius: 0.25rem;
  }
  :global(.dl-history-popover-close:hover) {
    background: rgb(229 231 235 / 60%);
  }
  :global(.dl-history-entry) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgb(229 231 235 / 60%);
    font-size: 0.75rem;
  }
  :global(.dark) :global(.dl-history-entry) {
    border-color: rgb(30 41 59 / 60%);
  }
  :global(.dl-history-entry:last-child) {
    border-bottom: none;
  }
  :global(.dl-history-time) {
    color: var(--aw-color-text-muted, #6b7280);
    font-size: 0.68rem;
  }
  :global(.dl-history-restore) {
    margin-top: 0.2rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-decoration: underline;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--aw-color-accent);
    text-align: left;
  }
  :global(.dl-history-restore:disabled) {
    color: var(--aw-color-text-muted, #6b7280);
    cursor: default;
    opacity: 0.6;
  }
  :global(.dl-history-empty) {
    padding: 0.75rem;
    font-size: 0.75rem;
    color: var(--aw-color-text-muted, #6b7280);
    text-align: center;
  }

  /* Node toolbar — pill-shaped, site-styled */
  :global(.dl-node-toolbar) {
    position: absolute;
    top: 0.4rem;
    right: 0.4rem;
    display: flex;
    gap: 0.25rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }
  :global(.dl-node-wrapper:hover .dl-node-toolbar),
  :global(.dl-node-wrapper[data-editing] .dl-node-toolbar) {
    opacity: 1;
    pointer-events: auto;
  }
  :global(.dl-node-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgb(209 213 219);
    background: rgb(255 255 255 / 0.97);
    color: var(--aw-color-text-heading);
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 1px 3px rgb(0 0 0 / 8%);
    transition:
      background 0.1s,
      border-color 0.1s,
      color 0.1s;
    line-height: 1.2;
    white-space: nowrap;
  }
  :global(.dark) :global(.dl-node-btn) {
    background: rgb(30 41 59 / 0.97);
    border-color: rgb(51 65 85);
    color: inherit;
  }
  :global(.dl-node-btn:hover) {
    background: rgb(94 140 138 / 12%);
    border-color: rgb(94 140 138 / 50%);
  }
  :global(.dl-node-btn.is-ai:hover) {
    background: rgb(124 58 237 / 10%);
    border-color: rgb(124 58 237 / 45%);
    color: rgb(109 40 217);
  }
  :global(.dark) :global(.dl-node-btn.is-ai:hover) {
    color: rgb(192 132 252);
  }
  :global(.dl-node-btn.is-history:hover) {
    background: rgb(59 130 246 / 10%);
    border-color: rgb(59 130 246 / 45%);
    color: rgb(37 99 235);
  }
  :global(.dark) :global(.dl-node-btn.is-history:hover) {
    color: rgb(147 197 253);
  }
  :global(.dl-node-btn.is-cancel) {
    color: rgb(220 38 38);
    border-color: rgb(220 38 38 / 40%);
  }
  :global(.dl-node-btn.is-cancel:hover) {
    background: rgb(220 38 38 / 10%);
    border-color: rgb(220 38 38 / 55%);
  }
  :global(.dark) :global(.dl-node-btn.is-cancel) {
    color: rgb(248 113 113);
  }

  /* Active state for icon toolbar buttons */
  :global(.dl-editor-toolbar button.is-active) {
    background: rgb(209 213 219 / 70%);
    color: rgb(17 24 39);
  }
  :global(.dark) :global(.dl-editor-toolbar button.is-active) {
    background: rgb(51 65 85);
    color: rgb(248 250 252);
  }

  /* TipTap editor chrome */
  :global(.dl-node-editor) {
    margin: -0.25rem;
  }
  :global(.dl-editor-content .ProseMirror) {
    outline: none;
  }
  :global(.dl-editor-content .ProseMirror p) {
    margin: 0 0 0.75em;
  }
  :global(.dl-editor-content .ProseMirror h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.5em;
  }
  :global(.dl-editor-content .ProseMirror h3) {
    font-size: 1.15rem;
    font-weight: 600;
