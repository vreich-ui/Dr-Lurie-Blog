      const getEditSlug = () => slugify(new URLSearchParams(window.location.search).get('edit') || '');

      const isEditMode = () => Boolean(getEditSlug());

      const getSlugEditHint = () => 'Publishing target is generated from the title and cannot be edited directly.';

      const setUnsavedChanges = (value) => {
        hasUnsavedChanges = Boolean(value);
        if (fields.unsavedChanges) fields.unsavedChanges.hidden = !hasUnsavedChanges;
        recalculateButtonState();
      };

      const renderSlugHint = (isInvalid) => {
        const editHint = getSlugEditHint();
        fields.slugHint.textContent = isInvalid ? slugInvalidMessage : editHint;
        fields.slugHint.hidden = !isInvalid && !editHint;
        fields.slugHint.classList.toggle('is-error', isInvalid);
      };

      const validateSlug = ({ announce = false } = {}) => {
        const slug = fields.slug.value.trim();
        const isInvalid = Boolean(slug) && !slugPattern.test(slug);
        fields.slug.classList.toggle('is-error', isInvalid);
        fields.slug.setAttribute('aria-invalid', String(isInvalid));
        renderSlugHint(isInvalid);

        if (isInvalid && announce) setStatus(slugInvalidMessage, false);
        return !isInvalid;
      };

      const getMarkdownWordCount = () => fields.content.value.trim().split(/\s+/).filter(Boolean).length;

      const getHasMinimumDraftContent = () =>
        Boolean(fields.title.value.trim() && slugify(fields.title.value) && fields.author.value.trim());

      const getHasPreviewContent = () =>
        Boolean(
          fields.title.value.trim() ||
            fields.content.value.trim() ||
            fields.excerpt.value.trim() ||
            getFeaturedImagePath().trim()
        );

      const formatStatusDate = (value, { includeComma = false } = {}) => {
        if (!value) return '';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return String(value);
        return new Intl.DateTimeFormat(undefined, {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        })
          .format(date)
          .replace(',', includeComma ? ',' : '');
      };

      const normalizeMarkdownForStatus = (value) =>
        String(value || '')
          .replace(/\s+$/g, '')
          .trim();

      const getCurrentArticleStatusState = () => {
        if (!articleStatus.published) return 'draft';
        return normalizeMarkdownForStatus(fields.outputMarkdown?.value) ===
          normalizeMarkdownForStatus(articleStatus.published.markdown)
          ? 'published'
          : 'modified';
      };

      const renderArticleStatusCard = () => {
        const state = getCurrentArticleStatusState();
        const published = articleStatus.published;
        const savedDate = lastSavedAt ? formatStatusDate(lastSavedAt) : '';
        const publishedDate = formatStatusDate(published?.publishDate, { includeComma: true });
        const publishedAuthor = published?.author || fields.author.value.trim() || 'Unknown';

        fields.articleStatusCard?.classList.remove(
          'article-status-card--published',
          'article-status-card--draft',
          'article-status-card--modified'
        );
        fields.articleStatusCard?.classList.add(`article-status-card--${state}`);

        if (state === 'published') {
          fields.articleStatusIcon.textContent = '✓';
          fields.articleStatusTitle.textContent = 'Published';
          fields.articleStatusSubtitle.textContent = publishedDate
            ? `Published ${publishedDate.replace(',', '')}`
            : 'Published version exists';
          fields.articleStatusDetails.innerHTML = `
            <p>by ${escapeHtml(publishedAuthor)}</p>
            <hr />
            <p>✓ Existing published article</p>
            <p class="article-status-slug">${escapeHtml(fields.slug.value.trim() || 'article-slug')}</p>
            <p><strong>Published:</strong></p>
            <p>${escapeHtml(publishedDate || 'Unknown')}</p>`;
        } else if (state === 'modified') {
          fields.articleStatusIcon.textContent = '⚠';
          fields.articleStatusTitle.textContent = 'Modified';
          fields.articleStatusSubtitle.textContent = 'Published version exists';
          fields.articleStatusDetails.innerHTML = `
            <p>Draft changes saved</p>
            <p>but not published</p>`;
        } else {
          fields.articleStatusIcon.textContent = '○';
          fields.articleStatusTitle.textContent = 'Draft';
          fields.articleStatusSubtitle.textContent = savedDate
            ? `Saved ${savedDate}`
            : 'Saved draft changes are not live';
          fields.articleStatusDetails.innerHTML = `
            <p>by ${escapeHtml(lastSavedBy || fields.author.value.trim() || 'Unknown')}</p>`;
        }
      };

      const updateContentModelIndicator = () => {
        if (!fields.contentModelIndicator) return;

        const hasPublished = Boolean(articleStatus.published);
        const { requestId, lockToken } = getCheckedOutWorkflowDraft();
        const pubStatus = getCurrentArticleStatusState();

        let workflowStatusLabel = 'none';
        if (lockToken) workflowStatusLabel = 'checked_out';
        else if (requestId || lastSavedDraftId) workflowStatusLabel = 'pending';

        const lines = [
          contentModel === 'article_body.v1'
            ? '<div><strong>Structured article:</strong> article_body.v1</div>'
            : '<div><strong>Legacy markdown converted to structured piece</strong></div>',
          `<div><strong>Workflow record:</strong> ${workflowStatusLabel}</div>`,
          `<div><strong>Publication status:</strong> ${pubStatus}</div>`,
          `<div><strong>Published article:</strong> ${hasPublished ? 'yes' : 'no'}</div>`,
          '<div><strong>Canonical source:</strong> article_body</div>',
        ];

        fields.contentModelIndicator.innerHTML = lines.join('');
      };

      const updatePublishDecisionControls = () => {
        const hasPublishedArticle = Boolean(articleStatus.published);
        const label = hasPublishedArticle ? 'Overwrite Published Article' : 'Publish Article';
        fields.publish.textContent = label;
        if (fields.topPublish) fields.topPublish.textContent = label;

        if (fields.overwritePublishControl) fields.overwritePublishControl.hidden = !hasPublishedArticle;
        if (!hasPublishedArticle) fields.overwrite.checked = false;

        const ariaDescribedBy = hasPublishedArticle ? 'overwrite-slug publish-blocked-message' : 'publish-blocked-message';
        fields.publish.setAttribute('aria-describedby', ariaDescribedBy);
        if (fields.topPublish) fields.topPublish.setAttribute('aria-describedby', ariaDescribedBy);

        const isOverwriteRequired = hasPublishedArticle && !fields.overwrite.checked;
        fields.publish.classList.toggle('is-overwrite-required', isOverwriteRequired);
        if (fields.topPublish) fields.topPublish.classList.toggle('is-overwrite-required', isOverwriteRequired);

        renderArticleStatusCard();
        updateContentModelIndicator();
      };

      const updateArticleStatusCard = () => {
        updatePublishDecisionControls();
      };

      const fetchPublishedArticleStatus = async ({ force = false } = {}) => {
        const slug = fields.slug.value.trim();
        if (!slugPattern.test(slug)) {
          articleStatus = { state: 'draft', published: null, checkedSlug: '' };
          updatePublishDecisionControls();
          return;
        }
        if (!force && articleStatus.checkedSlug === slug) {
          updatePublishDecisionControls();
          return;
        }

        const requestId = (articleStatusRequestId += 1);
        try {
          const token = await getClerkSessionToken();
          const response = await fetch(`/.netlify/functions/get-article-for-edit?slug=${encodeURIComponent(slug)}`, {
            method: 'GET',
            headers: {
              Authorization: `Bearer ${token}`,
              'Content-Type': 'application/json',
            },
          });
          const result = await response.json().catch(() => ({}));
          if (requestId !== articleStatusRequestId) return;
          if (response.status === 404) {
            articleStatus = { state: 'draft', published: null, checkedSlug: slug };
          } else if (response.ok) {
            const article = result.article || result;
            articleStatus = { state: 'published', published: article, checkedSlug: slug };
          } else {
            console.warn('Published article status could not be checked.', result.error || response.status);
            articleStatus = { state: 'draft', published: null, checkedSlug: slug };
          }
        } catch (error) {
          if (requestId !== articleStatusRequestId) return;
          console.warn('Published article status check failed.', error);
          articleStatus = { state: 'draft', published: null, checkedSlug: slug };
        }
        updatePublishDecisionControls();
        recalculateButtonState();
      };

      let articleStatusDebounceTimer;
      const queuePublishedArticleStatusCheck = () => {
        window.clearTimeout(articleStatusDebounceTimer);
        articleStatusDebounceTimer = window.setTimeout(() => {
          fetchPublishedArticleStatus().catch((error) => {
            console.warn('Published article status check could not be queued.', error);
          });
        }, 350);
      };

      const hasCurrentWorkflowLock = () => {
        const { requestId, lockToken } = getCheckedOutWorkflowDraft();
        if (!requestId) return true;
        if (!lockToken) return false;

        const expiresAt = workflowLockExpiresAt || sessionStorage.getItem('dr-lurie-workflow-lock-expires-at') || '';
        if (!expiresAt) return true;

        const expiresAtMs = Date.parse(expiresAt);
        return Number.isNaN(expiresAtMs) || expiresAtMs > Date.now();
      };

      const recalculateButtonState = () => {
        const hasDraftFields = getHasMinimumDraftContent();
        const hasValidSlug = slugPattern.test(fields.slug.value.trim());
        const missingRequiredFields = getMissingRequiredValidationItems();
        const hasRequiredValidationFields = missingRequiredFields.length === 0;
        const canUseWorkflowLock = hasCurrentWorkflowLock();
        const canSaveDraft = isAdmin && hasDraftFields && hasUnsavedChanges;
        const canPreview =
          isAdmin &&
          getHasPreviewContent() &&
          (getCheckedOutWorkflowDraft().requestId || lastSavedDraftId || (hasUnsavedChanges && hasDraftFields));
        const canPublish = Boolean(
          isAdmin &&
            hasRequiredValidationFields &&
            fields.author.value.trim() &&
            hasValidSlug &&
            getMarkdownWordCount() >= 5 &&
            canUseWorkflowLock &&
            (!articleStatus.published || fields.overwrite.checked)
        );

        fields.saveDraft.disabled = !canSaveDraft;
        if (fields.topSave) fields.topSave.disabled = !canSaveDraft;

        fields.preview.disabled = !canPreview;
        if (fields.topPreview) fields.topPreview.disabled = !canPreview;

        fields.publish.disabled = !canPublish;
        if (fields.topPublish) fields.topPublish.disabled = !canPublish;

        fields.copyOutput.disabled = !canPublish;
        fields.downloadJsonBackup.disabled = !canPublish;
        fields.backupPanel.classList.toggle('is-disabled', !canPublish);
        fields.publish.classList.toggle('is-validation-blocked', !hasRequiredValidationFields);
        if (fields.topPublish) fields.topPublish.classList.toggle('is-validation-blocked', !hasRequiredValidationFields);

        if (fields.publishBlockedMessage) {
          if (articleStatus.published && hasRequiredValidationFields && !fields.overwrite.checked) {
            fields.publishBlockedMessage.textContent = 'Check overwrite before replacing the live article.';
            fields.publishBlockedMessage.hidden = false;
