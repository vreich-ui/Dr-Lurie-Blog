---
import { Icon } from 'astro-icon/components';
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const publicGitHubRepoUrl = import.meta.env.PUBLIC_GITHUB_REPOSITORY_URL ?? '';
const publicGitHubBranch = import.meta.env.PUBLIC_GITHUB_BRANCH ?? 'main';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="admin-page mx-auto max-w-[1800px] px-4 py-8 sm:px-6 sm:py-12"
    data-admin-shell
    data-clerk-publishable-key={clerkPublishableKey}
    data-public-github-branch={publicGitHubBranch}
    data-public-github-repo-url={publicGitHubRepoUrl}
    hidden
  >
    <!-- ── Top action bar ──────────────────────────────────────── -->
    <header class="admin-top-bar">
      <div class="admin-top-bar-identity">
        <p id="publish-mode" class="admin-kicker">Agent-First Editor</p>
        <h1 class="admin-top-bar-title">{pageTitle}</h1>
      </div>
      <div class="top-bar-actions">
        <button id="top-preview" class="btn-secondary btn-sm" type="button">Preview</button>
        <button id="top-save" class="btn-secondary btn-sm" type="button">Save Draft</button>
        <button id="top-publish" class="btn-primary btn-sm" type="button">Publish Article</button>
      </div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <AdminNav />

    <div class="publish-workspace" data-auth-gated>
      <!-- ── Main editor column ───────────────────────────────── -->
      <main class="publish-main" aria-label="Article editor">
        <form id="publish-form" class="admin-form">

          <!-- ── Article Details card ──────────────────────── -->
          <section class="admin-card article-details-card" aria-labelledby="details-heading">
            <div class="card-section-header">
              <h2 id="details-heading">Article Details</h2>
            </div>

            <div class="field">
              <label for="title">Article Title</label>
              <input
                id="title"
                name="title"
                type="text"
                class="title-input"
                autocomplete="off"
                placeholder="Enter article title…"
              />
            </div>

            <div class="field">
              <label for="excerpt">Excerpt / Summary</label>
              <textarea
                id="excerpt"
                name="excerpt"
                rows="3"
                maxlength="300"
                placeholder="A brief summary shown on listing cards and search results…"
              ></textarea>
            </div>

            <div class="field-grid">
              <div class="field">
                <label for="category">Category</label>
                <input id="category" name="category" type="text" autocomplete="off" placeholder="e.g. Skin Science" />
              </div>
              <div class="field">
                <label for="tags">Tags</label>
                <input id="tags" name="tags" type="text" autocomplete="off" placeholder="e.g. barrier, lipids" />
              </div>
            </div>

            <div class="field checkbox-field mt-2">
              <input id="draft" name="draft" type="checkbox" />
              <label for="draft">Save as draft (unpublished)</label>
            </div>
          </section>

          <!-- ── Article Builder card ──────────────────────── -->
          <section
            class="admin-card article-builder-card"
            id="article-content-pieces"
            aria-labelledby="builder-heading"
          >
            <div class="card-section-header">
              <h2 id="builder-heading">Article Builder</h2>
              <p class="hint">Add and arrange content blocks to build your article.</p>
              <p id="legacy-markdown-conversion-notice" class="legacy-markdown-conversion-notice" hidden>
                Legacy content converted to editable blocks.
              </p>
            </div>

            <div class="pieces-quick-add" aria-label="Add content block">
              <span class="quick-add-label">Add block:</span>
              <button class="btn-tertiary btn-xs quick-add" data-template="prose_section" type="button">+ Text</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="image" type="button">+ Image</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="soft_action" type="button">+ CTA</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="contextual_offer" type="button">+ Offer</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="callout" type="button">+ Callout</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="summary" type="button">+ Summary</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="faq" type="button">+ FAQ</button>
              <button class="btn-tertiary btn-xs quick-add" data-template="chat_invite" type="button">+ Chat</button>
              <button id="add-piece" class="btn-secondary btn-xs" type="button">
                <Icon name="tabler:plus" class="piece-action-icon" aria-hidden="true" />
                More…
              </button>
            </div>

            <div id="pieces-empty-state" class="pieces-empty-state" hidden>
              <h3>Build Your Article</h3>
              <p>Start by adding your first content section.</p>
              <button class="btn-primary btn-sm mt-6 quick-add" data-template="prose_section" type="button">
                Add First Section
              </button>
            </div>

            <div id="pieces-container" class="pieces-container"></div>

            <dialog id="block-library-modal" class="json-draft-modal" aria-labelledby="block-library-heading">
              <div class="json-draft-modal-card">
                <div class="json-draft-modal-header">
                  <div>
                    <p class="sidebar-kicker">Block Library</p>
                    <h3 id="block-library-heading">Choose a block type</h3>
                  </div>
                  <button
                    id="block-library-close"
                    class="module-icon-button"
                    type="button"
                    aria-label="Close library"
                  >
                    <Icon name="tabler:x" class="module-action-icon" aria-hidden="true" />
                  </button>
                </div>
                <div id="block-library-list" class="block-library-list"></div>
              </div>
            </dialog>
          </section>

          <!-- ── Advanced / Developer Tools ───────────────── -->
          <details class="advanced-tools-accordion">
            <summary class="advanced-tools-summary">
              <Icon name="tabler:settings" class="advanced-tools-icon" aria-hidden="true" />
              Advanced / Developer Tools
            </summary>

            <div class="advanced-tools-content">
              <!-- Publishing identity -->
              <div class="field-grid">
                <div class="field">
                  <label for="slug">Publishing Target (Slug)</label>
                  <input
                    id="slug"
                    name="slug"
                    type="text"
                    autocomplete="off"
                    placeholder="article-slug"
                    aria-describedby="slug-edit-hint"
                    readonly
                  />
                  <p id="slug-edit-hint" class="hint" aria-live="polite" hidden></p>
                </div>
                <div class="field">
                  <label for="author">Author</label>
                  <input id="author" name="author" type="text" autocomplete="off" placeholder="Dr. Lurié" />
                </div>
              </div>

              <div class="field-grid">
                <div class="field">
                  <label for="publish-date">Publish Date Override</label>
                  <input id="publish-date" name="publishDate" type="datetime-local" />
                </div>
                <div class="field">
                  <label for="seo-description">SEO Description</label>
                  <input id="seo-description" name="seoDescription" type="text" maxlength="180" />
                </div>
              </div>

              <div class="field">
                <label for="sources">Sources</label>
                <textarea
                  id="sources"
                  name="sources"
                  class="sources-input"
                  rows="3"
                  placeholder="One source per line…"
                ></textarea>
              </div>

              <hr class="advanced-tools-divider" />

              <!-- Article JSON (Create / Edit Article / Upload Article) -->
              <section class="json-import-panel" aria-labelledby="json-import-heading">
                <div class="json-import-header">
                  <div>
                    <h3 id="json-import-heading" class="adv-section-heading">Article JSON</h3>
                    <p class="hint">Canonical article source. Paste, upload, or open a saved draft.</p>
                  </div>
                  <div class="json-import-toolbar">
                    <button id="open-json-drafts" class="json-upload-button" type="button">
                      <Icon name="tabler:folder-open" class="json-upload-icon" aria-hidden="true" />
                      <span>Edit Article</span>
                    </button>
                    <label class="json-upload-button" for="json-upload">
                      <Icon name="tabler:upload" class="json-upload-icon" aria-hidden="true" />
                      <span>Upload Article</span>
                    </label>
                  </div>
                  <input id="json-upload" class="visually-hidden" type="file" accept=".json" />
                </div>
                <textarea
                  id="json-import"
                  class="json-import-input"
                  rows="8"
                  placeholder='{ "record_type": "content_source", "schema_version": "content_source.v1", … }'
                ></textarea>
                <div class="json-import-actions">
                  <button id="load-json" class="btn-secondary btn-sm json-update-button" type="button" disabled>
                    <Icon name="tabler:refresh" class="json-update-icon" aria-hidden="true" />
                    <span>Create Article</span>
                  </button>
                  <span id="json-upload-name" class="json-upload-name" aria-live="polite"></span>
                </div>
                <p id="json-import-status" class="json-import-status" aria-live="polite"></p>
                <div id="content-model-indicator" class="content-model-indicator" aria-live="polite"></div>
              </section>

              <dialog id="json-draft-modal" class="json-draft-modal" aria-labelledby="json-draft-modal-heading">
                <div class="json-draft-modal-card">
                  <div class="json-draft-modal-header">
                    <div>
                      <p class="sidebar-kicker">Saved drafts</p>
                      <h3 id="json-draft-modal-heading">Edit Article</h3>
                    </div>
                    <button
                      id="json-draft-modal-close"
                      class="module-icon-button"
                      type="button"
                      aria-label="Close saved draft dialog"
                    >
                      <Icon name="tabler:x" class="module-action-icon" aria-hidden="true" />
                    </button>
                  </div>
                  <p id="json-draft-modal-status" class="json-draft-modal-status" aria-live="polite">
                    Select a saved draft to load into the editor.
                  </p>
                  <div id="json-draft-modal-actions" class="json-draft-modal-actions" hidden></div>
                  <div id="json-draft-list" class="json-draft-list"></div>
                </div>
              </dialog>

              <hr class="advanced-tools-divider" />

              <!-- Markdown body (legacy fallback) -->
              <div class="field">
                <div class="field-header">
                  <label for="content">Markdown Body (Legacy Fallback)</label>
                  <button id="convert-to-pieces" class="btn-tertiary btn-xs" type="button">Convert to Blocks</button>
                </div>
                <textarea id="content" name="content" class="h-48" placeholder="Markdown content…"></textarea>
              </div>

              <hr class="advanced-tools-divider" />

              <!-- Global media library -->
              <div class="field">
                <label for="image-upload">Global Media Library</label>
                <div class="image-upload-actions">
                  <label class="image-upload-button" for="image-upload">
                    <Icon name="tabler:upload" class="image-upload-icon" aria-hidden="true" />
                    <span>Upload Image</span>
                  </label>
                  <button id="select-blob-image" class="image-upload-button" type="button">
                    <Icon name="tabler:photo-search" class="image-upload-icon" aria-hidden="true" />
                    <span>Select Saved</span>
                  </button>
                </div>
                <input id="image-upload" class="visually-hidden" type="file" multiple accept="image/*" />
                <p class="hint">
                  Allowed: <span id="image-allowed-types">png/jpg/webp</span> · Max
                  <span id="image-max-file-size">0.5MB</span> · Up to <span id="image-max-count">10</span> images.
                </p>
                <ul id="image-list" class="image-list" aria-live="polite"></ul>
                <p id="image-import-warning" class="hint image-import-warning" role="status" hidden></p>

                <dialog id="blob-image-modal" class="json-draft-modal" aria-labelledby="blob-image-modal-heading">
                  <div class="json-draft-modal-card">
                    <div class="json-draft-modal-header">
                      <div>
                        <p class="sidebar-kicker">Saved images</p>
                        <h3 id="blob-image-modal-heading">Select Saved Image</h3>
                      </div>
                      <button
                        id="blob-image-modal-close"
                        class="module-icon-button"
                        type="button"
                        aria-label="Close saved image dialog"
                      >
                        <Icon name="tabler:x" class="module-action-icon" aria-hidden="true" />
                      </button>
                    </div>
                    <p id="blob-image-modal-status" class="json-draft-modal-status" aria-live="polite">
                      Select saved images to add to this article.
                    </p>
                    <div class="blob-image-modal-filters" aria-label="Saved image filters">
                      <label>
                        <span>Kind</span>
                        <select id="blob-image-kind-filter">
                          <option value="image" selected>Image</option>
                        </select>
                      </label>
                      <label>
                        <span>Request</span>
                        <select id="blob-image-request-filter">
                          <option value="current" selected>Current draft/request</option>
                          <option value="all">All requests</option>
                        </select>
                      </label>
                      <label class="blob-image-search-filter">
                        <span>Search</span>
                        <input
                          id="blob-image-search"
                          type="search"
                          placeholder="Label, filename, or tag"
                          autocomplete="off"
                        />
                      </label>
                      <button id="refresh-blob-images" class="btn-secondary btn-sm" type="button">Refresh</button>
                    </div>
                    <div class="blob-image-modal-actions">
                      <button id="select-marked-blob-images" class="btn-primary btn-sm" type="button">
                        Select Marked
                      </button>
                    </div>
                    <div id="blob-image-list" class="json-draft-list blob-image-list"></div>
                  </div>
                </dialog>
              </div>

              <!-- Featured image, video, global CTA -->
              <div class="field-grid adv-grid-3">
                <div class="field">
                  <label for="featured-image">Featured Image</label>
                  <select id="featured-image" name="featuredImage">
                    <option value="">Select image…</option>
                  </select>
                  <input id="existing-featured-image-path" name="existingFeaturedImagePath" type="hidden" />
                </div>
                <div class="field">
                  <label for="video-link">Optional Video</label>
                  <input id="video-link" name="videoLink" type="url" placeholder="https://…" />
                </div>
                <div class="field">
                  <label for="cta-link">Global CTA Link</label>
                  <input id="cta-link" name="ctaLink" type="url" placeholder="https://…" />
                </div>
              </div>
              <div class="field">
                <label for="cta-text">Global CTA Text</label>
                <input id="cta-text" name="ctaText" type="text" placeholder="Learn more" />
              </div>
            </div>
          </details>

        </form>

        <!-- Inline preview runtime (hidden) -->
        <div class="preview-runtime sr-only" aria-hidden="true" hidden>
          <button id="refresh-preview" type="button">Refresh inline preview</button>
          <p id="preview-excerpt" hidden></p>
          <img id="preview-image-inline" alt="" hidden />
          <h3 id="preview-title">Untitled article</h3>
          <span id="preview-featured-image">None selected</span>
          <div id="preview-meta" hidden></div>
          <div id="markdown-preview">Preview will appear here.</div>
        </div>
      </main>

      <!-- ── Publish sidebar ──────────────────────────────────── -->
      <aside class="publish-sidebar" aria-labelledby="publish-output-heading">
        <section class="admin-card admin-panel readiness-card">
          <p class="sidebar-kicker">Readiness & Status</p>
          <h2 id="publish-output-heading" class="sidebar-heading">Publish Settings</h2>

          <div
            id="article-status-card"
            class="article-status-card article-status-card--draft"
            aria-live="polite"
          >
            <h3 class="article-status-label">Article Status</h3>
            <div class="article-status-summary">
              <span id="article-status-icon" class="article-status-icon" aria-hidden="true">○</span>
              <div>
                <p id="article-status-title" class="article-status-title">Draft</p>
                <p id="article-status-subtitle" class="article-status-subtitle">No published article found</p>
              </div>
            </div>
            <div id="article-status-details" class="article-status-details">
              <p>Changes are not live until published.</p>
            </div>
          </div>

          <div class="publish-checklist" aria-labelledby="publish-checklist-heading">
            <div class="checklist-header">
              <h3 id="publish-checklist-heading" class="checklist-heading">Validation</h3>
              <details class="validation-details-toggle">
                <summary class="cursor-pointer text-xs font-bold text-accent hover:underline">View issues</summary>
              </details>
            </div>

            <ul id="publish-checklist" class="hidden-checklist" aria-live="polite">
              <li data-checklist-item="title">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Title</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="slug">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Publishing target</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="content">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Content</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="excerpt">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Excerpt</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="featuredImage">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Featured image</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="sources">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Sources</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="seoDescription">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">SEO description</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="category">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Category</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
              <li data-checklist-item="tags">
                <span class="checklist-icon" aria-hidden="true">☐</span>
                <span class="checklist-copy">
                  <span class="checklist-label">Tags</span>
                  <span class="checklist-message" hidden></span>
                </span>
              </li>
            </ul>
          </div>

          <div class="status-line">
            <p id="status" class="status" aria-live="polite"></p>
            <span id="unsaved-changes" class="unsaved-changes" aria-live="polite" hidden>Unsaved changes</span>
          </div>

          <div class="publish-output-summary" aria-label="Content output summary">
            <div class="summary-heading-row">
              <p class="summary-label">Publishing target</p>
              <a class="summary-edit-link" href="#slug" aria-label="Edit publishing target">
                <Icon name="tabler:pencil" class="summary-edit-icon" aria-hidden="true" />
                <span class="sr-only">Edit publishing target</span>
              </a>
            </div>
            <p id="suggested-location" class="suggestion">src/data/post/slug.md</p>
          </div>

          <div class="actions publish-actions" aria-label="Publishing actions">
            <div class="publish-action-group" aria-label="Primary publish action">
              <label id="overwrite-publish-control" class="overwrite-publish-control" for="overwrite-slug" hidden>
                <input id="overwrite-slug" name="overwrite" type="checkbox" />
                <span>Overwrite published article</span>
              </label>
              <button
                id="publish"
                class="btn-primary action-primary"
                type="button"
                aria-describedby="publish-blocked-message"
              >
                Publish Article
              </button>
              <p
                id="publish-blocked-message"
                class="publish-blocked-message"
                role="status"
                aria-live="polite"
                hidden
              >
                Complete required fields before publishing.
              </p>
            </div>
            <button id="save-draft" class="btn-secondary" type="button">Save Draft</button>
            <button id="preview" class="btn-secondary" type="button">Preview Page</button>
            <button id="new-draft" class="btn-tertiary action-tertiary" type="button">New / Reset</button>
          </div>

          <details class="markdown-backup" data-backup-panel open>
            <summary>Save backup</summary>
            <div class="backup-actions" aria-label="Backup actions">
              <button
                id="copy-output"
                class="icon-button backup-icon-button"
                type="button"
                aria-label="Copy Markdown backup"
                title="Copy Markdown backup"
              >
                <Icon name="tabler:copy" class="backup-action-icon" aria-hidden="true" />
                <span class="sr-only">Copy Markdown backup</span>
              </button>
              <button
                id="download-json-backup"
                class="icon-button backup-icon-button"
                type="button"
                aria-label="Download JSON backup"
                title="Download JSON backup"
              >
                <Icon name="tabler:download" class="backup-action-icon" aria-hidden="true" />
                <span class="sr-only">Download JSON backup</span>
              </button>
            </div>
            <textarea id="output-markdown" class="output-markdown" readonly></textarea>
          </details>
        </section>
      </aside>
    </div>

    <div id="toast" class="toast" aria-live="polite" hidden></div>
  </section>
</Layout>

<style>
  .admin-page {
    color: var(--aw-color-text-default);
  }

  .auth-status {
    margin: -1rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .publish-workspace[hidden] {
    display: none;
  }

  .publish-workspace {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 400px;
    gap: 40px;
    align-items: start;
  }

  .publish-main {
    display: grid;
    gap: 1.25rem;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
  }

  .publish-sidebar {
    position: sticky;
    top: 1rem;
    min-width: 0;
  }

  .readiness-card {
    margin-top: 0;
  }

  .sidebar-kicker {
    margin: 0 0 0.35rem;
    color: var(--aw-color-accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .toast {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    max-width: min(28rem, calc(100vw - 2rem));
    border: 1px solid rgb(22 163 74 / 30%);
    border-radius: 1rem;
    background: rgb(240 253 244 / 96%);
    box-shadow: 0 1rem 2.5rem rgb(15 23 42 / 16%);
    color: rgb(22 101 52);
    padding: 0.9rem 1rem;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .toast a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .toast-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.45rem;
  }

  :global(.dark) .toast {
    border-color: rgb(34 197 94 / 32%);
    background: rgb(20 83 45 / 94%);
    color: rgb(220 252 231);
  }

  .admin-card {
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 84%);
