      const authStatusMessages = {
        checking: 'Checking admin access…',
        'signed-out': 'Sign in to view admin tools.',
        forbidden: 'Access denied (not an admin).',
        error: 'Admin auth failed. Please refresh or contact support.',
        'signed-in': '',
      };

      const setAuthStatus = (message) => {
        if (authStatus) authStatus.textContent = message;
      };

      const setAuthState = (state) => {
        isAdmin = state === 'signed-in';
        setAuthStatus(authStatusMessages[state] || '');
        setAdminShellVisible(true);
        recalculateButtonState();
        setGatedContentVisible(isAdmin);

        if (!isAdmin && state !== 'checking' && state !== 'error') redirectToHome();
      };

      const getAdminStateForClerk = async (clerk) => {
        if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };

        const token = await clerk.session.getToken();
        if (!token) return { authenticated: true, isAdmin: false, error: 'Could not retrieve a Clerk session token.' };

        const response = await fetch('/.netlify/functions/admin-auth-state', {
          method: 'GET',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
        });

        return response
          .json()
          .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
      };

      const renderAuthState = async (clerk) => {
        const signedIn = Boolean(clerk.isSignedIn && clerk.session);
        console.info('Clerk signed-in state', { isSignedIn: signedIn });

        if (signedIn) {
          const adminState = await getAdminStateForClerk(clerk);

          if (adminState.isAdmin) {
            setAuthState('signed-in');
            const loadedDraft = await loadDraftFromBlobs(clerk);
            if (!loadedDraft) await initializeEditMode(clerk);
            return;
          }

          setAuthState('forbidden');
          return;
        }

        setAuthState('signed-out');
      };

      const initializeClerkAuth = async () => {
        setAuthState('checking');

        try {
          const clerk = await getClerk();
          if (abortController.signal.aborted) return;

          await renderAuthState(clerk);
          if (abortController.signal.aborted) return;

          if (typeof clerk.addListener === 'function') {
            const removeClerkListener = clerk.addListener(() => {
              renderAuthState(clerk).catch((error) => {
                console.error('Clerk authentication refresh failed.', error);
              });
            });

            if (typeof removeClerkListener === 'function') {
              if (abortController.signal.aborted) {
                removeClerkListener();
              } else {
                cleanupCallbacks.push(removeClerkListener);
              }
            }
          }
        } catch (error) {
          console.error('Clerk authentication initialization failed.', error);
          const message = error instanceof Error ? error.message : 'Clerk authentication could not be initialized.';
          setAuthState('error');
          setStatus(message, false);
        }
      };

      const getClerkSessionToken = async () => {
        const clerk = await getClerk();
        if (!clerk.isSignedIn || !clerk.session) {
          throw new Error('Authenticate with Clerk before publishing.');
        }

        if (!isAdmin) {
          throw new Error('This account is not authorized to publish articles.');
        }

        const token = await clerk.session.getToken();

        if (!token) {
          throw new Error('Could not retrieve a Clerk session token.');
        }

        return token;
      };

      const escapeHtml = (value) =>
        String(value || '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');

      // Expose escapeHtml to the global scope for the Pieces UI script
      window.escapeHtml = escapeHtml;

      const formatDateTimeLocal = (date) => {
        const offset = date.getTimezoneOffset();
        const localDate = new Date(date.getTime() - offset * 60000);
        return localDate.toISOString().slice(0, 16);
      };

      const getPublishDate = () => (fields.publishDate.value ? new Date(fields.publishDate.value) : new Date());

      const parseTags = (value) =>
        String(value)
          .split(',')
          .map((tag) => tag.trim())
          .filter(Boolean);

      const parseSources = (value) =>
        String(value)
          .split(/\n|,/)
          .map((source) => source.trim())
          .filter(Boolean);

      const isSimpleImportObject = (value) =>
        Boolean(
          value &&
            typeof value === 'object' &&
            !Array.isArray(value) &&
            Object.values(value).every((item) => item == null || ['string', 'number', 'boolean'].includes(typeof item))
        );

      const slugify = (value) =>
        String(value)
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');

      const sanitizeFilename = (value) =>
        String(value)
          .split(/[\\/]/)
          .pop()
          .toLowerCase()
          .replace(/[^a-z0-9._-]+/g, '-')
          .replace(/^-+|-+$/g, '') || 'upload';

      const extensionForContentType = (contentType) => {
        const normalized = String(contentType || '')
          .toLowerCase()
          .split(';')[0]
          .trim();
        return (
          {
            'image/png': '.png',
            'image/jpeg': '.jpg',
            'image/jpg': '.jpg',
            'image/webp': '.webp',
            'image/gif': '.gif',
            'image/svg+xml': '.svg',
          }[normalized] || ''
        );
      };

      const getArtifactRequestId = (reference) => {
        const metadataRequestId = String(reference?.metadata?.requestId || '').trim();
        if (metadataRequestId) return metadataRequestId;
        const [, requestId] = String(reference?.blobKey || '').split('/');
        return requestId || 'artifact';
      };

      const getArtifactImageName = (reference) => {
        const metadataFilename = String(
          reference?.metadata?.filename || reference?.metadata?.name || reference?.originalFilename || ''
        ).trim();
        if (metadataFilename) return sanitizeFilename(metadataFilename);
        const [, , blobFilename = ''] = String(reference?.blobKey || '').split('/');
        const extension = extensionForContentType(reference?.contentType);
        const baseName =
          blobFilename || `${getArtifactRequestId(reference)}-${reference?.sha256 || 'artifact'}${extension}`;
        return sanitizeFilename(baseName.includes('.') || !extension ? baseName : `${baseName}${extension}`);
      };

      const isImageArtifactReference = (reference) =>
        String(reference?.contentType || '')
          .toLowerCase()
          .startsWith('image/') || String(reference?.blobKey || '').startsWith('image/');

      const mergeArtifactReferences = (...groups) => {
        const byKey = new Map();
        groups.flat().forEach((reference) => {
          const blobKey = String(reference?.blobKey || '').trim();
          if (blobKey) byKey.set(blobKey, reference);
        });
        return Array.from(byKey.values());
      };

      const toTrimmedString = (value) => (typeof value === 'string' ? value.trim() : '');

      const getMediaEntryContentType = (entry) =>
        toTrimmedString(entry?.contentType) || toTrimmedString(entry?.type) || toTrimmedString(entry?.mimeType);

      const getMediaEntryContent = (entry) =>
        toTrimmedString(entry?.base64) || toTrimmedString(entry?.content) || toTrimmedString(entry?.data);

      const getMediaEntryImageName = (entry) =>
        sanitizeFilename(entry?.name || entry?.filename || entry?.repoPath || entry?.path || 'embedded-image');

      const imagePathPattern = /\.(?:png|jpe?g|webp|gif|svg)(?:[?#].*)?$/i;

      const getUploadRepoPath = (filename) => `src/assets/images/uploads/${getCurrentSlug()}/${filename}`;

      const normalizeUploadRepoPath = (value) => {
        const raw = toTrimmedString(value).replace(/[?#].*$/, '');
        if (!raw) return '';
        if (raw.startsWith('~/assets/images/uploads/')) {
          return raw.replace('~/assets/images/uploads/', 'src/assets/images/uploads/');
        }
        if (raw.startsWith('/src/assets/images/uploads/')) return raw.slice(1);
        return raw.startsWith('src/assets/images/uploads/') ? raw : '';
      };

      const getMediaEntryPathValue = (entry) =>
        toTrimmedString(entry?.repoPath) || toTrimmedString(entry?.path) || toTrimmedString(entry?.displayPath);

      const getMediaEntryFinalRepoPath = (entry) => {
        const normalizedPath = normalizeUploadRepoPath(getMediaEntryPathValue(entry));
        if (normalizedPath && imagePathPattern.test(normalizedPath)) return normalizedPath;
        return getUploadRepoPath(getMediaEntryImageName(entry));
      };

      const getMediaEntryPreviewPath = (entry) => getPreviewableImagePath(getMediaEntryPathValue(entry));

      const hasUsableMediaEntryContent = (entry) => {
        if (!entry || typeof entry !== 'object' || Array.isArray(entry)) return false;
        const content = getMediaEntryContent(entry);
        if (!content) return false;
        const contentType = getMediaEntryContentType(entry).toLowerCase();
        const kind = toTrimmedString(entry?.kind).toLowerCase();
        const imageName =
          toTrimmedString(entry?.name) ||
          toTrimmedString(entry?.filename) ||
          toTrimmedString(entry?.repoPath) ||
          toTrimmedString(entry?.path);
        return (
          content.startsWith('data:image/') ||
          contentType.startsWith('image/') ||
          kind === 'image' ||
          imagePathPattern.test(imageName)
        );
      };

      const hasPreviewableMediaEntry = (entry) =>
        hasUsableMediaEntryContent(entry) || Boolean(getMediaEntryPreviewPath(entry));

      const getMediaEntryPreviewSrc = (entry) => {
        const content = getMediaEntryContent(entry);
        if (content) {
          if (content.startsWith('data:image/')) return content;
          const contentType = getMediaEntryContentType(entry) || 'image/png';
          return `data:${contentType};base64,${content}`;
        }
        return getMediaEntryPreviewPath(entry);
      };

      const getMediaEntryBase64Content = (entry) => {
        const content = getMediaEntryContent(entry);
        if (!content) return '';
        if (content.startsWith('data:')) return content.split(',').pop() || '';
        return content;
      };

      const getMediaEntryUploadFile = (entry) => {
        const base64 = getMediaEntryBase64Content(entry);
        if (!base64) return undefined;
        const contentType = getMediaEntryContentType(entry) || 'image/png';
        const binary = atob(base64);
        const bytes = new Uint8Array(binary.length);
        for (let index = 0; index < binary.length; index += 1) bytes[index] = binary.charCodeAt(index);
        const filename = getMediaEntryImageName(entry) || `imported-image${extensionForContentType(contentType)}`;
        return new File([bytes], filename, { type: contentType });
      };

      const getPreviewableImagePath = (value) => {
        const raw = toTrimmedString(value);
        if (!raw || !imagePathPattern.test(raw)) return '';
        if (/^https?:\/\//i.test(raw) || raw.startsWith('/')) return raw;
        if (raw.startsWith('~/assets/images/uploads/')) {
          return raw.replace('~/assets/images/uploads/', 'https://kugelmedia.netlify.app/drlurieblog/uploads/');
        }
        if (raw.startsWith('src/assets/images/uploads/')) {
          return raw.replace('src/assets/images/uploads/', 'https://kugelmedia.netlify.app/drlurieblog/uploads/');
        }
        return raw.includes('/') ? raw : '';
      };

      const getImagePathEntryName = (source) => sanitizeFilename(source);

      const mergeImagePathEntries = (...groups) => {
        const bySource = new Map();
        groups.flat().forEach((source) => {
          const previewSrc = getPreviewableImagePath(source);
          if (!previewSrc) return;
          bySource.set(toTrimmedString(source), {
            name: getImagePathEntryName(source),
            source: toTrimmedString(source),
            previewSrc,
          });
        });
        return Array.from(bySource.values());
      };

      const mergeMediaEntries = (...groups) => {
        const byFinalPath = new Map();
        groups.flat().forEach((entry) => {
          if (!hasPreviewableMediaEntry(entry)) return;
          byFinalPath.set(getMediaEntryFinalRepoPath(entry).toLowerCase(), entry);
        });
        return Array.from(byFinalPath.values());
      };

      const createFileSelectedImage = (file) => {
        const name = sanitizeFilename(file.name);
        return {
          id: `file:${name}`,
          kind: 'file',
          name,
          finalRepoPath: getUploadRepoPath(name),
          optionValue: name,
          file,
        };
      };

      const createMediaSelectedImage = (mediaEntry) => {
        const name = getMediaEntryImageName(mediaEntry);
        const finalRepoPath = getMediaEntryFinalRepoPath(mediaEntry);
        return {
          id: `media:${finalRepoPath.toLowerCase()}`,
          kind: 'media',
          name,
          finalRepoPath,
          optionValue: name,
          mediaEntry,
        };
      };

      const createPathSelectedImage = (imagePathEntry) => {
        const finalRepoPath = normalizeUploadRepoPath(imagePathEntry.source) || imagePathEntry.source;
        return {
          id: `path:${imagePathEntry.source}`,
          kind: 'path',
          name: imagePathEntry.name,
          finalRepoPath,
          optionValue: imagePathEntry.source,
          imagePathEntry,
        };
      };

      const createArtifactSelectedImage = (artifactReference) => {
        const name = getArtifactImageName(artifactReference);
        const blobKey = String(artifactReference?.blobKey || '').trim();
        return {
          id: `artifact:${blobKey}`,
          kind: 'artifact',
          name,
          finalRepoPath: getUploadRepoPath(name),
          optionValue: name,
          artifactReference,
        };
      };

      const dedupeSelectedImages = (images) => {
        const byFinalPath = new Map();
        images.forEach((image) => {
          const finalPathKey = String(image?.finalRepoPath || image?.id || '')
            .trim()
            .toLowerCase();
          if (!finalPathKey || byFinalPath.has(finalPathKey)) return;
          byFinalPath.set(finalPathKey, image);
        });
        return Array.from(byFinalPath.values());
      };

      const syncImageNames = () => {
        selectedImages = dedupeSelectedImages(selectedImages);
        selectedFiles = selectedImages.filter((image) => image.kind === 'file').map((image) => image.file);
        selectedMediaEntries = selectedImages
          .filter((image) => image.kind === 'media')
          .map((image) => image.mediaEntry);
        selectedImagePathEntries = selectedImages
          .filter((image) => image.kind === 'path')
          .map((image) => image.imagePathEntry);
        selectedArtifactReferences = selectedImages
          .filter((image) => image.kind === 'artifact')
          .map((image) => image.artifactReference);
        imageNames = selectedImages.map((image) => image.name);
      };

      const getCurrentSlug = () => slugify(fields.title.value || 'untitled-article') || 'untitled-article';

      const syncSlugFromTitle = () => {
        const previousSlug = fields.slug.value;
        fields.slug.value = getCurrentSlug();
        if (previousSlug !== fields.slug.value) {
          articleStatus = { state: 'draft', published: null, checkedSlug: '' };
          queuePublishedArticleStatusCheck();
        }
        validateSlug();
        return fields.slug.value;
      };

      const getUploadPath = (filename) =>
        getUploadRepoPath(filename).replace('src/assets/images/uploads/', '~/assets/images/uploads/');

      const getFeaturedImagePath = () => {
        const value = fields.featuredImage.value.trim();
        if (!value) return '';
        if (value.startsWith('src/assets/images/uploads/')) {
          return value.replace('src/assets/images/uploads/', '~/assets/images/uploads/');
        }
        if (value.startsWith('~/assets/images/uploads/') || /^https?:\/\//i.test(value) || value.startsWith('/')) {
          return value;
        }
        return getUploadPath(value);
      };

      const isSelectedPublishableImageValue = (value) => {
        const normalized = String(value || '').trim();
        if (!normalized) return false;
        return selectedImages.some(
          (image) => image.kind !== 'path' && (image.optionValue === normalized || image.name === normalized)
        );
      };

      const getExistingFeaturedImagePathForPayload = () => {
        return isSelectedPublishableImageValue(fields.featuredImage.value)
          ? ''
          : fields.existingFeaturedImagePath.value.trim();
      };

      const getPersistableSelectedMediaEntries = () =>
        selectedMediaEntries.filter((entry) => !hasUsableMediaEntryContent(entry));

      const getDraft = () => ({
        title: fields.title.value,
        slug: fields.slug.value,
        excerpt: fields.excerpt.value,
        publishDate: fields.publishDate.value,
        author: fields.author.value,
        category: fields.category.value,
        tags: fields.tags.value,
        draft: fields.draft.checked,
        content: fields.content.value,
        sources: fields.sources.value,
        imageNames,
        artifactReferences: selectedArtifactReferences,
        mediaEntries: getPersistableSelectedMediaEntries(),
        featuredImage: fields.featuredImage.value,
        existingFeaturedImagePath: getExistingFeaturedImagePathForPayload(),
        videoLink: fields.videoLink.value,
        ctaLink: fields.ctaLink.value,
        ctaText: fields.ctaText.value,
        seoDescription: fields.seoDescription.value,
        overwrite: fields.overwrite.checked,
      });

      const getCheckedOutWorkflowDraft = () => {
        const params = new URLSearchParams(window.location.search);
        const storedLock = getStoredActiveWorkflowLock();
        if (workflowReadOnlyMode && !workflowRequestId && !workflowLockToken) {
          return { requestId: '', lockToken: '' };
        }

        const requestId =
          workflowRequestId ||
          params.get('draftId') ||
          params.get('request_id') ||
          storedLock?.request_id ||
          sessionStorage.getItem('dr-lurie-workflow-request-id') ||
          '';
        const lockToken =
          workflowLockToken ||
          params.get('lock_token') ||
          storedLock?.lock_token ||
          sessionStorage.getItem('dr-lurie-workflow-lock-token') ||
          '';

        return { requestId: requestId.trim(), lockToken: lockToken.trim() };
      };

      const buildContentSourceDraft = () => {
        const title = fields.title.value.trim();
        const tags = parseTags(fields.tags.value);
        const articleBody = {
          schema_version: 'article_body.v1',
          nodes: articleNodes,
        };

        return {
          record_type: 'content_source',
          schema_version: 'content_source.v1',
          content: {
            schema_version: 'content_blocks.v1',
            title,
            ...(fields.excerpt.value.trim()
              ? { deck: fields.excerpt.value.trim(), description: fields.excerpt.value.trim() }
              : {}),
            article_body: articleBody,
            blocks: fields.content.value.trim()
              ? [
                  {
                    block_id: 'admin-draft-markdown',
                    block_type: 'markdown',
                    payload: { markdown: fields.content.value },
                    section_id: 'body',
                  },
                ]
              : [],
          },
          taxonomy: {
            schema_version: 'taxonomy.v1',
            tags,
          },
          seo: {
            schema_version: 'seo.v1',
            ...(fields.title.value.trim() ? { meta_title: fields.title.value.trim() } : {}),
            ...(fields.seoDescription.value.trim() ? { meta_description: fields.seoDescription.value.trim() } : {}),
          },
          editorial: {
            schema_version: 'editorial.v1',
          },
          publication: {
            schema_version: 'publication.v2',
            published_time: null,
          },
          workflow: {
            schema_version: 'content_workflow.v1',
            current_agent: 'draft',
            next_agent: 'final_article',
            handoff_notes: 'Admin JSON draft saved from the publishing form.',
          },
          versioning: {
            schema_version: 'versioning.v1',
            record_version: 1,
          },
        };
      };

      const syncJsonImportFromCurrentForm = (message = '') => {
        const importJson = JSON.stringify(buildContentSourceDraft(), null, 2);
        fields.jsonImport.value = importJson;
        lastLoadedJsonImportValue = importJson.trim();
        updateJsonImportButtonState();
        if (message) setJsonImportStatus(message);
      };

      const setStatus = (message, autoClear = true) => {
        fields.status.textContent = message;
        if (message && autoClear) {
          window.setTimeout(() => {
            if (fields.status.textContent === message) fields.status.textContent = '';
          }, 2500);
        }
      };

      const getPublicGitHubRepoUrl = () => {
        if (!publicGitHubRepoUrl) return '';

        try {
          const url = new URL(publicGitHubRepoUrl);
          return url.hostname === 'github.com'
            ? url
                .toString()
                .replace(/\.git\/?$/, '')
                .replace(/\/$/, '')
            : '';
        } catch {
          return '';
        }
      };

      const getGitHubToastLinks = ({ articlePath, commit }) => {
        const repoUrl = getPublicGitHubRepoUrl();
        if (!repoUrl) return [];

        const links = [];
        const safeArticlePath = String(articlePath || '').replace(/^\/+/, '');
        const safeCommit = String(commit || '').trim();
        const safeBranch = String(publicGitHubBranch || 'main').trim();
        const fileRef = safeCommit || safeBranch;

        if (safeArticlePath) {
          links.push({
            href: `${repoUrl}/blob/${encodeURIComponent(fileRef)}/${safeArticlePath.split('/').map(encodeURIComponent).join('/')}`,
            label: 'View article on GitHub',
          });
        }

        if (safeCommit) {
          links.push({
            href: `${repoUrl}/commit/${encodeURIComponent(safeCommit)}`,
            label: 'View commit',
          });
        }

        return links;
      };

      const showToast = (message, links = []) => {
        if (!fields.toast) return;

        window.clearTimeout(toastTimer);
        fields.toast.replaceChildren();
        const messageElement = document.createElement('div');
        messageElement.textContent = message;
        fields.toast.append(messageElement);

        if (links.length) {
          const linksElement = document.createElement('div');
          linksElement.className = 'toast-links';
          links.forEach((link) => {
            const anchor = document.createElement('a');
            anchor.href = link.href;
            anchor.textContent = link.label;
            anchor.target = '_blank';
            anchor.rel = 'noopener noreferrer';
            linksElement.append(anchor);
          });
          fields.toast.append(linksElement);
        }

        fields.toast.hidden = false;
        toastTimer = window.setTimeout(() => {
          fields.toast.hidden = true;
          fields.toast.replaceChildren();
        }, 4000);
      };

      const setJsonImportStatus = (message, isError = false, mirrorGlobal = true) => {
        fields.jsonImportStatus.textContent = message;
        fields.jsonImportStatus.classList.toggle('is-error', Boolean(message && isError));
        fields.jsonImportStatus.classList.toggle('is-success', Boolean(message && !isError));

        if (mirrorGlobal) setStatus(message, !isError);
      };

      const copyText = async (text, successMessage) => {
        if (!text) return;

        try {
          await navigator.clipboard.writeText(text);
          setStatus(successMessage);
        } catch {
          fields.outputMarkdown.value = text;
          fields.outputMarkdown.focus();
          fields.outputMarkdown.select();
          setStatus('Clipboard unavailable. Text selected for manual copy.');
        }
      };

      const formatFileSize = (bytes) => {
        if (!Number.isFinite(bytes) || bytes < 0) return 'Unknown size';
        if (bytes >= 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
        return `${Math.max(1, Math.round(bytes / 1024))} KB`;
      };

      const shortenFilename = (value, maxLength = 24) => {
        const name = String(value || '').trim();
        if (name.length <= maxLength) return name;
        const dotIndex = name.lastIndexOf('.');
        const extension = dotIndex > 0 ? name.slice(dotIndex) : '';
        const base = extension ? name.slice(0, dotIndex) : name;
        const available = Math.max(8, maxLength - extension.length - 1);
        const frontLength = Math.ceil(available * 0.58);
        const backLength = Math.max(3, available - frontLength);
        return `${base.slice(0, frontLength)}…${base.slice(-backLength)}${extension}`;
      };

      const revokeImagePreviews = () => {
        imagePreviewUrls.forEach((url) => URL.revokeObjectURL(url));
        imagePreviewUrls = [];
      };

      const getArtifactPreviewParams = (artifactReference) => {
        const blobKey = String(artifactReference?.blobKey || '').trim();
        if (!blobKey) return undefined;

        const params = new URLSearchParams({ blobKey });
        const contentType = String(artifactReference?.contentType || '').trim();
        if (contentType) params.set('contentType', contentType);
        return params;
      };

      const fetchArtifactPreviewResponse = async (artifactReference, clerkToken) => {
        const params = getArtifactPreviewParams(artifactReference);
        if (!params) throw new Error('Saved image reference is missing a blob key.');

        return fetch(`/.netlify/functions/admin-get-blob-image?${params.toString()}`, {
          method: 'GET',
          headers: { Authorization: `Bearer ${clerkToken}` },
        });
      };

      const fetchArtifactPreviewUrl = async (artifactReference) => {
        const blobKey = String(artifactReference?.blobKey || '').trim();
        if (!blobKey) return '';
        if (artifactPreviewUrlCache.has(blobKey)) return artifactPreviewUrlCache.get(blobKey);

        const token = await getClerkSessionToken();
        const response = await fetchArtifactPreviewResponse(artifactReference, token);

        if (!response.ok) throw new Error(`Image preview could not be loaded (${response.status}).`);
        const objectUrl = URL.createObjectURL(await response.blob());
        artifactPreviewUrlCache.set(blobKey, objectUrl);
        return objectUrl;
      };

      const attachArtifactPreview = (imageElement, artifactReference) => {
        fetchArtifactPreviewUrl(artifactReference)
          .then((url) => {
            if (url) imageElement.src = url;
          })
          .catch((error) => {
            console.warn('Saved image preview could not be loaded.', error);
          });
      };

      const syncImageInputFiles = () => {
        if (typeof DataTransfer !== 'function') return;

        const dataTransfer = new DataTransfer();
        selectedFiles.forEach((file) => dataTransfer.items.add(file));
        fields.imageUpload.files = dataTransfer.files;
      };

      const setImageUploadMessage = (message, isError = false) => {
        imageUploadMessage = message;
        imageUploadMessageIsError = isError;
      };

      const validateImageFiles = (files) => {
        const validFiles = [];
        const errors = [];

        files.forEach((file) => {
          if (validFiles.length >= maxImageCount) {
            errors.push(`${file.name} was skipped because only ${maxImageCount} images can be uploaded at once.`);
            return;
          }

          if (!allowedImageTypes.has(file.type)) {
            errors.push(
              `${file.name} was skipped because ${file.type || 'its file type'} is not supported. Allowed types: ${allowedImageTypeLabels.join('/')}.`
            );
            return;
          }

          if (file.size > maxImageFileSizeBytes) {
            errors.push(
              `${file.name} was skipped because ${formatFileSize(file.size)} exceeds the ${formatImageRuleFileSize(
                maxImageFileSizeBytes
              )} limit.`
            );
            return;
          }

          validFiles.push(file);
        });

        return { validFiles, errors };
      };

      const removeSelectedImage = (id) => {
        const previousFeaturedImage = fields.featuredImage.value;
        selectedImages = selectedImages.filter((image) => image.id !== id);
        syncImageNames();
        syncImageInputFiles();
        setImageUploadMessage(
          imageNames.length ? `Removed image. ${imageNames.length} selected.` : 'Removed image.',
          false
        );
        renderImages();
        setUnsavedChanges(true);
        if (
          previousFeaturedImage &&
          Array.from(fields.featuredImage.options).some((option) => option.value === previousFeaturedImage)
        ) {
          fields.featuredImage.value = previousFeaturedImage;
        }
        updatePreview();
        updatePublishOutput();
      };

      const getSelectedImageTypeLabel = (image) =>
        image.kind === 'file'
          ? 'local upload'
          : image.kind === 'media'
            ? 'embedded media data'
            : image.kind === 'path'
              ? 'existing preview path'
              : image.kind === 'artifact'
                ? 'saved image record'
                : 'image';

      const getSelectedImageMeta = (image) => {
        if (image.kind === 'file') return `${formatFileSize(image.file.size)} • ${image.file.type || 'unknown type'}`;
        if (image.kind === 'media')
          return `embedded media data • ${getMediaEntryContentType(image.mediaEntry) || 'image'}`;
        if (image.kind === 'path') return 'existing preview path • not saved to the draft media library';
        if (image.kind === 'artifact') {
          return `${formatFileSize(image.artifactReference.sizeBytes)} • ${image.artifactReference.contentType || 'saved image'}`;
        }
        return 'Image';
      };

      const attachSelectedImageThumbnail = (details, image) => {
        const thumbnail = document.createElement('img');
        thumbnail.alt = `Preview of ${image.name}`;
        thumbnail.loading = 'lazy';
        thumbnail.className = 'image-item-thumbnail';

        if (image.kind === 'file') {
          const previewUrl = URL.createObjectURL(image.file);
          imagePreviewUrls.push(previewUrl);
          image.previewSrc = previewUrl;
          thumbnail.src = previewUrl;
        } else if (image.kind === 'media') {
          thumbnail.src = getMediaEntryPreviewSrc(image.mediaEntry);
        } else if (image.kind === 'path') {
          thumbnail.src = image.imagePathEntry.previewSrc;
        } else if (image.kind === 'artifact') {
          attachArtifactPreview(thumbnail, image.artifactReference);
        } else {
          return;
        }

        details.append(thumbnail);
      };

      const renderPieces = () => {
        fields.piecesContainer.innerHTML = '';
        const hasNodes = articleNodes.length > 0;
        if (fields.piecesEmptyState) fields.piecesEmptyState.hidden = hasNodes;

        articleNodes.forEach((node, index) => {
          const piece = document.createElement('div');
          piece.className = 'article-piece';
          piece.dataset.nodeId = node.id;

          const activeTemplateId = inferTemplateId(node);
          const template = articleNodeTemplates[activeTemplateId] || articleNodeTemplates.prose_section;
          const publicFields = node.public || {};
          const hasPublicField = (field) => Object.prototype.hasOwnProperty.call(publicFields, field);
          const mediaValue = publicFields.media;
          const mediaIsObject = mediaValue && typeof mediaValue === 'object' && !Array.isArray(mediaValue);
          const mediaSrc = mediaIsObject ? mediaValue.src || '' : typeof mediaValue === 'string' ? mediaValue : '';
          const mediaAlt = mediaIsObject ? mediaValue.alt || '' : '';
          const mediaCaption = mediaIsObject ? mediaValue.caption || '' : '';
          const mediaType = mediaIsObject ? mediaValue.type || 'image' : 'image';
          const commercialTypes = [
            'adSlot',
            'sponsoredPlacement',
            'productMention',
            'affiliateMention',
            'partnerResource',
            'offer',
            'housePromotion',
          ];
          const commercialType = node.commercial?.type || '';
          const commercialTypeOptions = [
            '<option value="">None</option>',
            ...(commercialType && !commercialTypes.includes(commercialType)
              ? [
                  `<option value="${window.escapeHtml(commercialType)}" selected>${window.escapeHtml(commercialType)}</option>`,
                ]
              : []),
            ...commercialTypes.map(
              (type) => `<option value="${type}" ${commercialType === type ? 'selected' : ''}>${type}</option>`
            ),
          ].join('');

          const mainTemplateIds = ['prose_section', 'callout', 'summary', 'faq', 'soft_action'];

          const mainTemplates = mainTemplateIds.map((id) => articleNodeTemplates[id]);
          const advancedTemplates = Object.values(articleNodeTemplates).filter((t) => !mainTemplateIds.includes(t.id));

          const createOption = (t) => {
            const opt = document.createElement('option');
            opt.value = t.id;
            opt.textContent = t.name;
            if (activeTemplateId === t.id) opt.selected = true;
            return opt.outerHTML;
          };

          const templateOptions = `
            <optgroup label="Common">
              ${mainTemplates.map(createOption).join('')}
            </optgroup>
            <optgroup label="Advanced / Commercial">
              ${advancedTemplates.map(createOption).join('')}
            </optgroup>
          `;

          const showTitle = hasPublicField('title');
          const showBody = hasPublicField('body');
          const showItems = hasPublicField('items');
          const showCta = hasPublicField('ctaText') || hasPublicField('ctaLink');
          const showLabel = hasPublicField('label');
          const showMedia = hasPublicField('media');
          const showCommercial = Boolean(node.commercial);
          const showDisclosure = Boolean(node.commercial?.disclosure);
          const showChat = Boolean(node.chat) || node.rendering?.presentation === 'chatInvite';
          const showAddControls = !showCta || !showCommercial || !showChat || !showMedia || !showDisclosure;
          const pieceSummary =
            publicFields.label ||
            publicFields.title ||
            (Array.isArray(publicFields.items) && publicFields.items.length
              ? `${publicFields.items.length} item${publicFields.items.length === 1 ? '' : 's'}`
              : '') ||
            (typeof publicFields.body === 'string' && publicFields.body.trim()
              ? `${publicFields.body.trim().slice(0, 90)}${publicFields.body.trim().length > 90 ? '…' : ''}`
              : '') ||
            activeTemplateId.replaceAll('_', ' ');

          const titleLabel =
            activeTemplateId === 'summary' ? 'Summary Heading' :
            activeTemplateId === 'faq' ? 'FAQ Heading' :
            activeTemplateId === 'chat_invite' ? 'Invite Heading' :
            activeTemplateId === 'commerce_offer' ? 'Offer Title' :
            activeTemplateId === 'callout' ? 'Callout Heading' :
            'Section Heading';

          const bodyLabel =
            activeTemplateId === 'image' ? 'Caption Text' :
            activeTemplateId === 'chat_invite' ? 'Invite Message' :
            activeTemplateId === 'product_mention' ? 'Description' :
            ['soft_action', 'contextual_offer', 'commerce_offer'].includes(activeTemplateId) ? 'Context Text' :
            'Content';

          const itemsLabel = activeTemplateId === 'faq' ? 'Q&A Items (one per line)' : 'List Items (one per line)';

          piece.innerHTML = `
            <details class="piece-card" ${!node.public?.body && !node.public?.title ? 'open' : ''}>
              <summary>
                <div class="piece-summary-view">
                  <span class="piece-type-tag">${window.escapeHtml(template.name)}</span>
                  <div class="piece-summary-content">
                    <span class="piece-summary-title">${window.escapeHtml(node.public?.title || '')}</span>
                    <span class="piece-summary-body">${window.escapeHtml(pieceSummary)}</span>
                  </div>
                </div>
                <span class="piece-card-chevron" aria-hidden="true">▼</span>
              </summary>
              <div class="piece-header">
                <div class="piece-controls">
                  <button class="btn-tertiary btn-xs move-up" title="Move up" type="button" ${index === 0 ? 'disabled' : ''}>↑</button>
                  <button class="btn-tertiary btn-xs move-down" title="Move down" type="button" ${index === articleNodes.length - 1 ? 'disabled' : ''}>↓</button>
                  <button class="btn-tertiary btn-xs duplicate-piece" type="button">Duplicate</button>
                  <button class="btn-tertiary btn-xs remove-piece" type="button">Remove</button>
                </div>
              </div>
              <div class="piece-form">
                ${showTitle ? `
                <div class="field">
                  <label>${titleLabel}</label>
                  <input type="text" class="piece-title" value="${window.escapeHtml(node.public?.title || '')}" placeholder="Enter heading…" />
                </div>` : ''}
                ${showBody ? `
                <div class="field">
                  <label>${bodyLabel}</label>
                  <textarea class="piece-body" rows="6" placeholder="Write your content here… Markdown is supported.">${window.escapeHtml(node.public?.body || '')}</textarea>
                </div>` : ''}
                ${showItems ? `
                <div class="field">
                  <label>${itemsLabel}</label>
                  <textarea class="piece-items" rows="4" placeholder="One item per line…">${window.escapeHtml((node.public?.items || []).join('\n'))}</textarea>
                </div>` : ''}
                ${showMedia ? `
                <div class="field">
                  <label>Image URL</label>
                  <input type="text" class="piece-media" value="${window.escapeHtml(mediaSrc)}" placeholder="artifact-id or https://…" />
                </div>
                <div class="field-grid">
                  <div class="field">
                    <label>Alt Text</label>
                    <input type="text" class="piece-media-alt" value="${window.escapeHtml(mediaAlt)}" placeholder="Describe the image for accessibility…" />
                  </div>
                  <div class="field">
                    <label>Caption</label>
                    <input type="text" class="piece-media-caption" value="${window.escapeHtml(mediaCaption)}" placeholder="Optional caption…" />
                  </div>
                </div>` : ''}
                ${showCta ? `
                <div class="field-grid">
                  <div class="field">
                    <label>Button Text</label>
                    <input type="text" class="piece-cta-text" value="${window.escapeHtml(node.public?.ctaText || '')}" placeholder="Learn more" />
                  </div>
                  <div class="field">
                    <label>Button URL</label>
                    <input type="url" class="piece-cta-link" value="${window.escapeHtml(node.public?.ctaLink || '')}" placeholder="https://…" />
                  </div>
                </div>` : ''}
                ${showChat ? `
                <div class="field-grid">
                  <div class="field">
                    <label>Invite Text</label>
                    <input type="text" class="piece-chat-invitation" value="${window.escapeHtml(node.chat?.invitationText || '')}" placeholder="Ask our assistant…" />
                  </div>
                  <div class="field">
                    <label>Suggested Question</label>
                    <input type="text" class="piece-chat-query" value="${window.escapeHtml(node.chat?.suggestedQuery || '')}" placeholder="What should readers ask?" />
                  </div>
                </div>` : ''}
                ${showLabel ? `
                <div class="field">
                  <label>Display Label</label>
                  <input type="text" class="piece-label" value="${window.escapeHtml(node.public?.label || '')}" placeholder="Advertisement" />
                </div>` : ''}
                <details class="piece-advanced">
                  <summary>Advanced</summary>
                  <div class="piece-advanced-content">
                    <details class="piece-type-change">
                      <summary>Change block type</summary>
                      <div class="field piece-template-selector">
                        <label>Block Type</label>
                        <select class="template-select">${templateOptions}</select>
                      </div>
                    </details>
                    <div class="field">
                      <label>Visibility</label>
                      <select class="piece-visibility">
                        <option value="public" ${!node.visibility || node.visibility === 'public' ? 'selected' : ''}>Public</option>
                        <option value="internal" ${node.visibility === 'internal' ? 'selected' : ''}>Internal</option>
                        <option value="hidden" ${node.visibility === 'hidden' ? 'selected' : ''}>Hidden</option>
                      </select>
                    </div>
                    ${showMedia ? `
                    <div class="field">
                      <label>Media Type</label>
                      <select class="piece-media-type">
                        ${['image', 'video', 'audio', 'embed'].map((t) => `<option value="${t}" ${mediaType === t ? 'selected' : ''}>${t.charAt(0).toUpperCase() + t.slice(1)}</option>`).join('')}
                      </select>
                    </div>` : ''}
                    ${showAddControls ? `
                    <div class="piece-add-controls">
                      ${!showCta ? '<button class="btn-tertiary btn-xs add-cta" type="button">+ Add CTA Button</button>' : ''}
                      ${!showCommercial ? '<button class="btn-tertiary btn-xs add-commercial" type="button">+ Add Commercial Info</button>' : ''}
                      ${!showChat ? '<button class="btn-tertiary btn-xs add-chat" type="button">+ Add Chat Invite</button>' : ''}
                      ${!showMedia ? '<button class="btn-tertiary btn-xs add-media" type="button">+ Add Image</button>' : ''}
                      ${!showDisclosure ? '<button class="btn-tertiary btn-xs add-disclosure" type="button">+ Add Disclosure</button>' : ''}
                    </div>` : ''}
                    ${showCommercial ? `
                    <div class="field-grid">
                      <div class="field">
                        <label>Commercial Type</label>
                        <select class="piece-commercial-type">${commercialTypeOptions}</select>
                      </div>
                      <div class="field">
                        <label>Sponsor</label>
                        <input type="text" class="piece-commercial-sponsor" value="${window.escapeHtml(node.commercial?.sponsorName || node.commercial?.merchantName || node.commercial?.advertiserName || '')}" placeholder="Optional sponsor" />
                      </div>
                    </div>` : ''}
                    ${showDisclosure ? `
                    <div class="field checkbox-field">
                      <input type="checkbox" class="piece-disclosure" ${node.commercial?.disclosure?.required ? 'checked' : ''} />
                      <label>Show sponsored label</label>
                    </div>
                    <div class="field">
                      <label>Disclosure Label</label>
                      <input type="text" class="piece-disclosure-label" value="${window.escapeHtml(node.commercial?.disclosure?.label || '')}" placeholder="Sponsored" />
                    </div>` : ''}
                    <div class="field">
                      <label>Raw Node JSON</label>
                      <textarea class="piece-raw-json" rows="8" spellcheck="false">${window.escapeHtml(JSON.stringify(node, null, 2))}</textarea>
                    </div>
                  </div>
                </details>
              </div>
            </details>
          `;

          // Event Listeners for Piece Controls
          piece.querySelector('.template-select').addEventListener('change', (e) => {
            const templateId = e.target.value;
            const newNode = createDefaultNodeFromTemplate(templateId);
            newNode.id = node.id; // Keep the same ID
            articleNodes[index] = newNode;
            renderPieces();
            updateFromPieces();
          });

          if (showBody) {
            piece.querySelector('.piece-body').addEventListener('input', (e) => {
              node.public.body = e.target.value;
              updateFromPieces();
            });
          }

          if (showTitle) {
            piece.querySelector('.piece-title').addEventListener('input', (e) => {
              node.public.title = e.target.value;
              updateFromPieces();
            });
          }

          if (showItems) {
            piece.querySelector('.piece-items').addEventListener('input', (e) => {
              node.public.items = e.target.value
                .split('\n')
                .map((s) => s.trim())
                .filter(Boolean);
              updateFromPieces();
            });
          }

          if (showLabel) {
            piece.querySelector('.piece-label').addEventListener('input', (e) => {
              node.public.label = e.target.value;
              updateFromPieces();
            });
          }

          if (showMedia) {
            const updateMedia = () => {
              node.public = node.public || {};
              node.public.media = {
                type: piece.querySelector('.piece-media-type')?.value || 'image',
                src: piece.querySelector('.piece-media')?.value || '',
                alt: piece.querySelector('.piece-media-alt')?.value || undefined,
                caption: piece.querySelector('.piece-media-caption')?.value || undefined,
              };
              updateFromPieces();
            };
            piece.querySelector('.piece-media-type')?.addEventListener('change', updateMedia);
            piece.querySelector('.piece-media')?.addEventListener('input', updateMedia);
            piece.querySelector('.piece-media-alt')?.addEventListener('input', updateMedia);
            piece.querySelector('.piece-media-caption')?.addEventListener('input', updateMedia);
          }

          if (showChat) {
            piece.querySelector('.piece-chat-invitation')?.addEventListener('input', (e) => {
              node.chat = node.chat || {};
              node.chat.invitationText = e.target.value;
              updateFromPieces();
            });
            piece.querySelector('.piece-chat-query')?.addEventListener('input', (e) => {
              node.chat = node.chat || {};
              node.chat.suggestedQuery = e.target.value;
              updateFromPieces();
            });
          }

          if (showCta) {
            piece.querySelector('.piece-cta-text').addEventListener('input', (e) => {
              node.public.ctaText = e.target.value;
              updateFromPieces();
            });
            piece.querySelector('.piece-cta-link').addEventListener('input', (e) => {
              node.public.ctaLink = e.target.value;
              updateFromPieces();
            });
          }

          piece.querySelector('.piece-visibility').addEventListener('change', (e) => {
            node.visibility = e.target.value;
            updateFromPieces();
          });

          piece.querySelector('.piece-raw-json').addEventListener('change', (e) => {
            try {
              const parsedNode = JSON.parse(e.target.value);
              articleNodes[index] = parsedNode;
              renderPieces();
              updateFromPieces();
            } catch (error) {
              window.alert(
                error instanceof Error ? `Raw node JSON is invalid: ${error.message}` : 'Raw node JSON is invalid.'
              );
            }
          });

          if (showCommercial) {
            piece.querySelector('.piece-commercial-type')?.addEventListener('change', (e) => {
              node.commercial = node.commercial || {};
              node.commercial.type = e.target.value || undefined;
              updateFromPieces();
            });
            piece.querySelector('.piece-commercial-sponsor')?.addEventListener('input', (e) => {
              node.commercial = node.commercial || {};
              node.commercial.sponsorName = e.target.value || undefined;
              updateFromPieces();
            });
          }

          if (showDisclosure) {
            piece.querySelector('.piece-disclosure')?.addEventListener('change', (e) => {
              node.commercial = node.commercial || {};
              node.commercial.disclosure = node.commercial.disclosure || { required: false };
              node.commercial.disclosure.required = e.target.checked;
              updateFromPieces();
            });
            piece.querySelector('.piece-disclosure-label')?.addEventListener('input', (e) => {
              node.commercial = node.commercial || {};
              node.commercial.disclosure = node.commercial.disclosure || { required: false };
              node.commercial.disclosure.label = e.target.value || undefined;
              updateFromPieces();
            });
          }

          piece.querySelector('.add-cta')?.addEventListener('click', () => {
            node.public = node.public || {};
            node.public.ctaText = node.public.ctaText || '';
            node.public.ctaLink = node.public.ctaLink || '';
            renderPieces();
            updateFromPieces();
          });

          piece.querySelector('.add-commercial')?.addEventListener('click', () => {
            node.commercial = node.commercial || { type: 'offer' };
            renderPieces();
            updateFromPieces();
          });

          piece.querySelector('.add-chat')?.addEventListener('click', () => {
            node.chat = node.chat || { invitationText: '', suggestedQuery: '' };
            node.rendering = node.rendering || {};
            node.rendering.presentation = node.rendering.presentation || 'chatInvite';
            renderPieces();
            updateFromPieces();
          });

          piece.querySelector('.add-media')?.addEventListener('click', () => {
            node.public = node.public || {};
            node.public.media = { type: 'image', src: '' };
            renderPieces();
            updateFromPieces();
          });

          piece.querySelector('.add-disclosure')?.addEventListener('click', () => {
            node.commercial = node.commercial || {};
            node.commercial.disclosure = node.commercial.disclosure || { required: true, label: 'Sponsored' };
            renderPieces();
            updateFromPieces();
          });

          piece.querySelector('.move-up').addEventListener('click', () => {
            if (index > 0) {
              [articleNodes[index - 1], articleNodes[index]] = [articleNodes[index], articleNodes[index - 1]];
              renderPieces();
              updateFromPieces();
            }
          });

          piece.querySelector('.move-down').addEventListener('click', () => {
            if (index < articleNodes.length - 1) {
              [articleNodes[index + 1], articleNodes[index]] = [articleNodes[index], articleNodes[index + 1]];
              renderPieces();
              updateFromPieces();
            }
          });

          piece.querySelector('.duplicate-piece').addEventListener('click', () => {
            const newNode = JSON.parse(JSON.stringify(node));
            newNode.id = createOpaqueNodeId();
            articleNodes.splice(index + 1, 0, newNode);
            renderPieces();
            updateFromPieces();
          });

          piece.querySelector('.remove-piece').addEventListener('click', () => {
            if (articleNodes.length > 1) {
              articleNodes.splice(index, 1);
              renderPieces();
              updateFromPieces();
            }
          });

          fields.piecesContainer.appendChild(piece);
        });
      };

      const updateFromPieces = () => {
        const markdown = articleBodyToMarkdown({
          schema_version: 'article_body.v1',
          nodes: articleNodes,
        });
        fields.content.value = markdown;
        updatePreview();
        updatePublishOutput();
        setUnsavedChanges(true);
      };

      const renderImages = () => {
        const previousFeaturedImage = fields.featuredImage.value;
        fields.imageList.innerHTML = '';
        fields.featuredImage.innerHTML = '<option value="">Select an uploaded image</option>';
        if (fields.imageImportWarning) {
          fields.imageImportWarning.textContent = imageImportWarningMessage;
          fields.imageImportWarning.hidden = !imageImportWarningMessage;
        }
        revokeImagePreviews();

        if (imageUploadMessage) {
          const messageItem = document.createElement('li');
          messageItem.setAttribute('role', 'status');
          messageItem.className = imageUploadMessageIsError ? 'image-list-message is-error' : 'image-list-message';
          messageItem.textContent = imageUploadMessage;
          fields.imageList.append(messageItem);
        }

        selectedImages.forEach((image) => {
          const option = document.createElement('option');
          option.value = image.optionValue;
          option.textContent = `${image.name} (${getSelectedImageTypeLabel(image)})`;
          fields.featuredImage.append(option);

          const item = document.createElement('li');
          const details = document.createElement('span');
          const filename = document.createElement('span');
          const meta = document.createElement('span');
          const actions = document.createElement('span');
          const removeButton = document.createElement('button');

          details.className = 'image-item-details';
          filename.className = 'filename';
          filename.textContent = shortenFilename(image.name, 26);
          filename.title = image.name;
          meta.textContent = getSelectedImageMeta(image);
          meta.className = 'image-item-meta';
          actions.className = 'image-item-actions';

          attachSelectedImageThumbnail(details, image);

          const text = document.createElement('span');
          text.className = 'image-item-text';
          text.append(filename, meta);
          details.append(text);

          removeButton.className = 'btn-secondary btn-sm image-remove-button';
          removeButton.type = 'button';
          removeButton.title = `Remove ${image.name}`;
          removeButton.setAttribute('aria-label', `Remove ${image.name}`);
          removeButton.textContent = '×';
          removeButton.addEventListener('click', () => removeSelectedImage(image.id));

          actions.append(removeButton);
          item.append(details, actions);
          fields.imageList.append(item);
        });

        if (
          previousFeaturedImage &&
          Array.from(fields.featuredImage.options).some((option) => option.value === previousFeaturedImage)
        ) {
          fields.featuredImage.value = previousFeaturedImage;
        }

        updateImageUploadAvailability();
      };

      const renderMarkdownPreview = (markdown) => {
        if (!markdown.trim()) return 'Preview will appear here.';

        return markdown
          .split(/\n{2,}/)
          .map((block) => {
            const text = block.trim();
            if (!text) return '';
            if (text.startsWith('### ')) return `<h3>${escapeHtml(text.slice(4))}</h3>`;
            if (text.startsWith('## ')) return `<h2>${escapeHtml(text.slice(3))}</h2>`;
            if (text.startsWith('# ')) return `<h1>${escapeHtml(text.slice(2))}</h1>`;
            if (text.startsWith('![')) return `<p><code>${escapeHtml(text)}</code></p>`;

            const inline = escapeHtml(text)
              .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
              .replace(/\*(.*?)\*/g, '<em>$1</em>')
              .replace(/`([^`]+)`/g, '<code>$1</code>')
              .replace(/\n/g, '<br />');
            return `<p>${inline}</p>`;
          })
          .join('');
      };

      const getFeaturedImagePreviewUrl = () => {
        const selectedValue = fields.featuredImage.value;
        const selectedImage = selectedImages.find(
          (image) => image.optionValue === selectedValue || image.name === selectedValue
        );
        if (selectedImage?.kind === 'file' && selectedImage.previewSrc) return selectedImage.previewSrc;
        if (selectedImage?.kind === 'media') return getMediaEntryPreviewSrc(selectedImage.mediaEntry);
        if (selectedImage?.kind === 'path') return selectedImage.imagePathEntry.previewSrc;
        const featuredPath = getFeaturedImagePath();
        return getPreviewableImagePath(featuredPath);
      };

      const updatePreview = () => {
        // Sync articleNodes with current content if nodes are empty
        if (articleNodes.length === 0 && fields.content.value.trim()) {
          articleNodes = [createLegacyBodyNode(fields.content.value)];
          renderPieces();
          setLegacyMarkdownConversionNotice(true);
        }

        const featuredPath = getFeaturedImagePath();
        const imagePreviewUrl = getFeaturedImagePreviewUrl();
        const excerpt = fields.excerpt.value.trim();
        const metaItems = [
          fields.author.value.trim() ? `By ${fields.author.value.trim()}` : '',
          fields.category.value.trim(),
          ...parseTags(fields.tags.value).slice(0, 4),
          fields.videoLink.value.trim() ? 'Video' : '',
          fields.ctaLink.value.trim() || fields.ctaText.value.trim() ? 'CTA' : '',
        ].filter(Boolean);

        fields.previewTitle.textContent = fields.title.value || 'Untitled article';
        fields.previewExcerpt.textContent = excerpt;
        fields.previewExcerpt.hidden = !excerpt;
        fields.previewImageInline.src = imagePreviewUrl;
        fields.previewImageInline.alt = fields.title.value
          ? `${fields.title.value} featured image preview`
          : 'Featured image preview';
        fields.previewImageInline.hidden = !imagePreviewUrl;
        fields.previewFeaturedImage.textContent = featuredPath || 'None selected';
        fields.previewMeta.innerHTML = metaItems.map((item) => `<span>${escapeHtml(item)}</span>`).join('');
        fields.previewMeta.hidden = metaItems.length === 0;
        fields.markdownPreview.innerHTML = renderMarkdownPreview(fields.content.value);
      };

      const buildMarkdown = () => {
        const slug = getCurrentSlug();

        return {
          slug,
          markdown: `${fields.content.value.trim()}\n`,
        };
      };

      const getValidationChecklistState = () => ({
        title: {
          required: true,
          isComplete: fields.title.value.trim().length > 0,
          message: 'Add a title.',
        },
        slug: {
          required: true,
          isComplete: slugPattern.test(fields.slug.value.trim()),
          message: fields.slug.value.trim() ? slugInvalidMessage : 'Add a valid publishing target.',
        },
        content: {
          required: true,
          isComplete: getMarkdownWordCount() >= 5,
          message: 'Add article body content (5+ words).',
        },
        excerpt: {
          required: true,
          isComplete: fields.excerpt.value.trim().length > 0,
          message: 'Add a short excerpt.',
        },
        featuredImage: {
          required: false,
          isComplete: getFeaturedImagePath().trim().length > 0,
        },
        sources: {
          required: false,
          isComplete: parseSources(fields.sources.value).length > 0,
        },
        seoDescription: {
          required: false,
          isComplete: fields.seoDescription.value.trim().length > 0,
        },
        category: {
          required: false,
          isComplete: fields.category.value.trim().length > 0,
        },
        tags: {
          required: false,
          isComplete: parseTags(fields.tags.value).length > 0,
        },
      });

      const getMissingRequiredValidationItems = () =>
        Object.entries(getValidationChecklistState()).filter(([, state]) => state.required && !state.isComplete);

      const updatePublishChecklist = () => {
        const checklistState = getValidationChecklistState();

        fields.publishChecklistItems.forEach((item) => {
          const key = item.dataset.checklistItem;
          const state = checklistState[key] || { required: false, isComplete: false };
          const icon = item.querySelector('.checklist-icon');
          const label = item.querySelector('.checklist-label')?.textContent.trim() || 'Checklist item';
          const message = item.querySelector('.checklist-message');
          const missingRequired = state.required && !state.isComplete;
          const missingOptional = !state.required && !state.isComplete;

          item.classList.toggle('is-complete', state.isComplete);
          item.classList.toggle('is-required-missing', missingRequired);
          item.classList.toggle('is-optional-missing', missingOptional);
          item.setAttribute(
            'aria-label',
            `${label}: ${state.isComplete ? 'complete' : state.required ? `missing, ${state.message}` : 'optional warning'}`
          );
          if (icon) icon.textContent = state.isComplete ? '✓' : missingRequired ? '!' : '⚠';
          if (message) {
            message.textContent = missingRequired ? state.message : '';
            message.hidden = !missingRequired;
          }
        });
      };

      const updateBackupDownload = () => {
        const { slug } = buildMarkdown();
        const backupJson = JSON.stringify(buildContentSourceDraft(), null, 2);
        fields.downloadJsonBackup.dataset.href = `data:application/json;charset=utf-8,${encodeURIComponent(backupJson)}`;
        fields.downloadJsonBackup.dataset.download = `${slug || 'dr-lurie-draft'}-backup.json`;
      };

      const resizeOutputMarkdown = () => {
        fields.outputMarkdown.style.height = 'auto';
        fields.outputMarkdown.style.height = `${fields.outputMarkdown.scrollHeight}px`;
      };

      const updatePublishOutput = () => {
        const { slug, markdown } = buildMarkdown();
        fields.suggestedLocation.textContent = `src/data/post/${slug}.md`;
        fields.outputMarkdown.value = markdown;
        resizeOutputMarkdown();
        updatePublishChecklist();
        updateBackupDownload();
        updatePublishDecisionControls();
      };

      const saveLocalRecoveryDraft = () => {
        try {
          localStorage.setItem(draftKey, JSON.stringify(getDraft()));
          return true;
        } catch (error) {
          console.warn('Local recovery draft could not be saved.', error);
          return false;
        }
      };

      const clearWorkflowLockRefreshTimer = () => {
        if (workflowLockRefreshTimer) window.clearTimeout(workflowLockRefreshTimer);
        workflowLockRefreshTimer = undefined;
      };

      const readActiveWorkflowLock = (storage) => {
        try {
          const raw = storage.getItem(workflowLockStorageKey);
          if (!raw) return undefined;

          const parsed = JSON.parse(raw);
          const requestId = String(parsed?.request_id || '').trim();
          const lockToken = String(parsed?.lock_token || '').trim();
          const ownerLabel = String(parsed?.owner_label || '').trim();
          if (!requestId || !lockToken || ownerLabel !== workflowLockOwnerLabel) return undefined;

          return { request_id: requestId, lock_token: lockToken, owner_label: ownerLabel };
        } catch (error) {
          console.warn('Stored workflow lock state could not be read.', error);
          return undefined;
        }
      };

      const getStoredActiveWorkflowLock = () =>
        readActiveWorkflowLock(localStorage) || readActiveWorkflowLock(sessionStorage);

      const getWorkflowLockFromPayload = (payload) => payload?.lock || payload?.lock_public || payload?.details?.lock;

      const createWorkflowLockError = (message, payload = {}, statusCode = 423) => {
        const error = new Error(message || 'This draft is currently checked out (locked).');
        error.name = 'WorkflowLockError';
        error.statusCode = statusCode;
        error.payload = payload;
        error.lock = getWorkflowLockFromPayload(payload);
        return error;
      };

      const isWorkflowLockPayload = (payload) =>
        Boolean(
          payload?.locked || payload?.lock || payload?.lock_public || payload?.error_code === 'lock_token_mismatch'
        );

      const isWorkflowLockError = (error) =>
        Boolean(
          error?.name === 'WorkflowLockError' || error?.statusCode === 423 || error?.payload?.locked || error?.lock
        );

      const formatWorkflowLockMessage = (error) => {
        const lock = error?.lock || getWorkflowLockFromPayload(error?.payload) || {};
        return [
          'This draft is currently checked out (locked).',
          `Owner: ${lock.owner_label || 'Unknown'}`,
          `Acquired: ${lock.acquired_at || 'Unknown'}`,
          `Expires at: ${lock.expires_at || 'Unknown'}`,
        ].join('\n');
      };

      const parseJsonContentText = (content) => {
        const text = content?.[0]?.text;
        if (!text) return undefined;

        try {
          return JSON.parse(text);
        } catch {
          return undefined;
        }
      };

      const persistActiveWorkflowLock = ({ request_id: requestId, lock_token: lockToken, owner_label: ownerLabel }) => {
        const lockState = {
          request_id: String(requestId || '').trim(),
          lock_token: String(lockToken || '').trim(),
          owner_label: String(ownerLabel || '').trim(),
        };
        if (!lockState.request_id || !lockState.lock_token || lockState.owner_label !== workflowLockOwnerLabel) return;

        const serialized = JSON.stringify(lockState);
        try {
          localStorage.setItem(workflowLockStorageKey, serialized);
          sessionStorage.setItem(workflowLockStorageKey, serialized);
        } catch (error) {
          console.warn('Workflow lock state could not be persisted.', error);
        }
      };

      const clearStoredWorkflowLockState = () => {
        localStorage.removeItem(workflowLockStorageKey);
        sessionStorage.removeItem(workflowLockStorageKey);
        sessionStorage.removeItem('dr-lurie-workflow-request-id');
        sessionStorage.removeItem('dr-lurie-workflow-lock-token');
        sessionStorage.removeItem('dr-lurie-workflow-lock-expires-at');
      };

      const clearLocalCheckoutState = () => {
        workflowRequestId = '';
        workflowLockToken = '';
        workflowLockExpiresAt = '';
        workflowReadOnlyMode = false;
        clearWorkflowLockRefreshTimer();
        clearStoredWorkflowLockState();
        localStorage.removeItem(draftKey);
        recalculateButtonState();
      };

      const mcpToolCall = async (name, args, options = {}) => {
        const response = await fetch('/mcp', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            ...(options.authorization ? { Authorization: options.authorization } : {}),
          },
          body: JSON.stringify({
            jsonrpc: '2.0',
            id: `admin-publish-${name}-${Date.now()}`,
            method: 'tools/call',
            params: { name, arguments: args },
          }),
        });
        const rpc = await response.json().catch(() => ({}));
        const result = rpc.result || {};

        if (!response.ok || rpc.error || result.isError) {
          const payload = result.structuredContent || parseJsonContentText(result.content) || {};
          const message =
            rpc.error?.message ||
            payload.message ||
            payload.error ||
            result.content?.[0]?.text ||
            `${name} failed with status ${response.status}.`;
          const statusCode = payload.statusCode || response.status;
          if (statusCode === 423 || isWorkflowLockPayload(payload))
            throw createWorkflowLockError(message, payload, 423);
          throw new Error(message);
        }

        return result.structuredContent || {};
      };

      const scheduleWorkflowLockRefresh = () => {
        clearWorkflowLockRefreshTimer();
        if (!workflowRequestId || !workflowLockToken || !workflowLockExpiresAt) return;

        const refreshInMs = Math.max(1000, Date.parse(workflowLockExpiresAt) - Date.now() - 120000);
        workflowLockRefreshTimer = window.setTimeout(() => {
          refreshWorkflowLock().catch((error) => {
            console.warn('Workflow lock refresh failed.', error);
          });
        }, refreshInMs);
      };

      const storeWorkflowLockFromRecord = (record) => {
        const requestId = record?.request_id || workflowRequestId;
        const lock = record?.lock || {};
        if (!requestId || !lock.token) return;

        workflowRequestId = requestId;
        workflowLockToken = lock.token;
        workflowLockExpiresAt = lock.expires_at || '';
        workflowReadOnlyMode = false;
        sessionStorage.setItem('dr-lurie-workflow-request-id', workflowRequestId);
        sessionStorage.setItem('dr-lurie-workflow-lock-token', workflowLockToken);
        if (workflowLockExpiresAt) sessionStorage.setItem('dr-lurie-workflow-lock-expires-at', workflowLockExpiresAt);
        persistActiveWorkflowLock({
          request_id: workflowRequestId,
          lock_token: workflowLockToken,
          owner_label: lock.owner_label || record?.lock?.owner_label || workflowLockOwnerLabel,
        });
        scheduleWorkflowLockRefresh();
        recalculateButtonState();
      };

      const checkoutWorkflowRequest = async (requestId) => {
        const result = await mcpToolCall('save_json_blob_checkout_request', {
          request_id: requestId,
          owner_id: workflowLockOwnerId,
          owner_label: workflowLockOwnerLabel,
          lease_seconds: 900,
        });
        storeWorkflowLockFromRecord(result.record);
        return result.record;
      };

      const refreshWorkflowLock = async () => {
        const { requestId, lockToken } = getCheckedOutWorkflowDraft();
        if (!requestId || !lockToken) return undefined;

        try {
          const result = await mcpToolCall('save_json_blob_refresh_lock', {
            request_id: requestId,
            lock_token: lockToken,
            lease_seconds: 900,
          });
          storeWorkflowLockFromRecord(result.record);
          return result.record;
        } catch {
          workflowLockToken = '';
          workflowLockExpiresAt = '';
          clearStoredWorkflowLockState();
          return checkoutWorkflowRequest(requestId);
        }
      };

      const ensureWorkflowLock = async (requestId) => {
        if (!requestId) return undefined;
        const current = getCheckedOutWorkflowDraft();
        workflowRequestId = requestId;

        if (current.lockToken && current.requestId === requestId) {
          const expiresAt = workflowLockExpiresAt || sessionStorage.getItem('dr-lurie-workflow-lock-expires-at') || '';
          if (Date.parse(expiresAt) - Date.now() > 120000) return current.lockToken;
          await refreshWorkflowLock();
          return workflowLockToken;
        }

        await checkoutWorkflowRequest(requestId);
        return workflowLockToken;
      };

      const checkinWorkflowRequest = async () => {
        const { requestId, lockToken } = getCheckedOutWorkflowDraft();
        if (!requestId || !lockToken) return;

        await mcpToolCall('save_json_blob_checkin_request', { request_id: requestId, lock_token: lockToken });
        clearLocalCheckoutState();
      };

      const releaseStoredWorkflowLockOnLoad = async () => {
        const storedLock = getStoredActiveWorkflowLock();
        if (!storedLock) return;

        try {
          await mcpToolCall('save_json_blob_checkin_request', {
            request_id: storedLock.request_id,
            lock_token: storedLock.lock_token,
          });
        } catch (error) {
          console.warn('Stored workflow lock could not be released on page load; clearing stale lock state.', error);
        } finally {
          if (workflowRequestId === storedLock.request_id) workflowRequestId = '';
          if (workflowLockToken === storedLock.lock_token) workflowLockToken = '';
          workflowLockExpiresAt = '';
          clearWorkflowLockRefreshTimer();
          clearStoredWorkflowLockState();
          recalculateButtonState();
        }
      };

      const sendWorkflowCheckinOnUnload = () => {
        const storedLock = getStoredActiveWorkflowLock();
        if (!storedLock) return;

        const body = JSON.stringify({
          jsonrpc: '2.0',
          id: `admin-publish-checkin-unload-${Date.now()}`,
          method: 'tools/call',
          params: {
            name: 'save_json_blob_checkin_request',
            arguments: { request_id: storedLock.request_id, lock_token: storedLock.lock_token },
          },
        });
        const blob = new Blob([body], { type: 'application/json' });

        if (navigator.sendBeacon?.('/mcp', blob)) return;

        fetch('/mcp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body,
          keepalive: true,
        }).catch((error) => {
          console.warn('Workflow lock check-in during unload could not be queued.', error);
        });
      };

      const fetchLatestWorkflowRequest = async (requestId) => {
        if (!requestId) return undefined;

        const result = await mcpToolCall('save_json_blob_get_request', { request_id: requestId });
        if (result.record?.lock?.token) storeWorkflowLockFromRecord(result.record);
        return result.record;
      };

      const getLatestArtifactReferences = (record) => {
        const artifactReferences = record?.input?.media?.artifactReferences || record?.input?.artifactReferences;
        return Array.isArray(artifactReferences) ? artifactReferences : [];
      };

      const getLatestSelectedArtifactReferences = (latestWorkflowRecord) => {
        const selectedBlobKeys = selectedArtifactReferences
          .map((reference) => String(reference?.blobKey || '').trim())
          .filter(Boolean);
        if (!selectedBlobKeys.length) return { references: [], missingBlobKeys: [] };

        const latestByBlobKey = new Map(
          getLatestArtifactReferences(latestWorkflowRecord)
            .filter((reference) => selectedBlobKeys.includes(String(reference?.blobKey || '').trim()))
            .map((reference) => [String(reference?.blobKey || '').trim(), reference])
        );
        const missingBlobKeys = selectedBlobKeys.filter((blobKey) => !latestByBlobKey.has(blobKey));

        return {
          references: selectedArtifactReferences.map((reference) => {
            const blobKey = String(reference?.blobKey || '').trim();
            return latestByBlobKey.get(blobKey) || reference;
          }),
          missingBlobKeys,
        };
      };

      const formatMissingArtifactWorkflowMessage = (missingBlobKeys) => {
        const details = missingBlobKeys
          .slice(0, 5)
          .map((blobKey) => {
            const selectedReference = selectedArtifactReferences.find((reference) => reference?.blobKey === blobKey);
            const name = selectedReference ? getArtifactImageName(selectedReference) : blobKey;
            return `${shortenFilename(name, 24)} (${shortenFilename(blobKey, 36)})`;
          })
          .join(', ');
        const suffix = missingBlobKeys.length > 5 ? `, +${missingBlobKeys.length - 5} more` : '';
        return `Some selected images were not saved into the draft. Save the draft again or re-select the images before publishing.${
          details ? ` Missing: ${details}${suffix}.` : ''
        }`;
      };

      const getArtifactFailureReference = (failure) => failure?.reference || failure;

      const getAdminBlobImageFailureLabel = (status) => {
        if (status === 400) return '400 bad request';
        if (status === 401) return '401 auth failure';
        if (status === 403) return '403 auth/authorization failure';
        if (status === 404) return '404 artifact bytes missing';
        if (status === 422) return '422 invalid image bytes';
        if (status >= 500) return `${status} server/config failure`;
        return `${status} HTTP failure`;
      };

      const formatBlobStoreDiagnosticSummary = (label, diagnostic) => {
        if (!diagnostic) return '';

        const site = diagnostic.siteId?.present
          ? `${diagnostic.siteId.envVar || 'site'}=${diagnostic.siteId.redacted}`
          : 'siteId=missing';

        return `${label}Source=${diagnostic.source}, ${label}ExplicitApi=${Boolean(
          diagnostic.explicitApiConfigUsed
        )}, ${label}LambdaContext=${Boolean(diagnostic.lambdaBlobContextUsed)}, ${label}Site=${site}`;
      };

      const formatAdminBlobImageFailureDetails = (payload) => {
        const storeDiagnostics = payload?.blobStoreDiagnostics || {};
        const readDiagnostics = payload?.diagnostics || {};
        const nearbyKeys = Array.isArray(readDiagnostics.nearbyKeys) ? readDiagnostics.nearbyKeys.slice(0, 5) : [];
        const details = [
          payload?.reason ? `reason=${payload.reason}` : '',
          payload?.blobKey ? `blobKey=${payload.blobKey}` : '',
          payload?.store ? `store=${payload.store}` : '',
          payload?.lookup ? `lookup=${payload.lookup}` : '',
          payload?.contentTypeSource ? `contentTypeSource=${payload.contentTypeSource}` : '',
          payload?.validationReason ? `validationReason=${payload.validationReason}` : '',
          readDiagnostics.parentPrefix ? `parentPrefix=${readDiagnostics.parentPrefix}` : '',
          readDiagnostics.exactFilename ? `exactFilename=${readDiagnostics.exactFilename}` : '',
          typeof readDiagnostics.exactFilenameExists === 'boolean'
            ? `exactFilenameExists=${readDiagnostics.exactFilenameExists}`
            : '',
          nearbyKeys.length ? `nearbyKeys=${nearbyKeys.join('|')}` : '',
          formatBlobStoreDiagnosticSummary('workflows', storeDiagnostics.workflows),
          formatBlobStoreDiagnosticSummary('artifactIndex', storeDiagnostics.artifactIndex),
          formatBlobStoreDiagnosticSummary('artifacts', storeDiagnostics.artifacts),
        ].filter(Boolean);

        return details.length ? ` (${details.join(', ')})` : '';
      };

      const readAdminBlobImageFailure = async (response, reference) => {
        const payload = await response
          .clone()
          .json()
          .catch(() => ({}));
        const name = shortenFilename(getArtifactImageName(reference), 24);
        const label = getAdminBlobImageFailureLabel(response.status);
        const serverMessage = payload?.error ? `: ${payload.error}` : '';
        const debugDetails = formatAdminBlobImageFailureDetails(payload);

        return `${name} — admin-get-blob-image returned ${label}${serverMessage}${debugDetails}`;
      };

      const formatArtifactReselectionMessage = (failures) => {
        const names = failures.map((failure) =>
          shortenFilename(getArtifactImageName(getArtifactFailureReference(failure)), 24)
        );
        const details = failures.map((failure) => failure?.failureMessage).filter(Boolean);
        const detailMessage = details.length ? ` Details: ${details.join('; ')}.` : '';

        return `Saved image${names.length === 1 ? '' : 's'} could not be read: ${names.join(', ')}.${detailMessage} Re-select or re-upload ${
          names.length === 1 ? 'this image' : 'these images'
        } before publishing.`;
      };

      const checkReadableArtifactReferences = async (
        artifactReferences,
        clerkToken,
        { logContext = 'artifact' } = {}
      ) => {
        if (!artifactReferences.length) return { readableReferences: [], failedReferences: [] };

        const results = await Promise.all(
          artifactReferences.map(async (reference) => {
            try {
              const response = await fetchArtifactPreviewResponse(reference, clerkToken);
              if (!response.ok) {
                return {
                  reference,
                  readable: false,
                  failureMessage: await readAdminBlobImageFailure(response, reference),
                };
              }
              await response.blob();
              return { reference, readable: true };
            } catch (error) {
              console.warn(`${logContext} saved image could not be read.`, error);
              return {
                reference,
                readable: false,
                failureMessage: `${shortenFilename(getArtifactImageName(reference), 24)} — ${
                  error instanceof Error ? error.message : 'admin-get-blob-image request failed'
                }`,
              };
            }
          })
        );

        return {
          readableReferences: results.filter((result) => result.readable).map((result) => result.reference),
          failedReferences: results.filter((result) => !result.readable),
        };
      };

      const validateReadableArtifactReferences = async (artifactReferences, clerkToken) => {
        if (!artifactReferences.length) return artifactReferences;

        setStatus(
          `Checking ${artifactReferences.length} saved image record${artifactReferences.length === 1 ? '' : 's'}…`,
          false
        );

        const { readableReferences, failedReferences } = await checkReadableArtifactReferences(
          artifactReferences,
          clerkToken,
          {
            logContext: 'Selected',
          }
        );

        if (failedReferences.length) {
          throw new Error(formatArtifactReselectionMessage(failedReferences));
        }

        return readableReferences;
      };

      const resetPublisherForm = () => {
        clearLocalCheckoutState();
        lastSavedDraftId = '';
        lastSavedAt = '';
        lastSavedBy = '';
        editArticleLoaded = false;
        workflowReadOnlyMode = false;
        articleStatus = { state: 'draft', published: null, checkedSlug: '' };
        fields.title.value = '';
        fields.slug.value = '';
        fields.excerpt.value = '';
        fields.publishDate.value = formatDateTimeLocal(new Date());
        fields.author.value = '';
        fields.category.value = '';
        fields.tags.value = '';
        fields.sources.value = '';
        fields.jsonImport.value = '';
        fields.jsonUpload.value = '';
        fields.jsonUploadName.textContent = '';
        setJsonImportStatus('');
        lastLoadedJsonImportValue = '';
        fields.draft.checked = false;
        fields.content.value = '';
        fields.imageUpload.value = '';
        fields.featuredImage.value = '';
        fields.existingFeaturedImagePath.value = '';
        fields.videoLink.value = '';
        fields.ctaLink.value = '';
        fields.ctaText.value = '';
        fields.seoDescription.value = '';
        fields.overwrite.checked = false;
        articleNodes = [];
        renderPieces();
        setLegacyMarkdownConversionNotice(false);
        selectedImages = [];
        stagedInlineMediaEntries = [];
        syncImageNames();
        availableBlobImageArtifacts = [];
        imageUploadMessage = '';
        imageUploadMessageIsError = false;
        imageImportWarningMessage = '';
        renderImages();
        updateJsonImportButtonState();
        setEditorModeCopy('publish');
        validateSlug();
        contentModel = 'article_body.v1';
        updatePreview();
        updatePublishOutput();
        setUnsavedChanges(false);
        setStatus('Ready for a new article.', false);
        window.history.replaceState({}, '', '/admin/publish');
        fields.title.focus();
      };

      const replaceInlineMediaEntriesWithArtifacts = (mediaEntries, artifactReferences) => {
        const uploadedEntries = new Set(mediaEntries);
        selectedArtifactReferences = mergeArtifactReferences(selectedArtifactReferences, artifactReferences);
        selectedImages = [
          ...selectedImages.filter((image) => !(image.kind === 'media' && uploadedEntries.has(image.mediaEntry))),
          ...artifactReferences.map(createArtifactSelectedImage),
        ];
        stagedInlineMediaEntries = stagedInlineMediaEntries.filter((entry) => !uploadedEntries.has(entry));
        syncImageNames();
      };

      const uploadStagedInlineMediaEntriesForRequest = async (requestId) => {
        const mediaEntries = mergeMediaEntries(
          stagedInlineMediaEntries,
          selectedMediaEntries.filter(hasUsableMediaEntryContent)
        );
        if (!requestId || !mediaEntries.length) return [];

        const artifactReferences = await uploadInlineMediaEntriesAsArtifacts(mediaEntries, requestId);
        replaceInlineMediaEntriesWithArtifacts(mediaEntries, artifactReferences);
        imageImportWarningMessage = '';
        if (fields.imageImportWarning) {
          fields.imageImportWarning.textContent = '';
          fields.imageImportWarning.hidden = true;
        }
        renderImages();
        updatePreview();
        updatePublishOutput();
        return artifactReferences;
      };

      const postJsonDraftToBlobs = async (clerkToken, requestId, lockToken) => {
        const response = await fetch('/.netlify/functions/admin-save-json-draft', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${clerkToken}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            ...(requestId ? { request_id: requestId } : {}),
            ...(lockToken ? { lock_token: lockToken } : {}),
            input: buildContentSourceDraft(),
          }),
        });
        const result = await response.json().catch(() => ({}));

        return { response, result };
      };

      const saveJsonDraftToBlobs = async () => {
        const clerkToken = await getClerkSessionToken();
        const shouldCloneReadOnlyDraft = workflowReadOnlyMode && !workflowRequestId && !workflowLockToken;

        const checkedOut = getCheckedOutWorkflowDraft();
        if (!shouldCloneReadOnlyDraft && checkedOut.requestId) await ensureWorkflowLock(checkedOut.requestId);

        let { requestId, lockToken } = shouldCloneReadOnlyDraft
          ? { requestId: '', lockToken: '' }
          : getCheckedOutWorkflowDraft();
        let { response, result } = await postJsonDraftToBlobs(clerkToken, requestId, lockToken);

        if (!response.ok && requestId && (result.lock_expired || result.error === 'lock_expired')) {
          await refreshWorkflowLock();
          ({ requestId, lockToken } = getCheckedOutWorkflowDraft());
          ({ response, result } = await postJsonDraftToBlobs(clerkToken, requestId, lockToken));
        }

        if (!response.ok) {
          const message = result.message || result.error || `JSON draft could not be saved (${response.status}).`;
          if (response.status === 423 || isWorkflowLockPayload(result))
            throw createWorkflowLockError(message, result, response.status);
          throw new Error(message);
        }

        const savedRequestId = result.record?.request_id || requestId;
        if (savedRequestId) {
          workflowRequestId = savedRequestId;
          sessionStorage.setItem('dr-lurie-workflow-request-id', savedRequestId);
          if (result.record?.lock?.token) storeWorkflowLockFromRecord(result.record);
          else if (!getCheckedOutWorkflowDraft().lockToken) await checkoutWorkflowRequest(savedRequestId);
          workflowReadOnlyMode = false;
        }

        if (
          savedRequestId &&
          (stagedInlineMediaEntries.length || selectedMediaEntries.some(hasUsableMediaEntryContent))
        ) {
          try {
            const uploadedReferences = await uploadStagedInlineMediaEntriesForRequest(savedRequestId);
            if (uploadedReferences.length) {
              const latestLock = getCheckedOutWorkflowDraft();
              ({ response, result } = await postJsonDraftToBlobs(clerkToken, savedRequestId, latestLock.lockToken));
              if (!response.ok) {
                const message = result.message || result.error || `JSON draft could not be saved (${response.status}).`;
                throw new Error(message);
              }
            }
          } catch (error) {
            console.warn('Imported inline media artifact upload failed after draft save.', error);
            imageImportWarningMessage =
              'An imported image could not be saved to the draft media library. Re-upload or re-select the image before publishing.';
            if (fields.imageImportWarning) {
              fields.imageImportWarning.textContent = imageImportWarningMessage;
              fields.imageImportWarning.hidden = false;
            }
          }
        }

        return result;
      };

      const saveDraft = async ({ confirm = true } = {}) => {
        const saveButton = fields.saveDraft;

        if (!getHasMinimumDraftContent()) {
          setStatus('Title, publishing target, and author are required to save the draft.', false);
          return false;
        }

        if (confirm) {
          const confirmed = window.confirm('Save this draft to Blobs as the source version?');
          if (!confirmed) return false;
        }

        saveButton.disabled = true;
        setStatus('Saving draft to Blobs (source of truth)…', false);

        try {
          const result = await saveJsonDraftToBlobs();
          lastSavedDraftId = result.record?.request_id || workflowRequestId || '';
          lastSavedAt = result.record?.updated_at || new Date().toISOString();
          lastSavedBy = workflowLockOwnerLabel;
          setUnsavedChanges(false);
          const savedRequestId = lastSavedDraftId ? ` (${lastSavedDraftId})` : '';
          setStatus(`Draft saved to Blobs (source of truth)${savedRequestId}.`, false);
          return true;
        } catch (error) {
          if (isAbortError(error)) {
            setStatus(error.message, false);
            return false;
          }

          console.error('Draft save failed.', error);
          const recoverySaved = saveLocalRecoveryDraft();
          const message = isWorkflowLockError(error)
            ? formatWorkflowLockMessage(error)
            : error instanceof Error
              ? error.message
              : 'Draft could not be saved.';
          setStatus(
            recoverySaved
              ? `${message} A local recovery draft was saved, but the draft was not saved to Blobs.`
              : `${message} the draft was not saved to Blobs and local recovery failed.`,
            false
          );
          return false;
        } finally {
          recalculateButtonState();
        }
      };

      const ensureFeaturedImageOption = (value, labelSuffix = 'existing path/name only') => {
        if (!value) return;
        const existingOption = Array.from(fields.featuredImage.options).find((option) => option.value === value);
        if (existingOption) {
          if (labelSuffix && !existingOption.textContent.includes('('))
            existingOption.textContent = `${value} (${labelSuffix})`;
          return;
        }

        const option = document.createElement('option');
        option.value = value;
        option.textContent = labelSuffix ? `${value} (${labelSuffix})` : value;
        fields.featuredImage.append(option);
      };

      const formatEditPublishDate = (value) => {
        if (!value) return formatDateTimeLocal(new Date());

        const date = new Date(value);
        return Number.isNaN(date.getTime()) ? formatDateTimeLocal(new Date()) : formatDateTimeLocal(date);
      };

      const populateArticleForEdit = (article) => {
        fields.title.value = article.title || '';
        syncSlugFromTitle();
        fields.excerpt.value = article.excerpt || '';
        fields.publishDate.value = formatEditPublishDate(article.publishDate);
        fields.author.value = article.author || '';
        fields.category.value = article.category || '';
        fields.tags.value = Array.isArray(article.tags) ? article.tags.join(', ') : article.tags || '';
        fields.draft.checked = Boolean(article.draft);

        // Handle article_body pieces
        const articleBody = article.content?.article_body || article.article_body;
        if (articleBody && Array.isArray(articleBody.nodes)) {
          articleNodes = articleBody.nodes;
          contentModel = 'article_body.v1';
          renderPieces();
          fields.content.value = articleBodyToMarkdown(articleBody);
          setLegacyMarkdownConversionNotice(false);
        } else {
          fields.content.value = article.content || '';
          articleNodes = [createLegacyBodyNode(fields.content.value)];
          contentModel = 'legacy_markdown_converted';
          renderPieces();
          setLegacyMarkdownConversionNotice(Boolean(fields.content.value.trim()));
        }
        fields.sources.value = Array.isArray(article.sources) ? article.sources.join('\n') : article.sources || '';
        fields.videoLink.value = article.videoLink || article.video || '';
        fields.ctaLink.value = article.ctaLink || '';
        fields.ctaText.value = article.ctaText || '';
        fields.seoDescription.value = article.seoDescription || article.metadata?.description || '';
        fields.overwrite.checked = false;
        fields.existingFeaturedImagePath.value = article.image || article.featuredImage || '';
        selectedImages = [];
        stagedInlineMediaEntries = [];
        syncImageNames();
        imageImportWarningMessage = '';
        renderImages();
        if (fields.existingFeaturedImagePath.value) {
          ensureFeaturedImageOption(fields.existingFeaturedImagePath.value);
          fields.featuredImage.value = fields.existingFeaturedImagePath.value;
        }
        updatePreview();
        updatePublishOutput();
        syncJsonImportFromCurrentForm('Existing article JSON loaded into the Import JSON module.');
        recalculateButtonState();
      };

      const initializeEditMode = async (clerk) => {
        const editSlug = getEditSlug();
        if (!editSlug || editArticleLoaded) return;

        editArticleLoaded = true;
        setEditorModeCopy('edit');
        setStatus(`Loading ${editSlug} for editing…`, false);

        try {
          const token = await clerk.session.getToken();
          if (!token) throw new Error('Could not retrieve a Clerk session token.');

          const response = await fetch(
            `/.netlify/functions/get-article-for-edit?slug=${encodeURIComponent(editSlug)}`,
            {
              method: 'GET',
              headers: {
                Authorization: `Bearer ${token}`,
                'Content-Type': 'application/json',
              },
            }
          );
          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(result.error || `Could not load article for editing (${response.status}).`);
          }

          populateArticleForEdit(result.article || result);
          setStatus(`Editing ${editSlug}. Publishing target is generated from the title.`, false);
        } catch (error) {
          editArticleLoaded = false;
          setStatus(error instanceof Error ? error.message : 'Article could not be loaded for editing.', false);
        }
      };

      const getDuplicateTopLevelKeys = (text) => {
        const duplicates = [];
        const seen = new Set();
        let depth = 0;
        let inString = false;
        let escaped = false;
        let keyStart = -1;
        let expectingKey = false;
        let possibleKey = false;
        let afterKey = false;
        let currentKey = '';

        for (let index = 0; index < text.length; index += 1) {
          const char = text[index];

          if (inString) {
            if (escaped) {
              escaped = false;
            } else if (char === '\\') {
              escaped = true;
            } else if (char === '"') {
              inString = false;
              if (depth === 1 && possibleKey) {
                currentKey = text.slice(keyStart, index);
                possibleKey = false;
                afterKey = true;
              }
            }
            continue;
          }

          if (char === '"') {
            inString = true;
            keyStart = index + 1;
            possibleKey = depth === 1 && expectingKey;
            continue;
          }

          if (/\s/.test(char)) continue;

          if (char === '{') {
            depth += 1;
            expectingKey = depth === 1;
            afterKey = false;
            continue;
          }

          if (char === '}') {
            depth -= 1;
            expectingKey = false;
            afterKey = false;
            continue;
          }

          if (char === '[') {
            depth += 1;
            expectingKey = false;
            afterKey = false;
            continue;
          }

          if (char === ']') {
            depth -= 1;
            expectingKey = false;
            afterKey = false;
            continue;
          }

          if (depth === 1 && afterKey && char === ':') {
            if (seen.has(currentKey) && !duplicates.includes(currentKey)) duplicates.push(currentKey);
            seen.add(currentKey);
            expectingKey = false;
            afterKey = false;
            continue;
          }

          if (depth === 1 && char === ',') {
            expectingKey = true;
            afterKey = false;
          }
        }

        return duplicates;
      };

      const baselineContentSourceSchemaVersion = 'content_source.v1';
      const contentSourceV1Error = 'Import JSON must use content_source.v1.';
      let currentContentSourceSchemaVersionPromise;

      const isPlainObject = (value) => Boolean(value && typeof value === 'object' && !Array.isArray(value));

      const hasOwn = (object, key) => Object.prototype.hasOwnProperty.call(object, key);

      const getPathValue = (object, path) => {
        let current = object;

        for (const key of path) {
          if (!isPlainObject(current) || !hasOwn(current, key)) return { exists: false, value: undefined };
          current = current[key];
        }

        return { exists: true, value: current };
      };

      const getFirstImportPathValue = (object, paths) => {
        for (const path of paths) {
          const result = getPathValue(object, path);
          if (result.exists) return result;
        }

        return { exists: false, value: undefined };
      };

      const getCurrentContentSourceSchemaVersion = async () => {
        currentContentSourceSchemaVersionPromise ||= (async () => {
          const response = await fetch('/mcp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ jsonrpc: '2.0', id: 'admin-publish-schema-version', method: 'tools/list' }),
          });

          if (!response.ok) {
            throw new Error('Could not verify the current content_source schema version.');
          }

          const body = await response.json();
          const tools = Array.isArray(body?.result?.tools) ? body.result.tools : [];
          const createRequestTool = tools.find((tool) => tool?.name === 'save_json_blob_create_request');
          const schemaVersion =
            createRequestTool?.inputSchema?.properties?.input?.properties?.schema_version?.const ||
            createRequestTool?.inputSchema?.properties?.input?.properties?.schema_version?.enum?.[0];

          if (typeof schemaVersion !== 'string' || !schemaVersion.trim()) {
            throw new Error('Could not verify the current content_source schema version.');
          }

          return schemaVersion.trim();
        })().catch((error) => {
          currentContentSourceSchemaVersionPromise = undefined;
          throw error;
        });

        return currentContentSourceSchemaVersionPromise;
      };

      const getUnsupportedSchemaMessage = (currentSchemaVersion) =>
        currentSchemaVersion === baselineContentSourceSchemaVersion
          ? contentSourceV1Error
          : `Import JSON must use ${baselineContentSourceSchemaVersion} or ${currentSchemaVersion}.`;

      const getAllowedContentSourceSchemaVersions = (currentSchemaVersion) =>
        new Set([baselineContentSourceSchemaVersion, currentSchemaVersion].filter(Boolean));

      const assertOptionalObject = (object, pathLabel, path) => {
        const result = getPathValue(object, path);
        if (result.exists && !isPlainObject(result.value)) {
          throw new Error(`JSON field "${pathLabel}" must be an object.`);
        }
      };

      const assertOptionalTextPath = (object, pathLabel, paths) => {
        const result = getFirstImportPathValue(object, paths);
        if (result.exists && result.value != null && typeof result.value !== 'string') {
          throw new Error(`JSON field "${pathLabel}" must be a string.`);
        }
      };

      const assertOptionalStringArrayPath = (object, pathLabel, paths) => {
        const result = getFirstImportPathValue(object, paths);
        if (!result.exists || result.value == null) return;

        if (!Array.isArray(result.value)) {
          throw new Error(`JSON field "${pathLabel}" must be an array.`);
        }

        if (result.value.some((item) => typeof item !== 'string')) {
          throw new Error(`JSON field "${pathLabel}" must contain only strings.`);
        }
      };

      const assertOptionalSourceListPath = (object) => {
        const result = getPathValue(object, ['sources', 'source_list']);
        if (!result.exists || result.value == null) return;

        if (!Array.isArray(result.value)) {
          throw new Error('JSON field "sources.source_list" must be an array.');
        }

        const hasInvalidItem = result.value.some((item) => typeof item !== 'string' && !isSimpleImportObject(item));
        if (hasInvalidItem) {
          throw new Error('JSON field "sources.source_list" must contain only strings or simple objects.');
        }
      };

      const partialPublishPayloadImportFields = ['slug', 'title', 'content', 'markdown', 'publishDate', 'draft'];
      const partialPublishPayloadSignalFields = ['slug', 'markdown', 'publishDate', 'draft'];
      const legacyArticleImportFields = ['title', 'content', 'excerpt', 'tags', 'sources'];
      const legacyArticleSignalFields = ['excerpt', 'tags', 'sources'];

      const hasAnyImportField = (object, fields) => fields.some((field) => hasOwn(object, field));

      const normalizePublishPayloadImport = (payload) => ({
        record_type: 'content_source',
        schema_version: baselineContentSourceSchemaVersion,
        content: {
          title: typeof payload.title === 'string' ? payload.title : '',
          markdown:
            typeof payload.markdown === 'string'
              ? payload.markdown
              : typeof payload.content === 'string'
                ? payload.content
                : '',
        },
        publication: {
          schema_version: 'publication.v2',
          published_time: null,
        },
        taxonomy: {
          tags: Array.isArray(payload.tags) ? payload.tags : [],
        },
        sources: {
          source_list: Array.isArray(payload.sources) ? payload.sources : [],
        },
      });

      const normalizeArticleBodyImport = (articleBody) => ({
        record_type: 'content_source',
        schema_version: baselineContentSourceSchemaVersion,
        content: {
          article_body: articleBody,
          markdown: articleBodyToMarkdown(articleBody),
        },
        publication: {
          schema_version: 'publication.v2',
          published_time: null,
        },
      });

      const normalizeLegacyArticleImport = (article) => {
        const articleBody = article.content?.article_body || article.article_body;
        const markdown =
          articleBody && Array.isArray(articleBody.nodes)
            ? articleBodyToMarkdown(articleBody)
            : typeof article.markdown === 'string'
              ? article.markdown
              : typeof article.content === 'string'
                ? article.content
                : '';

        return {
          record_type: 'content_source',
          schema_version: baselineContentSourceSchemaVersion,
          content: {
            title: typeof article.title === 'string' ? article.title : '',
            deck: typeof article.excerpt === 'string' ? article.excerpt : '',
            markdown,
            ...(articleBody && Array.isArray(articleBody.nodes) ? { article_body: articleBody } : {}),
          },
          publication: {
            schema_version: 'publication.v2',
            published_time: null,
          },
          taxonomy: {
            tags: Array.isArray(article.tags) ? article.tags : [],
          },
          sources: {
            source_list: Array.isArray(article.sources) ? article.sources : [],
          },
        };
      };

      const classifyJsonImport = (data) => {
        if (!isPlainObject(data)) {
          throw new Error(
            'JSON import must be a single top-level object. Arrays or multiple article objects are not supported.'
          );
        }

        if (isPlainObject(data.input) && data.input.record_type === 'content_source') {
          return { contentSource: data.input, loadedMessage: 'Loaded workflow record' };
        }

        if (data.record_type === 'content_source' && data.schema_version === baselineContentSourceSchemaVersion) {
          return { contentSource: data, loadedMessage: 'Loaded published payload' };
        }

        if (data.schema_version === 'article_body.v1' && Array.isArray(data.nodes)) {
          return {
            contentSource: normalizeArticleBodyImport(data),
            loadedMessage: 'Loaded article_body draft',
            allowIncomplete: true,
          };
        }

        if (
          hasAnyImportField(data, legacyArticleSignalFields) ||
          (hasAnyImportField(data, legacyArticleImportFields) &&
            !hasAnyImportField(data, partialPublishPayloadSignalFields))
        ) {
          return {
            contentSource: normalizeLegacyArticleImport(data),
            loadedMessage: 'Loaded legacy markdown fallback',
            allowIncomplete: true,
          };
        }

        if (hasAnyImportField(data, partialPublishPayloadImportFields)) {
          return {
            contentSource: normalizePublishPayloadImport(data),
            loadedMessage: 'Loaded partial publish payload',
            isPartial: true,
            allowIncomplete: true,
          };
        }

        return { contentSource: data, loadedMessage: 'Loaded published payload' };
      };

      const normalizeContentSourceImportWrapper = (data, currentSchemaVersion) => {
        const classification = classifyJsonImport(data);
        const candidate = classification.contentSource;
        const allowedSchemaVersions = getAllowedContentSourceSchemaVersions(currentSchemaVersion);
        if (candidate.record_type !== 'content_source' || !allowedSchemaVersions.has(candidate.schema_version)) {
          throw new Error(getUnsupportedSchemaMessage(currentSchemaVersion));
        }

        [
          ['content', ['content']],
          ['publication', ['publication']],
          ['editorial', ['editorial']],
          ['seo', ['seo']],
          ['taxonomy', ['taxonomy']],
          ['sources', ['sources']],
        ].forEach(([pathLabel, path]) => assertOptionalObject(candidate, pathLabel, path));

        assertOptionalTextPath(candidate, 'content.title', [['content', 'title']]);
        assertOptionalTextPath(candidate, 'content.deck', [['content', 'deck']]);
        assertOptionalTextPath(candidate, 'seo.meta_description', [['seo', 'meta_description']]);
        assertOptionalStringArrayPath(candidate, 'taxonomy.tags', [['taxonomy', 'tags']]);
        assertOptionalSourceListPath(candidate);

        return { ...classification, contentSource: candidate };
      };

      const validateContentSourceImportFormData = (formData) => {
        const allowedSchemaVersions = getAllowedContentSourceSchemaVersions(formData.currentSchemaVersion);
        if (!allowedSchemaVersions.has(formData.schemaVersion)) {
          throw new Error(getUnsupportedSchemaMessage(formData.currentSchemaVersion));
        }

        if (formData.allowIncomplete) return;

        if (!formData.title.exists || !formData.title.value.trim()) {
          throw new Error('Import JSON must include a non-empty title.');
        }

        if (!slugify(formData.title.value)) {
          throw new Error('Import JSON title must include enough text to compute a publishing target.');
        }
      };

      const parseContentSourceImportFormData = async (data) => {
        const currentSchemaVersion = await getCurrentContentSourceSchemaVersion();
        const importData = normalizeContentSourceImportWrapper(data, currentSchemaVersion);
        const formData = normalizeContentSourceImportToFormData(importData.contentSource, currentSchemaVersion);
        formData.loadedMessage = importData.loadedMessage;
        formData.isPartial = Boolean(importData.isPartial);
        formData.allowIncomplete = Boolean(importData.allowIncomplete || importData.isPartial);
        validateContentSourceImportFormData(formData);
        return formData;
      };

      const applyContentSourceImportFormData = async (formData) => {
        if (formData.title.exists) fields.title.value = formData.title.value;
        syncSlugFromTitle();
        if (formData.author.exists) fields.author.value = formData.author.value;
        if (formData.excerpt.exists) fields.excerpt.value = formData.excerpt.value;
        if (formData.seoDescription.exists) fields.seoDescription.value = formData.seoDescription.value;
        if (formData.content.exists) {
          fields.content.value = formData.content.value;
          // Sync pieces from imported content
          if (formData.articleBody?.exists && Array.isArray(formData.articleBody.value?.nodes)) {
            articleNodes = formData.articleBody.value.nodes;
            contentModel = 'article_body.v1';
            setLegacyMarkdownConversionNotice(false);
          } else {
            articleNodes = [createLegacyBodyNode(fields.content.value)];
            contentModel = 'legacy_markdown_converted';
            setLegacyMarkdownConversionNotice(Boolean(fields.content.value.trim()));
          }
          renderPieces();
        }
        if (formData.tags.exists) fields.tags.value = formData.tags.value;
        if (formData.sources.exists) fields.sources.value = formData.sources.value;

        const importedArtifactReferences = formData.artifactReferences?.exists
          ? mergeArtifactReferences(formData.artifactReferences.value)
          : [];
        const {
          readableReferences: importedReadableArtifactReferences,
          failedReferences: importedFailedArtifactReferences,
        } = importedArtifactReferences.length
          ? await checkReadableArtifactReferences(importedArtifactReferences, await getClerkSessionToken(), {
              logContext: 'Imported JSON',
            })
          : { readableReferences: [], failedReferences: [] };
        const importedMediaEntries = formData.mediaEntries?.exists
          ? mergeMediaEntries(formData.mediaEntries.value)
          : [];
        const importedInlineMediaEntries = importedMediaEntries.filter(hasUsableMediaEntryContent);
        const importedReferenceMediaEntries = importedMediaEntries.filter(
          (entry) => !hasUsableMediaEntryContent(entry)
        );
        let importedInlineArtifactReferences = [];
        let inlineMediaUploadWarning = '';
        if (importedInlineMediaEntries.length) {
          const { requestId } = getCheckedOutWorkflowDraft();
          if (requestId) {
            try {
              importedInlineArtifactReferences = await uploadInlineMediaEntriesAsArtifacts(
                importedInlineMediaEntries,
                requestId
              );
            } catch (error) {
              console.warn('Imported inline media could not be uploaded as artifacts.', error);
              inlineMediaUploadWarning =
                'An imported image could not be saved to the draft media library. Re-upload or re-select the image before publishing.';
            }
          } else {
            stagedInlineMediaEntries = mergeMediaEntries(stagedInlineMediaEntries, importedInlineMediaEntries);
            inlineMediaUploadWarning =
              'An imported image is ready to save to the draft media library after you save the draft.';
          }
        }

        const importedRawImageNames = formData.imageNames?.exists
          ? formData.imageNames.value.map((name) => String(name || '').trim()).filter(Boolean)
          : [];
        const importedImagePathEntries = mergeImagePathEntries(importedRawImageNames);
        selectedImages = [
          ...importedReferenceMediaEntries.map(createMediaSelectedImage),
          ...(importedInlineArtifactReferences.length
            ? importedInlineArtifactReferences.map(createArtifactSelectedImage)
            : importedInlineMediaEntries.map(createMediaSelectedImage)),
          ...importedImagePathEntries.map(createPathSelectedImage),
          ...importedReadableArtifactReferences.map(createArtifactSelectedImage),
        ];
        syncImageNames();

        const metadataOnlyImageCount = importedRawImageNames.filter((name) => {
          const sanitizedName = sanitizeFilename(name);
          return (
            !selectedImagePathEntries.some((entry) => entry.source === name || entry.name === sanitizedName) &&
            !selectedMediaEntries.some((entry) => getMediaEntryImageName(entry) === sanitizedName) &&
            !selectedArtifactReferences.some((reference) => getArtifactImageName(reference) === sanitizedName)
          );
        }).length;
        const unreadableArtifactWarning = importedFailedArtifactReferences.length
          ? formatArtifactReselectionMessage(importedFailedArtifactReferences)
          : '';
        const metadataOnlyImageWarning = metadataOnlyImageCount
          ? 'Image names were found in JSON, but no blob references or image data were available for thumbnails.'
          : '';
        imageImportWarningMessage = [unreadableArtifactWarning, metadataOnlyImageWarning, inlineMediaUploadWarning]
          .filter(Boolean)
          .join(' ');
        imageUploadMessage = imageNames.length
          ? `${imageNames.length} previewable image${imageNames.length === 1 ? '' : 's'} loaded from JSON.`
          : '';
        imageUploadMessageIsError = false;
        renderImages();

        const importedFeaturedImage = formData.featuredImage?.exists
          ? String(formData.featuredImage.value || '').trim()
          : '';
        const importedExistingFeaturedImage = formData.existingFeaturedImagePath?.exists
          ? String(formData.existingFeaturedImagePath.value || '').trim()
          : '';
        fields.existingFeaturedImagePath.value = getPreviewableImagePath(importedExistingFeaturedImage)
          ? importedExistingFeaturedImage
          : '';

        if (importedFeaturedImage) {
          const matchingArtifactName = selectedArtifactReferences
            .map(getArtifactImageName)
            .find((name) => name === sanitizeFilename(importedFeaturedImage));
          const matchingMediaEntryName = selectedMediaEntries
            .map(getMediaEntryImageName)
            .find((name) => name === sanitizeFilename(importedFeaturedImage));
          const matchingPathEntry = selectedImagePathEntries.find(
            (entry) => entry.source === importedFeaturedImage || entry.name === sanitizeFilename(importedFeaturedImage)
          );
          const previewableImportedFeaturedImage = getPreviewableImagePath(importedFeaturedImage)
            ? importedFeaturedImage
            : '';
          const featuredValue =
            matchingArtifactName ||
            matchingMediaEntryName ||
            matchingPathEntry?.source ||
            previewableImportedFeaturedImage;
          if (featuredValue) {
            const featuredSuffix = matchingArtifactName
              ? 'saved image record'
              : matchingMediaEntryName
                ? 'embedded media data'
                : matchingPathEntry
                  ? 'existing preview path'
                  : 'existing path';
            ensureFeaturedImageOption(featuredValue, featuredSuffix);
            fields.featuredImage.value = featuredValue;
            if (matchingArtifactName || matchingMediaEntryName) fields.existingFeaturedImagePath.value = '';
          } else {
            fields.featuredImage.value = '';
            imageImportWarningMessage = [
              imageImportWarningMessage,
              `Featured image ${shortenFilename(importedFeaturedImage, 24)} was found in JSON, but no saved image record, embedded image data, or existing image path was available.`,
            ]
              .filter(Boolean)
              .join(' ');
            if (fields.imageImportWarning) {
              fields.imageImportWarning.textContent = imageImportWarningMessage;
              fields.imageImportWarning.hidden = !imageImportWarningMessage;
            }
          }
        } else {
          fields.featuredImage.value = '';
        }

        updatePreview();
        updatePublishOutput();
        recalculateButtonState();
      };

      const getImportJsonObjectText = (text) => {
        const trimmed = text.trim();
        const fencedJson = trimmed.match(/```(?:json)?\s*([\s\S]*?)\s*```/i);
        const candidate = fencedJson ? fencedJson[1].trim() : trimmed;
        const objectStart = candidate.indexOf('{');

        if (objectStart === -1) {
          throw new Error('JSON import must include one top-level object.');
        }

        if (candidate.slice(0, objectStart).trim()) {
          throw new Error('Remove any text before the JSON object and try again.');
        }

        let depth = 0;
        let inString = false;
        let escaped = false;
        let objectEnd = -1;

        for (let index = objectStart; index < candidate.length; index += 1) {
          const char = candidate[index];

          if (inString) {
            if (escaped) {
              escaped = false;
            } else if (char === '\\') {
              escaped = true;
            } else if (char === '"') {
              inString = false;
            }
            continue;
          }

          if (char === '"') {
            inString = true;
            continue;
          }

          if (char === '{' || char === '[') depth += 1;
          if (char === '}' || char === ']') depth -= 1;

          if (depth === 0) {
            objectEnd = index;
            break;
          }
        }

        if (objectEnd === -1) {
          throw new Error('JSON import has an incomplete top-level object.');
        }

        const trailingText = candidate.slice(objectEnd + 1).trim();
        if (trailingText) {
          throw new Error(
            'JSON import must contain only one top-level object. Remove duplicate objects or trailing text.'
          );
        }

        return candidate.slice(objectStart, objectEnd + 1);
      };

      const failJsonImport = (message, { alert = true } = {}) => {
        setJsonImportStatus(message, true);
        if (alert) window.alert(message);
      };

      const loadJsonImport = async (rawValue = fields.jsonImport.value, { alertOnError = true } = {}) => {
        const rawJson = rawValue.trim();
        if (!rawJson) {
          failJsonImport('Paste JSON or choose a .json file before loading.', { alert: alertOnError });
          return false;
        }

        try {
          const objectJson = getImportJsonObjectText(rawJson);
          const duplicates = getDuplicateTopLevelKeys(objectJson);
          if (duplicates.length) {
            throw new Error(
              `JSON import has duplicate top-level field${duplicates.length === 1 ? '' : 's'}: ${duplicates.join(', ')}.`
            );
          }

          const data = JSON.parse(objectJson);
          const formData = await parseContentSourceImportFormData(data);
          fields.jsonImport.value = rawValue;
          lastLoadedJsonImportValue = fields.jsonImport.value.trim();
          updateJsonImportButtonState();
          await applyContentSourceImportFormData(formData);
          setUnsavedChanges(true);
          await fetchPublishedArticleStatus({ force: true });
          setJsonImportStatus(
            formData.isPartial
              ? `${formData.loadedMessage}. Partial data was loaded; review missing article fields before publishing.`
              : `${formData.loadedMessage || `${formData.schemaVersion} JSON loaded into the publishing form.`}.`
          );
          return true;
        } catch (error) {
          const message = error instanceof Error ? error.message : 'JSON import could not be parsed.';
          const isSyntaxError = error instanceof SyntaxError;
          failJsonImport(isSyntaxError ? `Invalid JSON. ${message}` : message, { alert: alertOnError });
          return false;
        }
      };

      const readJsonFile = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.addEventListener('load', () => resolve(String(reader.result || '')));
          reader.addEventListener('error', () => reject(reader.error || new Error('JSON file could not be read.')));
          reader.readAsText(file);
        });

      const getQueryDraftId = () => new URLSearchParams(window.location.search).get('draftId')?.trim() || '';

      const formatJsonDraftDate = (value) => {
        if (!value) return 'No updated date';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return String(value);
        return new Intl.DateTimeFormat(undefined, {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
        }).format(date);
      };

      const fetchJsonDraftInput = async (draftId, token) => {
        const response = await fetch(
          `/.netlify/functions/admin-get-json-draft?draftId=${encodeURIComponent(draftId)}`,
          {
            method: 'GET',
            headers: {
              Authorization: `Bearer ${token}`,
              'Content-Type': 'application/json',
            },
          }
        );
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          const message = result.message || result.error || `Draft could not be loaded (${response.status}).`;
          if (response.status === 423 || isWorkflowLockPayload(result))
            throw createWorkflowLockError(message, result, response.status);
          throw new Error(message);
        }

        const draftInput = result.input || result.draft?.input;
        if (!draftInput) throw new Error('Draft response did not include JSON input.');

        return { draftInput, result };
      };

      const appendCopySuffix = (value, suffix) => {
        const text = String(value || '').trim();
        return text ? `${text}${suffix}` : `Untitled${suffix}`;
      };

      const cloneContentSourceForCopy = (input) => {
        const copy = typeof structuredClone === 'function' ? structuredClone(input) : JSON.parse(JSON.stringify(input));
        copy.content ||= {};
        copy.publication = { schema_version: 'publication.v2', published_time: null };
        const currentTitle = copy.content.title || 'Untitled article';
        const copyTitle = appendCopySuffix(currentTitle, '-Copy');
        copy.content.title = copyTitle;
        return copy;
      };

      const applyBlobDraftInput = async (draftId, draftInput, { readOnly = false, draft = undefined } = {}) => {
        let input = readOnly ? cloneContentSourceForCopy(draftInput) : draftInput;
        if (!readOnly) {
          await ensureWorkflowLock(draftId);
          const checkedOutRecord = await fetchLatestWorkflowRequest(draftId);
          input = checkedOutRecord?.input || draftInput;
        }

        const loaded = await loadJsonImport(JSON.stringify(input, null, 2), { alertOnError: false });
        if (!loaded) return false;

        lastSavedDraftId = readOnly ? '' : draftId;
        lastSavedAt = readOnly ? '' : draft?.updatedAt || draft?.updated_at || '';
        lastSavedBy = readOnly ? '' : draft?.author || fields.author.value.trim();
        if (readOnly) {
          workflowRequestId = '';
          workflowLockToken = '';
          workflowLockExpiresAt = '';
          workflowReadOnlyMode = false;
          fields.overwrite.checked = false;
          clearWorkflowLockRefreshTimer();
          fields.jsonUploadName.textContent = `${draftId} (copy)`;
          setJsonImportStatus(`Opened saved JSON ${draftId} as a new copy. The original draft was not modified.`);
        }
        await fetchPublishedArticleStatus({ force: true });
        setUnsavedChanges(readOnly);
        recalculateButtonState();
        return true;
      };

      const loadDraftFromBlobs = async (clerk) => {
        const draftId = getQueryDraftId();
        if (!draftId) return false;

        setStatus(`Loading saved draft ${draftId}…`, false);

        let draftInput;
        try {
          const token = await clerk.session.getToken();
          if (!token) throw new Error('Could not retrieve a Clerk session token.');

          const result = await fetchJsonDraftInput(draftId, token);
          draftInput = result.draftInput;
          const loaded = await applyBlobDraftInput(draftId, draftInput, result.result);
          if (!loaded) return false;

          setStatus(`Loaded draft ${draftId}.`, true);
          return true;
        } catch (error) {
          console.error('Draft load failed.', error);
          if (isWorkflowLockError(error) && draftInput) {
            setStatus(formatWorkflowLockMessage(error), false);
            showWorkflowLockActions({ draftId, draftInput, error });
            return false;
          }
          setStatus(
            error instanceof Error ? error.message : 'Draft could not be loaded. You can continue manually.',
            false
          );
          return false;
        }
      };

      const clearJsonDraftModalActions = () => {
        fields.jsonDraftModalActions.innerHTML = '';
        fields.jsonDraftModalActions.hidden = true;
      };

      const setJsonDraftModalStatus = (message, isError = false) => {
        fields.jsonDraftModalStatus.textContent = message;
        fields.jsonDraftModalStatus.classList.toggle('is-error', isError);
        if (!isError) clearJsonDraftModalActions();
      };

      const showJsonDraftModal = () => {
        if (fields.jsonDraftModal?.open) return;
        if (fields.jsonDraftModal?.showModal) {
          fields.jsonDraftModal.showModal();
        } else {
          fields.jsonDraftModal?.setAttribute('open', '');
        }
      };

      const recoverStoredWorkflowSession = async (draftId, draftInput) => {
        const storedLock = getStoredActiveWorkflowLock();
        if (!storedLock || storedLock.request_id !== draftId)
          throw new Error('No recoverable workflow lock was found.');

        workflowRequestId = storedLock.request_id;
        workflowLockToken = storedLock.lock_token;
        workflowLockExpiresAt = sessionStorage.getItem('dr-lurie-workflow-lock-expires-at') || '';
        await refreshWorkflowLock();
        const loaded = await applyBlobDraftInput(draftId, draftInput);
        if (!loaded) throw new Error('Recovered workflow lock could not be applied to the form.');
      };

      const showWorkflowLockActions = ({ draftId, draftInput, error }) => {
        setJsonDraftModalStatus(formatWorkflowLockMessage(error), true);
        fields.jsonDraftList.innerHTML = '';
        fields.jsonDraftModalActions.hidden = false;

        const lock = error?.lock || getWorkflowLockFromPayload(error?.payload) || {};
        const storedLock = getStoredActiveWorkflowLock();
        const canRecover =
          lock.owner_id === workflowLockOwnerId && storedLock?.request_id === draftId && Boolean(storedLock.lock_token);

        fields.jsonDraftModalActions.innerHTML = `
        <button class="btn-secondary btn-sm" type="button" data-lock-action="open-read-only">Open read-only</button>
        ${canRecover ? '<button class="btn-primary btn-sm" type="button" data-lock-action="recover-session">Recover session</button>' : ''}
        <button class="btn-secondary btn-sm" type="button" data-lock-action="try-again-later">Try again later</button>
      `;

        fields.jsonDraftModalActions
          .querySelector('[data-lock-action="open-read-only"]')
          ?.addEventListener('click', async () => {
            try {
              const loaded = await applyBlobDraftInput(draftId, draftInput, { readOnly: true });
              if (!loaded) throw new Error('Saved draft could not be opened read-only.');
              setStatus(`Opened saved JSON ${draftId} read-only. No workflow lock was acquired.`, false);
              closeJsonDraftModal();
            } catch (readOnlyError) {
              setJsonDraftModalStatus(
                readOnlyError instanceof Error ? readOnlyError.message : 'Saved draft could not be opened read-only.',
                true
              );
            }
          });

        fields.jsonDraftModalActions
          .querySelector('[data-lock-action="recover-session"]')
          ?.addEventListener('click', async () => {
            try {
              await recoverStoredWorkflowSession(draftId, draftInput);
              fields.jsonUploadName.textContent = draftId;
              setJsonImportStatus(`Recovered saved JSON ${draftId}.`);
              setStatus(`Recovered saved JSON ${draftId}.`, true);
              closeJsonDraftModal();
            } catch (recoverError) {
              setJsonDraftModalStatus(
                recoverError instanceof Error ? recoverError.message : 'Saved draft session could not be recovered.',
                true
              );
            }
          });

        fields.jsonDraftModalActions
          .querySelector('[data-lock-action="try-again-later"]')
          ?.addEventListener('click', () => {
            clearJsonDraftModalActions();
            setJsonDraftModalStatus('Try again after the current lock expires or the owner checks in the draft.');
          });

        showJsonDraftModal();
      };

      const closeJsonDraftModal = () => {
        if (fields.jsonDraftModal?.close) {
          fields.jsonDraftModal.close();
        } else {
          fields.jsonDraftModal?.removeAttribute('open');
        }
      };

      const getJsonDraftLifecycleLabel = (draft) => {
        const status = draft.recordStatus || draft.lifecycleStatus;
        if (status === 'published') return { label: 'Published', className: 'is-published' };
        if (status === 'published_saved_json')
          return { label: 'Published + Saved JSON', className: 'is-published-saved-json' };
        if (status === 'saved_json_only') return { label: 'Saved JSON only', className: 'is-saved-json-only' };
        if (status === 'draft_workflow') return { label: 'Draft workflow', className: 'is-draft-workflow' };
        if (status === 'unpublished_changes' || status === 'modified')
          return { label: 'Unpublished changes', className: 'is-unpublished-changes' };
        if (status === 'mcp_workflow_record')
          return { label: 'MCP workflow record', className: 'is-mcp-workflow-record' };
        if (draft.published?.exists) return { label: 'Published', className: 'is-published' };
        return { label: 'Saved JSON only', className: 'is-saved-json-only' };
      };

      const renderJsonDraftLifecycleMeta = (draft) => {
        const status = getJsonDraftLifecycleLabel(draft);
        const published = draft.published || {};
        const savedAt = draft.savedAt || draft.updatedAt || draft.updated_at || draft.modifiedAt;
        const savedBy = draft.savedBy || draft.author || 'Unknown';
        const publishedRows = published.exists
          ? `<span>Published:</span><strong>${escapeHtml(formatJsonDraftDate(published.date))}</strong><span>By:</span><strong>${escapeHtml(published.by || 'Unknown')}</strong>`
          : '';
        return `<span class="json-draft-lifecycle ${status.className}">${escapeHtml(status.label)}</span>
          <span class="json-draft-status-grid">
            ${publishedRows}
            <span>Saved:</span><strong>${escapeHtml(formatJsonDraftDate(savedAt))}</strong>
            <span>By:</span><strong>${escapeHtml(savedBy)}</strong>
          </span>`;
      };

      const renderJsonDraftChoices = (drafts) => {
        if (!drafts.length) {
          fields.jsonDraftList.innerHTML = '<p class="json-draft-empty">No saved drafts were found.</p>';
          return;
        }

        fields.jsonDraftList.innerHTML = drafts
          .map((draft) => {
            const id = draft.id || draft.key || draft.request_id || '';
            const title = draft.title || 'Untitled draft';
            const slug = draft.slug || 'no-slug';
            const author = draft.author || 'unknown author';
            const updatedAt = formatJsonDraftDate(draft.updatedAt || draft.updated_at || draft.modifiedAt);

            return `<button class="json-draft-choice" type="button" data-draft-id="${escapeHtml(id)}">
            <span>
              <span class="json-draft-choice-title">${escapeHtml(title)}</span>
              <span class="json-draft-choice-meta">${escapeHtml(slug)} · ${escapeHtml(author)} · ${escapeHtml(updatedAt)}</span>
              ${renderJsonDraftLifecycleMeta(draft)}
            </span>
            <span class="json-draft-choice-icon" aria-hidden="true">↗</span>
          </button>`;
          })
          .join('');
      };

      const loadJsonDraftChoices = async () => {
        fields.jsonDraftList.innerHTML = '';
        setJsonDraftModalStatus('Loading saved drafts…');

        try {
          const token = await getClerkSessionToken();
          const response = await fetch('/.netlify/functions/admin-list-json-drafts', {
            method: 'GET',
            headers: {
              Authorization: `Bearer ${token}`,
              'Content-Type': 'application/json',
            },
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok) throw new Error(result.error || `Saved drafts could not be listed (${response.status}).`);

          const drafts = Array.isArray(result.drafts) ? result.drafts : [];
          renderJsonDraftChoices(drafts);
          setJsonDraftModalStatus(
            drafts.length ? 'Select a saved draft to load into the form.' : 'No saved drafts were found.'
          );
        } catch (error) {
          console.error('Saved JSON draft list failed.', error);
          setJsonDraftModalStatus(error instanceof Error ? error.message : 'Saved drafts could not be listed.', true);
        }
      };

      const setBlobImageModalStatus = (message, isError = false) => {
        fields.blobImageModalStatus.textContent = message;
        fields.blobImageModalStatus.classList.toggle('is-error', Boolean(message && isError));
      };

      const closeBlobImageModal = () => {
        if (fields.blobImageModal?.close) fields.blobImageModal.close();
        else fields.blobImageModal?.removeAttribute('open');
      };

      const showBlobImageModal = () => {
        if (fields.blobImageModal?.showModal && !fields.blobImageModal.open) fields.blobImageModal.showModal();
        else fields.blobImageModal?.setAttribute('open', '');
      };

      const artifactKindFromReference = (artifact) => String(artifact?.blobKey || '').split('/')[0] || '';

      const getArtifactDisplayLabel = (artifact) =>
        String(
          artifact?.label ||
            artifact?.originalFilename ||
            artifact?.metadata?.filename ||
            getArtifactImageName(artifact)
        ).trim();

      const getCurrentBlobImageRequestId = () => {
        const { requestId } = getCheckedOutWorkflowDraft();
        return requestId || workflowRequestId || lastSavedDraftId || '';
      };

      const getArtifactSearchText = (artifact) =>
        [
          artifact?.label,
          artifact?.originalFilename,
          artifact?.metadata?.filename,
          artifact?.metadata?.name,
          getArtifactImageName(artifact),
          ...(Array.isArray(artifact?.tags) ? artifact.tags : []),
        ]
          .map((value) => String(value || '').toLowerCase())
          .join(' ');

      const artifactCreatedAtMs = (artifact) => {
        const timestamp = Date.parse(artifact?.createdAtISO || '');
        return Number.isFinite(timestamp) ? timestamp : 0;
      };

      const sortArtifactsByCreatedDesc = (artifacts) =>
        [...artifacts].sort((left, right) => artifactCreatedAtMs(right) - artifactCreatedAtMs(left));

      const filterBlobImageArtifacts = (artifacts, { artifactKind, requestId, requestScope, searchTerm }) => {
        const normalizedSearch = String(searchTerm || '')
          .trim()
          .toLowerCase();
        return sortArtifactsByCreatedDesc(
          artifacts.filter((artifact) => {
            if (!isImageArtifactReference(artifact)) return false;
            if (artifactKind && artifactKindFromReference(artifact) !== artifactKind) return false;
            if (requestScope === 'current' && requestId && getArtifactRequestId(artifact) !== requestId) return false;
            if (normalizedSearch && !getArtifactSearchText(artifact).includes(normalizedSearch)) return false;
            return true;
          })
        );
      };

      const mcpAdminArtifactToolCall = async (name, args) => {
        const token = await getClerkSessionToken();
        return mcpToolCall(name, args, { authorization: `Bearer ${token}` });
      };

      const loadAllArtifactBrowsePages = async (toolName, args) => {
        const artifacts = [];
        let cursor = args.cursor || '';
        for (let page = 0; page < 10; page += 1) {
          const result = await mcpAdminArtifactToolCall(toolName, {
            ...args,
            limit: 100,
            ...(cursor ? { cursor } : {}),
          });
          artifacts.push(...(Array.isArray(result.artifacts) ? result.artifacts : []));
          cursor = result.nextCursor || '';
          if (!cursor) break;
        }
        return artifacts;
      };

      const loadBlobImageArtifactsFromMcp = async () => {
        const artifactKind = fields.blobImageKindFilter?.value || 'image';
        const requestScope = fields.blobImageRequestFilter?.value || 'current';
        const requestId = getCurrentBlobImageRequestId();
        const searchTerm = fields.blobImageSearch?.value || '';
        const baseArgs = { artifactKind };
        const baseArtifacts =
          requestScope === 'current' && requestId
            ? await loadAllArtifactBrowsePages('list_artifacts_by_request', { requestId, ...baseArgs })
            : await loadAllArtifactBrowsePages('list_artifacts_by_kind', baseArgs);
        let artifacts = baseArtifacts;
        const trimmedSearch = searchTerm.trim();

        if (trimmedSearch) {
          try {
            const tagArtifacts = await loadAllArtifactBrowsePages('search_artifacts', { tag: trimmedSearch });
            artifacts = mergeArtifactReferences(artifacts, tagArtifacts);
          } catch (error) {
            console.warn('Artifact tag search failed; falling back to loaded artifact metadata search.', error);
          }
        }

        return filterBlobImageArtifacts(mergeArtifactReferences(selectedArtifactReferences, artifacts), {
          artifactKind,
          requestId,
          requestScope,
          searchTerm,
        });
      };

      const renderBlobImageChoices = (artifacts) => {
        if (!artifacts.length) {
          fields.blobImageList.innerHTML = '<p class="json-draft-empty">No saved images matched these filters.</p>';
          return;
        }

        fields.blobImageList.replaceChildren();
        artifacts.forEach((artifact, index) => {
          const name = getArtifactImageName(artifact);
          const label = getArtifactDisplayLabel(artifact);
          const tags = Array.isArray(artifact.tags) && artifact.tags.length ? ` · #${artifact.tags.join(' #')}` : '';
          const createdAt = artifact.createdAtISO ? ` · ${new Date(artifact.createdAtISO).toLocaleDateString()}` : '';
          const meta = `${artifactKindFromReference(artifact) || 'artifact'} · ${artifact.contentType || 'unknown'} · ${formatFileSize(artifact.sizeBytes)}${createdAt}${tags}`;
          const choice = document.createElement('label');
          const thumbnail = document.createElement('img');
          const title = document.createElement('span');
          const metaElement = document.createElement('span');
          const checkbox = document.createElement('input');

          choice.className = 'json-draft-choice blob-image-choice';
          choice.dataset.blobImageIndex = String(index);
          thumbnail.className = 'blob-image-choice-thumb';
          thumbnail.alt = `Preview of ${label || name}`;
          thumbnail.loading = 'lazy';
          title.className = 'blob-image-choice-title';
          title.textContent = shortenFilename(label || name, 24);
          title.title = label || name;
          metaElement.className = 'blob-image-choice-meta';
          metaElement.textContent = meta;
          metaElement.title = meta;
          checkbox.className = 'blob-image-choice-checkbox';
          checkbox.type = 'checkbox';
          checkbox.dataset.blobImageCheckbox = String(index);
          checkbox.checked = stagedBlobImageKeys.has(artifact.blobKey);

          if (isImageArtifactReference(artifact)) attachArtifactPreview(thumbnail, artifact);
          else thumbnail.alt = `${artifactKindFromReference(artifact) || 'Artifact'} preview unavailable`;
          choice.append(thumbnail, title, metaElement, checkbox);
          fields.blobImageList.append(choice);
        });
      };

      const loadBlobImageChoices = async () => {
        fields.blobImageList.innerHTML = '';
        setBlobImageModalStatus('Loading saved images…');

        try {
          availableBlobImageArtifacts = await loadBlobImageArtifactsFromMcp();
          stagedBlobImageKeys = new Set(selectedArtifactReferences.map((reference) => reference.blobKey));

          renderBlobImageChoices(availableBlobImageArtifacts);
          setBlobImageModalStatus(
            availableBlobImageArtifacts.length
              ? 'Choose saved images to add to this article. Results are sorted newest first.'
              : 'No saved images matched these filters.'
          );
        } catch (error) {
          console.error('Saved image list failed.', error);
          setBlobImageModalStatus(error instanceof Error ? error.message : 'Saved images could not be listed.', true);
        }
      };

      const openBlobImageModal = () => {
        showBlobImageModal();
        loadBlobImageChoices();
      };

      const toggleStagedBlobImage = (index, selected) => {
        const artifact = availableBlobImageArtifacts[index];
        if (!artifact?.blobKey) return;
        if (selected) stagedBlobImageKeys.add(artifact.blobKey);
        else stagedBlobImageKeys.delete(artifact.blobKey);
      };

      const selectMarkedBlobImages = () => {
        const artifactImages = availableBlobImageArtifacts
          .filter((artifact) => stagedBlobImageKeys.has(artifact.blobKey) && isImageArtifactReference(artifact))
          .map(createArtifactSelectedImage);
        selectedImages = [...selectedImages.filter((image) => image.kind !== 'artifact'), ...artifactImages];
        syncImageNames();
        setImageUploadMessage(
          selectedArtifactReferences.length
            ? `${selectedArtifactReferences.length} saved image${selectedArtifactReferences.length === 1 ? '' : 's'} selected.`
            : 'No saved images selected.',
          false
        );
        renderImages();
        updatePreview();
        updatePublishOutput();
        setUnsavedChanges(true);
        closeBlobImageModal();
      };

      const openJsonDraftModal = () => {
        showJsonDraftModal();
        loadJsonDraftChoices();
      };

      const loadSelectedJsonDraft = async (draftId) => {
        if (!draftId) return;
        if (hasUnsavedChanges) {
          const replaceDraft = window.confirm('Open this saved draft? Unsaved changes in the form will be replaced.');
          if (!replaceDraft) return;
        }

        setJsonDraftModalStatus(`Opening ${draftId}…`);

        let draftInput;
        try {
          const token = await getClerkSessionToken();
          const draftResult = await fetchJsonDraftInput(draftId, token);
          draftInput = draftResult.draftInput;
          const loaded = await applyBlobDraftInput(draftId, draftInput, draftResult.result);
          if (!loaded) throw new Error('Saved draft could not be applied to the form.');

          fields.jsonUploadName.textContent = draftId;
          setJsonImportStatus(`Opened saved JSON ${draftId}.`);
          setStatus(`Opened saved JSON ${draftId}.`, true);
          closeJsonDraftModal();
        } catch (error) {
          console.error('Saved draft open failed.', error);
          if (isWorkflowLockError(error) && draftInput) {
            showWorkflowLockActions({ draftId, draftInput, error });
            return;
          }
          setJsonDraftModalStatus(error instanceof Error ? error.message : 'Saved draft could not be opened.', true);
        }
      };

      fields.title.addEventListener('input', () => {
        syncSlugFromTitle();
      });

      fields.jsonUpload.addEventListener('change', async () => {
        const [file] = Array.from(fields.jsonUpload.files || []);
        if (!file) return;

        fields.jsonUploadName.textContent = file.name;
        if (!file.name.toLowerCase().endsWith('.json')) {
          failJsonImport('Choose a .json file for import.');
          fields.jsonUpload.value = '';
          return;
        }

        try {
          const rawJson = await readJsonFile(file);
          await loadJsonImport(rawJson);
        } catch (error) {
          failJsonImport(error instanceof Error ? error.message : 'JSON file could not be read.');
        }
      });

      fields.jsonImport.addEventListener('input', updateJsonImportButtonState);
      fields.jsonImport.addEventListener('change', updateJsonImportButtonState);

      fields.loadJson.addEventListener('click', () => {
        loadJsonImport();
      });

      fields.openJsonDrafts.addEventListener('click', openJsonDraftModal);
      fields.selectBlobImage.addEventListener('click', openBlobImageModal);
      fields.jsonDraftModalClose.addEventListener('click', closeJsonDraftModal);
      fields.blobImageModalClose.addEventListener('click', closeBlobImageModal);
      fields.blobImageKindFilter?.addEventListener('change', loadBlobImageChoices);
      fields.blobImageRequestFilter?.addEventListener('change', loadBlobImageChoices);
      fields.blobImageSearch?.addEventListener('input', () => {
        window.clearTimeout(Number(fields.blobImageSearch.dataset.searchTimer || 0));
        fields.blobImageSearch.dataset.searchTimer = String(window.setTimeout(loadBlobImageChoices, 250));
      });
      fields.refreshBlobImages?.addEventListener('click', loadBlobImageChoices);
      fields.blobImageList.addEventListener('change', (event) => {
        const target = event.target instanceof HTMLInputElement ? event.target : null;
        if (!target?.matches('[data-blob-image-checkbox]')) return;
        toggleStagedBlobImage(Number(target.dataset.blobImageCheckbox), target.checked);
      });
      fields.selectMarkedBlobImages.addEventListener('click', selectMarkedBlobImages);
      fields.blobImageModal.addEventListener('click', (event) => {
        if (event.target === fields.blobImageModal) closeBlobImageModal();
      });
      fields.jsonDraftList.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const choice = target?.closest('[data-draft-id]');
        if (!choice) return;
        loadSelectedJsonDraft(choice.dataset.draftId || '');
      });
      fields.jsonDraftModal.addEventListener('click', (event) => {
        if (event.target === fields.jsonDraftModal) closeJsonDraftModal();
      });

      fields.imageUpload.addEventListener('change', () => {
        const previousFeaturedImage = fields.featuredImage.value;
        const { validFiles, errors } = validateImageFiles(Array.from(fields.imageUpload.files || []));
        selectedImages = [
          ...selectedImages.filter((image) => image.kind !== 'file'),
          ...validFiles.map(createFileSelectedImage),
        ];
        syncImageNames();
        syncImageInputFiles();
        setImageUploadMessage(
          errors.length
            ? errors.join(' ')
            : imageNames.length
              ? `${imageNames.length} image${imageNames.length === 1 ? '' : 's'} ready to upload.`
              : '',
          errors.length > 0
        );
        renderImages();
        if (
          previousFeaturedImage &&
          !Array.from(fields.featuredImage.options).some((option) => option.value === previousFeaturedImage)
        )
          ensureFeaturedImageOption(previousFeaturedImage);
        if (previousFeaturedImage) fields.featuredImage.value = previousFeaturedImage;
        updatePreview();
        updatePublishOutput();
        recalculateButtonState();
        setUnsavedChanges(true);
      });

      const openDedicatedPreviewPage = async () => {
        if (fields.preview.disabled) return;

        const { requestId } = getCheckedOutWorkflowDraft();
        const previewReadyId = requestId || lastSavedDraftId;
        if (!hasUnsavedChanges && previewReadyId) {
          window.location.href = `/admin/review/${encodeURIComponent(previewReadyId)}`;
          return;
        }

        if (!getHasMinimumDraftContent()) {
          setStatus('Title, publishing target, and author are required before opening the preview page.', false);
          return;
        }

        fields.preview.disabled = true;
        setStatus('Saving draft before opening preview…', false);

        try {
          const result = await saveJsonDraftToBlobs();
          const previewRequestId = result.record?.request_id || requestId || lastSavedDraftId;
          lastSavedDraftId = previewRequestId;
          if (!previewRequestId) throw new Error('Draft was saved, but no preview ID was returned.');
          setUnsavedChanges(false);
          window.location.href = `/admin/review/${encodeURIComponent(previewRequestId)}`;
        } catch (error) {
          setStatus(error instanceof Error ? error.message : 'Preview page could not be opened.', false);
          recalculateButtonState();
        }
      };

      const startNewDraft = async () => {
        if (hasUnsavedChanges) {
          const saveFirst = window.confirm(
            'Save the current draft before starting a new article? Choose Cancel to disregard it instead.'
          );

          if (saveFirst) {
            const saved = await saveDraft({ confirm: false });
            if (!saved) return;
          } else {
            const discard = window.confirm('Discard the current unsaved draft and start a new article?');
            if (!discard) return;
          }
        }

        resetPublisherForm();
      };

      const openBlockLibrary = () => {
        fields.blockLibraryList.innerHTML = Object.values(articleNodeTemplates)
          .map(
            (t) => `
            <button class="block-template-choice" type="button" data-template-id="${window.escapeHtml(t.id)}">
              <span>
                <strong>${window.escapeHtml(t.name)}</strong>
                <p>${window.escapeHtml(t.description)}</p>
              </span>
              <span style="font-size: 1.5rem; font-weight: bold; color: var(--aw-color-accent);">+</span>
            </button>
          `
          )
          .join('');

        if (fields.blockLibraryModal?.showModal) fields.blockLibraryModal.showModal();
        else fields.blockLibraryModal?.setAttribute('open', '');
      };

      const closeBlockLibrary = () => {
        if (fields.blockLibraryModal?.close) fields.blockLibraryModal.close();
        else fields.blockLibraryModal?.removeAttribute('open');
      };

      fields.addPiece.addEventListener('click', openBlockLibrary);
      fields.blockLibraryClose.addEventListener('click', closeBlockLibrary);
      fields.blockLibraryList.addEventListener('click', (e) => {
        const btn = e.target.closest('.block-template-choice');
        if (!btn) return;
        const templateId = btn.dataset.templateId;
        articleNodes.push(createDefaultNodeFromTemplate(templateId));
        setLegacyMarkdownConversionNotice(false);
        renderPieces();
        updateFromPieces();
        closeBlockLibrary();
        // Scroll to new piece
        fields.piecesContainer.lastElementChild?.scrollIntoView({ behavior: 'smooth' });
      });

      document.querySelectorAll('.quick-add').forEach((btn) => {
        btn.addEventListener('click', () => {
          const templateId = btn.dataset.templateId;
          articleNodes.push(createDefaultNodeFromTemplate(templateId));
          setLegacyMarkdownConversionNotice(false);
          renderPieces();
          updateFromPieces();
          fields.piecesContainer.lastElementChild?.scrollIntoView({ behavior: 'smooth' });
        });
      });

      fields.convertToPieces.addEventListener('click', () => {
        if (fields.content.value.trim()) {
          articleNodes = [createLegacyBodyNode(fields.content.value)];
          contentModel = 'legacy_markdown_converted';
          setLegacyMarkdownConversionNotice(true);
          renderPieces();
          updateFromPieces();
        }
      });

      fields.newDraft.addEventListener('click', startNewDraft);
      fields.saveDraft.addEventListener('click', () => saveDraft());
      if (fields.topSave) fields.topSave.addEventListener('click', () => saveDraft());

      fields.refreshPreview.addEventListener('click', () => {
        updatePreview();
        setStatus('Inline preview refreshed.');
      });
      fields.preview.addEventListener('click', openDedicatedPreviewPage);
      if (fields.topPreview) fields.topPreview.addEventListener('click', openDedicatedPreviewPage);
      if (fields.topPublish) fields.topPublish.addEventListener('click', publishArticle);
      const arrayBufferToHex = (buffer) =>
        Array.from(new Uint8Array(buffer))
          .map((byte) => byte.toString(16).padStart(2, '0'))
          .join('');

      const getFileSha256 = async (file) =>
        arrayBufferToHex(await crypto.subtle.digest('SHA-256', await file.arrayBuffer()));

      const uploadFileAsArtifact = async (file, requestId) => {
        const filename = sanitizeFilename(file.name);
        if (!filename) throw new Error(`Invalid upload filename: ${file.name}`);

        const contentType = file.type || 'application/octet-stream';
        const expectedSha256 = await getFileSha256(file);
        const intent = await mcpToolCall('create_artifact_upload_intent', {
          requestId,
          artifactKind: 'image',
          contentType,
          expectedSizeBytes: file.size,
          expectedSha256,
          filename,
          label: filename,
        });
        const uploadUrl = intent.uploadUrl || '/api/artifacts/upload';
        const requiredHeaders = intent.requiredHeaders || {};
        const uploadResponse = await fetch(uploadUrl, {
          method: 'POST',
          headers: requiredHeaders,
          body: file,
        });
        const uploadResult = await uploadResponse.json().catch(() => ({}));
        if (!uploadResponse.ok || !uploadResult?.artifact) {
          throw new Error(uploadResult.error || `Artifact upload failed for ${filename} (${uploadResponse.status}).`);
        }

        return uploadResult.artifact;
      };

      const uploadInlineMediaEntriesAsArtifacts = async (mediaEntries, requestId) => {
        const files = mediaEntries.map(getMediaEntryUploadFile);
        if (files.some((file) => !file)) {
          throw new Error('Imported image data could not be decoded for artifact upload.');
        }
        return Promise.all(files.map((file) => uploadFileAsArtifact(file, requestId)));
      };

      const uploadSelectedFilesAsArtifacts = async (requestId) => {
        const files = selectedFiles.filter(Boolean);
        if (!files.length) return [];

        setStatus(
          `Saving ${files.length} selected image${files.length === 1 ? '' : 's'} to the draft media library…`,
          false
        );
        return Promise.all(files.map((file) => uploadFileAsArtifact(file, requestId)));
      };

      const publishArticle = async () => {
        updatePreview();
        updatePublishOutput();

        const { slug } = buildMarkdown();
        syncSlugFromTitle();
        if (!validateSlug({ announce: true })) {
          recalculateButtonState();
          return;
        }

        const missingRequiredFields = getMissingRequiredValidationItems();
        if (missingRequiredFields.length) {
          setStatus('Complete required fields before publishing.', false);
          recalculateButtonState();
          return;
        }

        if (
          !fields.title.value.trim() ||
          !slugPattern.test(fields.slug.value.trim()) ||
          !fields.author.value.trim() ||
          getMarkdownWordCount() < 5
        ) {
          setStatus(
            'Title, publishing target, author, and Markdown content (5+ words) are required before publishing.',
            false
          );
          return;
        }

        if (articleStatus.published && !fields.overwrite.checked) {
          setStatus('Check overwrite before replacing the live article.', false);
          recalculateButtonState();
          return;
        }

        const confirmed = window.confirm(
          articleStatus.published
            ? 'Save the draft, check its saved image records, then overwrite the published article on GitHub? This replaces the live version.'
            : 'Save the draft, check its saved image records, then publish this article to GitHub?'
        );
        if (!confirmed) return;

        const publishButton = fields.publish;
        publishButton.disabled = true;
        setStatus('Checking Clerk session…', false);

        try {
          const clerkToken = await getClerkSessionToken();
          setStatus('Saving draft to Blobs (source of truth)…', false);
          await saveJsonDraftToBlobs();
          const { requestId, lockToken } = getCheckedOutWorkflowDraft();
          if (!requestId || !lockToken) {
            throw new Error(
              'A checked-out workflow lock is required before publishing. Save the draft again to acquire a lock.'
            );
          }
          if (selectedMediaEntries.some(hasUsableMediaEntryContent)) {
            setStatus(
              'An imported image could not be saved to the draft media library. Re-upload or re-select the image before publishing.',
              false
            );
            return;
          }

          const uploadedArtifactReferences = await uploadSelectedFilesAsArtifacts(requestId);
          if (uploadedArtifactReferences.length) {
            selectedArtifactReferences = mergeArtifactReferences(
              selectedArtifactReferences,
              uploadedArtifactReferences
            );
            setStatus('Saving image records to the draft…', false);
            await saveJsonDraftToBlobs();
          }

          setStatus('Checking the saved draft for image records…', false);
          const latestWorkflowRecord = await fetchLatestWorkflowRequest(requestId);
          const latestSelectedArtifacts = getLatestSelectedArtifactReferences(latestWorkflowRecord);
          if (latestSelectedArtifacts.missingBlobKeys.length) {
            setStatus(formatMissingArtifactWorkflowMessage(latestSelectedArtifacts.missingBlobKeys), false);
            return;
          }
          const artifactReferences = await validateReadableArtifactReferences(
            mergeArtifactReferences(latestSelectedArtifacts.references, uploadedArtifactReferences),
            clerkToken
          );

          setStatus('Committing article content to GitHub…', false);

          const response = await fetch('/.netlify/functions/publish-article', {
            method: 'POST',
            headers: {
              Authorization: `Bearer ${clerkToken}`,
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              title: fields.title.value,
              slug,
              excerpt: fields.excerpt.value,
              publishDate: getPublishDate().toISOString(),
              author: fields.author.value,
              category: fields.category.value,
              tags: parseTags(fields.tags.value),
              draft: fields.draft.checked,
              content: fields.content.value,
              markdown: fields.outputMarkdown.value,
              sources: parseSources(fields.sources.value),
              featuredImage: fields.featuredImage.value,
              existingFeaturedImagePath: getExistingFeaturedImagePathForPayload(),
              seoDescription: fields.seoDescription.value,
              videoLink: fields.videoLink.value,
              ctaLink: fields.ctaLink.value,
              ctaText: fields.ctaText.value,
              overwrite: fields.overwrite.checked,
              article_body: {
                schema_version: 'article_body.v1',
                nodes: articleNodes,
              },
              requestId,
              request_id: requestId,
              lock_token: lockToken,
              ...(getPersistableSelectedMediaEntries().length
                ? { mediaEntries: getPersistableSelectedMediaEntries() }
                : {}),
              ...(artifactReferences.length ? { artifactReferences } : {}),
            }),
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            const message = result.error || `Publish failed with status ${response.status}.`;
            setStatus(response.status === 409 ? `${message} Check overwrite to replace it.` : message, false);
            return;
          }

          const publishedPath = result.articlePath || result.path || `src/data/post/${slug}.md`;
          const commit = String(result.commit || '').trim();
          const shortCommit = commit.slice(0, 7);
          const commitText = shortCommit ? ` in commit ${shortCommit}` : '';
          const toastMessage = `Published ${publishedPath}.${commit ? ` Commit: ${commit}` : ''}`;
          articleStatus = {
            state: 'published',
            checkedSlug: slug,
            published: {
              markdown: fields.outputMarkdown.value,
              publishDate: getPublishDate().toISOString(),
              author: fields.author.value.trim(),
              slug,
            },
          };
          fields.overwrite.checked = false;
          let workflowWarning = '';
          try {
            await mcpToolCall('save_json_blob_publish_by_time', {
              request_id: requestId,
              expected_record_version: latestWorkflowRecord?.version,
              lock_token: lockToken,
              published_time: getPublishDate().toISOString(),
            });
            try {
              await checkinWorkflowRequest();
            } catch (error) {
              console.warn('Published workflow check-in failed.', error);
              workflowWarning = ' Workflow lock could not be released automatically.';
            }
          } catch (error) {
            console.warn('Published workflow time update failed.', error);
            workflowWarning = ' Workflow publication time was not updated, so the workflow lock remains checked out.';
          }

          setStatus(
            `${isEditMode() ? `Updated ${publishedPath} in place${commitText}.` : `Published ${publishedPath}${commitText}.`}${workflowWarning}`,
            false
          );
          setUnsavedChanges(false);
          showToast(toastMessage, getGitHubToastLinks({ articlePath: publishedPath, commit }));
        } catch (error) {
          setStatus(
            isWorkflowLockError(error)
              ? formatWorkflowLockMessage(error)
              : error instanceof Error
                ? error.message
                : 'Article could not be published.',
            false
          );
        } finally {
          recalculateButtonState();
        }
      };

      fields.publish.addEventListener('click', publishArticle);
      fields.copyOutput.addEventListener('click', () => {
        if (fields.copyOutput.disabled) return;
        updatePublishOutput();
        copyText(fields.outputMarkdown.value, 'Publish Markdown copied.');
      });

      fields.downloadJsonBackup.addEventListener('click', () => {
        if (fields.downloadJsonBackup.disabled) return;
        updatePublishOutput();
        const link = document.createElement('a');
        link.href = fields.downloadJsonBackup.dataset.href || '#';
        link.download = fields.downloadJsonBackup.dataset.download || 'dr-lurie-draft-backup.json';
        document.body.append(link);
        link.click();
        link.remove();
      });

      ['input', 'change'].forEach((eventName) => {
        document.querySelector('#publish-form').addEventListener(eventName, (event) => {
          updatePreview();
          updatePublishOutput();
          if (event.target !== fields.overwrite) setUnsavedChanges(true);
          if (event.target === fields.overwrite) recalculateButtonState();
          else queuePublishedArticleStatusCheck();
        });
      });

      addScopedEventListener(window, 'pagehide', sendWorkflowCheckinOnUnload);
      addScopedEventListener(window, 'beforeunload', (event) => {
        if (!hasUnsavedChanges) {
          sendWorkflowCheckinOnUnload();
          return;
        }

        event.preventDefault();
        event.returnValue = '';
      });
      cleanupCallbacks.push(() => {
        if (workflowLockRefreshTimer) window.clearTimeout(workflowLockRefreshTimer);
        workflowLockRefreshTimer = undefined;
        if (toastTimer) window.clearTimeout(toastTimer);
        toastTimer = undefined;
        if (articleStatusDebounceTimer) window.clearTimeout(articleStatusDebounceTimer);
        artifactPreviewUrlCache.forEach((url) => URL.revokeObjectURL(url));
        artifactPreviewUrlCache.clear();
      });

      releaseStoredWorkflowLockOnLoad();
      lastLoadedJsonImportValue = fields.jsonImport.value.trim();
      updateJsonImportButtonState();
      renderImageRulesHint();
      if (!fields.publishDate.value) fields.publishDate.value = formatDateTimeLocal(new Date());
      setEditorModeCopy(isEditMode() ? 'edit' : 'publish');
      if (!isEditMode() && !getQueryDraftId()) localStorage.removeItem(draftKey);
      recalculateButtonState();
      updatePreview();
      updatePublishOutput();
      setUnsavedChanges(false);
      initializeClerkAuth();
    };

    if (!publishPageState.listenerRegistered) {
      publishPageState.listenerRegistered = true;
      document.addEventListener('astro:page-load', initializeAdminPublishPage);
    }

    initializeAdminPublishPage();
  })();
</script>
