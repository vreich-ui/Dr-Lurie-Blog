---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const metadata = {
  title: pageTitle,
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <section class="admin-page mx-auto max-w-[900px] px-4 py-8 sm:px-6 sm:py-12" data-admin-shell hidden>
    <header class="admin-top-bar">
      <div>
        <p class="admin-kicker">Article Editor</p>
        <h1 class="admin-top-bar-title">{pageTitle}</h1>
      </div>
      <div class="top-bar-actions">
        <button id="btn-all-drafts" class="btn-secondary btn-sm" type="button">All drafts</button>
      </div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <div class="publish-workspace" data-auth-gated>
      <AdminNav activePath="/admin/publish" />

      <!-- ── Lock status bar ─────────────────────────────────── -->
      <div id="lock-bar" class="lock-bar" hidden>
        <span id="lock-icon" aria-hidden="true"></span>
        <span id="lock-label" class="lock-label"></span>
        <button id="btn-force-release" class="btn-tertiary btn-xs" type="button" hidden>Force release</button>
        <button id="btn-done-editing" class="btn-secondary btn-xs" type="button" hidden>Done editing</button>
      </div>

      <!-- ── No-draft state ──────────────────────────────────── -->
      <div id="no-draft" class="admin-card text-center py-10" hidden>
        <p class="text-lg font-bold mb-2">No draft selected</p>
        <p class="text-sm text-muted mb-6">Open a draft from the list to start editing.</p>
        <button id="btn-open-draft-list" class="btn-primary" type="button">Open draft list</button>
      </div>

      <!-- ── Loading state ──────────────────────────────────── -->
      <p id="load-status" class="load-status" aria-live="polite" hidden></p>

      <!-- ── Article workspace (shown once a draft is loaded) ── -->
      <div id="article-workspace" hidden>
        <!-- ── 1. Admin setup module ─────────────────────────── -->
        <section id="meta-editor" class="admin-setup-module" aria-label="Article setup">
          <p class="setup-module-label">Article setup</p>
          <div class="setup-grid">
            <!-- Author -->
            <div class="field">
              <label for="pub-author" class="field-label">Author</label>
              <input id="pub-author" name="author" type="text" autocomplete="off" placeholder="Dr. Lurie" />
            </div>
            <!-- Publish date -->
            <div class="field">
              <label for="pub-date" class="field-label">Publish date</label>
              <input id="pub-date" name="publishDate" type="date" />
            </div>
            <!-- Category -->
            <div class="field">
              <label for="pub-category" class="field-label">Category</label>
              <input id="pub-category" name="category" type="text" autocomplete="off" />
            </div>
            <!-- Tags -->
            <div class="field">
              <label for="pub-tags" class="field-label">Tags</label>
              <input id="pub-tags" name="tags" type="text" autocomplete="off" placeholder="comma-separated" />
            </div>
            <!-- SEO description (full width) -->
            <div class="field field-full">
              <label for="pub-seo" class="field-label">
                SEO description <span class="char-counter" id="seo-char-count"></span>
              </label>
              <input id="pub-seo" name="seoDescription" type="text" maxlength="180" autocomplete="off" />
            </div>
            <!-- Generated article path (read-only, full width) -->
            <div class="field field-full">
              <label for="pub-article-path" class="field-label"
                >Article path <span class="field-label-hint">— generated, read-only</span></label
              >
              <input
                id="pub-article-path"
                name="articlePath"
                type="text"
                readonly
                class="article-path-field"
                tabindex="-1"
                aria-readonly="true"
                placeholder="Enter a title to generate path…"
              />
            </div>
          </div>
          <!-- Module action -->
          <div class="meta-actions">
            <button id="btn-save-meta" class="btn-secondary btn-sm" type="button">Save metadata</button>
            <p id="meta-status" class="meta-status" aria-live="polite"></p>
          </div>
        </section>

        <!-- ── 2. Readiness strip ────────────────────────────── -->
        <div id="readiness-strip" class="readiness-strip">
          <div class="readiness-strip-main">
            <span id="readiness-label" class="readiness-pill" aria-live="polite"></span>
            <button id="readiness-toggle" class="readiness-toggle btn-link" type="button" aria-expanded="false">
              Details
            </button>
            <span class="strip-spacer"></span>
            <button id="btn-publish" class="btn-primary btn-sm" type="button" disabled>Mark as published</button>
          </div>
          <div id="readiness-audit" class="readiness-audit" hidden>
            <div id="readiness-groups" class="readiness-groups"></div>
          </div>
          <p id="publish-status" class="publish-status" aria-live="polite"></p>
        </div>

        <!-- ── 3. Article header (title + excerpt) ──────────── -->
        <section class="admin-card article-header-card" aria-label="Article title and excerpt">
          <!-- Title — textarea for wrapping long titles -->
          <div class="field">
            <label for="pub-title" class="field-label">Title</label>
            <textarea
              id="pub-title"
              name="title"
              rows="2"
              class="article-title-input"
              placeholder="Article title…"
              autocomplete="off"
              spellcheck="true"></textarea>
            <p class="field-error" id="err-title" role="alert" hidden></p>
          </div>

          <!-- Excerpt -->
          <div class="field">
            <label for="pub-excerpt" class="field-label">Excerpt / deck</label>
            <textarea
              id="pub-excerpt"
              name="excerpt"
              rows="2"
              maxlength="300"
              class="article-excerpt-input"
              placeholder="Short excerpt shown in listings…"></textarea>
            <p class="field-error" id="err-excerpt" role="alert" hidden></p>
          </div>
        </section>

        <!-- ── 4. Article body (read mode + per-block editing) ── -->
        <article id="article-view" class="article-view">
          <div id="nodes-container" class="nodes-container editorial-prose"></div>
        </article>
      </div><!-- /article-workspace -->
    </div>
  </section>

  <!-- ── Draft picker modal ────────────────────────────────────────────────── -->
  <div id="draft-picker-modal" class="modal-backdrop" aria-hidden="true">
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="draft-picker-title">
      <div class="modal-header">
        <h2 id="draft-picker-title" class="modal-title">Open JSON draft</h2>
        <button id="btn-modal-close" class="modal-close-btn" type="button" aria-label="Close draft picker">✕</button>
      </div>
      <p class="modal-helper">Choose a JSON workflow record from Netlify Blobs.</p>
      <div class="modal-toolbar">
        <input
          id="draft-picker-search"
          type="search"
          class="modal-search"
          placeholder="Filter by title, author, or ID…"
          autocomplete="off"
        />
        <button id="btn-modal-refresh" class="btn-secondary btn-sm" type="button">Refresh</button>
      </div>
      <p id="modal-status" class="modal-status" aria-live="polite" role="status"></p>
      <div id="draft-picker-list" class="draft-picker-list"></div>
      <div id="draft-picker-empty" class="draft-picker-empty" hidden>
        <p>No JSON drafts found.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .admin-page {
    color: var(--aw-color-text-default);
  }

  .admin-top-bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(229 231 235);
  }
  :global(.dark) .admin-top-bar {
    border-color: rgb(30 41 59);
  }

  .admin-kicker {
    margin: 0 0 0.25rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .admin-top-bar-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .top-bar-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
  }

  .auth-status {
    margin: -0.5rem 0 1rem;
    color: var(--aw-color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .publish-workspace {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Lock bar */
  .lock-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    background: rgb(245 158 11 / 8%);
    border: 1px solid rgb(245 158 11 / 30%);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .lock-bar[data-locked-by-agent] {
    background: rgb(239 68 68 / 6%);
    border-color: rgb(239 68 68 / 30%);
    color: rgb(185 28 28);
  }
  :global(.dark) .lock-bar[data-locked-by-agent] {
    color: rgb(252 165 165);
  }
  .lock-bar[data-held] {
    background: rgb(16 185 129 / 6%);
    border-color: rgb(16 185 129 / 30%);
    color: rgb(6 95 70);
  }
  :global(.dark) .lock-bar[data-held] {
    color: rgb(110 231 183);
  }
  .lock-label {
    flex: 1;
  }

  /* Load status */
  .load-status {
    padding: 2rem;
    text-align: center;
    color: var(--aw-color-text-muted);
    font-weight: 700;
  }

  /* ── Admin card base ────────────────────────────────────────────────────────── */
  .admin-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.9);
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgb(15 23 42 / 4%);
  }
  :global(.dark) .admin-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.7);
  }

  /* ── Admin setup module ─────────────────────────────────────────────────────── */
  .admin-setup-module {
    border: 1px solid rgb(229 231 235 / 80%);
    border-radius: 1rem;
    background: rgb(249 250 251 / 0.7);
    padding: 0.9rem 1.1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  :global(.dark) .admin-setup-module {
    border-color: rgb(30 41 59 / 70%);
    background: rgb(15 23 42 / 0.35);
  }

  .setup-module-label {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
    opacity: 0.7;
  }

  .setup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem 0.75rem;
  }
  .field-full {
    grid-column: 1 / -1;
  }
  @media (max-width: 540px) {
    .setup-grid {
      grid-template-columns: 1fr;
    }
    .field-full {
      grid-column: 1;
    }
  }

  /* ── Fields ─────────────────────────────────────────────────────────────────── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .field-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .field-label-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.68rem;
    opacity: 0.7;
  }

  .char-counter {
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--aw-color-text-muted);
    letter-spacing: 0;
    text-transform: none;
    float: right;
  }

  .field-error {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(239 68 68);
  }
  :global(.dark) .field-error {
    color: rgb(252 165 165);
  }

  /* Setup module inputs — consistent compact style */
  .admin-setup-module input:not(.article-path-field),
  .admin-setup-module input[type='date'] {
    border: 1px solid rgb(209 213 219);
    border-radius: 0.4rem;
    padding: 0.35rem 0.55rem;
    font-size: 0.83rem;
    background: white;
    color: inherit;
    width: 100%;
    line-height: 1.4;
  }
  .admin-setup-module input:focus {
    outline: none;
    border-color: var(--aw-color-accent);
    box-shadow: 0 0 0 2px rgb(94 140 138 / 15%);
  }
  :global(.dark) .admin-setup-module input:not(.article-path-field),
  :global(.dark) .admin-setup-module input[type='date'] {
    border-color: rgb(51 65 85);
    background: rgb(15 23 42 / 0.5);
  }

  /* Generated article path — read-only, monospace, greyed */
  .article-path-field {
    border: 1px solid rgb(209 213 219);
    border-radius: 0.4rem;
    padding: 0.35rem 0.55rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    background: rgb(248 250 252);
    color: var(--aw-color-text-muted);
    cursor: default;
    width: 100%;
    user-select: all;
  }
  :global(.dark) .article-path-field {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.3);
    color: rgb(100 116 139);
  }

  .meta-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }

  .meta-status {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    min-height: 1.2em;
  }
  .meta-status.is-error {
    color: rgb(239 68 68);
  }
  .meta-status.is-ok {
    color: rgb(22 163 74);
  }

  /* ── Readiness strip ─────────────────────────────────────────────────────────── */
  .readiness-strip {
    border: 1px solid rgb(229 231 235);
    border-radius: 0.75rem;
    padding: 0.55rem 0.9rem;
    background: transparent;
    font-size: 0.83rem;
  }
  :global(.dark) .readiness-strip {
    border-color: rgb(30 41 59);
  }

  .readiness-strip-main {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .strip-spacer {
    flex: 1;
  }

  .readiness-toggle {
    font-size: 0.73rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    line-height: 1;
  }
  .readiness-toggle:hover {
    color: var(--aw-color-text-default);
  }

  .readiness-audit {
    margin-top: 0.65rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgb(229 231 235);
  }
  :global(.dark) .readiness-audit {
    border-top-color: rgb(30 41 59);
  }

  .readiness-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 900;
  }
  .readiness-pill.is-missing {
    background: rgb(239 68 68 / 10%);
    color: rgb(185 28 28);
  }
  :global(.dark) .readiness-pill.is-missing {
    color: rgb(252 165 165);
  }
  .readiness-pill.is-warning {
    background: rgb(245 158 11 / 12%);
    color: rgb(146 64 14);
  }
  :global(.dark) .readiness-pill.is-warning {
    color: rgb(253 230 138);
  }
  .readiness-pill.is-ready {
    background: rgb(34 197 94 / 12%);
    color: rgb(22 101 52);
  }
  :global(.dark) .readiness-pill.is-ready {
    color: rgb(187 247 208);
  }

  .readiness-groups {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.readiness-group) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.readiness-group-label) {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--aw-color-text-muted);
    margin: 0;
  }

  :global(.readiness-criteria-list) {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  :global(.readiness-criterion) {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  :global(.criterion-pill) {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 900;
    width: 1em;
    text-align: center;
  }
  :global(.criterion-pill.complete) {
    color: rgb(22 163 74);
  }
  :global(.criterion-pill.warning) {
    color: rgb(217 119 6);
  }
  :global(.criterion-pill.missing) {
    color: rgb(220 38 38);
  }
  :global(.criterion-pill.optional) {
    color: var(--aw-color-text-muted);
  }

  :global(.criterion-text) {
    font-weight: 600;
  }
  :global(.criterion-message) {
    color: var(--aw-color-text-muted);
    font-size: 0.73rem;
  }
  :global(.criterion-message::before) {
    content: '— ';
  }

  .publish-status {
    min-height: 1.2em;
    font-size: 0.82rem;
    font-weight: 700;
    margin-top: 0.4rem;
  }
  .publish-status.is-error {
    color: rgb(220 38 38);
  }
  .publish-status.is-ok {
    color: rgb(22 163 74);
  }

  /* ── Article header card (title + excerpt) ───────────────────────────────────── */
  .article-header-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 1.75rem;
  }

  /* Title: textarea with article-heading visual style */
  .article-title-input {
    font-family: var(--aw-font-heading, inherit);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--aw-color-text-heading);
    padding: 0.1rem 0;
    width: 100%;
    resize: none;
    overflow: hidden;
    display: block;
    /* Ensure at least one line is visible before JS auto-resize runs */
    min-height: 3rem;
  }
  .article-title-input:focus {
    outline: none;
    border-bottom-color: var(--aw-color-accent);
  }
  .article-title-input::placeholder {
    color: var(--aw-color-text-muted);
    font-weight: 400;
    font-size: 1.5rem;
    opacity: 0.55;
  }

  /* Excerpt styled as article deck */
  .article-excerpt-input {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--aw-color-text-muted);
    border: none;
    border-bottom: 1px solid transparent;
    background: transparent;
    padding: 0.1rem 0;
    width: 100%;
    resize: none;
    line-height: 1.55;
  }
  .article-excerpt-input:focus {
    outline: none;
    border-bottom-color: var(--aw-color-accent);
  }
  .article-excerpt-input::placeholder {
    color: var(--aw-color-text-muted);
    opacity: 0.55;
  }

  /* ── Article body ─────────────────────────────────────────────────────────── */
  .article-view {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .nodes-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Node wrapper */
  :global(.dl-node-wrapper) {
    position: relative;
    border-radius: 0.75rem;
    transition: box-shadow 0.15s;
  }
  :global(.dl-node-wrapper:hover) {
    box-shadow: 0 0 0 2px rgb(94 140 138 / 25%);
  }
  :global(.dl-node-wrapper[data-editing]) {
    box-shadow: 0 0 0 2px var(--aw-color-accent);
  }

  /* Node toolbar — pill-shaped, site-styled */
  :global(.dl-node-toolbar) {
    position: absolute;
    top: 0.4rem;
    right: 0.4rem;
    display: flex;
    gap: 0.25rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }
  :global(.dl-node-wrapper:hover .dl-node-toolbar),
  :global(.dl-node-wrapper[data-editing] .dl-node-toolbar) {
    opacity: 1;
    pointer-events: auto;
  }
  :global(.dl-node-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgb(209 213 219);
    background: rgb(255 255 255 / 0.97);
    color: var(--aw-color-text-heading);
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 1px 3px rgb(0 0 0 / 8%);
    transition:
      background 0.1s,
      border-color 0.1s,
      color 0.1s;
    line-height: 1.2;
    white-space: nowrap;
  }
  :global(.dark) :global(.dl-node-btn) {
    background: rgb(30 41 59 / 0.97);
    border-color: rgb(51 65 85);
    color: inherit;
  }
  :global(.dl-node-btn:hover) {
    background: rgb(94 140 138 / 12%);
    border-color: rgb(94 140 138 / 50%);
  }
  :global(.dl-node-btn.is-ai:hover) {
    background: rgb(124 58 237 / 10%);
    border-color: rgb(124 58 237 / 45%);
    color: rgb(109 40 217);
  }
  :global(.dark) :global(.dl-node-btn.is-ai:hover) {
    color: rgb(192 132 252);
  }

  /* TipTap editor chrome */
  :global(.dl-node-editor) {
    margin: -0.25rem;
  }
  :global(.dl-editor-content .ProseMirror) {
    outline: none;
  }
  :global(.dl-editor-content .ProseMirror p) {
    margin: 0 0 0.75em;
  }
  :global(.dl-editor-content .ProseMirror h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.5em;
  }
  :global(.dl-editor-content .ProseMirror h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.5em;
  }
  :global(.dl-editor-content .ProseMirror a) {
    text-decoration: underline;
    color: var(--aw-color-accent);
  }

  /* Buttons */
  .btn-primary,
  .btn-secondary,
  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary {
    padding: 0.72rem 1.25rem;
    border: 1px solid rgb(94 140 138 / 55%);
    background: rgb(94 140 138 / 18%);
    color: var(--aw-color-text-heading);
  }
  .btn-secondary {
    padding: 0.72rem 1.25rem;
    border: 1px solid rgb(209 213 219);
    color: var(--aw-color-text-heading);
    background: transparent;
  }
  .btn-tertiary {
    padding: 0.3rem 0.65rem;
    border: 1px solid rgb(209 213 219);
    color: var(--aw-color-text-muted);
    background: transparent;
    font-size: 0.8rem;
  }
  .btn-link {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: inherit;
  }
  .btn-sm {
    padding: 0.45rem 0.9rem;
    font-size: 0.85rem;
  }
  .btn-xs {
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
  }
  button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .text-center {
    text-align: center;
  }
  .py-10 {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }
  .text-lg {
    font-size: 1.125rem;
  }
  .font-bold {
    font-weight: 700;
  }
  .mb-2 {
    margin-bottom: 0.5rem;
  }
  .text-sm {
    font-size: 0.875rem;
  }
  .text-muted {
    color: var(--aw-color-text-muted);
  }
  .mb-6 {
    margin-bottom: 1.5rem;
  }

  /* ── Draft picker modal ────────────────────────────────────────────────── */
  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding: 1.5rem;
    background: rgb(15 23 42 / 55%);
    overflow-y: auto;
  }
  .modal-backdrop.is-open {
    display: flex;
  }
  :global(.dark) .modal-backdrop {
    background: rgb(0 0 0 / 70%);
  }

  .modal-dialog {
    position: relative;
    width: 100%;
    max-width: 720px;
    margin-top: 2rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255);
    padding: 1.5rem;
    box-shadow: 0 8px 32px rgb(15 23 42 / 18%);
  }
  :global(.dark) .modal-dialog {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .modal-title {
    font-size: 1.15rem;
    font-weight: 800;
    margin: 0;
  }

  .modal-close-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--aw-color-text-muted);
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.1s;
  }
  .modal-close-btn:hover {
    background: rgb(229 231 235);
  }
  :global(.dark) .modal-close-btn:hover {
    background: rgb(30 41 59);
  }

  .modal-helper {
    margin: 0 0 1rem;
    color: var(--aw-color-text-muted);
    font-size: 0.88rem;
  }

  .modal-toolbar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .modal-search {
    flex: 1;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.5rem;
    padding: 0.45rem 0.65rem;
    font-size: 0.9rem;
    background: white;
    color: inherit;
  }
  :global(.dark) .modal-search {
    border-color: rgb(51 65 85);
    background: rgb(15 23 42 / 0.5);
  }

  .modal-status {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--aw-color-text-muted);
    min-height: 1.4em;
  }

  .draft-picker-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 420px;
    overflow-y: auto;
  }

  :global(.dp-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 0.75rem;
    background: rgb(249 250 251);
  }
  :global(.dark) :global(.dp-row) {
    border-color: rgb(30 41 59);
    background: rgb(30 41 59 / 0.5);
  }
  :global(.dp-row:hover) {
    border-color: rgb(94 140 138 / 40%);
  }

  :global(.dp-row-main) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  :global(.dp-title) {
    font-weight: 700;
    font-size: 0.9rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  :global(.dp-meta) {
    color: var(--aw-color-text-muted);
    font-size: 0.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem;
    align-items: center;
  }

  :global(.dp-slug) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  :global(.dp-sep) {
    opacity: 0.4;
  }

  :global(.dp-badge) {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
    font-size: 0.73rem;
    font-weight: 900;
    align-self: flex-start;
    margin-top: 0.15rem;
  }
  :global(.dp-badge.is-ready) {
    background: rgb(34 197 94 / 12%);
    color: rgb(22 101 52);
  }
  :global(.dp-badge.is-draft) {
    background: rgb(245 158 11 / 14%);
    color: rgb(146 64 14);
  }
  :global(.dark .dp-badge.is-ready) {
    color: rgb(187 247 208);
  }
  :global(.dark .dp-badge.is-draft) {
    color: rgb(253 230 138);
  }

  :global(.dp-load-btn) {
    flex-shrink: 0;
  }

  .draft-picker-empty {
    padding: 2rem;
    text-align: center;
    color: var(--aw-color-text-muted);
    font-size: 0.9rem;
  }
</style>

<script>
  import { currentUser, getAccessToken, handleOAuthCallback } from '~/utils/goTrueClient';
  import { LockManager } from '~/lib/admin/lock-manager';
  import { renderNode, wrapNode } from '~/lib/admin/node-renderer';
  import { NodeEditor } from '~/lib/admin/node-editor';
  import { askAiForNode, renderSuggestionOverlay, showInstructionPopover } from '~/lib/admin/ai-suggestion';
  import { evaluateReadiness, readinessLevel } from '~/lib/admin/readiness-criteria';
  import { generateArticlePath } from '~/lib/admin/article-path';
  import type { ArticleBodyNode } from '~/schema/article-content-v1';
  import type { ReadinessGroup } from '~/lib/admin/readiness-criteria';

  // ─── constants ──────────────────────────────────────────────────────────────
  const DRAFT_ENDPOINT = '/.netlify/functions/admin-get-json-draft';
  const UPDATE_NODE_ENDPOINT = '/.netlify/functions/admin-update-node';
  const LIST_DRAFTS_ENDPOINT = '/.netlify/functions/admin-list-json-drafts';
  const PATCH_WORKFLOW_ENDPOINT = '/.netlify/functions/admin-patch-workflow';

  // ─── page init ──────────────────────────────────────────────────────────────
  const init = () => {
    const page = document.querySelector<HTMLElement>('.admin-page');
    if (!page || page.dataset.publishInitialized === 'true') return;
    page.dataset.publishInitialized = 'true';

    const params = new URLSearchParams(window.location.search);
    const initialDraftId = params.get('draftId') ?? params.get('requestId') ?? '';

    type DraftSummary = {
      id: string;
      title: string;
      slug: string;
      author: string;
      updatedAt: string;
      savedAt: string;
      savedBy: string;
      recordStatus: string;
      lifecycleStatus?: string;
      readiness: { isReady: boolean; missing: string[]; ready: number; total: number };
    };

    // DOM refs
    const els = {
      authStatus: document.querySelector<HTMLElement>('[data-auth-status]'),
      gated: Array.from(document.querySelectorAll<HTMLElement>('[data-auth-gated]')),
      lockBar: document.querySelector<HTMLElement>('#lock-bar')!,
      lockIcon: document.querySelector<HTMLElement>('#lock-icon')!,
      lockLabel: document.querySelector<HTMLElement>('#lock-label')!,
      btnForceRelease: document.querySelector<HTMLButtonElement>('#btn-force-release')!,
      btnDoneEditing: document.querySelector<HTMLButtonElement>('#btn-done-editing')!,
      noDraft: document.querySelector<HTMLElement>('#no-draft')!,
      loadStatus: document.querySelector<HTMLElement>('#load-status')!,
      articleWorkspace: document.querySelector<HTMLElement>('#article-workspace')!,
      nodesContainer: document.querySelector<HTMLElement>('#nodes-container')!,
      // Setup / metadata fields
      pubAuthor: document.querySelector<HTMLInputElement>('#pub-author')!,
      pubDate: document.querySelector<HTMLInputElement>('#pub-date')!,
      pubCategory: document.querySelector<HTMLInputElement>('#pub-category')!,
      pubTags: document.querySelector<HTMLInputElement>('#pub-tags')!,
      pubSeo: document.querySelector<HTMLInputElement>('#pub-seo')!,
      pubArticlePath: document.querySelector<HTMLInputElement>('#pub-article-path')!,
      seoCharCount: document.querySelector<HTMLElement>('#seo-char-count')!,
      btnSaveMeta: document.querySelector<HTMLButtonElement>('#btn-save-meta')!,
      metaStatus: document.querySelector<HTMLElement>('#meta-status')!,
      // Article header fields
      pubTitle: document.querySelector<HTMLTextAreaElement>('#pub-title')!,
      pubExcerpt: document.querySelector<HTMLTextAreaElement>('#pub-excerpt')!,
      errTitle: document.querySelector<HTMLElement>('#err-title')!,
      errExcerpt: document.querySelector<HTMLElement>('#err-excerpt')!,
      // Readiness strip
      readinessLabel: document.querySelector<HTMLElement>('#readiness-label')!,
      readinessToggle: document.querySelector<HTMLButtonElement>('#readiness-toggle')!,
      readinessAudit: document.querySelector<HTMLElement>('#readiness-audit')!,
      readinessGroups: document.querySelector<HTMLElement>('#readiness-groups')!,
      btnPublish: document.querySelector<HTMLButtonElement>('#btn-publish')!,
      publishStatus: document.querySelector<HTMLElement>('#publish-status')!,
      // Modal
      modal: document.querySelector<HTMLElement>('#draft-picker-modal')!,
      btnModalClose: document.querySelector<HTMLButtonElement>('#btn-modal-close')!,
      btnModalRefresh: document.querySelector<HTMLButtonElement>('#btn-modal-refresh')!,
      modalStatus: document.querySelector<HTMLElement>('#modal-status')!,
      modalSearch: document.querySelector<HTMLInputElement>('#draft-picker-search')!,
      draftPickerList: document.querySelector<HTMLElement>('#draft-picker-list')!,
      draftPickerEmpty: document.querySelector<HTMLElement>('#draft-picker-empty')!,
      btnAllDrafts: document.querySelector<HTMLButtonElement>('#btn-all-drafts')!,
      btnOpenDraftList: document.querySelector<HTMLButtonElement>('#btn-open-draft-list')!,
    };

    // ── State ──────────────────────────────────────────────────────────────────
    let lockManager: LockManager | null = null;
    let activeEditor: NodeEditor | null = null;
    let activeNodeWrapper: HTMLElement | null = null;
    let currentNodes: ArticleBodyNode[] = [];
    let currentRequestId = initialDraftId;
    let currentRecordVersion = 0;
    let metadataSaved = false;
    let modalDraftsCache: DraftSummary[] | null = null;
    let allDraftRows: DraftSummary[] = [];

    const getToken = async (): Promise<string> => {
      const token = await getAccessToken();
      if (!token) throw new Error('Not authenticated');
      return token;
    };

    // ── Auth shell ────────────────────────────────────────────────────────────
    const setAuthStatus = (msg: string) => {
      if (els.authStatus) els.authStatus.textContent = msg;
    };
    const setGated = (visible: boolean) =>
      els.gated.forEach((el) => {
        el.hidden = !visible;
      });
    const setPageVisible = (visible: boolean) => {
      if (page) page.hidden = !visible;
    };

    const authState = (state: 'checking' | 'signed-out' | 'forbidden' | 'error' | 'signed-in') => {
      const msgs: Record<string, string> = {
        checking: 'Checking admin access…',
        'signed-out': 'Sign in to view admin tools.',
        forbidden: 'Access denied.',
        error: 'Auth failed. Refresh or contact support.',
        'signed-in': '',
      };
      setAuthStatus(msgs[state] ?? '');
      setPageVisible(state === 'signed-in');
      setGated(state === 'signed-in');
      if (!['checking', 'signed-in'].includes(state)) window.location.replace('/');
    };

    // ── Title textarea auto-resize ─────────────────────────────────────────────
    const autoResize = (el: HTMLTextAreaElement) => {
      el.style.height = 'auto';
      el.style.height = `${el.scrollHeight}px`;
    };
    // Size on first paint (handles any pre-filled value; min-height CSS handles empty state)
    autoResize(els.pubTitle);

    // ── Lock bar ──────────────────────────────────────────────────────────────
    const updateLockBar = (state: {
      held: boolean;
      agentLock?: { owner_label: string; expires_at: string };
      lockToken?: string;
      expires_at?: string;
    }) => {
      els.lockBar.hidden = false;
      delete els.lockBar.dataset.lockedByAgent;
      delete els.lockBar.dataset.held;

      if (state.held) {
        els.lockBar.dataset.held = 'true';
        els.lockIcon.textContent = '🔓';
        els.lockLabel.textContent = 'You hold the edit lock';
        els.btnDoneEditing.hidden = false;
        els.btnForceRelease.hidden = true;
      } else if (state.agentLock) {
        els.lockBar.dataset.lockedByAgent = 'true';
        els.lockIcon.textContent = '🔒';
        const exp = new Date(state.agentLock.expires_at);
        const expStr = Number.isFinite(exp.getTime()) ? `expires ${exp.toLocaleTimeString()}` : 'expiry unknown';
        els.lockLabel.textContent = `Agent editing: ${state.agentLock.owner_label} (${expStr})`;
        els.btnDoneEditing.hidden = true;
        els.btnForceRelease.hidden = false;
      } else {
        els.lockIcon.textContent = '✏️';
        els.lockLabel.textContent = 'Click any block to start editing';
        els.btnDoneEditing.hidden = true;
        els.btnForceRelease.hidden = true;
      }

      updateReadinessPanel(Boolean(state.agentLock));
    };

    const resetLockBar = () => {
      els.lockBar.hidden = true;
      delete els.lockBar.dataset.held;
      delete els.lockBar.dataset.lockedByAgent;
      els.lockIcon.textContent = '';
      els.lockLabel.textContent = '';
      els.btnDoneEditing.hidden = true;
      els.btnForceRelease.hidden = true;
    };

    // ── Lock actions ──────────────────────────────────────────────────────────
    const acquireLock = async (): Promise<boolean> => {
      if (!lockManager) return false;
      const token = await lockManager.checkout();
      return token !== null;
    };

    els.btnDoneEditing.addEventListener('click', async () => {
      closeActiveEditor(false);
      if (lockManager) await lockManager.checkin();
    });

    els.btnForceRelease.addEventListener('click', async () => {
      if (!lockManager) return;
      if (!confirm('Force-release the agent lock? The agent may be mid-edit.')) return;
      await lockManager.forceRelease();
    });

    // ── Readiness strip ───────────────────────────────────────────────────────
    els.readinessToggle.addEventListener('click', () => {
      const expanded = els.readinessAudit.hidden === false;
      els.readinessAudit.hidden = expanded;
      els.readinessToggle.textContent = expanded ? 'Details' : 'Hide details';
      els.readinessToggle.setAttribute('aria-expanded', String(!expanded));
    });

    const updateReadinessPanel = (agentLockPresent = false) => {
      const tags = els.pubTags.value
        .split(',')
        .map((t) => t.trim())
        .filter(Boolean);

      const groups = evaluateReadiness({
        title: els.pubTitle.value.trim(),
        excerpt: els.pubExcerpt.value.trim(),
        author: els.pubAuthor.value.trim(),
        publishDate: els.pubDate.value.trim(),
        articlePath: els.pubArticlePath.value.trim(),
        seoDescription: els.pubSeo.value.trim(),
        category: els.pubCategory.value.trim(),
        tags,
        nodes: currentNodes,
        lockHeld: Boolean(lockManager?.currentToken),
        canonicalSaved: metadataSaved,
        agentLockPresent,
      });

      renderReadinessGroups(groups);

      const level = readinessLevel(groups);
      const levelMap = {
        missing: { label: 'Review needed', cls: 'is-missing' },
        warning: { label: 'Nearly ready', cls: 'is-warning' },
        ready: { label: 'Ready to publish', cls: 'is-ready' },
      };
      const { label, cls } = levelMap[level];
      els.readinessLabel.textContent = label;
      els.readinessLabel.className = `readiness-pill ${cls}`;

      const missingCount = groups.flatMap((g) => g.criteria).filter((c) => c.status === 'missing').length;
      els.btnPublish.disabled = missingCount > 0;
    };

    const renderReadinessGroups = (groups: ReadinessGroup[]) => {
      els.readinessGroups.innerHTML = '';

      for (const group of groups) {
        const groupEl = document.createElement('div');
        groupEl.className = 'readiness-group';

        const groupLabel = document.createElement('p');
        groupLabel.className = 'readiness-group-label';
        groupLabel.textContent = group.label;
        groupEl.append(groupLabel);

        const ul = document.createElement('ul');
        ul.className = 'readiness-criteria-list';

        for (const criterion of group.criteria) {
          const li = document.createElement('li');
          li.className = 'readiness-criterion';

          const icons: Record<string, string> = { complete: '✓', warning: '⚠', missing: '✗', optional: '○' };
          const pill = document.createElement('span');
          pill.className = `criterion-pill ${criterion.status}`;
          pill.textContent = icons[criterion.status] ?? '○';
          pill.setAttribute('aria-label', criterion.status);

          const text = document.createElement('span');
          text.className = 'criterion-text';
          text.textContent = criterion.label;

          li.append(pill, text);

          if (criterion.message) {
            const msg = document.createElement('span');
            msg.className = 'criterion-message';
            msg.textContent = criterion.message;
            li.append(msg);
          }

          ul.append(li);
        }

        groupEl.append(ul);
        els.readinessGroups.append(groupEl);
      }
    };

    // ── Field validation helpers ──────────────────────────────────────────────
    const showFieldError = (el: HTMLElement, msg: string) => {
      el.textContent = msg;
      el.hidden = false;
    };
    const clearFieldError = (el: HTMLElement) => {
      el.textContent = '';
      el.hidden = true;
    };

    const setMetaStatus = (msg: string, kind: '' | 'is-error' | 'is-ok' = '') => {
      els.metaStatus.textContent = msg;
      els.metaStatus.className = `meta-status${kind ? ' ' + kind : ''}`;
    };

    // SEO character counter
    const updateSeoCharCount = () => {
      const len = els.pubSeo.value.length;
      els.seoCharCount.textContent = `${len}/180`;
    };
    els.pubSeo.addEventListener('input', updateSeoCharCount);

    // Article path: regenerated live from title + requestId
    const refreshArticlePath = () => {
      const title = els.pubTitle.value.trim();
      els.pubArticlePath.value = title ? generateArticlePath(title, currentRequestId) : '';
    };

    // Live readiness re-evaluation on any metadata change
    const setupFields: (HTMLInputElement | HTMLTextAreaElement)[] = [
      els.pubTitle,
      els.pubExcerpt,
      els.pubAuthor,
      els.pubDate,
      els.pubCategory,
      els.pubTags,
      els.pubSeo,
    ];
    for (const field of setupFields) {
      field.addEventListener('input', () => {
        if (field === els.pubTitle) {
          clearFieldError(els.errTitle);
          autoResize(els.pubTitle);
          refreshArticlePath();
        }
        if (field === els.pubExcerpt) {
          clearFieldError(els.errExcerpt);
        }
        if (metadataSaved) {
          metadataSaved = false;
          setMetaStatus('Unsaved changes');
        }
        updateReadinessPanel();
      });
    }

    // ── Save metadata ─────────────────────────────────────────────────────────
    const saveMetadata = async () => {
      clearFieldError(els.errTitle);
      clearFieldError(els.errExcerpt);

      const title = els.pubTitle.value.trim();
      const articlePath = els.pubArticlePath.value.trim();

      let hasErrors = false;
      if (!title) {
        showFieldError(els.errTitle, 'Title is required before saving.');
        hasErrors = true;
      }
      if (hasErrors) return;

      if (!lockManager?.currentToken) {
        const acquired = await acquireLock();
        if (!acquired) {
          setMetaStatus('Could not acquire edit lock.', 'is-error');
          return;
        }
      }

      const lockToken = lockManager?.currentToken;
      if (!lockToken) {
        setMetaStatus('Edit lock not held.', 'is-error');
        return;
      }

      let token: string;
      try {
        token = await getToken();
      } catch {
        setMetaStatus('Authentication error.', 'is-error');
        return;
      }

      els.btnSaveMeta.disabled = true;
      setMetaStatus('Saving…');

      const tags = els.pubTags.value
        .split(',')
        .map((t) => t.trim())
        .filter(Boolean);

      // Derive the slug from the generated path for backward compatibility
      const derivedSlug = articlePath ? articlePath.replace('src/data/post/', '').replace('.md', '') : '';

      const publishPayload: Record<string, unknown> = { title };
      if (derivedSlug) publishPayload.slug = derivedSlug;
      if (articlePath) publishPayload.articlePath = articlePath;

      const excerpt = els.pubExcerpt.value.trim();
      if (excerpt) publishPayload.excerpt = excerpt;

      const author = els.pubAuthor.value.trim();
      if (author) publishPayload.author = author;

      const publishDate = els.pubDate.value.trim();
      if (publishDate) publishPayload.publishDate = publishDate;

      const seoDesc = els.pubSeo.value.trim();
      if (seoDesc) publishPayload.seoDescription = seoDesc;

      const category = els.pubCategory.value.trim();
      if (category) publishPayload.category = category;

      if (tags.length) publishPayload.tags = tags;

      try {
        const res = await fetch(PATCH_WORKFLOW_ENDPOINT, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            action: 'patch_canonical_input',
            request_id: currentRequestId,
            lock_token: lockToken,
            expected_record_version: currentRecordVersion,
            promote_publish_payload: publishPayload,
          }),
        });

        const json = (await res.json().catch(() => ({ ok: false }))) as Record<string, unknown>;
        if (!res.ok || !json.ok) {
          const errMsg = typeof json.error === 'string' ? json.error : `HTTP ${res.status}`;
          setMetaStatus(`Save failed: ${errMsg}`, 'is-error');
          return;
        }

        const record = json.record as Record<string, unknown> | undefined;
        if (typeof record?.version === 'number') {
          currentRecordVersion = record.version as number;
        }

        metadataSaved = true;
        setMetaStatus('✓ Metadata saved', 'is-ok');
        updateReadinessPanel();
      } catch (err) {
        setMetaStatus(err instanceof Error ? err.message : 'Save failed.', 'is-error');
      } finally {
        els.btnSaveMeta.disabled = false;
      }
    };

    els.btnSaveMeta.addEventListener('click', saveMetadata);

    // ── Node rendering ────────────────────────────────────────────────────────
    const renderArticle = (nodes: ArticleBodyNode[]) => {
      currentNodes = nodes;
      els.nodesContainer.innerHTML = '';

      for (const node of nodes) {
        if (node.visibility && node.visibility !== 'public') continue;

        const rendered = renderNode(node);
        const wrapper = wrapNode(node, rendered);

        const toolbar = document.createElement('div');
        toolbar.className = 'dl-node-toolbar';

        const editBtn = document.createElement('button');
        editBtn.className = 'dl-node-btn';
        editBtn.title = 'Edit this block';
        editBtn.textContent = 'Edit';
        editBtn.addEventListener('click', () => onEditClick(node, wrapper));

        const aiBtn = document.createElement('button');
        aiBtn.className = 'dl-node-btn is-ai';
        aiBtn.title = 'Ask AI to revise this block';
        aiBtn.textContent = 'AI';
        aiBtn.addEventListener('click', () => onAskAiClick(node, wrapper));

        toolbar.append(editBtn, aiBtn);
        wrapper.append(toolbar);

        wrapper.addEventListener('mouseup', () => {
          if (wrapper.dataset.editing) return;
          const sel = window.getSelection();
          if (sel && sel.rangeCount > 0 && !sel.isCollapsed && wrapper.contains(sel.anchorNode)) {
            aiBtn.classList.add('ai-has-selection');
          } else {
            aiBtn.classList.remove('ai-has-selection');
          }
        });

        els.nodesContainer.append(wrapper);
      }
    };

    // ── Editor open/close ─────────────────────────────────────────────────────
    const closeActiveEditor = (save: boolean) => {
      if (!activeEditor || !activeNodeWrapper) return;
      if (!save) activeEditor.unmount();
      activeNodeWrapper.removeAttribute('data-editing');
      activeEditor = null;
      activeNodeWrapper = null;
    };

    const onEditClick = async (node: ArticleBodyNode, wrapper: HTMLElement) => {
      if (wrapper.dataset.editing) return;
      closeActiveEditor(false);

      if (!lockManager?.currentToken) {
        updateLockBar({ held: false });
        const acquired = await acquireLock();
        if (!acquired) return;
      }

      wrapper.dataset.editing = 'true';
      activeNodeWrapper = wrapper;
      activeEditor = new NodeEditor();

      activeEditor.mount(node, wrapper, {
        onSave: async (updatedFields) => {
          await saveNodeUpdate(node.id, updatedFields, wrapper, node);
          closeActiveEditor(false);
        },
        onCancel: () => closeActiveEditor(false),
      });
    };

    // ── AI ask flow ───────────────────────────────────────────────────────────
    const onAskAiClick = (node: ArticleBodyNode, wrapper: HTMLElement) => {
      if (!currentRequestId) return;

      let selectedText: string | undefined;
      if (wrapper.dataset.editing && activeEditor) {
        const sel = activeEditor.getSelectionText();
        if (sel) selectedText = sel;
      } else {
        const browserSel = window.getSelection();
        if (browserSel && !browserSel.isCollapsed && wrapper.contains(browserSel.anchorNode)) {
          selectedText = browserSel.toString().trim() || undefined;
        }
      }

      showInstructionPopover(
        wrapper,
        selectedText,
        async (instruction) => {
          const spinnerEl = Object.assign(document.createElement('div'), {
            className:
              'absolute inset-0 z-20 flex items-center justify-center rounded-xl bg-white/80 dark:bg-slate-900/80 text-sm font-bold',
            textContent: 'Asking AI…',
          });
          wrapper.style.position = 'relative';
          wrapper.append(spinnerEl);

          let token: string;
          try {
            token = await getToken();
          } catch {
            spinnerEl.remove();
            return;
          }

          const result = await askAiForNode({
            requestId: currentRequestId,
            nodeId: node.id,
            selectedText,
            instruction,
            token: token,
          });
          spinnerEl.remove();

          if (!result.ok) {
            alert(`AI request failed: ${result.error}`);
            return;
          }

          renderSuggestionOverlay(
            wrapper,
            node.public,
            result.suggestion,
            async (fields) => {
              if (!lockManager?.currentToken) {
                const acquired = await acquireLock();
                if (!acquired) {
                  alert('Could not acquire edit lock to apply suggestion.');
                  return;
                }
              }
              await saveNodeUpdate(node.id, fields, wrapper, node);
            },
            () => {}
          );
        },
        () => {}
      );
    };

    // ── Node save ─────────────────────────────────────────────────────────────
    const saveNodeUpdate = async (
      nodeId: string,
      updatedFields: Partial<ArticleBodyNode['public']>,
      wrapper: HTMLElement,
      originalNode: ArticleBodyNode
    ) => {
      const lockToken = lockManager?.currentToken;
      if (!lockToken) {
        alert('Edit lock not held. Please retry.');
        return;
      }

      let token: string;
      try {
        token = await getToken();
      } catch {
        alert('Authentication error. Please refresh.');
        return;
      }

      const res = await fetch(UPDATE_NODE_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ requestId: currentRequestId, lockToken, nodeId, updatedPublicFields: updatedFields }),
      });

      const json = (await res.json().catch(() => ({ ok: false, error: 'Parse error' }))) as Record<string, unknown>;
      if (!res.ok || !json.ok) {
        alert(`Save failed: ${typeof json.error === 'string' ? json.error : 'Unknown error'}`);
        return;
      }

      const updatedNode: ArticleBodyNode = { ...originalNode, public: { ...originalNode.public, ...updatedFields } };
      const nodeIndex = currentNodes.findIndex((n) => n.id === nodeId);
      if (nodeIndex !== -1) currentNodes[nodeIndex] = updatedNode;

      const newRendered = renderNode(updatedNode);
      const existingToolbar = wrapper.querySelector('.dl-node-toolbar');
      wrapper.innerHTML = '';
      wrapper.append(newRendered);
      if (existingToolbar) wrapper.append(existingToolbar);

      updateReadinessPanel();
    };

    // ── Reset draft view ──────────────────────────────────────────────────────
    const resetDraftView = async () => {
      closeActiveEditor(false);

      if (lockManager) {
        if (lockManager.currentToken) {
          await lockManager.checkin().catch(() => {});
        }
        lockManager = null;
      }

      resetLockBar();
      els.articleWorkspace.hidden = true;
      els.nodesContainer.innerHTML = '';
      els.btnPublish.disabled = true;
      els.loadStatus.hidden = true;
      els.loadStatus.textContent = '';
      els.noDraft.hidden = true;
      currentNodes = [];
      currentRecordVersion = 0;
      metadataSaved = false;
      els.readinessGroups.innerHTML = '';
      els.readinessLabel.textContent = '';
      els.readinessLabel.className = 'readiness-pill';
      els.publishStatus.textContent = '';
      els.readinessAudit.hidden = true;
      els.readinessToggle.textContent = 'Details';
      els.readinessToggle.setAttribute('aria-expanded', 'false');
    };

    // ── Load draft ────────────────────────────────────────────────────────────
    const loadDraft = async (requestId: string, token: string) => {
      if (!requestId) {
        els.noDraft.hidden = false;
        return;
      }

      await resetDraftView();

      currentRequestId = requestId;

      const currentParams = new URLSearchParams(window.location.search);
      const urlDraftId = currentParams.get('draftId') ?? currentParams.get('requestId') ?? '';
      const newUrl = new URL(window.location.href);
      newUrl.searchParams.set('draftId', requestId);
      newUrl.searchParams.delete('requestId');
      if (urlDraftId !== requestId) {
        history.pushState({}, '', newUrl.toString());
      } else {
        history.replaceState({}, '', newUrl.toString());
      }

      els.loadStatus.hidden = false;
      els.loadStatus.textContent = 'Loading article…';

      try {
        const res = await fetch(`${DRAFT_ENDPOINT}?draftId=${encodeURIComponent(requestId)}`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const json = (await res.json().catch(() => ({ ok: false }))) as Record<string, unknown>;
        if (!res.ok || !json.ok) {
          els.loadStatus.textContent = typeof json.error === 'string' ? json.error : `Load failed (${res.status})`;
          return;
        }

        if (typeof json.recordVersion === 'number') {
          currentRecordVersion = json.recordVersion as number;
        }

        const input = (json.input ?? {}) as Record<string, unknown>;
        const content = (input.content ?? {}) as Record<string, unknown>;
        const publication = (input.publication ?? {}) as Record<string, unknown>;
        const publishPayload = (publication.publish_payload ?? {}) as Record<string, unknown>;
        const taxonomy = (input.taxonomy ?? {}) as Record<string, unknown>;
        const seo = (input.seo ?? {}) as Record<string, unknown>;

        // Prefer publish_payload (editor's saved values) over raw input fields
        const title = String(
          publishPayload.title ??
            content.title ??
            (json.draft && (json.draft as Record<string, unknown>).title) ??
            'Untitled'
        );
        const excerpt = String(publishPayload.excerpt ?? content.deck ?? '');
        const author = String(publishPayload.author ?? content.author ?? '');
        const category = String(publishPayload.category ?? taxonomy.category ?? '');
        const tagsArr = Array.isArray(publishPayload.tags)
          ? (publishPayload.tags as string[])
          : Array.isArray(taxonomy.tags)
            ? (taxonomy.tags as string[])
            : [];
        const seoDesc = String(publishPayload.seoDescription ?? seo.meta_description ?? '');

        // Publish date: prefer saved, fall back to publication.publish_date
        const savedPublishDate = String(publishPayload.publishDate ?? publication.publish_date ?? '');
        let publishDateValue = '';
        if (savedPublishDate) {
          try {
            const d = new Date(savedPublishDate);
            if (Number.isFinite(d.getTime())) {
              publishDateValue = d.toISOString().slice(0, 10);
            }
          } catch {
            publishDateValue = '';
          }
        }

        // Article path: use saved or generate from title
        const savedArticlePath = String(publishPayload.articlePath ?? '');
        const articlePath = savedArticlePath || generateArticlePath(title, requestId);

        els.pubTitle.value = title;
        els.pubExcerpt.value = excerpt;
        els.pubAuthor.value = author;
        els.pubDate.value = publishDateValue;
        els.pubCategory.value = category;
        els.pubTags.value = tagsArr.join(', ');
        els.pubSeo.value = seoDesc;
        els.pubArticlePath.value = articlePath;
        updateSeoCharCount();
        autoResize(els.pubTitle);

        // Consider metadata saved if a publish_payload with title exists
        if (publishPayload.title) {
          metadataSaved = true;
          setMetaStatus('Metadata loaded from saved record', 'is-ok');
        }

        const articleBody = content.article_body as { nodes?: ArticleBodyNode[] } | undefined;
        if (articleBody?.nodes?.length) {
          renderArticle(articleBody.nodes);
          els.articleWorkspace.hidden = false;
        } else {
          els.loadStatus.textContent = 'This draft has no article body nodes yet.';
          els.loadStatus.hidden = false;
          return;
        }

        lockManager = new LockManager(currentRequestId, getToken);
        lockManager.setOnStateChange((state) => updateLockBar(state as Parameters<typeof updateLockBar>[0]));
        lockManager.attachUnloadHandler();

        const lockStatus = await lockManager.status();
        updateLockBar(lockStatus as Parameters<typeof updateLockBar>[0]);

        els.loadStatus.hidden = true;
      } catch (err) {
        els.loadStatus.textContent = err instanceof Error ? err.message : 'Failed to load draft.';
      }
    };

    // ── Publish ───────────────────────────────────────────────────────────────
    els.btnPublish.addEventListener('click', async () => {
      if (!currentRequestId) return;

      const title = els.pubTitle.value.trim();
      const articlePath = els.pubArticlePath.value.trim();

      if (!title) {
        showFieldError(els.errTitle, 'Title is required.');
        els.pubTitle.focus();
        return;
      }
      if (!articlePath) {
        els.publishStatus.textContent = 'Article path not generated. Enter a title first.';
        els.publishStatus.className = 'publish-status is-error';
        return;
      }
      if (!currentNodes.length) {
        els.publishStatus.textContent = 'No article body to publish.';
        els.publishStatus.className = 'publish-status is-error';
        return;
      }

      if (
        !confirm(
          `Mark "${title}" as published?\n\nThis records the publication timestamp on the workflow record. Trigger a site deploy separately to make the article live.`
        )
      )
        return;

      els.btnPublish.disabled = true;
      els.publishStatus.textContent = 'Publishing…';
      els.publishStatus.className = 'publish-status';

      let token: string;
      try {
        token = await getToken();
      } catch {
        els.publishStatus.textContent = 'Auth error';
        els.publishStatus.className = 'publish-status is-error';
        els.btnPublish.disabled = false;
        return;
      }

      const lockToken = lockManager?.currentToken;

      try {
        const body: Record<string, unknown> = {
          action: 'set_published_time',
          request_id: currentRequestId,
          lock_token: lockToken,
          published_time: new Date().toISOString(),
        };

        const res = await fetch(PATCH_WORKFLOW_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          const j = (await res.json().catch(() => ({}))) as Record<string, unknown>;
          throw new Error(typeof j.error === 'string' ? j.error : `HTTP ${res.status}`);
        }

        if (lockManager) await lockManager.checkin();
        els.publishStatus.textContent = '✓ Publication timestamp recorded. Trigger a site deploy to go live.';
        els.publishStatus.className = 'publish-status is-ok';
        els.btnPublish.disabled = false;
      } catch (err) {
        els.publishStatus.textContent = err instanceof Error ? err.message : 'Publish failed.';
        els.publishStatus.className = 'publish-status is-error';
        els.btnPublish.disabled = false;
      }
    });

    // ── Draft picker modal ────────────────────────────────────────────────────
    const escapeHtml = (value: unknown) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatDate = (value: string) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return 'Unknown';
      return new Intl.DateTimeFormat(undefined, { dateStyle: 'medium', timeStyle: 'short' }).format(date);
    };

    const getReadinessLabel = (r: DraftSummary['readiness']) => `${r?.ready ?? 0}/${r?.total ?? 4} ready`;

    const getDisplayTitle = (title: string) =>
      String(title || 'Untitled draft')
        .replace(/\s+admin-draft-[a-f0-9-]{12,}$/i, '')
        .trim() || 'Untitled draft';

    const openModal = () => {
      els.modal.classList.add('is-open');
      els.modal.setAttribute('aria-hidden', 'false');
      const firstFocusable = els.modal.querySelector<HTMLElement>('button, input, [tabindex="0"]');
      firstFocusable?.focus();
    };

    const closeModal = () => {
      els.modal.classList.remove('is-open');
      els.modal.setAttribute('aria-hidden', 'true');
    };

    const renderDraftPickerRows = (drafts: DraftSummary[]) => {
      els.draftPickerList.innerHTML = '';
      if (drafts.length === 0) {
        els.draftPickerEmpty.hidden = false;
        return;
      }
      els.draftPickerEmpty.hidden = true;

      for (const draft of drafts) {
        const row = document.createElement('div');
        row.className = 'dp-row';

        const readinessClass = draft.readiness?.isReady ? 'is-ready' : 'is-draft';
        const readinessLabel = getReadinessLabel(draft.readiness);
        const displayTitle = getDisplayTitle(draft.title);
        const dateStr = formatDate(draft.updatedAt || draft.savedAt);
        const statusLabel = draft.lifecycleStatus || draft.recordStatus || 'draft';
        const savedByStr = draft.savedBy
          ? `<span class="dp-sep">·</span><span>by ${escapeHtml(draft.savedBy)}</span>`
          : '';
        const shortId = draft.id.length > 8 ? draft.id.slice(0, 8) + '…' : draft.id;

        row.innerHTML = `
          <div class="dp-row-main">
            <span class="dp-title">${escapeHtml(displayTitle)}</span>
            <span class="dp-meta">
              <span class="dp-slug">${escapeHtml(shortId)}</span>
              <span class="dp-sep">·</span>
              <span>${escapeHtml(statusLabel)}</span>
              <span class="dp-sep">·</span>
              <span>${escapeHtml(dateStr)}</span>
              ${savedByStr}
            </span>
            <span class="dp-badge ${readinessClass}">${escapeHtml(readinessLabel)}</span>
          </div>
          <button class="btn-secondary btn-sm dp-load-btn" type="button" data-draft-id="${escapeHtml(draft.id)}">Load</button>
        `;

        row.querySelector<HTMLButtonElement>('.dp-load-btn')!.addEventListener('click', async () => {
          closeModal();
          const token = await getAccessToken();
          if (!token) return;
          await loadDraft(draft.id, token);
        });

        els.draftPickerList.append(row);
      }
    };

    const filterDraftRows = () => {
      const q = els.modalSearch.value.toLowerCase().trim();
      if (!q) {
        renderDraftPickerRows(allDraftRows);
        return;
      }
      const filtered = allDraftRows.filter(
        (d) =>
          d.title?.toLowerCase().includes(q) || d.id?.toLowerCase().includes(q) || d.author?.toLowerCase().includes(q)
      );
      renderDraftPickerRows(filtered);
    };

    const fetchDraftList = async () => {
      els.modalStatus.textContent = 'Loading JSON drafts…';
      els.draftPickerList.innerHTML = '';
      els.draftPickerEmpty.hidden = true;
      els.btnModalRefresh.disabled = true;

      try {
        const token = await getAccessToken();
        if (!token) {
          els.modalStatus.textContent = 'Not authenticated.';
          return;
        }
        const res = await fetch(LIST_DRAFTS_ENDPOINT, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const json = (await res.json().catch(() => ({ ok: false }))) as Record<string, unknown>;
        if (!res.ok || !json.ok) {
          els.modalStatus.textContent =
            typeof json.error === 'string' ? json.error : `Could not load drafts (${res.status})`;
          return;
        }
        allDraftRows = Array.isArray(json.drafts) ? (json.drafts as DraftSummary[]) : [];
        modalDraftsCache = allDraftRows;
        els.modalStatus.textContent = `${allDraftRows.length} draft${allDraftRows.length === 1 ? '' : 's'} loaded.`;
        filterDraftRows();
      } catch (err) {
        els.modalStatus.textContent = err instanceof Error ? err.message : 'Failed to load drafts.';
      } finally {
        els.btnModalRefresh.disabled = false;
      }
    };

    const openDraftPicker = () => {
      openModal();
      if (modalDraftsCache === null) {
        fetchDraftList();
      } else {
        allDraftRows = modalDraftsCache;
        filterDraftRows();
      }
    };

    els.btnAllDrafts.addEventListener('click', openDraftPicker);
    els.btnOpenDraftList.addEventListener('click', openDraftPicker);
    els.btnModalClose.addEventListener('click', closeModal);

    els.btnModalRefresh.addEventListener('click', () => {
      modalDraftsCache = null;
      fetchDraftList();
    });

    els.modalSearch.addEventListener('input', filterDraftRows);

    els.modal.addEventListener('click', (e) => {
      if (e.target === els.modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && els.modal.classList.contains('is-open')) closeModal();
    });

    // ── Auth bootstrap ────────────────────────────────────────────────────────
    authState('checking');

    (async () => {
      try {
        const oauthUser = await handleOAuthCallback();
        if (oauthUser) window.__drLurieLoginModal?.close();
        const user = currentUser();
        if (!user) {
          authState('signed-out');
          return;
        }

        const authToken = await getAccessToken();
        if (!authToken) {
          authState('error');
          return;
        }

        const stateRes = await fetch('/.netlify/functions/admin-auth-state', {
          headers: { Authorization: `Bearer ${authToken}`, 'Content-Type': 'application/json' },
        }).catch(() => null);
        const stateJson = await stateRes?.json().catch(() => null);
        if (!stateJson?.isAdmin) {
          authState('forbidden');
          return;
        }

        authState('signed-in');
        await loadDraft(initialDraftId, authToken);

        document.addEventListener('dr-lurie:logout', () => authState('signed-out'));
        document.addEventListener('dr-lurie:login', async () => {
          const t = await getAccessToken();
          if (!t) {
            authState('error');
            return;
          }
          authState('signed-in');
        });
      } catch {
        authState('error');
      }
    })();
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>
