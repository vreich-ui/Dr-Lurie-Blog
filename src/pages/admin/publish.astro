---
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Dr. Lurié Science Admin';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section class="admin-page mx-auto max-w-[900px] px-4 py-10 sm:px-6 sm:py-14">
    <header class="admin-header mb-8 flex flex-col gap-4 border-b border-gray-200 pb-6 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800">
      <div>
        <p class="admin-kicker text-sm font-semibold uppercase tracking-[0.18em] text-accent">Publishing workspace</p>
        <h1 class="mt-2 font-heading text-4xl font-bold tracking-tight text-default sm:text-5xl">{pageTitle}</h1>
      </div>
      <a class="admin-logout btn-secondary btn-sm w-fit" href="/">Logout</a>
    </header>

    <section class="admin-card" aria-label="Publishing form">
      <form id="publish-form" class="admin-form">
        <div class="field">
          <label for="title">Title</label>
          <input id="title" name="title" type="text" autocomplete="off" />
        </div>

        <div class="field">
          <label for="slug">Slug</label>
          <input id="slug" name="slug" type="text" autocomplete="off" placeholder="article-slug" />
        </div>

        <div class="field">
          <label for="excerpt">Excerpt</label>
          <textarea
            id="excerpt"
            name="excerpt"
            class="short-textarea"
            maxlength="240"
            placeholder="Short card and topic-summary copy."
          ></textarea>
        </div>

        <div class="form-grid">
          <div class="field">
            <label for="category">Category</label>
            <input id="category" name="category" type="text" autocomplete="off" placeholder="Skin Science" />
          </div>

          <div class="field">
            <label for="tags">Tags</label>
            <input id="tags" name="tags" type="text" autocomplete="off" placeholder="barrier health, aging skin" />
            <p class="hint">Separate tags with commas.</p>
          </div>

          <div class="field">
            <label for="author">Author</label>
            <input id="author" name="author" type="text" autocomplete="off" placeholder="Dr. Lurié" />
          </div>

          <div class="field">
            <label for="publish-date">Publish date</label>
            <input id="publish-date" name="publishDate" type="date" />
          </div>
        </div>

        <div class="field checkbox-field">
          <input id="draft" name="draft" type="checkbox" />
          <label for="draft">Save as draft</label>
        </div>

        <div class="field">
          <label for="content">Markdown content</label>
          <textarea id="content" name="content" placeholder="Paste article content here. Markdown is supported."></textarea>
        </div>

        <div class="field">
          <label for="image-upload">Image upload</label>
          <input id="image-upload" type="file" multiple accept="image/*" />
          <p class="hint">Selected images are uploaded to GitHub with this post and listed below for Markdown copy helpers.</p>
          <ul id="image-list" class="image-list" aria-live="polite"></ul>
        </div>

        <div class="field">
          <label for="post-image">Post image</label>
          <select id="post-image" name="postImage">
            <option value="">Select an uploaded image</option>
          </select>
        </div>

        <div class="field">
          <label for="video-link">Optional video link</label>
          <input id="video-link" name="videoLink" type="url" placeholder="https://example.com/video" />
        </div>

        <div class="form-grid">
          <div class="field">
            <label for="cta-link">Optional CTA link</label>
            <input id="cta-link" name="ctaLink" type="url" placeholder="https://example.com/call-to-action" />
          </div>

          <div class="field">
            <label for="cta-text">Optional CTA text</label>
            <input id="cta-text" name="ctaText" type="text" placeholder="Learn more" />
          </div>
        </div>

        <div class="field">
          <label for="seo-description">Optional SEO description</label>
          <input id="seo-description" name="seoDescription" type="text" maxlength="180" />
        </div>

        <div class="actions">
          <button id="save-draft" class="btn-secondary" type="button">Save Draft</button>
          <button id="preview" class="btn-secondary" type="button">Preview</button>
          <button id="publish" class="btn-primary publish-button" type="button">Publish to GitHub</button>
        </div>
        <p id="status" class="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="admin-card admin-panel" aria-labelledby="preview-heading">
      <h2 id="preview-heading">Preview</h2>
      <div class="preview-box">
        <h3 id="preview-title">Untitled article</h3>
        <p>
          Image path:
          <span id="preview-post-image" class="preview-image-path">None selected</span>
        </p>
        <div id="markdown-preview" class="markdown-preview">Preview will appear here.</div>
      </div>
    </section>

    <section class="admin-card admin-panel" aria-labelledby="publish-output-heading">
      <h2 id="publish-output-heading">Publish output</h2>
      <p>
        Suggested filename: <span id="suggested-filename" class="suggestion">slug.md</span><br />
        Suggested destination: <span id="suggested-location" class="suggestion">src/data/post/slug.md</span>
      </p>
      <button id="copy-output" class="btn-secondary btn-sm copy-button" type="button">Copy Markdown</button>
      <textarea id="output-markdown" class="output-markdown" readonly></textarea>
      <p class="mvp-message">Publishing submits this Markdown and selected images to GitHub; copy remains available as a fallback.</p>
    </section>
  </section>
</Layout>

<style>
  .admin-page {
    color: var(--aw-color-text-default);
  }

  .admin-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 84%);
    box-shadow: 0 1.5rem 4rem rgb(15 23 42 / 6%);
    padding: 1.5rem;
  }

  :global(.dark) .admin-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
    box-shadow: none;
  }

  .admin-panel {
    margin-top: 1.5rem;
  }

  .admin-panel h2 {
    margin: 0 0 0.9rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .field {
    margin-bottom: 1.15rem;
  }

  label,
  .field-title {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--aw-color-text-heading);
    font-weight: 700;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.85rem;
    padding: 0.78rem 0.9rem;
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-page);
    font: inherit;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  :global(.dark) input,
  :global(.dark) select,
  :global(.dark) textarea {
    border-color: rgb(51 65 85);
    background: rgb(2 6 23 / 70%);
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--aw-color-accent);
    box-shadow: 0 0 0 3px rgb(94 140 138 / 18%);
    outline: none;
  }

  textarea {
    min-height: 420px;
    resize: vertical;
    line-height: 1.6;
  }

  .short-textarea {
    min-height: 110px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .checkbox-field {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .checkbox-field input {
    width: auto;
  }

  .checkbox-field label {
    margin-bottom: 0;
  }

  .hint {
    margin: 0.45rem 0 0;
    color: var(--aw-color-text-muted);
    font-size: 0.92rem;
  }

  .image-list {
    display: grid;
    gap: 0.6rem;
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
  }

  .image-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 0.75rem;
    background: var(--aw-color-bg-surface);
  }

  :global(.dark) .image-list li {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
  }

  .filename,
  .preview-image-path,
  .suggestion {
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  .filename {
    font-size: 0.9rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .publish-button {
    box-shadow: 0 0.9rem 1.8rem rgb(46 111 149 / 20%);
  }

  .copy-button {
    margin-bottom: 0.8rem;
  }

  .preview-box,
  .output-box {
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 1rem;
    background: var(--aw-color-bg-page);
  }

  :global(.dark) .preview-box,
  :global(.dark) .output-box {
    border-color: rgb(30 41 59);
  }

  .preview-box h3 {
    margin: 0 0 0.75rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
  }

  .markdown-preview {
    margin-top: 1rem;
    line-height: 1.7;
  }

  .markdown-preview h1,
  .markdown-preview h2,
  .markdown-preview h3 {
    margin: 1rem 0 0.5rem;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
  }

  .markdown-preview p {
    margin: 0 0 0.8rem;
  }

  .markdown-preview code {
    border-radius: 0.4rem;
    padding: 0.12rem 0.32rem;
    background: var(--aw-color-bg-surface);
  }

  .output-markdown {
    min-height: 260px;
    margin-top: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.9rem;
  }

  .mvp-message {
    margin: 0.85rem 0 0;
    color: var(--aw-color-secondary);
    font-weight: 800;
  }

  .status {
    min-height: 1.3em;
    margin: 0.9rem 0 0;
    color: var(--aw-color-accent);
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .admin-page {
      padding-top: 1.5rem;
      padding-bottom: 2.5rem;
    }

    .admin-card {
      border-radius: 1.1rem;
      padding: 1rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .image-list li {
      align-items: stretch;
      flex-direction: column;
    }

    .actions > button,
    .admin-logout {
      width: 100%;
    }
  }
</style>

<script is:inline>
  const draftKey = 'dr-lurie-admin-draft';
  const publishEndpoint = '/.netlify/functions/publish-post';
  const fields = {
    title: document.querySelector('#title'),
    slug: document.querySelector('#slug'),
    excerpt: document.querySelector('#excerpt'),
    category: document.querySelector('#category'),
    tags: document.querySelector('#tags'),
    author: document.querySelector('#author'),
    publishDate: document.querySelector('#publish-date'),
    draft: document.querySelector('#draft'),
    content: document.querySelector('#content'),
    imageUpload: document.querySelector('#image-upload'),
    imageList: document.querySelector('#image-list'),
    postImage: document.querySelector('#post-image'),
    videoLink: document.querySelector('#video-link'),
    ctaLink: document.querySelector('#cta-link'),
    ctaText: document.querySelector('#cta-text'),
    seoDescription: document.querySelector('#seo-description'),
    status: document.querySelector('#status'),
    previewTitle: document.querySelector('#preview-title'),
    previewPostImage: document.querySelector('#preview-post-image'),
    markdownPreview: document.querySelector('#markdown-preview'),
    suggestedFilename: document.querySelector('#suggested-filename'),
    suggestedLocation: document.querySelector('#suggested-location'),
    outputMarkdown: document.querySelector('#output-markdown'),
  };

  let selectedFiles = [];

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const escapeYaml = (value) => String(value).replaceAll('\\', '\\\\').replaceAll('"', '\\"');

  const toYamlString = (value) => `"${escapeYaml(value)}"`;

  const parseTags = (value) =>
    String(value)
      .split(',')
      .map((tag) => tag.trim())
      .filter(Boolean);

  const slugify = (value) =>
    String(value)
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');

  const sanitizeFilename = (value) => {
    const filename = String(value).split(/[\\/]/).pop() || 'image';
    const dotIndex = filename.lastIndexOf('.');
    const rawName = dotIndex > 0 ? filename.slice(0, dotIndex) : filename;
    const rawExtension = dotIndex > 0 ? filename.slice(dotIndex + 1) : '';
    const safeName = slugify(rawName) || 'image';
    const safeExtension = rawExtension.toLowerCase().replace(/[^a-z0-9]/g, '');

    return safeExtension ? `${safeName}.${safeExtension}` : safeName;
  };

  const getCurrentSlug = () => slugify(fields.slug.value || fields.title.value || 'untitled-article') || 'untitled-article';

  const getUploadPath = (filename) => `/images/uploads/${getCurrentSlug()}/${sanitizeFilename(filename)}`;

  const getRepoUploadPath = (filename) => `public${getUploadPath(filename)}`;

  const getPostImagePath = () => fields.postImage.value;

  const getPostPath = () => `src/data/post/${getCurrentSlug()}.md`;

  const getSelectedFilenameFromPostImage = () => {
    const path = getPostImagePath();
    return path ? path.split('/').pop() : '';
  };

  const getDraft = () => ({
    title: fields.title.value,
    slug: fields.slug.value,
    excerpt: fields.excerpt.value,
    category: fields.category.value,
    tags: fields.tags.value,
    author: fields.author.value,
    publishDate: fields.publishDate.value,
    draft: fields.draft.checked,
    content: fields.content.value,
    imageNames: selectedFiles.map(({ filename }) => filename),
    postImage: fields.postImage.value,
    videoLink: fields.videoLink.value,
    ctaLink: fields.ctaLink.value,
    ctaText: fields.ctaText.value,
    seoDescription: fields.seoDescription.value,
  });

  const setStatus = (message, persist = false) => {
    fields.status.textContent = message;
    if (message && !persist) {
      window.setTimeout(() => {
        if (fields.status.textContent === message) fields.status.textContent = '';
      }, 3500);
    }
  };

  const copyText = async (text, successMessage) => {
    if (!text) return;

    try {
      await navigator.clipboard.writeText(text);
      setStatus(successMessage);
    } catch (error) {
      fields.outputMarkdown.value = text;
      fields.outputMarkdown.focus();
      fields.outputMarkdown.select();
      setStatus('Clipboard unavailable. Text selected for manual copy.');
    }
  };

  const renderImages = () => {
    const previousFilename = getSelectedFilenameFromPostImage();
    fields.imageList.innerHTML = '';
    fields.postImage.innerHTML = '<option value="">Select an uploaded image</option>';

    selectedFiles.forEach(({ filename }) => {
      const uploadPath = getUploadPath(filename);
      const option = document.createElement('option');
      option.value = uploadPath;
      option.textContent = filename;
      fields.postImage.append(option);

      const item = document.createElement('li');
      const fileLabel = document.createElement('span');
      const copyButton = document.createElement('button');

      fileLabel.className = 'filename';
      fileLabel.textContent = filename;
      copyButton.className = 'btn-secondary btn-sm copy-button';
      copyButton.type = 'button';
      copyButton.textContent = 'Copy Markdown';
      copyButton.addEventListener('click', () => {
        copyText(`![Alt text](${uploadPath})`, `Copied Markdown for ${filename}.`);
      });

      item.append(fileLabel, copyButton);
      fields.imageList.append(item);
    });

    if (previousFilename) {
      const matchingOption = Array.from(fields.postImage.options).find((option) => option.textContent === previousFilename);
      if (matchingOption) fields.postImage.value = matchingOption.value;
    }
  };

  const renderMarkdownPreview = (markdown) => {
    if (!markdown.trim()) return 'Preview will appear here.';

    return markdown
      .split(/\n{2,}/)
      .map((block) => {
        const text = block.trim();
        if (!text) return '';
        if (text.startsWith('### ')) return `<h3>${escapeHtml(text.slice(4))}</h3>`;
        if (text.startsWith('## ')) return `<h2>${escapeHtml(text.slice(3))}</h2>`;
        if (text.startsWith('# ')) return `<h1>${escapeHtml(text.slice(2))}</h1>`;
        if (text.startsWith('![')) return `<p><code>${escapeHtml(text)}</code></p>`;

        const inline = escapeHtml(text)
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.*?)\*/g, '<em>$1</em>')
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/\n/g, '<br />');
        return `<p>${inline}</p>`;
      })
      .join('');
  };

  const updatePreview = () => {
    const imagePath = getPostImagePath();
    fields.previewTitle.textContent = fields.title.value || 'Untitled article';
    fields.previewPostImage.textContent = imagePath || 'None selected';
    fields.markdownPreview.innerHTML = renderMarkdownPreview(fields.content.value);
  };

  const buildMarkdown = () => {
    const slug = getCurrentSlug();
    const imagePath = getPostImagePath();
    const tags = parseTags(fields.tags.value);
    const frontmatter = [
      '---',
      `title: ${toYamlString(fields.title.value || 'Untitled article')}`,
      ...(fields.excerpt.value ? [`excerpt: ${toYamlString(fields.excerpt.value)}`] : []),
      ...(fields.publishDate.value ? [`publishDate: ${fields.publishDate.value}`] : []),
      ...(fields.draft.checked ? ['draft: true'] : []),
      ...(imagePath ? [`image: ${toYamlString(imagePath)}`] : []),
      ...(fields.category.value ? [`category: ${toYamlString(fields.category.value)}`] : []),
      ...(tags.length ? ['tags:', ...tags.map((tag) => `  - ${toYamlString(tag)}`)] : []),
      ...(fields.author.value ? [`author: ${toYamlString(fields.author.value)}`] : []),
      ...(fields.seoDescription.value
        ? ['metadata:', `  description: ${toYamlString(fields.seoDescription.value)}`]
        : []),
      ...(fields.videoLink.value ? [`video: ${toYamlString(fields.videoLink.value)}`] : []),
      ...(fields.ctaLink.value || fields.ctaText.value
        ? [
            'cta:',
            `  text: ${toYamlString(fields.ctaText.value || 'Learn more')}`,
            ...(fields.ctaLink.value ? [`  href: ${toYamlString(fields.ctaLink.value)}`] : []),
          ]
        : []),
      '---',
      '',
    ];

    return {
      slug,
      markdown: `${frontmatter.join('\n')}${fields.content.value.trim()}\n`,
      postPath: getPostPath(),
    };
  };

  const updatePublishOutput = () => {
    const { slug, markdown, postPath } = buildMarkdown();
    fields.suggestedFilename.textContent = `${slug}.md`;
    fields.suggestedLocation.textContent = postPath;
    fields.outputMarkdown.value = markdown;
  };

  const saveDraft = () => {
    localStorage.setItem(draftKey, JSON.stringify(getDraft()));
    setStatus('Draft saved. Re-select images before publishing if you reload this page.');
  };

  const readFileAsBase64 = (file) =>
    new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.addEventListener('load', () => {
        const result = String(reader.result || '');
        resolve(result.includes(',') ? result.split(',').pop() : result);
      });
      reader.addEventListener('error', () => reject(reader.error));
      reader.readAsDataURL(file);
    });

  const getUploadPayload = async () =>
    Promise.all(
      selectedFiles
        .filter(({ file }) => file)
        .map(async ({ file, filename }) => ({
          path: getRepoUploadPath(filename),
          content: await readFileAsBase64(file),
          encoding: 'base64',
        }))
    );

  const submitPublish = async ({ overwrite = false } = {}) => {
    const { slug, markdown, postPath } = buildMarkdown();
    const payload = {
      slug,
      postPath,
      markdown,
      postImage: getPostImagePath(),
      overwrite,
      files: await getUploadPayload(),
    };

    setStatus(overwrite ? 'Overwriting existing post…' : 'Publishing post…', true);

    const response = await fetch(publishEndpoint, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(payload),
    });

    let result = {};
    try {
      result = await response.json();
    } catch (error) {
      result = {};
    }

    if (response.status === 409) {
      const shouldOverwrite = window.confirm(
        `A post already exists at ${postPath}. Do you want to overwrite it on the main branch?`
      );
      if (shouldOverwrite) return submitPublish({ overwrite: true });
      setStatus('Publish canceled. Existing post was not overwritten.', true);
      return;
    }

    if (!response.ok) {
      throw new Error(result.error || 'Publishing failed.');
    }

    setStatus(`Published ${postPath} to GitHub.`, true);
    localStorage.removeItem(draftKey);
  };

  const loadDraft = () => {
    const saved = localStorage.getItem(draftKey);
    if (!saved) return;

    try {
      const draft = JSON.parse(saved);
      fields.title.value = draft.title || '';
      fields.slug.value = draft.slug || '';
      fields.excerpt.value = draft.excerpt || '';
      fields.category.value = draft.category || '';
      fields.tags.value = draft.tags || '';
      fields.author.value = draft.author || '';
      fields.publishDate.value = draft.publishDate || '';
      fields.draft.checked = Boolean(draft.draft);
      fields.content.value = draft.content || '';
      fields.videoLink.value = draft.videoLink || '';
      fields.ctaLink.value = draft.ctaLink || '';
      fields.ctaText.value = draft.ctaText || '';
      fields.seoDescription.value = draft.seoDescription || '';
      selectedFiles = Array.isArray(draft.imageNames)
        ? draft.imageNames.map((filename) => ({ filename: sanitizeFilename(filename) }))
        : [];
      renderImages();
      fields.postImage.value = draft.postImage || '';
    } catch (error) {
      localStorage.removeItem(draftKey);
    }
  };

  fields.title.addEventListener('input', () => {
    if (!fields.slug.value.trim()) fields.slug.value = slugify(fields.title.value);
    renderImages();
  });

  fields.slug.addEventListener('input', () => {
    renderImages();
  });

  fields.imageUpload.addEventListener('change', () => {
    selectedFiles = Array.from(fields.imageUpload.files || []).map((file) => ({
      file,
      filename: sanitizeFilename(file.name),
    }));
    renderImages();
    updatePreview();
    updatePublishOutput();
  });

  document.querySelector('#save-draft').addEventListener('click', saveDraft);
  document.querySelector('#preview').addEventListener('click', () => {
    updatePreview();
    setStatus('Preview updated.');
  });
  document.querySelector('#publish').addEventListener('click', async () => {
    updatePreview();
    updatePublishOutput();

    try {
      await submitPublish();
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Publishing failed.', true);
    }
  });
  document.querySelector('#copy-output').addEventListener('click', () => {
    updatePublishOutput();
    copyText(fields.outputMarkdown.value, 'Publish Markdown copied.');
  });

  ['input', 'change'].forEach((eventName) => {
    document.querySelector('#publish-form').addEventListener(eventName, () => {
