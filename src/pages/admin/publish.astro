</style>

<script>
  import { currentUser, getAccessToken, handleOAuthCallback } from '~/utils/goTrueClient';
  import { LockManager } from '~/lib/admin/lock-manager';
  import { renderNode, wrapNode } from '~/lib/admin/node-renderer';
  import { NodeEditor } from '~/lib/admin/node-editor';
  import { askAiForNode, renderSuggestionOverlay, showInstructionPopover } from '~/lib/admin/ai-suggestion';
  import { evaluateReadiness, readinessLevel } from '~/lib/admin/readiness-criteria';
  import { generateArticlePath } from '~/lib/admin/article-path';
  import type { ArticleBodyNode } from '~/schema/article-content-v1';
  import type { ReadinessGroup } from '~/lib/admin/readiness-criteria';

  // ─── constants ──────────────────────────────────────────────────────────────
  const DRAFT_ENDPOINT = '/.netlify/functions/admin-get-json-draft';
  const UPDATE_NODE_ENDPOINT = '/.netlify/functions/admin-update-node';
  const LIST_DRAFTS_ENDPOINT = '/.netlify/functions/admin-list-json-drafts';
  const PATCH_WORKFLOW_ENDPOINT = '/.netlify/functions/admin-patch-workflow';
  const TAXONOMY_ENDPOINT = '/.netlify/functions/admin-taxonomy';

  // ─── page init ──────────────────────────────────────────────────────────────
  const init = () => {
    const page = document.querySelector<HTMLElement>('.admin-page');
    if (!page || page.dataset.publishInitialized === 'true') return;
    page.dataset.publishInitialized = 'true';

    const params = new URLSearchParams(window.location.search);
    const initialDraftId = params.get('draftId') ?? params.get('requestId') ?? '';

    type DraftSummary = {
      id: string;
      title: string;
      slug: string;
      author: string;
      updatedAt: string;
      savedAt: string;
      savedBy: string;
      recordStatus: string;
      lifecycleStatus?: string;
      readiness: { isReady: boolean; missing: string[]; ready: number; total: number };
    };

    // DOM refs
    const els = {
      authStatus: document.querySelector<HTMLElement>('[data-auth-status]'),
      gated: Array.from(document.querySelectorAll<HTMLElement>('[data-auth-gated]')),
      lockBar: document.querySelector<HTMLElement>('#lock-bar')!,
      lockIcon: document.querySelector<HTMLElement>('#lock-icon')!,
      lockLabel: document.querySelector<HTMLElement>('#lock-label')!,
      btnForceRelease: document.querySelector<HTMLButtonElement>('#btn-force-release')!,
      btnDoneEditing: document.querySelector<HTMLButtonElement>('#btn-done-editing')!,
      loadStatus: document.querySelector<HTMLElement>('#load-status')!,
      articleWorkspace: document.querySelector<HTMLElement>('#article-workspace')!,
      articleHeaderCard: document.querySelector<HTMLElement>('#article-header-card')!,
      articleView: document.querySelector<HTMLElement>('#article-view')!,
      inspectorPanel: document.querySelector<HTMLElement>('#inspector-panel')!,
      inspectorEmpty: document.querySelector<HTMLElement>('#inspector-empty')!,
      inspectorContent: document.querySelector<HTMLElement>('#inspector-content')!,
      nodesContainer: document.querySelector<HTMLElement>('#nodes-container')!,
      // Setup / metadata fields
      pubAuthor: document.querySelector<HTMLInputElement>('#pub-author')!,
      pubDate: document.querySelector<HTMLInputElement>('#pub-date')!,
      pubSeo: document.querySelector<HTMLInputElement>('#pub-seo')!,
      pubArticlePath: document.querySelector<HTMLInputElement>('#pub-article-path')!,
      seoCharCount: document.querySelector<HTMLElement>('#seo-char-count')!,
      btnSaveMeta: document.querySelector<HTMLButtonElement>('#btn-save-meta')!,
      metaStatus: document.querySelector<HTMLElement>('#meta-status')!,
      // General section (Author, Date, Category)
      generalSummary: document.querySelector<HTMLElement>('#general-summary')!,
      generalForm: document.querySelector<HTMLElement>('#general-form')!,
      btnGeneralToggle: document.querySelector<HTMLButtonElement>('#btn-general-toggle')!,
      generalDirtyDot: document.querySelector<HTMLElement>('#general-dirty-dot')!,
      // Metadata section (Tags, SEO, Path)
      metaSummary: document.querySelector<HTMLElement>('#meta-summary')!,
      metaForm: document.querySelector<HTMLElement>('#meta-form')!,
      btnMetaToggle: document.querySelector<HTMLButtonElement>('#btn-meta-toggle')!,
      metaDirtyDot: document.querySelector<HTMLElement>('#meta-dirty-dot')!,
      btnCopyPath: document.querySelector<HTMLButtonElement>('#btn-copy-path')!,
      btnOpenDraftListInspector: document.querySelector<HTMLButtonElement>('#btn-open-draft-list-inspector')!,
      // Tag pill picker
      pubTagsContainer: document.querySelector<HTMLElement>('#pub-tags-container')!,
      pubTagsPills: document.querySelector<HTMLElement>('#pub-tags-pills')!,
      pubTagsInput: document.querySelector<HTMLInputElement>('#pub-tags-input')!,
      pubTagsSuggestions: document.querySelector<HTMLElement>('#pub-tags-suggestions')!,
      // Category combobox
      pubCategoryContainer: document.querySelector<HTMLElement>('#pub-category-container')!,
      pubCategoryChips: document.querySelector<HTMLElement>('#pub-category-chips')!,
      pubCategoryInput: document.querySelector<HTMLInputElement>('#pub-category-input')!,
      pubCategorySuggestions: document.querySelector<HTMLElement>('#pub-category-suggestions')!,
      // Article header fields
      pubTitle: document.querySelector<HTMLTextAreaElement>('#pub-title')!,
      pubExcerpt: document.querySelector<HTMLTextAreaElement>('#pub-excerpt')!,
      errTitle: document.querySelector<HTMLElement>('#err-title')!,
      errExcerpt: document.querySelector<HTMLElement>('#err-excerpt')!,
      // Readiness strip
      readinessLabel: document.querySelector<HTMLElement>('#readiness-label')!,
      readinessToggle: document.querySelector<HTMLButtonElement>('#readiness-toggle')!,
      readinessChips: document.querySelector<HTMLElement>('#readiness-chips')!,
      readinessAudit: document.querySelector<HTMLElement>('#readiness-audit')!,
      readinessGroups: document.querySelector<HTMLElement>('#readiness-groups')!,
      btnPublish: document.querySelector<HTMLButtonElement>('#btn-publish')!,
      publishStatus: document.querySelector<HTMLElement>('#publish-status')!,
      // Modal
      modal: document.querySelector<HTMLElement>('#draft-picker-modal')!,
      btnModalClose: document.querySelector<HTMLButtonElement>('#btn-modal-close')!,
      btnModalRefresh: document.querySelector<HTMLButtonElement>('#btn-modal-refresh')!,
      modalStatus: document.querySelector<HTMLElement>('#modal-status')!,
      modalSearch: document.querySelector<HTMLInputElement>('#draft-picker-search')!,
      draftPickerList: document.querySelector<HTMLElement>('#draft-picker-list')!,
      draftPickerEmpty: document.querySelector<HTMLElement>('#draft-picker-empty')!,
      // History / undo
      btnHeaderHistory: document.querySelector<HTMLButtonElement>('#btn-header-history')!,
      btnMetaUndo: document.querySelector<HTMLButtonElement>('#btn-meta-undo')!,
    };

    // ── Inspector panel positioning ────────────────────────────────────────────
    const reposition = () => {
      const panel = els.inspectorPanel;
      if (!panel) return;
      const { width: panelW, height: panelH } = panel.getBoundingClientRect();
      const contentRect = contentEl?.getBoundingClientRect();
      const idealLeft = contentRect ? contentRect.right + 19 : (window.innerWidth - panelW) / 2;
      const idealTop = contentRect ? contentRect.top : (window.innerHeight - panelH) / 2;
      const clampedLeft = Math.max(8, Math.min(idealLeft, window.innerWidth - panelW - 8));
      const clampedTop = Math.max(8, Math.min(idealTop, window.innerHeight - panelH - 8));
      panel.style.left = `${clampedLeft}px`;
      panel.style.top = `${clampedTop}px`;
    };
    const contentEl = document.querySelector<HTMLElement>('.publish-main');
    const ro = new ResizeObserver(reposition);
    ro.observe(els.inspectorPanel);
    if (contentEl) ro.observe(contentEl);
    window.addEventListener('scroll', reposition, { passive: true });
    window.addEventListener('resize', reposition, { passive: true });

    // ── Scroll engagement-band detection ───────────────────────────────────────
    const getEngagementBand = () => ({
      top: window.innerHeight * 0.4,
      bottom: window.innerHeight * 0.55,
    });

    let candidateNodeId: string | null = null;
    let attachedNodeId: string | null = null;
    let settleTimer: ReturnType<typeof setTimeout> | null = null;
    const dockMarker = document.querySelector<HTMLElement>('#dock-marker');

    let dirtyCheckInterval: ReturnType<typeof setInterval> | null = null;

    const stopDirtyWatch = () => {
      if (dirtyCheckInterval) {
        clearInterval(dirtyCheckInterval);
        dirtyCheckInterval = null;
      }
      document.querySelectorAll<HTMLElement>('.dl-node-wrapper.is-dock-dirty').forEach((el) => {
        el.classList.remove('is-dock-dirty');
      });
      dockMarker?.classList.remove('is-marker-dirty');
    };

    const startDirtyWatch = () => {
      if (dirtyCheckInterval) return;
      dirtyCheckInterval = setInterval(() => {
        if (!activeEditor) {
          stopDirtyWatch();
          return;
        }
        const nodeId = activeNodeWrapper?.dataset.nodeId ?? null;
        const isDirty = activeEditor.isDirty();
        if (nodeId && nodeId === attachedNodeId) {
          document
            .querySelector<HTMLElement>(`.dl-node-wrapper[data-node-id="${nodeId}"]`)
            ?.classList.toggle('is-dock-dirty', isDirty);
          dockMarker?.classList.toggle('is-marker-dirty', isDirty);
        }
      }, 100);
    };

    const setAttached = (id: string | null) => {
      if (id === attachedNodeId) return;

      // Guard: if the currently-attached node is being edited with unsaved changes, confirm first
      if (attachedNodeId !== null && activeNodeWrapper?.dataset.nodeId === attachedNodeId) {
        if (activeEditor?.isDirty()) {
          const keep = !window.confirm('You have unsaved changes in this block. Discard them and edit another block?');
          if (keep) return;
        }
        closeActiveEditor(false);
      }

      if (attachedNodeId) {
        document
          .querySelector<HTMLElement>(`.dl-node-wrapper[data-node-id="${attachedNodeId}"]`)
          ?.classList.remove('is-dock-attached');
      }
      attachedNodeId = id;
      if (attachedNodeId) {
        document
          .querySelector<HTMLElement>(`.dl-node-wrapper[data-node-id="${attachedNodeId}"]`)
          ?.classList.add('is-dock-attached');
      }
      dockMarker?.classList.toggle('is-visible', attachedNodeId !== null);
    };

    const detectCandidate = () => {
      const band = getEngagementBand();
      const wrappers = document.querySelectorAll<HTMLElement>('.dl-node-wrapper');
      let found: string | null = null;
      for (const wrapper of wrappers) {
        const rect = wrapper.getBoundingClientRect();
        if (rect.bottom >= band.top && rect.top <= band.bottom) {
          found = wrapper.dataset.nodeId ?? null;
          break;
        }
      }
      if (found !== candidateNodeId) {
        candidateNodeId = found;
        console.log('[dock-candidate]', candidateNodeId ?? '(gap)');
        if (settleTimer !== null) clearTimeout(settleTimer);
        settleTimer = setTimeout(() => {
          settleTimer = null;
          setAttached(candidateNodeId);
        }, 300);
      }
    };

    let rafPending = false;
    const onScrollDetect = () => {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        detectCandidate();
        rafPending = false;
      });
    };

    detectCandidate();
    window.addEventListener('scroll', onScrollDetect, { passive: true });

    // ── State ──────────────────────────────────────────────────────────────────
    let lockManager: LockManager | null = null;
    let activeEditor: NodeEditor | null = null;
    let activeNodeWrapper: HTMLElement | null = null;
    let currentNodes: ArticleBodyNode[] = [];
    let currentRequestId = initialDraftId;
    let currentRecordVersion = 0;
    let metadataSaved = false;
    let metadataDirty = false;
    let modalDraftsCache: DraftSummary[] | null = null;
    let allDraftRows: DraftSummary[] = [];
    // History snapshots loaded from the workflow record
    type HistoryEntry = { at: string; action: string; details?: Record<string, unknown> };
    let draftHistory: HistoryEntry[] = [];
    // Pending undo for metadata (set after a successful save, cleared on next save or undo)
    let metaUndoPayload: Record<string, unknown> | null = null;
    // History button refs per node id — used to enable/disable after saves
    const nodeHistBtns = new Map<string, HTMLButtonElement>();
    // Current editor-mode: used for mutual exclusivity and CSS state
    let editMode: 'idle' | 'editing' | 'ai' = 'idle';
    // Tag / category pill state
    let selectedTags: string[] = [];
    let selectedCategory: string | null = null;
    let allTagSuggestions: string[] = [];
    let allCategorySuggestions: string[] = [];
    const setMode = (m: typeof editMode) => {
      editMode = m;
      if (m === 'idle') {
        delete els.nodesContainer.dataset.mode;
      } else {
        els.nodesContainer.dataset.mode = m;
      }
    };

    // Enable/disable history buttons based on whether any entries exist
    const updateHistoryButtonStates = () => {
      const hasMetaHistory = draftHistory.some((e) => e.action === 'patch_canonical_input');
      els.btnHeaderHistory.disabled = !hasMetaHistory;
      for (const [nodeId, btn] of nodeHistBtns) {
        const hasNodeHistory = draftHistory.some(
          (e) => e.action === 'admin_update_node' && e.details?.nodeId === nodeId
        );
        btn.disabled = !hasNodeHistory;
      }
    };

    // ── Icon helper ───────────────────────────────────────────────────────────
    // Clones a pre-rendered SVG icon from the hidden template container.
    // Falls back to a text label if the template is missing (dev/test).
    const cloneIcon = (name: string, fallback = ''): Node => {
      const tmpl = document.querySelector<HTMLElement>(`[data-icon="${name}"]`);
      if (tmpl) return tmpl.cloneNode(true);
      return document.createTextNode(fallback);
    };

    const getToken = async (): Promise<string> => {
      const token = await getAccessToken();
      if (!token) throw new Error('Not authenticated');
      return token;
    };

    // ── Auth shell ────────────────────────────────────────────────────────────
    const setAuthStatus = (msg: string) => {
      if (els.authStatus) els.authStatus.textContent = msg;
    };
    const setGated = (visible: boolean) =>
      els.gated.forEach((el) => {
        el.hidden = !visible;
      });
    const setPageVisible = (visible: boolean) => {
      if (page) page.hidden = !visible;
    };

    const authState = (state: 'checking' | 'signed-out' | 'forbidden' | 'error' | 'signed-in') => {
      const msgs: Record<string, string> = {
        checking: 'Checking admin access…',
        'signed-out': 'Sign in to view admin tools.',
        forbidden: 'Access denied.',
        error: 'Auth failed. Refresh or contact support.',
        'signed-in': '',
      };
      setAuthStatus(msgs[state] ?? '');
      setPageVisible(state === 'signed-in');
      setGated(state === 'signed-in');
      if (!['checking', 'signed-in'].includes(state)) window.location.replace('/');
    };

    // ── Title textarea auto-resize ─────────────────────────────────────────────
    const autoResize = (el: HTMLTextAreaElement) => {
      el.style.height = 'auto';
      el.style.height = `${el.scrollHeight}px`;
    };
    // Note: initial autoResize skipped — textarea is hidden until a draft loads

    // ── Lock bar ──────────────────────────────────────────────────────────────
    const updateLockBar = (state: {
      held: boolean;
      agentLock?: { owner_label: string; expires_at: string };
      lockToken?: string;
      expires_at?: string;
    }) => {
      els.lockBar.hidden = false;
      delete els.lockBar.dataset.lockedByAgent;
      delete els.lockBar.dataset.held;

      const agentHoldsLock = Boolean(!state.held && state.agentLock);

      const setLockIcon = (iconName: string) => {
        els.lockIcon.innerHTML = '';
        els.lockIcon.appendChild(cloneIcon(iconName));
      };
      if (state.held) {
        els.lockBar.dataset.held = 'true';
        setLockIcon('lock-open');
        els.lockLabel.textContent = 'You hold the edit lock';
        els.btnDoneEditing.hidden = false;
        els.btnForceRelease.hidden = true;
      } else if (state.agentLock) {
        els.lockBar.dataset.lockedByAgent = 'true';
        setLockIcon('lock');
        const exp = new Date(state.agentLock.expires_at);
        const expStr = Number.isFinite(exp.getTime()) ? `expires ${exp.toLocaleTimeString()}` : 'expiry unknown';
        els.lockLabel.textContent = `Agent: ${state.agentLock.owner_label} (${expStr})`;
        els.btnDoneEditing.hidden = true;
        els.btnForceRelease.hidden = false;
      } else {
        setLockIcon('pencil');
        els.lockLabel.textContent = 'Click a block to start editing';
        els.btnDoneEditing.hidden = true;
        els.btnForceRelease.hidden = true;
      }

      // Gate all edit controls via data-lock attribute (Rule 4)
      els.articleWorkspace.dataset.lock = agentHoldsLock ? 'agent' : state.held ? 'held' : 'free';
      els.btnSaveMeta.disabled = agentHoldsLock;

      updateReadinessPanel(agentHoldsLock);
    };

    const resetLockBar = () => {
      els.lockBar.hidden = true;
      delete els.lockBar.dataset.held;
      delete els.lockBar.dataset.lockedByAgent;
      delete els.articleWorkspace.dataset.lock;
      els.lockIcon.innerHTML = '';
      els.lockLabel.textContent = '';
      els.btnDoneEditing.hidden = true;
      els.btnForceRelease.hidden = true;
      els.btnSaveMeta.disabled = false;
    };

    // ── Lock actions ──────────────────────────────────────────────────────────
    const acquireLock = async (): Promise<boolean> => {
      if (!lockManager) return false;
      const token = await lockManager.checkout();
      return token !== null;
    };

    els.btnDoneEditing.addEventListener('click', async () => {
      if (activeEditor?.isDirty()) {
        if (!window.confirm('You have unsaved edits in a block. Discard them and release the lock?')) return;
      }
      closeActiveEditor(false);
      if (lockManager) await lockManager.checkin();
    });

    els.btnForceRelease.addEventListener('click', async () => {
      if (!lockManager) return;
      if (!confirm('Force-release the agent lock? The agent may be mid-edit.')) return;
      await lockManager.forceRelease();
    });

    // ── Readiness strip ───────────────────────────────────────────────────────
    els.readinessToggle.addEventListener('click', () => {
      const expanded = els.readinessAudit.hidden === false;
      els.readinessAudit.hidden = expanded;
      els.readinessToggle.textContent = expanded ? 'Details' : 'Hide details';
      els.readinessToggle.setAttribute('aria-expanded', String(!expanded));
    });

    const updateReadinessPanel = (agentLockPresent = false) => {
      const groups = evaluateReadiness({
        title: els.pubTitle.value.trim(),
        excerpt: els.pubExcerpt.value.trim(),
        author: els.pubAuthor.value.trim(),
        publishDate: els.pubDate.value.trim(),
        articlePath: els.pubArticlePath.value.trim(),
        seoDescription: els.pubSeo.value.trim(),
        category: selectedCategory ?? '',
        tags: selectedTags,
        nodes: currentNodes,
        lockHeld: Boolean(lockManager?.currentToken),
        canonicalSaved: metadataSaved,
        agentLockPresent,
      });

      renderReadinessGroups(groups);
      renderReadinessChips(groups);

      const level = readinessLevel(groups);
      const levelMap = {
        missing: { label: 'Review needed', cls: 'is-missing' },
        warning: { label: 'Nearly ready', cls: 'is-warning' },
        ready: { label: 'Ready to publish', cls: 'is-ready' },
      };
      const { label, cls } = levelMap[level];
      els.readinessLabel.textContent = label;
      els.readinessLabel.className = `readiness-pill ${cls}`;

      const missingCount = groups.flatMap((g) => g.criteria).filter((c) => c.status === 'missing').length;
      els.btnPublish.disabled = missingCount > 0 || metadataDirty;
    };

    const MAX_CHIPS = 3;
    const renderReadinessChips = (groups: ReadinessGroup[]) => {
      els.readinessChips.innerHTML = '';
      const allCriteria = groups.flatMap((g) => g.criteria);
      const notable = allCriteria.filter((c) => c.status === 'missing' || c.status === 'warning');

      if (notable.length === 0) {
        const chip = document.createElement('span');
        chip.className = 'readiness-chip complete';
        chip.textContent = 'All checks pass';
        els.readinessChips.append(chip);
        return;
      }

      const visible = notable.slice(0, MAX_CHIPS);
      const extra = notable.slice(MAX_CHIPS);

      for (const criterion of visible) {
        const chip = document.createElement('span');
        chip.className = `readiness-chip ${criterion.status}`;
        chip.textContent = criterion.label;
        if (criterion.message) chip.title = criterion.message;
        els.readinessChips.append(chip);
      }

      if (extra.length > 0) {
        const moreBtn = document.createElement('button');
        moreBtn.type = 'button';
        moreBtn.className = 'readiness-chip-more';
        moreBtn.textContent = `+${extra.length} more`;
        let expanded = false;
        moreBtn.addEventListener('click', () => {
          expanded = !expanded;
          if (expanded) {
            for (const criterion of extra) {
              const chip = document.createElement('span');
              chip.className = `readiness-chip ${criterion.status}`;
              chip.textContent = criterion.label;
              if (criterion.message) chip.title = criterion.message;
              els.readinessChips.insertBefore(chip, moreBtn);
            }
            moreBtn.textContent = 'Show less';
          } else {
            const chips = [...els.readinessChips.querySelectorAll<HTMLElement>('.readiness-chip')];
            for (const chip of chips.slice(MAX_CHIPS)) chip.remove();
            moreBtn.textContent = `+${extra.length} more`;
          }
        });
        els.readinessChips.append(moreBtn);
      }
    };

    const renderReadinessGroups = (groups: ReadinessGroup[]) => {
      els.readinessGroups.innerHTML = '';

      for (const group of groups) {
        const groupEl = document.createElement('div');
        groupEl.className = 'readiness-group';

        const groupLabel = document.createElement('p');
        groupLabel.className = 'readiness-group-label';
        groupLabel.textContent = group.label;
        groupEl.append(groupLabel);

        const ul = document.createElement('ul');
        ul.className = 'readiness-criteria-list';

        for (const criterion of group.criteria) {
          const li = document.createElement('li');
          li.className = 'readiness-criterion';

          const icons: Record<string, string> = { complete: '✓', warning: '⚠', missing: '✗', optional: '○' };
          const pill = document.createElement('span');
          pill.className = `criterion-pill ${criterion.status}`;
          pill.textContent = icons[criterion.status] ?? '○';
          pill.setAttribute('aria-label', criterion.status);

          const text = document.createElement('span');
          text.className = 'criterion-text';
          text.textContent = criterion.label;

          li.append(pill, text);

          if (criterion.message) {
            const msg = document.createElement('span');
            msg.className = 'criterion-message';
            msg.textContent = criterion.message;
            li.append(msg);
          }

          ul.append(li);
        }

        groupEl.append(ul);
        els.readinessGroups.append(groupEl);
      }
    };

    // ── Field validation helpers ──────────────────────────────────────────────
    const showFieldError = (el: HTMLElement, msg: string) => {
      el.textContent = msg;
      el.hidden = false;
    };
    const clearFieldError = (el: HTMLElement) => {
      el.textContent = '';
      el.hidden = true;
    };

    const setMetaStatus = (msg: string, kind: '' | 'is-error' | 'is-ok' = '') => {
      els.metaStatus.textContent = msg;
      els.metaStatus.className = `meta-status-inline${kind ? ' ' + kind : ''}`;
    };

    // ── Section summaries (one-line compact text) ─────────────────────────────

    const updateGeneralSummary = () => {
      const author = els.pubAuthor.value.trim();
      const date = (() => {
        const d = els.pubDate.value.trim();
        if (!d) return '';
        try {
          const parsed = new Date(d);
          if (Number.isFinite(parsed.getTime())) {
            return parsed.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' });
          }
        } catch {
          return d;
        }
        return d;
      })();
      const category = selectedCategory ?? '';
      const parts = [author, date, category].filter(Boolean);
      els.generalSummary.textContent = parts.length > 0 ? parts.join(' · ') : '—';
      els.generalSummary.className = `section-summary-text${parts.length === 0 ? ' is-empty' : ''}`;
    };

    const updateMetaSummary = () => {
      const tagsText =
        selectedTags.length === 0 ? '' : `${selectedTags.length} tag${selectedTags.length === 1 ? '' : 's'}`;
      const seoText = els.pubSeo.value.trim() ? `SEO ${els.pubSeo.value.trim().length}/180` : '';
      const pathText = els.pubArticlePath.value.trim() ? 'path set' : '';
      const parts = [tagsText, seoText, pathText].filter(Boolean);
      els.metaSummary.textContent = parts.length > 0 ? parts.join(' · ') : '—';
      els.metaSummary.className = `section-summary-text${parts.length === 0 ? ' is-empty' : ''}`;
    };

    const toggleGeneralForm = (forceOpen?: boolean) => {
      const isOpen = !els.generalForm.hidden;
      const open = forceOpen !== undefined ? forceOpen : !isOpen;
      if (open) toggleMetaForm(false);
      if (!open && isOpen) updateGeneralSummary();
      els.generalForm.hidden = !open;
      els.generalSummary.hidden = open;
      els.btnGeneralToggle.setAttribute('aria-expanded', String(open));
      reposition();
    };

    const toggleMetaForm = (forceOpen?: boolean) => {
      const isOpen = !els.metaForm.hidden;
      const open = forceOpen !== undefined ? forceOpen : !isOpen;
      if (open) toggleGeneralForm(false);
      if (!open && isOpen) updateMetaSummary();
      els.metaForm.hidden = !open;
      els.metaSummary.hidden = open;
      els.btnMetaToggle.setAttribute('aria-expanded', String(open));
      reposition();
    };

    // ── History popover ───────────────────────────────────────────────────────
    let openPopover: HTMLElement | null = null;
    const closeOpenPopover = () => {
      openPopover?.remove();
      openPopover = null;
    };

    const formatRelativeTime = (isoString: string): string => {
      const diff = Date.now() - Date.parse(isoString);
      if (diff < 60_000) return 'just now';
      if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
      if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
      return new Date(isoString).toLocaleDateString();
    };

    const showHistoryPopover = (
      anchor: HTMLElement,
      nodeId: string | 'metadata',
      onRestore?: (entry: HistoryEntry) => void
    ) => {
      closeOpenPopover();

      const entries =
        nodeId === 'metadata'
          ? draftHistory
              .filter((e) => e.action === 'patch_canonical_input')
              .slice(-8)
              .reverse()
          : draftHistory
              .filter((e) => e.action === 'admin_update_node' && e.details?.nodeId === nodeId)
              .slice(-8)
              .reverse();

      const pop = document.createElement('div');
      pop.className = 'dl-history-popover';
      pop.style.position = 'absolute';

      const header = document.createElement('div');
      header.className = 'dl-history-popover-header';
      const title = document.createElement('span');
      title.textContent = nodeId === 'metadata' ? 'Metadata history' : 'Block history';
      const closeBtn = document.createElement('button');
      closeBtn.className = 'dl-history-popover-close';
      closeBtn.type = 'button';
      closeBtn.setAttribute('aria-label', 'Close history');
      closeBtn.textContent = '✕';
      closeBtn.addEventListener('click', closeOpenPopover);
      header.append(title, closeBtn);
      pop.append(header);

      if (entries.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'dl-history-empty';
        empty.textContent = 'No saved history yet.';
        pop.append(empty);
      } else {
        for (const entry of entries) {
          const row = document.createElement('div');
          row.className = 'dl-history-entry';

          const time = document.createElement('span');
          time.className = 'dl-history-time';
          time.textContent = formatRelativeTime(entry.at);
          time.title = new Date(entry.at).toLocaleString();
          row.append(time);

          if (nodeId === 'metadata' && entry.details?.previousPayload) {
            const prev = entry.details.previousPayload as Record<string, unknown>;
            const desc = document.createElement('span');
            desc.textContent = `Title: "${String(prev.title ?? '').slice(0, 40) || '(none)'}"`;
            row.append(desc);
          } else if (nodeId !== 'metadata' && entry.details?.previousPublic) {
            const prev = entry.details.previousPublic as Record<string, unknown>;
            const bodySnippet = String(prev.body ?? prev.title ?? '(empty)')
              .replace(/<[^>]+>/g, '')
              .slice(0, 60);
            const desc = document.createElement('span');
            desc.textContent = bodySnippet || '(empty block)';
            row.append(desc);
          }

          const restoreBtn = document.createElement('button');
          restoreBtn.className = 'dl-history-restore';
          restoreBtn.type = 'button';
          const hasSnapshot =
            nodeId === 'metadata' ? !!entry.details?.previousPayload : !!entry.details?.previousPublic;
          restoreBtn.disabled = !hasSnapshot || !onRestore;
          restoreBtn.textContent = hasSnapshot && onRestore ? 'Restore this version' : 'Restore (not available)';
          if (hasSnapshot && onRestore) {
            restoreBtn.addEventListener('click', () => {
              onRestore(entry);
              closeOpenPopover();
            });
          }
          row.append(restoreBtn);
          pop.append(row);
        }
      }

      // Anchor popover to the button's parent (must be positioned)
      const anchorParent = anchor.closest<HTMLElement>('.admin-setup-module, .article-header-card, .dl-node-wrapper');
      if (anchorParent) {
        if (!anchorParent.style.position || anchorParent.style.position === 'static') {
          anchorParent.style.position = 'relative';
        }
        anchorParent.append(pop);
      } else {
        anchor.parentElement?.append(pop);
      }
      openPopover = pop;

      // Close on outside click
      const onOutside = (e: MouseEvent) => {
        if (!pop.contains(e.target as Node) && e.target !== anchor) {
          closeOpenPopover();
          document.removeEventListener('mousedown', onOutside, true);
        }
      };
      requestAnimationFrame(() => document.addEventListener('mousedown', onOutside, true));
    };

    // ── SEO character counter
    const updateSeoCharCount = () => {
      const len = els.pubSeo.value.length;
      els.seoCharCount.textContent = `${len}/180`;
    };
    els.pubSeo.addEventListener('input', updateSeoCharCount);

    // Article path: regenerated live from title + requestId
    const refreshArticlePath = () => {
      const title = els.pubTitle.value.trim();
      els.pubArticlePath.value = title ? generateArticlePath(title, currentRequestId) : '';
    };

    const markGeneralDirty = () => {
      metadataDirty = true;
      els.generalDirtyDot.hidden = false;
      if (metadataSaved) {
        metadataSaved = false;
        setMetaStatus('Unsaved changes');
      }
      updateReadinessPanel();
    };

    const markMetaDirty = () => {
      metadataDirty = true;
      els.metaDirtyDot.hidden = false;
      if (metadataSaved) {
        metadataSaved = false;
        setMetaStatus('Unsaved changes');
      }
      updateReadinessPanel();
    };

    // Live readiness re-evaluation on any metadata change
    const setupFields: (HTMLInputElement | HTMLTextAreaElement)[] = [
      els.pubTitle,
      els.pubExcerpt,
      els.pubAuthor,
      els.pubDate,
      els.pubSeo,
    ];
    for (const field of setupFields) {
      field.addEventListener('input', () => {
        if (field === els.pubTitle) {
          clearFieldError(els.errTitle);
          autoResize(els.pubTitle);
          refreshArticlePath();
        }
        if (field === els.pubExcerpt) {
          clearFieldError(els.errExcerpt);
        }
        // Author/Date belong to the General section; SEO to the Metadata section
        if (field === els.pubAuthor || field === els.pubDate) {
          markGeneralDirty();
        } else {
          markMetaDirty();
        }
      });
    }

    // ── Taxonomy loading ──────────────────────────────────────────────────────
    const loadTaxonomy = async () => {
      try {
        const token = await getToken();
        const res = await fetch(TAXONOMY_ENDPOINT, { headers: { Authorization: `Bearer ${token}` } });
        const json = (await res.json().catch(() => ({}))) as Record<string, unknown>;
        if (json.ok) {
          allTagSuggestions = Array.isArray(json.tags) ? (json.tags as string[]) : [];
          allCategorySuggestions = Array.isArray(json.categories) ? (json.categories as string[]) : [];
        }
      } catch {
        // non-critical: suggestions will just be empty
      }
    };

    // ── Tag pill picker ───────────────────────────────────────────────────────
    const renderTagPills = () => {
      els.pubTagsPills.innerHTML = '';
      for (const tag of selectedTags) {
        const pill = document.createElement('span');
        pill.className = 'tag-pill';
        const text = document.createElement('span');
        text.textContent = tag;
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'tag-pill-remove';
        removeBtn.setAttribute('aria-label', `Remove tag ${tag}`);
        removeBtn.textContent = '×';
        removeBtn.addEventListener('click', () => {
          selectedTags = selectedTags.filter((t) => t !== tag);
          renderTagPills();
          markMetaDirty();
        });
        pill.append(text, removeBtn);
        els.pubTagsPills.append(pill);
      }
    };

    const showTagSuggestions = (filter: string) => {
      const input = filter.toLowerCase().trim();
      const existing = new Set(selectedTags.map((t) => t.toLowerCase()));
      const matches = allTagSuggestions.filter((t) => (!input || t.includes(input)) && !existing.has(t));

      els.pubTagsSuggestions.innerHTML = '';

      if (input && !matches.find((t) => t.toLowerCase() === input)) {
        const createItem = document.createElement('div');
        createItem.className = 'tag-suggestion-item';
        createItem.textContent = `Create "${filter.trim()}"`;
        createItem.addEventListener('mousedown', (e) => {
          e.preventDefault();
          addTag(filter.trim());
        });
        els.pubTagsSuggestions.append(createItem);
      }

      for (const match of matches.slice(0, 10)) {
        const item = document.createElement('div');
        item.className = 'tag-suggestion-item';
        item.textContent = match;
        item.addEventListener('mousedown', (e) => {
          e.preventDefault();
          addTag(match);
        });
        els.pubTagsSuggestions.append(item);
      }

      els.pubTagsSuggestions.hidden = els.pubTagsSuggestions.children.length === 0;
    };

    const addTag = (tag: string) => {
      const normalized = tag.toLowerCase().trim();
      if (!normalized || selectedTags.some((t) => t.toLowerCase() === normalized)) return;
      selectedTags = [...selectedTags, normalized];
      els.pubTagsInput.value = '';
      els.pubTagsSuggestions.hidden = true;
      renderTagPills();
      markMetaDirty();
    };

    els.pubTagsInput.addEventListener('input', () => showTagSuggestions(els.pubTagsInput.value));
    els.pubTagsInput.addEventListener('focus', () => showTagSuggestions(els.pubTagsInput.value));
    els.pubTagsInput.addEventListener('blur', () => {
      setTimeout(() => {
        els.pubTagsSuggestions.hidden = true;
      }, 150);
    });
    els.pubTagsInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const val = els.pubTagsInput.value.trim();
        if (val) addTag(val);
      } else if (e.key === 'Backspace' && !els.pubTagsInput.value && selectedTags.length) {
        selectedTags = selectedTags.slice(0, -1);
        renderTagPills();
        markMetaDirty();
      }
    });
    els.pubTagsContainer.addEventListener('click', () => els.pubTagsInput.focus());

    // ── Category combobox ─────────────────────────────────────────────────────
    const renderCategoryChip = () => {
      els.pubCategoryChips.innerHTML = '';
      if (selectedCategory) {
        const chip = document.createElement('span');
        chip.className = 'tag-pill';
        const text = document.createElement('span');
        text.textContent = selectedCategory;
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'tag-pill-remove';
        removeBtn.setAttribute('aria-label', `Remove category ${selectedCategory}`);
        removeBtn.textContent = '×';
        removeBtn.addEventListener('click', () => {
          selectedCategory = null;
          renderCategoryChip();
          markGeneralDirty();
        });
        chip.append(text, removeBtn);
        els.pubCategoryChips.append(chip);
        els.pubCategoryInput.placeholder = '';
      } else {
        els.pubCategoryInput.placeholder = 'Select or create…';
      }
    };

    const showCategorySuggestions = (filter: string) => {
      const input = filter.toLowerCase().trim();
      const matches = allCategorySuggestions.filter((c) => !input || c.includes(input));

      els.pubCategorySuggestions.innerHTML = '';

      if (input && !matches.find((c) => c.toLowerCase() === input)) {
        const createItem = document.createElement('div');
        createItem.className = 'tag-suggestion-item';
        createItem.textContent = `Create "${filter.trim()}"`;
        createItem.addEventListener('mousedown', (e) => {
          e.preventDefault();
          selectCategory(filter.trim());
        });
        els.pubCategorySuggestions.append(createItem);
      }

      for (const match of matches.slice(0, 8)) {
        const item = document.createElement('div');
        item.className = 'tag-suggestion-item';
        item.textContent = match;
        item.addEventListener('mousedown', (e) => {
          e.preventDefault();
          selectCategory(match);
        });
        els.pubCategorySuggestions.append(item);
      }

      els.pubCategorySuggestions.hidden = els.pubCategorySuggestions.children.length === 0;
    };

    const selectCategory = (category: string) => {
      selectedCategory = category.toLowerCase().trim() || null;
      els.pubCategoryInput.value = '';
      els.pubCategorySuggestions.hidden = true;
      renderCategoryChip();
      markGeneralDirty();
    };

    els.pubCategoryInput.addEventListener('input', () => showCategorySuggestions(els.pubCategoryInput.value));
    els.pubCategoryInput.addEventListener('focus', () => showCategorySuggestions(els.pubCategoryInput.value));
    els.pubCategoryInput.addEventListener('blur', () => {
      setTimeout(() => {
        els.pubCategorySuggestions.hidden = true;
      }, 150);
    });
    els.pubCategoryInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const val = els.pubCategoryInput.value.trim();
        if (val) selectCategory(val);
      }
    });
    els.pubCategoryContainer.addEventListener('click', () => els.pubCategoryInput.focus());

    // ── Save metadata ─────────────────────────────────────────────────────────
    const applyMetaPayloadToForm = (payload: Record<string, unknown>) => {
      els.pubTitle.value = String(payload.title ?? '');
      els.pubExcerpt.value = String(payload.excerpt ?? '');
      els.pubAuthor.value = String(payload.author ?? '');
      els.pubDate.value = String(payload.publishDate ?? '');
      els.pubSeo.value = String(payload.seoDescription ?? '');
      const ap = String(payload.articlePath ?? '');
      els.pubArticlePath.value = ap || generateArticlePath(els.pubTitle.value, currentRequestId);
      // Tags and category via pill components
      selectedTags = Array.isArray(payload.tags)
        ? (payload.tags as string[]).map((t) => String(t).trim()).filter(Boolean)
        : [];
      const rawCat = String(payload.category ?? '').trim();
      selectedCategory = rawCat || null;
      renderTagPills();
      renderCategoryChip();
      autoResize(els.pubTitle);
      updateSeoCharCount();
      updateGeneralSummary();
      updateMetaSummary();
    };

    const saveMetadata = async (payloadOverride?: Record<string, unknown>) => {
      clearFieldError(els.errTitle);
      clearFieldError(els.errExcerpt);

      const title = payloadOverride ? String(payloadOverride.title ?? '') : els.pubTitle.value.trim();
      const articlePath = payloadOverride ? String(payloadOverride.articlePath ?? '') : els.pubArticlePath.value.trim();

      let hasErrors = false;
      if (!title) {
        showFieldError(els.errTitle, 'Title is required before saving.');
        hasErrors = true;
      }
      if (hasErrors) return;

      if (!lockManager?.currentToken) {
        const acquired = await acquireLock();
        if (!acquired) {
          setMetaStatus('Could not acquire edit lock.', 'is-error');
          return;
        }
      }

      const lockToken = lockManager?.currentToken;
      if (!lockToken) {
        setMetaStatus('Edit lock not held.', 'is-error');
        return;
      }

      let token: string;
      try {
        token = await getToken();
      } catch {
        setMetaStatus('Authentication error.', 'is-error');
        return;
      }

      els.btnSaveMeta.disabled = true;
      els.btnMetaUndo.hidden = true;
      setMetaStatus('Saving…');

      let publishPayload: Record<string, unknown>;

      if (payloadOverride) {
        publishPayload = payloadOverride;
      } else {
        // Derive the slug from the generated path for backward compatibility
        const derivedSlug = articlePath ? articlePath.replace('src/data/post/', '').replace('.md', '') : '';

        publishPayload = { title };
        if (derivedSlug) publishPayload.slug = derivedSlug;
        if (articlePath) publishPayload.articlePath = articlePath;

        const excerpt = els.pubExcerpt.value.trim();
        if (excerpt) publishPayload.excerpt = excerpt;

        const author = els.pubAuthor.value.trim();
        if (author) publishPayload.author = author;

        const publishDate = els.pubDate.value.trim();
        if (publishDate) publishPayload.publishDate = publishDate;

        const seoDesc = els.pubSeo.value.trim();
        if (seoDesc) publishPayload.seoDescription = seoDesc;

        if (selectedCategory) publishPayload.category = selectedCategory;
        if (selectedTags.length) publishPayload.tags = [...selectedTags];
      }

      // Capture current payload for undo before overwriting
      const previousPayloadForUndo = metaUndoPayload ?? null;
      const currentPayloadForUndo: Record<string, unknown> = {
        title: els.pubTitle.value.trim(),
        excerpt: els.pubExcerpt.value.trim(),
        author: els.pubAuthor.value.trim(),
        publishDate: els.pubDate.value.trim(),
        category: selectedCategory ?? '',
        tags: [...selectedTags],
        seoDescription: els.pubSeo.value.trim(),
        articlePath: els.pubArticlePath.value.trim(),
      };

      try {
        const res = await fetch(PATCH_WORKFLOW_ENDPOINT, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            action: 'patch_canonical_input',
            request_id: currentRequestId,
            lock_token: lockToken,
            expected_record_version: currentRecordVersion,
            promote_publish_payload: publishPayload,
          }),
        });

        const json = (await res.json().catch(() => ({ ok: false }))) as Record<string, unknown>;
        if (!res.ok || !json.ok) {
          if (res.status === 409) {
            // Version conflict: another save (node or AI) advanced the record version.
            // Re-fetch to sync currentRecordVersion, then restore the user's form values.
            setMetaStatus('Draft changed since this panel loaded. Refreshing…');
            try {
              const freshToken = await getToken();
              const refreshRes = await fetch(`${DRAFT_ENDPOINT}?draftId=${encodeURIComponent(currentRequestId)}`, {
                headers: { Authorization: `Bearer ${freshToken}` },
              });
              const freshJson = (await refreshRes.json().catch(() => ({}))) as Record<string, unknown>;
              if (typeof freshJson.recordVersion === 'number') {
                currentRecordVersion = freshJson.recordVersion as number;
              }
              // Restore the user's unsaved edits to the form so they can retry
              applyMetaPayloadToForm(currentPayloadForUndo);
            } catch {
              // ignore secondary fetch errors; user still sees retry prompt
            }
            setMetaStatus('Draft refreshed — try Save again.', 'is-error');
            return;
          }
          const errMsg = typeof json.error === 'string' ? json.error : `HTTP ${res.status}`;
          setMetaStatus(`Save failed: ${errMsg}`, 'is-error');
          return;
        }

        const record = json.record as Record<string, unknown> | undefined;
        if (typeof record?.version === 'number') {
          currentRecordVersion = record.version as number;
        }

        // Update local history snapshot so the popover reflects this save
        draftHistory.push({
          at: new Date().toISOString(),
          action: 'patch_canonical_input',
          details: { previousPayload: currentPayloadForUndo, nextPayload: publishPayload },
        });
        updateHistoryButtonStates();

        // If restoring a previous payload, apply its values to the form
        if (payloadOverride) applyMetaPayloadToForm(payloadOverride);

        // Set undo target: one-step undo goes back to what the form showed before this save
        metaUndoPayload = payloadOverride ? null : currentPayloadForUndo;
        void previousPayloadForUndo; // not used for multi-step undo chain

        metadataSaved = true;
        metadataDirty = false;
        els.generalDirtyDot.hidden = true;
        els.metaDirtyDot.hidden = true;
        setMetaStatus('Saved', 'is-ok');
        updateGeneralSummary();
        updateMetaSummary();
        toggleGeneralForm(false);
        toggleMetaForm(false);

        if (metaUndoPayload) {
          els.btnMetaUndo.hidden = false;
        }

        updateReadinessPanel();
      } catch (err) {
        setMetaStatus(err instanceof Error ? err.message : 'Save failed.', 'is-error');
      } finally {
        els.btnSaveMeta.disabled = false;
      }
    };

    els.btnGeneralToggle.addEventListener('click', () => toggleGeneralForm());
    els.btnMetaToggle.addEventListener('click', () => toggleMetaForm());

    els.btnCopyPath.addEventListener('click', async () => {
      const path = els.pubArticlePath.value.trim();
      if (!path) return;
      try {
        await navigator.clipboard.writeText(path);
        const orig = els.btnCopyPath.title;
        els.btnCopyPath.title = 'Copied!';
        setTimeout(() => {
          els.btnCopyPath.title = orig;
        }, 1500);
      } catch {
        // clipboard not available — silently ignore
      }
    });

    els.btnSaveMeta.addEventListener('click', () => saveMetadata());

    els.btnMetaUndo.addEventListener('click', async () => {
      if (!metaUndoPayload) return;
      const target = metaUndoPayload;
      metaUndoPayload = null;
      els.btnMetaUndo.hidden = true;
      await saveMetadata(target);
    });

    els.btnHeaderHistory.addEventListener('click', () => {
      showHistoryPopover(els.btnHeaderHistory, 'metadata', (entry) => {
        const prev = entry.details?.previousPayload as Record<string, unknown> | undefined;
        if (prev) void saveMetadata(prev);
      });
    });

    // ── Node rendering ────────────────────────────────────────────────────────
    const renderArticle = (nodes: ArticleBodyNode[]) => {
      currentNodes = nodes;
      els.nodesContainer.innerHTML = '';
      nodeHistBtns.clear();

      for (const node of nodes) {
        if (node.visibility && node.visibility !== 'public') continue;

        const rendered = renderNode(node);
        const wrapper = wrapNode(node, rendered);

        const toolbar = document.createElement('div');
        toolbar.className = 'dl-node-toolbar';

        const editBtn = document.createElement('button');
        editBtn.className = 'dl-node-btn is-edit';
        editBtn.setAttribute('aria-label', 'Edit this block');
        editBtn.title = 'Edit this block';
        editBtn.append(cloneIcon('pencil', 'Edit'));
        editBtn.addEventListener('click', () => {
          if (wrapper.dataset.editing) {
            // Cancel flow: guard unsaved changes
            if (!activeEditor?.isDirty()) {
              closeActiveEditor(false);
            } else if (window.confirm('Discard unsaved changes in this block?')) {
              closeActiveEditor(false);
            }
          } else {
            void onEditClick(node, wrapper);
          }
        });

        const aiBtn = document.createElement('button');
        aiBtn.className = 'dl-node-btn is-ai';
        aiBtn.setAttribute('aria-label', 'Ask AI to revise this block');
        aiBtn.title = 'Ask AI to revise this block';
        aiBtn.append(cloneIcon('sparkles', 'AI'));
        aiBtn.addEventListener('click', () => onAskAiClick(node, wrapper));

        const histBtn = document.createElement('button');
        histBtn.className = 'dl-node-btn is-history';
        histBtn.setAttribute('aria-label', 'View block edit history');
        histBtn.title = 'Block history';
        histBtn.append(cloneIcon('history', 'History'));
        histBtn.addEventListener('click', () => showHistoryPopover(histBtn, node.id));
        // Disable initially if no history entries for this node (Rule 3)
        const hasNodeHistory = draftHistory.some(
          (e) => e.action === 'admin_update_node' && e.details?.nodeId === node.id
        );
        histBtn.disabled = !hasNodeHistory;
        nodeHistBtns.set(node.id, histBtn);

        toolbar.append(editBtn, aiBtn, histBtn);
        wrapper.append(toolbar);

        // Persistent node badge: always at bottom-left, shows node ID + saved/undo state
        const badge = document.createElement('div');
        badge.className = 'dl-node-badge';
        badge.setAttribute('aria-hidden', 'true');

        const badgeId = document.createElement('span');
        badgeId.className = 'dl-node-badge-id';
        badgeId.textContent = node.id;

        const badgeSaved = document.createElement('span');
        badgeSaved.className = 'dl-node-badge-saved';
        badgeSaved.textContent = '· Saved';

        const badgeUndo = document.createElement('button');
        badgeUndo.type = 'button';
        badgeUndo.className = 'dl-node-badge-undo';
        badgeUndo.title = 'Undo last save';
        badgeUndo.setAttribute('aria-label', 'Undo last save');
        badgeUndo.append(cloneIcon('arrow-back-up', '↩'));

        badge.append(badgeId, badgeSaved, badgeUndo);
        wrapper.append(badge);

        wrapper.addEventListener('mouseup', () => {
          if (wrapper.dataset.editing) return;
          const sel = window.getSelection();
          if (sel && sel.rangeCount > 0 && !sel.isCollapsed && wrapper.contains(sel.anchorNode)) {
            aiBtn.classList.add('ai-has-selection');
          } else {
            aiBtn.classList.remove('ai-has-selection');
          }
        });

        els.nodesContainer.append(wrapper);
      }
    };

    // ── Editor open/close ─────────────────────────────────────────────────────
    const closeActiveEditor = (save: boolean) => {
      if (!activeEditor || !activeNodeWrapper) return;
      stopDirtyWatch();
      if (!save) activeEditor.unmount();
      // Restore the block's edit button from cancel (X) back to pencil
      const eBtn = activeNodeWrapper.querySelector<HTMLButtonElement>('.dl-node-btn.is-edit');
      if (eBtn) {
        eBtn.innerHTML = '';
        eBtn.append(cloneIcon('pencil', 'Edit'));
        eBtn.setAttribute('aria-label', 'Edit this block');
        eBtn.title = 'Edit this block';
        eBtn.classList.remove('is-cancel');
      }
      activeNodeWrapper.removeAttribute('data-editing');
      activeEditor = null;
      activeNodeWrapper = null;
      setMode('idle');
    };

    // Update the persistent badge after a block save: show "Saved · Undo" until next save or undo.
    const updateNodeBadge = (
      wrapper: HTMLElement,
      nodeId: string,
      previousPublic: Partial<ArticleBodyNode['public']>
    ) => {
      const badge = wrapper.querySelector<HTMLElement>('.dl-node-badge');
      if (!badge) return;

      badge.classList.add('has-saved');

      const undoBtn = badge.querySelector<HTMLButtonElement>('.dl-node-badge-undo');
      if (!undoBtn) return;

      // Replace previous listener by cloning the button
      const fresh = undoBtn.cloneNode(true) as HTMLButtonElement;
      undoBtn.replaceWith(fresh);

      fresh.addEventListener('click', async () => {
        badge.classList.remove('has-saved');
        const currentNode = currentNodes.find((n) => n.id === nodeId);
        if (!currentNode) return;
        const saved = await saveNodeUpdate(nodeId, previousPublic, wrapper, currentNode);
        if (saved) {
          draftHistory.push({
            at: new Date().toISOString(),
            action: 'admin_update_node',
            details: { nodeId, previousPublic: currentNode.public, nextPublic: previousPublic },
          });
        }
      });
    };

    const onEditClick = async (node: ArticleBodyNode, wrapper: HTMLElement) => {
      if (wrapper.dataset.editing) return;
      if (editMode === 'ai') return;

      // Dirty-check: if switching away from an unsaved editor, confirm first
      if (activeEditor?.isDirty() && activeNodeWrapper && activeNodeWrapper !== wrapper) {
        const keep = !window.confirm('You have unsaved changes in this block. Discard them and edit another block?');
        if (keep) return;
      }

      closeActiveEditor(false);

      if (!lockManager?.currentToken) {
        updateLockBar({ held: false });
        const acquired = await acquireLock();
        if (!acquired) return;
      }

      // Snapshot public fields before editing for Cancel and one-step undo
      const previousPublic = { ...node.public } as Partial<ArticleBodyNode['public']>;

      wrapper.dataset.editing = 'true';
      activeNodeWrapper = wrapper;
      activeEditor = new NodeEditor();
      setMode('editing');

      // Transform pencil button to cancel (X) while this block is in edit mode
      const eBtn = wrapper.querySelector<HTMLButtonElement>('.dl-node-btn.is-edit');
      if (eBtn) {
        eBtn.innerHTML = '';
        eBtn.append(cloneIcon('x', '✕'));
        eBtn.setAttribute('aria-label', 'Cancel editing this block');
        eBtn.title = 'Cancel editing this block';
        eBtn.classList.add('is-cancel');
      }

      activeEditor.mount(node, wrapper, {
        onSave: async (updatedFields) => {
          const saved = await saveNodeUpdate(node.id, updatedFields, wrapper, node);
          if (saved) {
            draftHistory.push({
              at: new Date().toISOString(),
              action: 'admin_update_node',
              details: { nodeId: node.id, previousPublic, nextPublic: updatedFields },
            });
            const hBtn = nodeHistBtns.get(node.id);
            if (hBtn) hBtn.disabled = false;
            closeActiveEditor(false);
            updateNodeBadge(wrapper, node.id, previousPublic);
          }
        },
        onCancel: () => closeActiveEditor(false),
        onNoChange: () => closeActiveEditor(false),
      });
      startDirtyWatch();
    };

    // ── AI ask flow ───────────────────────────────────────────────────────────
    const onAskAiClick = (node: ArticleBodyNode, wrapper: HTMLElement) => {
      if (!currentRequestId) return;
      if (editMode === 'editing') return;

      let selectedText: string | undefined;
      if (wrapper.dataset.editing && activeEditor) {
        const sel = activeEditor.getSelectionText();
        if (sel) selectedText = sel;
      } else {
        const browserSel = window.getSelection();
        if (browserSel && !browserSel.isCollapsed && wrapper.contains(browserSel.anchorNode)) {
          selectedText = browserSel.toString().trim() || undefined;
        }
      }

      setMode('ai');
      showInstructionPopover(
        wrapper,
        selectedText,
        async (instruction) => {
          const spinnerEl = Object.assign(document.createElement('div'), {
            className:
              'absolute inset-0 z-20 flex items-center justify-center rounded-xl bg-white/80 dark:bg-slate-900/80 text-sm font-bold',
            textContent: 'Asking AI…',
          });
          wrapper.style.position = 'relative';
          wrapper.append(spinnerEl);

          let token: string;
          try {
            token = await getToken();
          } catch {
            spinnerEl.remove();
            setMode('idle');
            return;
          }

          const result = await askAiForNode({
            requestId: currentRequestId,
            nodeId: node.id,
            selectedText,
            instruction,
            token: token,
          });
          spinnerEl.remove();

          if (!result.ok) {
            alert(`AI request failed: ${result.error}`);
            setMode('idle');
            return;
          }

          renderSuggestionOverlay(
            wrapper,
            node.public,
            result.suggestion,
            async (fields) => {
              if (!lockManager?.currentToken) {
                const acquired = await acquireLock();
                if (!acquired) {
                  alert('Could not acquire edit lock to apply suggestion.');
                  setMode('idle');
                  return;
                }
              }
              await saveNodeUpdate(node.id, fields, wrapper, node);
              setMode('idle');
            },
            () => {
              setMode('idle');
            }
          );
        },
        () => {
          setMode('idle');
        }
      );
    };

    // ── Node save ─────────────────────────────────────────────────────────────
    const saveNodeUpdate = async (
      nodeId: string,
      updatedFields: Partial<ArticleBodyNode['public']>,
      wrapper: HTMLElement,
      originalNode: ArticleBodyNode
    ): Promise<boolean> => {
      const lockToken = lockManager?.currentToken;
      if (!lockToken) {
        alert('Edit lock not held. Please retry.');
        return false;
      }

      let token: string;
      try {
        token = await getToken();
      } catch {
        alert('Authentication error. Please refresh.');
        return false;
      }

      const res = await fetch(UPDATE_NODE_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ requestId: currentRequestId, lockToken, nodeId, updatedPublicFields: updatedFields }),
      });

      const json = (await res.json().catch(() => ({ ok: false, error: 'Parse error' }))) as Record<string, unknown>;
      if (!res.ok || !json.ok) {
        alert(`Save failed: ${typeof json.error === 'string' ? json.error : 'Unknown error'}`);
        return false;
      }

      // Node save increments the record version — keep our local copy in sync
      if (typeof json.version === 'number') {
        currentRecordVersion = json.version as number;
      }

      const updatedNode: ArticleBodyNode = { ...originalNode, public: { ...originalNode.public, ...updatedFields } };
      const nodeIndex = currentNodes.findIndex((n) => n.id === nodeId);
      if (nodeIndex !== -1) currentNodes[nodeIndex] = updatedNode;

      const newRendered = renderNode(updatedNode);
      const existingToolbar = wrapper.querySelector('.dl-node-toolbar');
      const existingBadge = wrapper.querySelector('.dl-node-badge');
      wrapper.innerHTML = '';
      wrapper.append(newRendered);
      if (existingToolbar) wrapper.append(existingToolbar);
      if (existingBadge) wrapper.append(existingBadge);

      updateReadinessPanel();
      return true;
    };

    // ── Reset draft view ──────────────────────────────────────────────────────
    const resetDraftView = async () => {
      closeActiveEditor(false);

      if (lockManager) {
        if (lockManager.currentToken) {
          await lockManager.checkin().catch(() => {});
        }
        lockManager = null;
      }

      resetLockBar();
      // Hide active content, show inspector empty state
      els.articleHeaderCard.hidden = true;
      els.articleView.hidden = true;
      els.inspectorEmpty.hidden = false;
      els.inspectorContent.hidden = true;
      els.nodesContainer.innerHTML = '';
      els.btnPublish.disabled = true;
      els.loadStatus.hidden = true;
      els.loadStatus.textContent = '';
      currentNodes = [];
      currentRecordVersion = 0;
      metadataSaved = false;
      metadataDirty = false;
      draftHistory = [];
      metaUndoPayload = null;
      els.btnMetaUndo.hidden = true;
      els.generalDirtyDot.hidden = true;
      els.metaDirtyDot.hidden = true;
      closeOpenPopover();
      els.readinessGroups.innerHTML = '';
      els.readinessChips.innerHTML = '';
      els.readinessLabel.textContent = '';
      els.readinessLabel.className = 'readiness-pill';
      els.publishStatus.textContent = '';
      els.readinessAudit.hidden = true;
      els.readinessToggle.textContent = 'Details';
      els.readinessToggle.setAttribute('aria-expanded', 'false');
      // Reset both sections to compact summary view
      toggleGeneralForm(false);
      els.generalSummary.textContent = '';
      els.generalDirtyDot.hidden = true;
      toggleMetaForm(false);
      els.metaSummary.textContent = '';
      setMetaStatus('');
      // Reset tag/category pickers
      selectedTags = [];
      selectedCategory = null;
      els.pubTagsPills.innerHTML = '';
      els.pubTagsInput.value = '';
      els.pubCategoryChips.innerHTML = '';
      els.pubCategoryInput.value = '';
      els.pubCategoryInput.placeholder = 'Select or create…';
    };

    // ── Load draft ────────────────────────────────────────────────────────────
    const loadDraft = async (requestId: string, token: string) => {
      if (!requestId) {
        // No draft — show compact dock empty state, nothing in left column
        els.inspectorEmpty.hidden = false;
        els.inspectorContent.hidden = true;
        return;
      }

      await resetDraftView();

      currentRequestId = requestId;

      const currentParams = new URLSearchParams(window.location.search);
      const urlDraftId = currentParams.get('draftId') ?? currentParams.get('requestId') ?? '';
      const newUrl = new URL(window.location.href);
      newUrl.searchParams.set('draftId', requestId);
      newUrl.searchParams.delete('requestId');
      if (urlDraftId !== requestId) {
        history.pushState({}, '', newUrl.toString());
      } else {
        history.replaceState({}, '', newUrl.toString());
      }

      els.loadStatus.hidden = false;
      els.loadStatus.textContent = 'Loading article…';

      try {
        const res = await fetch(`${DRAFT_ENDPOINT}?draftId=${encodeURIComponent(requestId)}`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const json = (await res.json().catch(() => ({ ok: false }))) as Record<string, unknown>;
        if (!res.ok || !json.ok) {
          els.loadStatus.textContent = typeof json.error === 'string' ? json.error : `Load failed (${res.status})`;
          return;
        }

        if (typeof json.recordVersion === 'number') {
          currentRecordVersion = json.recordVersion as number;
        }

        // Load history snapshots for this draft
        draftHistory = Array.isArray(json.history) ? (json.history as HistoryEntry[]) : [];
        metaUndoPayload = null;
        els.btnMetaUndo.hidden = true;

        const input = (json.input ?? {}) as Record<string, unknown>;
        const content = (input.content ?? {}) as Record<string, unknown>;
        const publication = (input.publication ?? {}) as Record<string, unknown>;
        const publishPayload = (publication.publish_payload ?? {}) as Record<string, unknown>;
        const taxonomy = (input.taxonomy ?? {}) as Record<string, unknown>;
        const seo = (input.seo ?? {}) as Record<string, unknown>;

        // Prefer publish_payload (editor's saved values) over raw input fields
        const title = String(
          publishPayload.title ??
            content.title ??
            (json.draft && (json.draft as Record<string, unknown>).title) ??
            'Untitled'
        );
        const excerpt = String(publishPayload.excerpt ?? content.deck ?? '');
        const author = String(publishPayload.author ?? content.author ?? '');
        const category = String(publishPayload.category ?? taxonomy.category ?? '');
        const tagsArr = Array.isArray(publishPayload.tags)
          ? (publishPayload.tags as string[])
          : Array.isArray(taxonomy.tags)
            ? (taxonomy.tags as string[])
            : [];
        const seoDesc = String(publishPayload.seoDescription ?? seo.meta_description ?? '');

        // Publish date: prefer saved, fall back to publication.publish_date, then default to today
        const savedPublishDate = String(publishPayload.publishDate ?? publication.publish_date ?? '');
        let publishDateValue = '';
        if (savedPublishDate) {
          try {
            const d = new Date(savedPublishDate);
            if (Number.isFinite(d.getTime())) {
              publishDateValue = d.toISOString().slice(0, 10);
            }
          } catch {
            publishDateValue = '';
          }
        }
        if (!publishDateValue) {
          publishDateValue = new Date().toISOString().slice(0, 10);
        }

        // Article path: use saved or generate from title
        const savedArticlePath = String(publishPayload.articlePath ?? '');
        const articlePath = savedArticlePath || generateArticlePath(title, requestId);

        els.pubTitle.value = title;
        els.pubExcerpt.value = excerpt;
        els.pubAuthor.value = author;
        els.pubDate.value = publishDateValue;
        els.pubSeo.value = seoDesc;
        els.pubArticlePath.value = articlePath;
        // Load tags and category into pill components
        selectedTags = tagsArr.map((t) => String(t).trim()).filter(Boolean);
        selectedCategory = category.trim() || null;
        renderTagPills();
        renderCategoryChip();
        updateSeoCharCount();
        autoResize(els.pubTitle);
        updateGeneralSummary();
        updateMetaSummary();

        // Consider metadata saved if a publish_payload with title exists
        if (publishPayload.title) {
          metadataSaved = true;
          setMetaStatus('Loaded', 'is-ok');
        }

        const articleBody = content.article_body as { nodes?: ArticleBodyNode[] } | undefined;
        if (articleBody?.nodes?.length) {
          renderArticle(articleBody.nodes);
          updateHistoryButtonStates();
          // Show article content and inspector
          els.articleHeaderCard.hidden = false;
          els.articleView.hidden = false;
          els.inspectorEmpty.hidden = true;
          els.inspectorContent.hidden = false;
        } else {
          els.loadStatus.textContent = 'This draft has no article body nodes yet.';
          els.loadStatus.hidden = false;
          return;
        }

        lockManager = new LockManager(currentRequestId, getToken);
        lockManager.setOnStateChange((state) => updateLockBar(state as Parameters<typeof updateLockBar>[0]));
        lockManager.attachUnloadHandler();

        const lockStatus = await lockManager.status();
        updateLockBar(lockStatus as Parameters<typeof updateLockBar>[0]);

        els.loadStatus.hidden = true;

        // Load taxonomy suggestions in the background (non-blocking)
        void loadTaxonomy();
      } catch (err) {
        els.loadStatus.textContent = err instanceof Error ? err.message : 'Failed to load draft.';
      }
    };

    // ── Publish ───────────────────────────────────────────────────────────────
    els.btnPublish.addEventListener('click', async () => {
      if (!currentRequestId) return;

      const title = els.pubTitle.value.trim();
      const articlePath = els.pubArticlePath.value.trim();

      if (!title) {
        showFieldError(els.errTitle, 'Title is required.');
        els.pubTitle.focus();
        return;
      }
      if (!articlePath) {
        els.publishStatus.textContent = 'Article path not generated. Enter a title first.';
        els.publishStatus.className = 'publish-status is-error';
        return;
      }
      if (!currentNodes.length) {
        els.publishStatus.textContent = 'No article body to publish.';
        els.publishStatus.className = 'publish-status is-error';
        return;
      }

      if (
        !confirm(
          `Mark "${title}" as published?\n\nThis records the publication timestamp on the workflow record. Trigger a site deploy separately to make the article live.`
        )
      )
        return;

      els.btnPublish.disabled = true;
      els.publishStatus.textContent = 'Publishing…';
      els.publishStatus.className = 'publish-status';

      let token: string;
      try {
        token = await getToken();
      } catch {
        els.publishStatus.textContent = 'Auth error';
        els.publishStatus.className = 'publish-status is-error';
        els.btnPublish.disabled = false;
        return;
      }

      const lockToken = lockManager?.currentToken;

      try {
        const body: Record<string, unknown> = {
          action: 'set_published_time',
          request_id: currentRequestId,
          lock_token: lockToken,
          published_time: new Date().toISOString(),
        };

        const res = await fetch(PATCH_WORKFLOW_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          const j = (await res.json().catch(() => ({}))) as Record<string, unknown>;
          throw new Error(typeof j.error === 'string' ? j.error : `HTTP ${res.status}`);
        }

        if (lockManager) await lockManager.checkin();
        els.publishStatus.textContent = '✓ Publication timestamp recorded. Trigger a site deploy to go live.';
        els.publishStatus.className = 'publish-status is-ok';
        els.btnPublish.disabled = false;
      } catch (err) {
        els.publishStatus.textContent = err instanceof Error ? err.message : 'Publish failed.';
        els.publishStatus.className = 'publish-status is-error';
        els.btnPublish.disabled = false;
      }
    });

    // ── Draft picker modal ────────────────────────────────────────────────────
    const escapeHtml = (value: unknown) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatDate = (value: string) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return 'Unknown';
      return new Intl.DateTimeFormat(undefined, { dateStyle: 'medium', timeStyle: 'short' }).format(date);
    };

    const getReadinessLabel = (r: DraftSummary['readiness']) => `${r?.ready ?? 0}/${r?.total ?? 4} ready`;

    const getDisplayTitle = (title: string) =>
      String(title || 'Untitled draft')
        .replace(/\s+admin-draft-[a-f0-9-]{12,}$/i, '')
        .trim() || 'Untitled draft';

    const openModal = () => {
      els.modal.classList.add('is-open');
      els.modal.setAttribute('aria-hidden', 'false');
      const firstFocusable = els.modal.querySelector<HTMLElement>('button, input, [tabindex="0"]');
      firstFocusable?.focus();
    };

    const closeModal = () => {
      els.modal.classList.remove('is-open');
      els.modal.setAttribute('aria-hidden', 'true');
    };

    const renderDraftPickerRows = (drafts: DraftSummary[]) => {
      els.draftPickerList.innerHTML = '';
      if (drafts.length === 0) {
        els.draftPickerEmpty.hidden = false;
        return;
      }
      els.draftPickerEmpty.hidden = true;

      for (const draft of drafts) {
        const row = document.createElement('div');
        row.className = 'dp-row';

        const readinessClass = draft.readiness?.isReady ? 'is-ready' : 'is-draft';
        const readinessLabel = getReadinessLabel(draft.readiness);
        const displayTitle = getDisplayTitle(draft.title);
        const dateStr = formatDate(draft.updatedAt || draft.savedAt);
        const statusLabel = draft.lifecycleStatus || draft.recordStatus || 'draft';
        const savedByStr = draft.savedBy
          ? `<span class="dp-sep">·</span><span>by ${escapeHtml(draft.savedBy)}</span>`
          : '';
        const shortId = draft.id.length > 8 ? draft.id.slice(0, 8) + '…' : draft.id;

        row.innerHTML = `
          <div class="dp-row-main">
            <span class="dp-title">${escapeHtml(displayTitle)}</span>
            <span class="dp-meta">
              <span class="dp-slug">${escapeHtml(shortId)}</span>
              <span class="dp-sep">·</span>
              <span>${escapeHtml(statusLabel)}</span>
              <span class="dp-sep">·</span>
              <span>${escapeHtml(dateStr)}</span>
              ${savedByStr}
            </span>
            <span class="dp-badge ${readinessClass}">${escapeHtml(readinessLabel)}</span>
          </div>
          <button class="btn-secondary btn-sm dp-load-btn" type="button" data-draft-id="${escapeHtml(draft.id)}">Load</button>
        `;

        row.querySelector<HTMLButtonElement>('.dp-load-btn')!.addEventListener('click', async () => {
          closeModal();
          const token = await getAccessToken();
          if (!token) return;
          await loadDraft(draft.id, token);
        });

        els.draftPickerList.append(row);
      }
    };

    const filterDraftRows = () => {
      const q = els.modalSearch.value.toLowerCase().trim();
      if (!q) {
        renderDraftPickerRows(allDraftRows);
        return;
      }
      const filtered = allDraftRows.filter(
        (d) =>
          d.title?.toLowerCase().includes(q) || d.id?.toLowerCase().includes(q) || d.author?.toLowerCase().includes(q)
      );
      renderDraftPickerRows(filtered);
    };

    const fetchDraftList = async () => {
      els.modalStatus.textContent = 'Loading JSON drafts…';
      els.draftPickerList.innerHTML = '';
      els.draftPickerEmpty.hidden = true;
      els.btnModalRefresh.disabled = true;

      try {
        const token = await getAccessToken();
        if (!token) {
          els.modalStatus.textContent = 'Not authenticated.';
          return;
        }
        const res = await fetch(LIST_DRAFTS_ENDPOINT, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const json = (await res.json().catch(() => ({ ok: false }))) as Record<string, unknown>;
        if (!res.ok || !json.ok) {
          els.modalStatus.textContent =
            typeof json.error === 'string' ? json.error : `Could not load drafts (${res.status})`;
          return;
        }
        allDraftRows = Array.isArray(json.drafts) ? (json.drafts as DraftSummary[]) : [];
        modalDraftsCache = allDraftRows;
        els.modalStatus.textContent = `${allDraftRows.length} draft${allDraftRows.length === 1 ? '' : 's'} loaded.`;
        filterDraftRows();
      } catch (err) {
        els.modalStatus.textContent = err instanceof Error ? err.message : 'Failed to load drafts.';
      } finally {
        els.btnModalRefresh.disabled = false;
      }
    };

    const openDraftPicker = () => {
      openModal();
      if (modalDraftsCache === null) {
        fetchDraftList();
      } else {
        allDraftRows = modalDraftsCache;
        filterDraftRows();
      }
    };

    els.btnOpenDraftListInspector.addEventListener('click', openDraftPicker);
    els.btnModalClose.addEventListener('click', closeModal);

    els.btnModalRefresh.addEventListener('click', () => {
      modalDraftsCache = null;
      fetchDraftList();
    });

    els.modalSearch.addEventListener('input', filterDraftRows);

    els.modal.addEventListener('click', (e) => {
      if (e.target === els.modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && els.modal.classList.contains('is-open')) closeModal();
    });

    // ── Auth bootstrap ────────────────────────────────────────────────────────
    authState('checking');

    (async () => {
      try {
        const oauthUser = await handleOAuthCallback();
        if (oauthUser) window.__drLurieLoginModal?.close();
        const user = currentUser();
        if (!user) {
          authState('signed-out');
          return;
        }

        const authToken = await getAccessToken();
        if (!authToken) {
          authState('error');
          return;
        }

        const stateRes = await fetch('/.netlify/functions/admin-auth-state', {
          headers: { Authorization: `Bearer ${authToken}`, 'Content-Type': 'application/json' },
        }).catch(() => null);
        const stateJson = await stateRes?.json().catch(() => null);
        if (!stateJson?.isAdmin) {
          authState('forbidden');
          return;
        }

        authState('signed-in');
        await loadDraft(initialDraftId, authToken);

        document.addEventListener('dr-lurie:logout', () => authState('signed-out'));
        document.addEventListener('dr-lurie:login', async () => {
          const t = await getAccessToken();
          if (!t) {
            authState('error');
            return;
          }
          authState('signed-in');
        });
      } catch {
        authState('error');
      }
    })();
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>
