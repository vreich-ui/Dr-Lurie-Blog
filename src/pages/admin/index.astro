---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Admin Dashboard';
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="admin-dashboard mx-auto max-w-[920px] px-4 py-10 sm:px-6 sm:py-14"
    data-admin-shell
    data-clerk-publishable-key={clerkPublishableKey}
    hidden
  >
    <header class="dashboard-header">
      <div>
        <p class="dashboard-kicker">Admin workspace</p>
        <h1>{pageTitle}</h1>
        <p class="dashboard-intro">A private command center for Dr. Lurié publishing and workflow tools.</p>
      </div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <AdminNav />

    <section class="dashboard-grid" data-auth-gated hidden>
      <article class="dashboard-card">
        <p class="dashboard-kicker">Publishing</p>
        <h2>Publish Article</h2>
        <p>Create or update Markdown articles, upload imagery, and queue the GitHub-backed publish flow.</p>
        <a class="btn-primary" href="/admin/publish">Open publisher</a>
      </article>

      <article class="dashboard-card">
        <p class="dashboard-kicker">Draft review</p>
        <h2>Drafts</h2>
        <p>Open saved JSON workflow drafts and route them through the gated review workspace.</p>
        <a class="btn-secondary" href="/admin/drafts">Review drafts</a>
      </article>

      <article class="dashboard-card">
        <p class="dashboard-kicker">AI workflow</p>
        <h2>AI Publisher</h2>
        <p>
          Use the ChatKit-powered assistant to prepare approved article payloads and run the server publisher agent.
        </p>
        <a class="btn-secondary" href="/admin/agent-admin">Open AI publisher</a>
      </article>

      <article class="dashboard-card dashboard-card-wide">
        <p class="dashboard-kicker">Coming soon</p>
        <h2>Dashboard roadmap</h2>
        <ul>
          <li>Review recent publishing activity and deploy status.</li>
          <li>Manage draft queues and research note handoffs.</li>
          <li>Monitor admin-only workflow health checks.</li>
        </ul>
      </article>
    </section>
  </section>
</Layout>

<style>
  .admin-dashboard {
    color: var(--aw-color-text-default);
  }

  .dashboard-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgb(229 231 235);
  }

  :global(.dark) .dashboard-header {
    border-color: rgb(30 41 59);
  }

  .dashboard-kicker {
    margin: 0 0 0.5rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .dashboard-header h1,
  .dashboard-card h2 {
    margin: 0;
    font-family: var(--aw-font-heading, inherit);
    font-weight: 800;
    line-height: 1.05;
  }

  .dashboard-header h1 {
    font-size: clamp(2.35rem, 7vw, 4rem);
  }

  .dashboard-intro,
  .dashboard-card p,
  .dashboard-card li,
  .hint {
    color: var(--aw-color-text-muted);
  }

  .dashboard-intro {
    max-width: 42rem;
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }

  .auth-status {
    margin: -0.75rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .dashboard-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.86);
    padding: 1.5rem;
    box-shadow: 0 18px 45px rgb(15 23 42 / 0.07);
  }

  :global(.dark) .dashboard-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.76);
  }

  .dashboard-card p {
    margin: 0.85rem 0 1.15rem;
  }

  .dashboard-card ul {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
  }

  .dashboard-card-wide {
    grid-column: 1 / -1;
  }

  @media (max-width: 767px) {
    .admin-dashboard {
      padding-top: 1.5rem;
    }

    .dashboard-header {
      flex-direction: column;
    }

    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  import { loadClerk } from '~/utils/clerkLoader';

  (() => {
    const adminPage = document.querySelector('.admin-dashboard');
    const clerkPublishableKey = adminPage?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
    const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
    const adminShell = document.querySelector('[data-admin-shell]');
    const authStatus = document.querySelector('[data-auth-status]');
    let clerkLoadPromise;

    const setGatedContentVisible = (visible) => {
      gatedContent.forEach((element) => {
        element.hidden = !visible;
      });
    };

    const getClerk = async () => {
      if (!clerkPublishableKey) {
        throw new Error('Admin authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.');
      }

      clerkLoadPromise ||= loadClerk({ publishableKey: clerkPublishableKey, scriptSrc: clerkJsScriptSrc });

      return clerkLoadPromise;
    };

    const setAdminShellVisible = (visible) => {
      if (adminShell) adminShell.hidden = !visible;
    };

    const redirectToHome = () => {
      window.location.replace('/');
    };

    const authStatusMessages = {
      checking: 'Checking admin access…',
      'signed-out': 'Sign in to view admin tools.',
      forbidden: 'Access denied (not an admin).',
      error: 'Admin auth failed. Please refresh or contact support.',
      'signed-in': '',
    };

    const setAuthStatus = (message) => {
      if (authStatus) authStatus.textContent = message;
    };

    const setAuthState = (state) => {
      const isSignedIn = state === 'signed-in';
      setAuthStatus(authStatusMessages[state] || '');
      setAdminShellVisible(isSignedIn);
      setGatedContentVisible(isSignedIn);

      if (!isSignedIn && state !== 'checking') redirectToHome();
    };

    const getAdminStateForClerk = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };

      const token = await clerk.session.getToken();
      if (!token) return { authenticated: true, isAdmin: false, error: 'Could not retrieve a Clerk session token.' };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response
        .json()
        .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
    };

    const renderAuthState = async (clerk) => {
      const signedIn = Boolean(clerk.isSignedIn && clerk.session);

      if (signedIn) {
        const adminState = await getAdminStateForClerk(clerk);

        if (adminState.isAdmin) {
          setAuthState('signed-in');
          return;
        }

        setAuthState('forbidden');
        return;
      }

      setAuthState('signed-out');
    };

    const initializeClerkAuth = async () => {
      setAuthState('checking');

      try {
        const clerk = await getClerk();
        await renderAuthState(clerk);

        if (typeof clerk.addListener === 'function') {
          clerk.addListener(() => {
            renderAuthState(clerk).catch((error) => {
              console.error('Clerk authentication refresh failed.', error);
            });
          });
        }
      } catch (error) {
        console.error('Clerk authentication initialization failed.', error);
        setAuthState('error');
      }
    };

    initializeClerkAuth();
  })();
</script>
