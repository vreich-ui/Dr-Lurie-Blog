---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Admin Dashboard';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section class="admin-dashboard mx-auto max-w-[920px] px-4 py-10 sm:px-6 sm:py-14">
    <header class="dashboard-header">
      <div>
        <p class="dashboard-kicker">Admin workspace</p>
        <h1>{pageTitle}</h1>
        <p class="dashboard-intro">Publishing and workflow tools for Dr. Lurié.</p>
      </div>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <!-- Shown when signed out -->
    <div data-admin-signin-prompt hidden class="admin-gate-panel">
      <p class="admin-gate-message">
        Sign in with your editor account to access publishing tools. Public articles remain available without login.
      </p>
      <button type="button" class="btn-primary admin-gate-btn" data-admin-open-login> Sign in to editor </button>
    </div>

    <!-- Shown when signed in but not an admin -->
    <div data-admin-forbidden-prompt hidden class="admin-gate-panel">
      <p class="admin-gate-message">Your account does not have editor permissions.</p>
    </div>

    <!-- Shown when signed-in admin -->
    <div data-admin-shell hidden>
      <AdminNav />

      <section class="dashboard-grid" data-auth-gated hidden>
        <article class="dashboard-card">
          <p class="dashboard-kicker">Publishing</p>
          <h2>Library</h2>
          <p>Manage published articles, review unpublished GitHub drafts, and toggle public visibility.</p>
          <a class="btn-primary" href="/admin/library">Open library</a>
        </article>

        <article class="dashboard-card">
          <p class="dashboard-kicker">Editor</p>
          <h2>Publish Article</h2>
          <p>Create or update Markdown articles, upload imagery, and queue the GitHub-backed publish flow.</p>
          <a class="btn-secondary" href="/admin/publish">Open publisher</a>
        </article>

        <article class="dashboard-card">
          <p class="dashboard-kicker">Draft review</p>
          <h2>Drafts</h2>
          <p>Open saved JSON workflow drafts and route them through the gated review workspace.</p>
          <a class="btn-secondary" href="/admin/drafts">Review drafts</a>
        </article>

        <article class="dashboard-card">
          <p class="dashboard-kicker">AI workflow</p>
          <h2>AI Publisher</h2>
          <p>
            Use the ChatKit-powered assistant to prepare approved article payloads and run the server publisher agent.
          </p>
          <a class="btn-secondary" href="/admin/agent-admin">Open AI publisher</a>
        </article>

        <article class="dashboard-card">
          <p class="dashboard-kicker">Storage</p>
          <h2>Blob Store</h2>
          <p>Search, inspect, edit, duplicate, rename, and delete Netlify Blobs objects, or wipe stores entirely.</p>
          <a class="btn-secondary" href="/admin/blobs">Manage blobs</a>
        </article>

        <article class="dashboard-card dashboard-card-wide">
          <p class="dashboard-kicker">Coming soon</p>
          <h2>Dashboard roadmap</h2>
          <ul>
            <li>Review recent publishing activity and deploy status.</li>
            <li>Manage draft queues and research note handoffs.</li>
            <li>Monitor admin-only workflow health checks.</li>
          </ul>
        </article>
      </section>
    </div>
  </section>
</Layout>

<style>
  .admin-dashboard {
    color: var(--aw-color-text-default);
  }

  .dashboard-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgb(229 231 235);
  }

  :global(.dark) .dashboard-header {
    border-color: rgb(30 41 59);
  }

  .dashboard-kicker {
    margin: 0 0 0.5rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .dashboard-header h1,
  .dashboard-card h2 {
    margin: 0;
    font-family: var(--aw-font-heading, inherit);
    font-weight: 800;
    line-height: 1.05;
  }

  .dashboard-header h1 {
    font-size: clamp(2.35rem, 7vw, 4rem);
  }

  .dashboard-intro,
  .dashboard-card p,
  .dashboard-card li,
  .hint {
    color: var(--aw-color-text-muted);
  }

  .dashboard-intro {
    max-width: 42rem;
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }

  .auth-status {
    margin: -0.75rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .admin-gate-panel {
    padding: 2.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .admin-gate-message {
    max-width: 36rem;
    color: var(--aw-color-text-muted, #64748b);
    font-size: 1rem;
    line-height: 1.6;
  }

  .admin-gate-btn {
    min-width: 10rem;
  }

  .dashboard-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.86);
    padding: 1.5rem;
    box-shadow: 0 18px 45px rgb(15 23 42 / 0.07);
  }

  :global(.dark) .dashboard-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.76);
  }

  .dashboard-card p {
    margin: 0.85rem 0 1.15rem;
  }

  .dashboard-card ul {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
  }

  .dashboard-card-wide {
    grid-column: 1 / -1;
  }

  @media (max-width: 767px) {
    .admin-dashboard {
      padding-top: 1.5rem;
    }

    .dashboard-header {
      flex-direction: column;
    }

    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  import { currentUser, getAccessToken, handleOAuthCallback } from '~/utils/goTrueClient';

  (() => {
    const initializeAdminDashboardPage = () => {
      const pageRoot = document.querySelector('.admin-dashboard');
      if (!pageRoot || pageRoot.dataset.adminDashboardInitialized === 'true') return;
      pageRoot.dataset.adminDashboardInitialized = 'true';

      const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
      const adminShell = document.querySelector('[data-admin-shell]');
      const authStatus = document.querySelector('[data-auth-status]');
      const signinPrompt = document.querySelector('[data-admin-signin-prompt]');
      const forbiddenPrompt = document.querySelector('[data-admin-forbidden-prompt]');

      const setGatedContentVisible = (visible) => {
        gatedContent.forEach((element) => {
          element.hidden = !visible;
        });
      };

      const setAdminShellVisible = (visible) => {
        if (adminShell) adminShell.hidden = !visible;
      };

      const authStatusMessages = {
        checking: 'Checking editor access…',
        'signed-out': '',
        forbidden: '',
        error: 'Something went wrong. Please refresh or try again.',
        'signed-in': '',
      };

      const setAuthStatus = (message) => {
        if (authStatus) authStatus.textContent = message;
      };

      const setAuthState = (state) => {
        const isSignedIn = state === 'signed-in';
        const isSignedOut = state === 'signed-out';
        const isForbidden = state === 'forbidden';

        setAuthStatus(authStatusMessages[state] ?? '');
        setAdminShellVisible(isSignedIn);
        setGatedContentVisible(isSignedIn);
        if (signinPrompt) signinPrompt.hidden = !isSignedOut;
        if (forbiddenPrompt) forbiddenPrompt.hidden = !isForbidden;
      };

      // Wire up the Sign In button inside the gate panel
      document.querySelector('[data-admin-open-login]')?.addEventListener('click', () => {
        window.__drLurieLoginModal?.open();
      });

      const getAdminStateForUser = async (_user) => {
        const token = await getAccessToken();
        if (!token) return { authenticated: false, isAdmin: false };

        const response = await fetch('/.netlify/functions/admin-auth-state', {
          method: 'GET',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
        });

        return response
          .json()
          .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
      };

      const renderAuthState = async () => {
        const user = currentUser();
        const signedIn = Boolean(user);

        if (signedIn) {
          const adminState = await getAdminStateForUser(user);

          if (adminState.isAdmin) {
            setAuthState('signed-in');
            return;
          }

          setAuthState('forbidden');
          return;
        }

        setAuthState('signed-out');
      };

      const initializeIdentityAuth = async () => {
        setAuthState('checking');

        try {
          const oauthUser = await handleOAuthCallback();
          if (oauthUser) {
            // OAuth redirect landed on this page — close modal if somehow open
            window.__drLurieLoginModal?.close();
          }
          await renderAuthState();

          document.addEventListener('dr-lurie:login', () => {
            renderAuthState().catch((error) => {
              console.error('Identity authentication refresh failed.', error);
            });
          });
          document.addEventListener('dr-lurie:logout', () => {
            renderAuthState().catch((error) => {
              console.error('Identity authentication refresh failed.', error);
            });
          });
        } catch (error) {
          console.error('Identity authentication initialization failed.', error);
          setAuthState('error');
        }
      };

      initializeIdentityAuth();
    };

    if (!window.__drLurieAdminDashboardPageLoadListener) {
      window.__drLurieAdminDashboardPageLoadListener = true;
      document.addEventListener('astro:page-load', initializeAdminDashboardPage);
    }

    initializeAdminDashboardPage();
  })();
</script>
