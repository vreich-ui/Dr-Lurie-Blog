---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

export function getStaticPaths() {
  return [{ params: { draftId: 'draft' } }];
}

const routeDraftId = Astro.params.draftId ?? '';
const pageTitle = 'Review Draft';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="review-page mx-auto max-w-[980px] px-4 py-10 sm:px-6 sm:py-14"
    data-admin-shell
    data-route-draft-id={routeDraftId}
    hidden
  >
    <header class="review-header">
      <div>
        <p class="review-kicker">Admin workspace</p>
        <h1>{pageTitle}</h1>
        <p class="review-intro">Preview a saved JSON draft with the same article styling used on the public blog.</p>
      </div>
      <a class="btn-secondary" href="/admin/drafts">Open draft list</a>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <section class="review-workspace" data-auth-gated hidden>
      <AdminNav activePath="/admin/review" />

      <div class="preview-toolbar" aria-label="Draft preview controls">
        <div>
          <span class="preview-badge">Preview mode</span>
          <p id="draft-id-copy" class="draft-id-copy">Loading draft…</p>
        </div>
        <div class="review-actions">
          <a id="edit-draft-link" class="btn-primary" href="/admin/publish">Back to edit</a>
          <a class="btn-secondary" href="/admin/drafts">Open draft list</a>
        </div>
      </div>

      <p id="review-load-status" class="review-load-status" aria-live="polite">Loading draft preview…</p>

      <section id="not-found-panel" class="review-card not-found-panel" hidden>
        <p class="review-kicker">Draft not found</p>
        <h2>We could not load this draft.</h2>
        <p class="hint">Check that the draft still exists in Netlify Blobs, or return to the draft list.</p>
        <div class="review-actions">
          <a class="btn-primary" href="/admin/drafts">Open draft list</a>
          <a id="not-found-edit-link" class="btn-secondary" href="/admin/publish">Back to editor</a>
        </div>
      </section>

      <section id="draft-preview" class="draft-preview dl-pt-s dl-pb-l sm:py-8 lg:py-10 mx-auto" hidden>
        <article data-print-article data-post-unpublished="true">
          <header class="intersect-once intersect-quarter">
            <h1
              id="preview-title"
              class="px-4 sm:px-6 max-w-[720px] mx-auto font-serif text-4xl md:text-5xl font-bold leading-tighter tracking-tighter"
            >
              Untitled draft
            </h1>
            <p
              id="preview-excerpt"
              class="line-clamp-3 max-w-[720px] mx-auto dl-mt-s dl-mb-s px-4 sm:px-6 text-[0.7875rem] sm:text-sm leading-normal italic text-muted dark:text-slate-400"
            >
            </p>

            <div class="max-w-[720px] mx-auto dl-mb-s flex items-center gap-3 px-4 sm:px-6">
              <p class="inline-flex flex-wrap items-center gap-2 text-xs text-muted dark:text-slate-400">
                <span id="preview-reading-time" hidden></span>
                <span id="preview-reading-separator" aria-hidden="true" hidden>·</span>
                <time id="preview-date" datetime=""></time>
              </p>
              <span
                class="ml-auto inline-flex rounded-full border border-amber-300 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800 dark:border-amber-700 dark:bg-amber-950/50 dark:text-amber-200"
              >
                Preview / Unpublished draft
              </span>
            </div>

            <img
              id="preview-image"
              class="w-full max-w-[720px] aspect-[16/9] object-cover mx-auto dl-mb-s sm:rounded-md bg-gray-400 dark:bg-slate-700"
              alt=""
              loading="eager"
              decoding="async"
              hidden
            />
            <div id="preview-divider" class="max-w-[720px] mx-auto px-4 sm:px-6">
              <div class="border-t dark:border-slate-700"></div>
            </div>

            <div id="preview-video-wrap" class="mx-auto dl-mt-m max-w-[720px] px-4 sm:px-6" hidden>
              <div
                class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 shadow-sm dark:border-slate-800 dark:bg-slate-900"
              >
                <iframe
                  id="preview-video"
                  class="aspect-video w-full"
                  title="Draft video"
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen></iframe>
              </div>
            </div>

            <div id="preview-cta-wrap" class="mx-auto dl-mt-m max-w-[720px] px-4 sm:px-6" hidden>
              <a id="preview-cta" class="btn-primary" href="#">Learn more</a>
            </div>
          </header>
          <div id="preview-content" class="editorial-prose px-6 sm:px-6 dl-mt-s dl-gap-m"></div>
        </article>
      </section>
    </section>
  </section>
</Layout>

<style>
  .review-page {
    color: var(--aw-color-text-default);
  }

  .review-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding-bottom: 1.5rem;
  }

  :global(.dark) .review-header {
    border-color: rgb(30 41 59);
  }

  .review-kicker {
    margin: 0 0 0.5rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .review-header h1,
  .review-card h2 {
    margin: 0;
    font-family: var(--aw-font-heading, inherit);
    font-weight: 800;
    line-height: 1.05;
  }

  .review-header h1 {
    font-size: clamp(2.35rem, 7vw, 4rem);
  }

  .review-intro,
  .hint,
  .review-load-status,
  .draft-id-copy {
    color: var(--aw-color-text-muted);
  }

  .review-intro {
    max-width: 42rem;
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }

  .auth-status {
    margin: -0.75rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .review-workspace[hidden] {
    display: none;
  }

  .preview-toolbar,
  .review-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.88);
    padding: 1rem;
    box-shadow: 0 1.25rem 3rem rgb(15 23 42 / 6%);
  }

  :global(.dark) .preview-toolbar,
  :global(.dark) .review-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.72);
    box-shadow: none;
  }

  .preview-toolbar {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .preview-badge {
    display: inline-flex;
    border-radius: 999px;
    background: rgb(245 158 11 / 14%);
    color: rgb(146 64 14);
    padding: 0.3rem 0.65rem;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.dark) .preview-badge {
    color: rgb(253 230 138);
  }

  .draft-id-copy {
    margin: 0.5rem 0 0;
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.86rem;
    font-weight: 800;
  }

  .review-load-status {
    min-height: 1.5em;
    margin: 1rem 0;
    font-weight: 800;
  }

  .review-load-status.is-error {
    color: var(--aw-color-accent);
  }

  .draft-preview[hidden],
  .not-found-panel[hidden] {
    display: none;
  }

  .draft-preview {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.92);
    box-shadow: 0 1.25rem 3rem rgb(15 23 42 / 6%);
  }

  :global(.dark) .draft-preview {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.72);
    box-shadow: none;
  }

  [data-print-article][data-post-unpublished='true'] {
    opacity: 0.92;
  }

  .hint {
    margin: 1rem 0 0;
    line-height: 1.6;
  }

  .review-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.72rem 1rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
  }

  .btn-primary {
    border: 1px solid rgb(94 140 138 / 55%);
    background: rgb(94 140 138 / 18%);
    color: var(--aw-color-text-heading);
  }

  .btn-secondary {
    border: 1px solid rgb(209 213 219);
    color: var(--aw-color-text-heading);
  }

  @media (max-width: 767px) {
    .review-page {
      padding-top: 2rem;
      padding-bottom: 2.5rem;
    }

    .review-header,
    .preview-toolbar {
      flex-direction: column;
      align-items: stretch;
    }

    .review-actions > a {
      width: 100%;
    }
  }
</style>

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  import { currentUser, getAccessToken, handleOAuthCallback } from '~/utils/goTrueClient';

  (() => {
    const initializeAdminReviewPage = () => {
      const pageRoot = document.querySelector('.review-page');
      if (!pageRoot || pageRoot.dataset.adminReviewInitialized === 'true') return;
      pageRoot.dataset.adminReviewInitialized = 'true';

      const adminPage = pageRoot;
      const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
      const authStatus = document.querySelector('[data-auth-status]');
      const routeDraftId = adminPage?.dataset.routeDraftId || '';
      const pathDraftId = decodeURIComponent(window.location.pathname.split('/').filter(Boolean).at(-1) || '');
      const draftId = pathDraftId || routeDraftId;
      const fields = {
        draftIdCopy: document.querySelector('#draft-id-copy'),
        editDraftLink: document.querySelector('#edit-draft-link'),
        notFoundEditLink: document.querySelector('#not-found-edit-link'),
        loadStatus: document.querySelector('#review-load-status'),
        notFoundPanel: document.querySelector('#not-found-panel'),
        preview: document.querySelector('#draft-preview'),
        title: document.querySelector('#preview-title'),
        excerpt: document.querySelector('#preview-excerpt'),
        readingTime: document.querySelector('#preview-reading-time'),
        readingSeparator: document.querySelector('#preview-reading-separator'),
        date: document.querySelector('#preview-date'),
        image: document.querySelector('#preview-image'),
        divider: document.querySelector('#preview-divider'),
        videoWrap: document.querySelector('#preview-video-wrap'),
        video: document.querySelector('#preview-video'),
        ctaWrap: document.querySelector('#preview-cta-wrap'),
        cta: document.querySelector('#preview-cta'),
        content: document.querySelector('#preview-content'),
      };

      const setGatedContentVisible = (visible) => {
        gatedContent.forEach((element) => {
          element.hidden = !visible;
        });
      };

      const setAdminShellVisible = (visible) => {
        if (adminPage) adminPage.hidden = !visible;
      };

      const setAuthStatus = (message) => {
        if (authStatus) authStatus.textContent = message;
      };

      const setLoadStatus = (message, isError = false) => {
        if (!fields.loadStatus) return;
        fields.loadStatus.textContent = message;
        fields.loadStatus.classList.toggle('is-error', isError);
      };

      const redirectToHome = () => {
        window.location.replace('/');
      };

      const setAuthState = (state) => {
        const isSignedIn = state === 'signed-in';
        const messages = {
          checking: 'Checking admin access…',
          'signed-out': 'Sign in to view admin tools.',
          forbidden: 'Access denied (not an admin).',
          error: 'Admin auth failed. Please refresh or contact support.',
          'signed-in': '',
        };
        setAuthStatus(messages[state] || '');
        setAdminShellVisible(isSignedIn);
        setGatedContentVisible(isSignedIn);

        if (!isSignedIn && state !== 'checking') redirectToHome();
      };

      const getAdminStateForUser = async (_user) => {
        const token = await getAccessToken();
        if (!token) return { authenticated: false, isAdmin: false };

        const response = await fetch('/.netlify/functions/admin-auth-state', {
          method: 'GET',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
        });

        return response
          .json()
          .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
      };

      const formatDate = (value) => {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return { display: 'Draft date unavailable', iso: '' };

        return {
          display: new Intl.DateTimeFormat(undefined, { month: 'long', year: 'numeric' }).format(date),
          iso: date.toISOString(),
        };
      };

      const setText = (element, value) => {
        if (element) element.textContent = value || '';
      };

      const setPreviewMedia = (draft) => {
        const image = String(draft.image || '').trim();
        const canRenderImage = image.startsWith('http://') || image.startsWith('https://') || image.startsWith('/');
        if (fields.image) {
          fields.image.hidden = !canRenderImage;
          if (canRenderImage) fields.image.src = image;
          fields.image.alt = draft.excerpt || draft.title || '';
        }
        if (fields.divider) fields.divider.hidden = canRenderImage;

        if (fields.videoWrap && fields.video) {
          fields.videoWrap.hidden = !draft.video;
          if (draft.video) {
            fields.video.src = draft.video;
            fields.video.title = `${draft.title || 'Draft'} video`;
          }
        }

        if (fields.ctaWrap && fields.cta) {
          fields.ctaWrap.hidden = !draft.ctaLink;
          if (draft.ctaLink) {
            fields.cta.href = draft.ctaLink;
            fields.cta.textContent = draft.ctaText || 'Learn more';
          }
        }
      };

      const renderDraft = (draft) => {
        const date = formatDate(draft.publishDate || draft.updatedAt);
        setText(fields.title, draft.title || 'Untitled draft');
        setText(fields.excerpt, draft.excerpt || '');
        setText(fields.date, date.display);
        if (fields.date) fields.date.dateTime = date.iso;

        const readingTime = Number(draft.readingTime);
        const hasReadingTime = Number.isFinite(readingTime) && readingTime > 0;
        if (fields.readingTime) {
          fields.readingTime.hidden = !hasReadingTime;
          fields.readingTime.textContent = hasReadingTime ? `${readingTime} min read` : '';
        }
        if (fields.readingSeparator) fields.readingSeparator.hidden = !hasReadingTime;
        if (fields.content) fields.content.innerHTML = draft.html || '';
        setPreviewMedia(draft);

        if (fields.preview) fields.preview.hidden = false;
        if (fields.notFoundPanel) fields.notFoundPanel.hidden = true;
        setLoadStatus('');
      };

      const showNotFound = (message) => {
        if (fields.preview) fields.preview.hidden = true;
        if (fields.notFoundPanel) fields.notFoundPanel.hidden = false;
        setLoadStatus(message || 'Draft was not found.', true);
      };

      const loadDraft = async (token) => {
        if (!draftId) {
          showNotFound('No draft id was provided.');
          return;
        }

        setLoadStatus('Loading draft preview…');

        try {
          const response = await fetch(
            `/.netlify/functions/admin-get-json-draft?draftId=${encodeURIComponent(draftId)}`,
            {
              method: 'GET',
              headers: {
                Authorization: `Bearer ${token}`,
                'Content-Type': 'application/json',
              },
            }
          );
          const result = await response.json().catch(() => ({}));

          if (response.status === 404 || result.not_found) {
            showNotFound(result.error || 'Draft was not found.');
            return;
          }

          if (!response.ok) throw new Error(result.error || `Draft could not be loaded (${response.status}).`);

          renderDraft(result.draft || {});
        } catch (error) {
          showNotFound(error instanceof Error ? error.message : 'Draft could not be loaded.');
        }
      };

      const renderAuthState = async () => {
        const user = currentUser();
        const signedIn = Boolean(user);

        if (signedIn) {
          const adminState = await getAdminStateForUser(user);

          if (adminState.isAdmin) {
            const token = activeUser?.token?.access_token;
            setAuthState('signed-in');
            await loadDraft(token);
            return;
          }

          setAuthState('forbidden');
          return;
        }

        setAuthState('signed-out');
      };

      const initializeIdentityAuth = async () => {
        setAuthState('checking');

        try {
          await handleOAuthCallback().catch(() => {});
          await renderAuthState();

          document.addEventListener('dr-lurie:login', () => {
            renderAuthState().catch((error) => {
              console.error('Identity authentication refresh failed.', error);
            });
          });
          document.addEventListener('dr-lurie:logout', () => {
            renderAuthState().catch((error) => {
              console.error('Identity authentication refresh failed.', error);
            });
          });
        } catch (error) {
          console.error('Identity authentication initialization failed.', error);
          setAuthState('error');
        }
      };

      const encodedDraftId = encodeURIComponent(draftId || '');
      setText(fields.draftIdCopy, draftId ? `Draft ID: ${draftId}` : 'No draft id provided');
      if (fields.editDraftLink) fields.editDraftLink.href = `/admin/publish?draftId=${encodedDraftId}`;
      if (fields.notFoundEditLink) fields.notFoundEditLink.href = `/admin/publish?draftId=${encodedDraftId}`;

      initializeIdentityAuth();
    };

    if (!window.__drLurieAdminReviewPageLoadListener) {
      window.__drLurieAdminReviewPageLoadListener = true;
      document.addEventListener('astro:page-load', initializeAdminReviewPage);
    }

    initializeAdminReviewPage();
  })();
</script>
