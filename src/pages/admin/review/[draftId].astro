---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

export function getStaticPaths() {
  return [{ params: { draftId: 'draft' } }];
}

const routeDraftId = Astro.params.draftId ?? '';
const pageTitle = 'Review Draft';
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="review-page mx-auto max-w-[920px] px-4 py-10 sm:px-6 sm:py-14"
    data-admin-shell
    data-clerk-publishable-key={clerkPublishableKey}
    data-route-draft-id={routeDraftId}
    hidden
  >
    <header class="review-header">
      <div>
        <p class="review-kicker">Admin workspace</p>
        <h1>{pageTitle}</h1>
        <p class="review-intro">Review a saved workflow draft before continuing the publishing process.</p>
      </div>
      <a class="btn-secondary" href="/admin/drafts">Back to drafts</a>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <AdminNav activePath="/admin/review" />

    <section class="review-card" aria-labelledby="review-heading" data-auth-gated hidden>
      <p class="review-kicker">Selected draft</p>
      <h2 id="review-heading">Draft request</h2>
      <dl class="review-meta">
        <div>
          <dt>Request ID</dt>
          <dd id="draft-id-value">{routeDraftId}</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>Ready for gated review tooling</dd>
        </div>
      </dl>
      <p class="hint">
        This page is intentionally rendered inside the admin gate. Protected workflow data should be fetched only
        through server-side admin endpoints after Clerk authentication resolves.
      </p>
      <div class="review-actions">
        <a id="edit-draft-link" class="btn-primary" href="/admin/publish">Continue in publisher</a>
        <a class="btn-secondary" href="/admin/drafts">Choose another draft</a>
      </div>
    </section>
  </section>
</Layout>

<style>
  .review-page {
    color: var(--aw-color-text-default);
  }

  .review-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding-bottom: 1.5rem;
  }

  :global(.dark) .review-header {
    border-color: rgb(30 41 59);
  }

  .review-kicker {
    margin: 0 0 0.5rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .review-header h1,
  .review-card h2 {
    margin: 0;
    font-family: var(--aw-font-heading, inherit);
    font-weight: 800;
    line-height: 1.05;
  }

  .review-header h1 {
    font-size: clamp(2.35rem, 7vw, 4rem);
  }

  .review-intro,
  .hint,
  .review-meta dt {
    color: var(--aw-color-text-muted);
  }

  .review-intro {
    max-width: 42rem;
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }

  .auth-status {
    margin: -0.75rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .review-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.88);
    padding: 1.35rem;
    box-shadow: 0 1.25rem 3rem rgb(15 23 42 / 6%);
  }

  :global(.dark) .review-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.72);
    box-shadow: none;
  }

  .review-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 1.25rem 0 0;
  }

  .review-meta div {
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 0.9rem;
  }

  :global(.dark) .review-meta div {
    border-color: rgb(30 41 59);
  }

  .review-meta dt {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .review-meta dd {
    margin: 0.35rem 0 0;
    overflow-wrap: anywhere;
    color: var(--aw-color-text-heading);
    font-weight: 800;
  }

  .hint {
    margin: 1rem 0 0;
    line-height: 1.6;
  }

  .review-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.72rem 1rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
  }

  .btn-primary {
    border: 1px solid rgb(94 140 138 / 55%);
    background: rgb(94 140 138 / 18%);
    color: var(--aw-color-text-heading);
  }

  .btn-secondary {
    border: 1px solid rgb(209 213 219);
    color: var(--aw-color-text-heading);
  }

  @media (max-width: 767px) {
    .review-page {
      padding-top: 2rem;
      padding-bottom: 2.5rem;
    }

    .review-header {
      flex-direction: column;
    }

    .review-meta {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  const reviewPage = document.querySelector('.review-page');
  const pathDraftId = decodeURIComponent(window.location.pathname.split('/').filter(Boolean).at(-1) || '');
  const draftId = pathDraftId || reviewPage?.dataset.routeDraftId || '';
  const draftIdValue = document.querySelector('#draft-id-value');
  const editDraftLink = document.querySelector('#edit-draft-link');

  if (draftIdValue) draftIdValue.textContent = draftId;
  if (editDraftLink && draftId) editDraftLink.href = `/admin/publish?draftId=${encodeURIComponent(draftId)}`;
</script>
<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  import { loadClerk } from '~/utils/clerkLoader';

  (() => {
    const adminPage = document.querySelector('[data-admin-shell]');
    const clerkPublishableKey = adminPage?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
    const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
    const authStatus = document.querySelector('[data-auth-status]');
    let clerkLoadPromise;

    const setGatedContentVisible = (visible) => {
      gatedContent.forEach((element) => {
        element.hidden = !visible;
      });
    };

    const getClerk = async () => {
      if (!clerkPublishableKey) {
        throw new Error('Admin authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.');
      }

      clerkLoadPromise ||= loadClerk({ publishableKey: clerkPublishableKey, scriptSrc: clerkJsScriptSrc });

      return clerkLoadPromise;
    };

    const setAdminShellVisible = (visible) => {
      if (adminPage) adminPage.hidden = !visible;
    };

    const redirectToHome = () => {
      window.location.replace('/');
    };

    const authStatusMessages = {
      checking: 'Checking admin access…',
      'signed-out': 'Sign in to view admin tools.',
      forbidden: 'Access denied (not an admin).',
      error: 'Admin auth failed. Please refresh or contact support.',
      'signed-in': '',
    };

    const setAuthStatus = (message) => {
      if (authStatus) authStatus.textContent = message;
    };

    const setAuthState = (state) => {
      const isSignedIn = state === 'signed-in';
      setAuthStatus(authStatusMessages[state] || '');
      setAdminShellVisible(isSignedIn);
      setGatedContentVisible(isSignedIn);

      if (!isSignedIn && state !== 'checking') redirectToHome();
    };

    const getAdminStateForClerk = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };

      const token = await clerk.session.getToken();
      if (!token) return { authenticated: true, isAdmin: false, error: 'Could not retrieve a Clerk session token.' };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response
        .json()
        .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
    };

    const renderAuthState = async (clerk) => {
      const signedIn = Boolean(clerk.isSignedIn && clerk.session);

      if (signedIn) {
        const adminState = await getAdminStateForClerk(clerk);

        if (adminState.isAdmin) {
          setAuthState('signed-in');
          return;
        }

        setAuthState('forbidden');
        return;
      }

      setAuthState('signed-out');
    };

    const initializeClerkAuth = async () => {
      setAuthState('checking');

      try {
        const clerk = await getClerk();
        await renderAuthState(clerk);

        if (typeof clerk.addListener === 'function') {
          clerk.addListener(() => {
            renderAuthState(clerk).catch((error) => {
              console.error('Clerk authentication refresh failed.', error);
            });
          });
        }
      } catch (error) {
        console.error('Clerk authentication initialization failed.', error);
        setAuthState('error');
      }
    };

    initializeClerkAuth();
  })();
</script>
