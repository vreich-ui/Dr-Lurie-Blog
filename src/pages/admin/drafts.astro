---
import AdminNav from '~/components/admin/AdminNav.astro';
import Layout from '~/layouts/PageLayout.astro';

const pageTitle = 'Admin Drafts';
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="drafts-page mx-auto max-w-[1080px] px-4 py-10 sm:px-6 sm:py-14"
    data-admin-shell
    data-clerk-publishable-key={clerkPublishableKey}
    hidden
  >
    <header class="drafts-header">
      <div>
        <p class="drafts-kicker">Admin workspace</p>
        <h1>{pageTitle}</h1>
        <p class="drafts-intro">
          Review JSON workflow drafts saved in Netlify Blobs and continue them in the publisher.
        </p>
      </div>
      <a class="btn-secondary" href="/admin/publish">Create draft</a>
    </header>

    <p class="auth-status" data-auth-status aria-live="polite" role="status"></p>

    <AdminNav />

    <section class="drafts-card" aria-labelledby="drafts-heading" data-auth-gated hidden>
      <div class="drafts-card-header">
        <div>
          <p class="drafts-kicker">Saved JSON drafts</p>
          <h2 id="drafts-heading">Netlify Blobs drafts</h2>
          <p class="hint">Draft metadata is loaded through an admin-only server function after Clerk auth resolves.</p>
        </div>
        <div class="drafts-card-actions">
          <a class="btn-secondary btn-sm" href="/admin/publish">New</a>
          <button id="refresh-drafts" class="btn-secondary btn-sm" type="button">Refresh</button>
        </div>
      </div>

      <p id="drafts-list-status" class="list-status" aria-live="polite">Checking admin access…</p>

      <div class="drafts-table-wrap" data-drafts-table-wrap hidden>
        <table class="drafts-table">
          <colgroup>
            <col class="col-title" />
            <col class="col-slug" />
            <col class="col-author" />
            <col class="col-updated" />
            <col class="col-readiness" />
            <col class="col-actions" />
          </colgroup>
          <thead>
            <tr>
              <th scope="col">Title</th>
              <th scope="col">Slug</th>
              <th scope="col">Author</th>
              <th scope="col">Updated</th>
              <th scope="col">Readiness</th>
              <th scope="col">Actions</th>
            </tr>
          </thead>
          <tbody id="drafts-table-body"></tbody>
        </table>
      </div>

      <div id="drafts-empty" class="empty-state" hidden>
        <h3>No JSON drafts found</h3>
        <p>Save a draft from the publisher, then return here to open it in the editor or preview page.</p>
        <a class="btn-primary" href="/admin/publish">Create your first draft</a>
      </div>

      <details class="manual-open-panel">
        <summary>Open a draft by request ID</summary>
        <form id="draft-open-form" class="draft-open-form">
          <label for="draft-id">Draft request ID</label>
          <div class="draft-open-row">
            <input id="draft-id" name="draftId" type="text" placeholder="admin-draft-…" autocomplete="off" required />
            <button class="btn-primary" type="submit">Preview draft</button>
          </div>
        </form>
      </details>
    </section>
  </section>
</Layout>

<style>
  .drafts-page {
    color: var(--aw-color-text-default);
  }

  .drafts-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding-bottom: 1.5rem;
  }

  :global(.dark) .drafts-header {
    border-color: rgb(30 41 59);
  }

  .drafts-kicker {
    margin: 0 0 0.5rem;
    color: var(--aw-color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .drafts-header h1,
  .drafts-card h2,
  .empty-state h3 {
    margin: 0;
    font-family: var(--aw-font-heading, inherit);
    font-weight: 800;
    line-height: 1.05;
  }

  .drafts-header h1 {
    font-size: clamp(2.35rem, 7vw, 4rem);
  }

  .drafts-intro,
  .hint,
  .list-status,
  .empty-state p {
    color: var(--aw-color-text-muted);
  }

  .drafts-intro {
    max-width: 42rem;
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }

  .auth-status {
    margin: -0.75rem 0 1.5rem;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .drafts-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.94);
    padding: 1.35rem;
    box-shadow: 0 1rem 2.4rem rgb(15 23 42 / 5%);
  }

  :global(.dark) .drafts-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 0.72);
    box-shadow: none;
  }

  .drafts-card-header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .drafts-card-actions {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .hint,
  .list-status {
    margin: 0.75rem 0 0;
    line-height: 1.6;
  }

  .list-status {
    min-height: 1.5em;
    font-weight: 700;
  }

  .list-status.is-error {
    color: var(--aw-color-accent);
  }

  .drafts-table-wrap {
    margin-top: 1rem;
    overflow-x: auto;
  }

  .drafts-table {
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
    min-width: 940px;
    font-size: 0.92rem;
  }

  .col-title {
    width: 31%;
  }

  .col-slug {
    width: 21%;
  }

  .col-author {
    width: 11%;
  }

  .col-updated {
    width: 14%;
  }

  .col-readiness {
    width: 13%;
  }

  .col-actions {
    width: 5.5rem;
  }

  .drafts-table th,
  .drafts-table td {
    border-bottom: 1px solid rgb(229 231 235);
    padding: 0.85rem 0.7rem;
    text-align: left;
    vertical-align: middle;
  }

  .drafts-table th:last-child,
  .drafts-table td:last-child {
    text-align: right;
    white-space: nowrap;
  }

  :global(.dark) .drafts-table th,
  :global(.dark) .drafts-table td {
    border-color: rgb(30 41 59);
  }

  .drafts-table th {
    color: var(--aw-color-text-heading);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  :global(.draft-title) {
    display: -webkit-box;
    overflow: hidden;
    color: var(--aw-color-text-heading);
    font-weight: 850;
    line-height: 1.35;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  :global(.draft-slug),
  :global(.draft-id) {
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  :global(.draft-slug) {
    color: var(--aw-color-text-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  :global(.draft-id) {
    display: block;
    margin-top: 0.32rem;
    color: var(--aw-color-text-muted);
    font-size: 0.72rem;
  }

  :global(.readiness-badge) {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.3rem 0.58rem;
    font-size: 0.78rem;
    font-weight: 900;
    white-space: nowrap;
  }

  :global(.readiness-badge.is-ready) {
    background: rgb(34 197 94 / 12%);
    color: rgb(22 101 52);
  }

  :global(.readiness-badge.is-draft) {
    background: rgb(245 158 11 / 14%);
    color: rgb(146 64 14);
  }

  :global(.dark .readiness-badge.is-ready) {
    color: rgb(187 247 208);
  }

  :global(.dark .readiness-badge.is-draft) {
    color: rgb(253 230 138);
  }

  :global(.readiness-missing) {
    margin: 0.38rem 0 0;
    color: var(--aw-color-text-muted);
    font-size: 0.8rem;
  }

  :global(.draft-actions) {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: nowrap;
    gap: 0.15rem;
  }

  :global(.icon-action) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--aw-color-text-muted);
    text-decoration: none;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  :global(.icon-action:hover),
  :global(.icon-action:focus-visible) {
    background: rgb(94 140 138 / 12%);
    color: var(--aw-color-accent);
    outline: none;
  }

  :global(.icon-action svg),
  :global(.draft-action-icon) {
    width: 0.95rem;
    height: 0.95rem;
    color: currentColor;
    stroke-width: 1.75;
  }

  :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
    padding: 0;
  }

  .empty-state {
    margin-top: 1rem;
    border: 1px dashed rgb(209 213 219);
    border-radius: 1rem;
    padding: 1.25rem;
    text-align: center;
  }

  :global(.dark) .empty-state {
    border-color: rgb(51 65 85);
  }

  .empty-state p {
    margin: 0.75rem auto 1rem;
    max-width: 34rem;
  }

  .manual-open-panel {
    margin-top: 1.25rem;
    border-top: 1px solid rgb(229 231 235);
    padding-top: 1rem;
  }

  :global(.dark) .manual-open-panel {
    border-color: rgb(30 41 59);
  }

  .manual-open-panel summary {
    color: var(--aw-color-text-heading);
    cursor: pointer;
    font-weight: 850;
  }

  .draft-open-form {
    margin-top: 1rem;
  }

  .draft-open-form label {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--aw-color-text-heading);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .draft-open-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
  }

  .draft-open-row input {
    width: 100%;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.85rem;
    background: rgb(255 255 255 / 0.94);
    padding: 0.8rem 0.95rem;
    color: var(--aw-color-text-default);
    font: inherit;
  }

  :global(.dark) .draft-open-row input {
    border-color: rgb(51 65 85);
    background: rgb(15 23 42 / 0.7);
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.72rem 1rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
  }

  .btn-primary {
    border: 1px solid rgb(94 140 138 / 55%);
    background: rgb(94 140 138 / 18%);
    color: var(--aw-color-text-heading);
  }

  .btn-secondary {
    border: 1px solid rgb(209 213 219);
    color: var(--aw-color-text-heading);
  }

  .btn-sm {
    padding: 0.52rem 0.72rem;
    font-size: 0.84rem;
  }

  @media (max-width: 767px) {
    .drafts-page {
      padding-top: 2rem;
      padding-bottom: 2.5rem;
    }

    .drafts-header,
    .drafts-card-header,
    .draft-open-row {
      grid-template-columns: 1fr;
      flex-direction: column;
    }

    .drafts-table-wrap {
      margin-right: -1rem;
      margin-left: -1rem;
      padding: 0 1rem;
    }

    .drafts-table {
      min-width: 0;
    }

    .drafts-table thead,
    .drafts-table colgroup {
      display: none;
    }

    .drafts-table,
    .drafts-table tbody,
    .drafts-table tr,
    .drafts-table td {
      display: block;
      width: 100%;
    }

    .drafts-table tr {
      border: 1px solid rgb(229 231 235);
      border-radius: 1rem;
      padding: 0.85rem;
      background: var(--aw-color-bg-page);
    }

    .drafts-table tr + tr {
      margin-top: 0.85rem;
    }

    .drafts-table td {
      border: 0;
      padding: 0.35rem 0;
    }

    .drafts-table td::before {
      display: block;
      margin-bottom: 0.18rem;
      color: var(--aw-color-text-muted);
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .drafts-table td:nth-child(2)::before {
      content: 'Slug';
    }

    .drafts-table td:nth-child(3)::before {
      content: 'Author';
    }

    .drafts-table td:nth-child(4)::before {
      content: 'Updated';
    }

    .drafts-table td:nth-child(5)::before {
      content: 'Readiness';
    }

    .drafts-table td:last-child {
      text-align: left;
    }

    :global(.draft-actions) {
      justify-content: flex-start;
      margin-top: 0.25rem;
    }
  }
</style>

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  import { loadClerk } from '~/utils/clerkLoader';

  (() => {
    const adminPage = document.querySelector('[data-admin-shell]');
    const clerkPublishableKey = adminPage?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
    const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
    const authStatus = document.querySelector('[data-auth-status]');
    const draftOpenForm = document.querySelector('#draft-open-form');
    const draftsTableWrap = document.querySelector('[data-drafts-table-wrap]');
    const draftsTableBody = document.querySelector('#drafts-table-body');
    const draftsEmpty = document.querySelector('#drafts-empty');
    const draftsListStatus = document.querySelector('#drafts-list-status');
    const refreshDraftsButton = document.querySelector('#refresh-drafts');
    let clerkLoadPromise;
    let activeToken = '';

    const setGatedContentVisible = (visible) => {
      gatedContent.forEach((element) => {
        element.hidden = !visible;
      });
    };

    const getClerk = async () => {
      if (!clerkPublishableKey) {
        throw new Error('Admin authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.');
      }

      clerkLoadPromise ||= loadClerk({ publishableKey: clerkPublishableKey, scriptSrc: clerkJsScriptSrc });

      return clerkLoadPromise;
    };

    const setAdminShellVisible = (visible) => {
      if (adminPage) adminPage.hidden = !visible;
    };

    const redirectToHome = () => {
      window.location.replace('/');
    };

    const authStatusMessages = {
      checking: 'Checking admin access…',
      'signed-out': 'Sign in to view admin tools.',
      forbidden: 'Access denied (not an admin).',
      error: 'Admin auth failed. Please refresh or contact support.',
      'signed-in': '',
    };

    const setAuthStatus = (message) => {
      if (authStatus) authStatus.textContent = message;
    };

    const setListStatus = (message, isError = false) => {
      if (!draftsListStatus) return;
      draftsListStatus.textContent = message;
      draftsListStatus.classList.toggle('is-error', isError);
    };

    const setAuthState = (state) => {
      const isSignedIn = state === 'signed-in';
      setAuthStatus(authStatusMessages[state] || '');
      setAdminShellVisible(isSignedIn);
      setGatedContentVisible(isSignedIn);

      if (!isSignedIn && state !== 'checking') redirectToHome();
    };

    const getAdminStateForClerk = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };

      const token = await clerk.session.getToken();
      if (!token) return { authenticated: true, isAdmin: false, error: 'Could not retrieve a Clerk session token.' };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response
        .json()
        .catch(() => ({ authenticated: true, isAdmin: false, error: 'Admin access could not be verified.' }));
    };

    const escapeHtml = (value) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatDate = (value) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return 'Unknown';

      return new Intl.DateTimeFormat(undefined, {
        dateStyle: 'medium',
        timeStyle: 'short',
      }).format(date);
    };

    const getReadinessLabel = (readiness) => `${readiness?.ready ?? 0}/${readiness?.total ?? 4} ready`;

    const getShortDraftId = (id) => {
      const value = String(id || '');
      return value.length > 18 ? `${value.slice(0, 11)}…${value.slice(-6)}` : value;
    };

    const getDisplayTitle = (title) =>
      String(title || 'Untitled draft')
        .replace(/\s+admin-draft-[a-f0-9-]{12,}$/i, '')
        .trim() || 'Untitled draft';

    const renderDrafts = (drafts) => {
      const hasDrafts = drafts.length > 0;
      if (draftsTableWrap) draftsTableWrap.hidden = !hasDrafts;
      if (draftsEmpty) draftsEmpty.hidden = hasDrafts;
      if (!draftsTableBody) return;

      draftsTableBody.innerHTML = drafts
        .map((draft) => {
          const readiness = draft.readiness || { isReady: false, missing: [], ready: 0, total: 4 };
          const encodedId = encodeURIComponent(draft.id);
          const readinessClass = readiness.isReady ? 'is-ready' : 'is-draft';
          const displayTitle = getDisplayTitle(draft.title);
          const shortId = getShortDraftId(draft.id);
          const missing = readiness.missing?.length
            ? `<p class="readiness-missing">Missing: ${escapeHtml(readiness.missing.join(', '))}</p>`
            : '';

          return `
            <tr>
              <td>
                <span class="draft-title" title="${escapeHtml(draft.title || 'Untitled draft')}">${escapeHtml(displayTitle)}</span>
                <span class="draft-id" title="${escapeHtml(draft.id)}">ID ${escapeHtml(shortId)}</span>
              </td>
              <td class="draft-slug">${escapeHtml(draft.slug || '—')}</td>
              <td>${escapeHtml(draft.author || '—')}</td>
              <td>${escapeHtml(formatDate(draft.updatedAt))}</td>
              <td>
                <span class="readiness-badge ${readinessClass}">${escapeHtml(getReadinessLabel(readiness))}</span>
                ${missing}
              </td>
              <td>
                <div class="draft-actions">
                  <a class="icon-action" href="/admin/publish?draftId=${encodedId}" aria-label="Edit draft" title="Edit draft">
                    <svg class="draft-action-icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 20h9" />
                      <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
                    </svg>
                    <span class="sr-only">Edit draft</span>
                  </a>
                  <a class="icon-action" href="/admin/review/${encodedId}" aria-label="Preview draft" title="Preview draft">
                    <svg class="draft-action-icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                      <circle cx="12" cy="12" r="3" />
                    </svg>
                    <span class="sr-only">Preview draft</span>
                  </a>
                </div>
              </td>
            </tr>
          `;
        })
        .join('');
    };

    const loadDrafts = async (token = activeToken) => {
      if (!token) return;
      activeToken = token;
      setListStatus('Loading JSON drafts…');
      if (refreshDraftsButton) refreshDraftsButton.disabled = true;

      try {
        const response = await fetch('/.netlify/functions/admin-list-json-drafts', {
          method: 'GET',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || `Drafts could not be loaded (${response.status}).`);
        }

        const drafts = Array.isArray(result.drafts) ? result.drafts : [];
        renderDrafts(drafts);
        setListStatus(`${drafts.length} JSON draft${drafts.length === 1 ? '' : 's'} loaded.`);
      } catch (error) {
        renderDrafts([]);
        setListStatus(error instanceof Error ? error.message : 'JSON drafts could not be loaded.', true);
      } finally {
        if (refreshDraftsButton) refreshDraftsButton.disabled = false;
      }
    };

    const renderAuthState = async (clerk) => {
      const signedIn = Boolean(clerk.isSignedIn && clerk.session);

      if (signedIn) {
        const adminState = await getAdminStateForClerk(clerk);

        if (adminState.isAdmin) {
          const token = await clerk.session.getToken();
          setAuthState('signed-in');
          await loadDrafts(token);
          return;
        }

        setAuthState('forbidden');
        return;
      }

      setAuthState('signed-out');
    };

    const initializeClerkAuth = async () => {
      setAuthState('checking');

      try {
        const clerk = await getClerk();
        await renderAuthState(clerk);

        if (typeof clerk.addListener === 'function') {
          clerk.addListener(() => {
            renderAuthState(clerk).catch((error) => {
              console.error('Clerk authentication refresh failed.', error);
            });
          });
        }
      } catch (error) {
        console.error('Clerk authentication initialization failed.', error);
        setAuthState('error');
      }
    };

    draftOpenForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(draftOpenForm);
      const draftId = String(formData.get('draftId') || '').trim();

      if (!draftId) return;

      window.location.href = `/admin/review/${encodeURIComponent(draftId)}`;
    });

    refreshDraftsButton?.addEventListener('click', () => {
      loadDrafts().catch((error) => {
        console.error('JSON drafts refresh failed.', error);
      });
    });

    initializeClerkAuth();
  })();
</script>
