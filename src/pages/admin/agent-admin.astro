---
import Layout from '~/layouts/PageLayout.astro';
import publishingWidgetBuilderOutputRaw from '~/chatkit/widgets/AI Publishing Workflow.widget?raw';

const pageTitle = 'Dr. Lurié Agent Admin';
const publishingWidgetBuilderOutput = JSON.parse(publishingWidgetBuilderOutputRaw) as {
  encodedWidget?: string;
  jsonSchema?: { properties?: Record<string, unknown> };
  template?: string;
};
const publishingWidgetConfig = JSON.parse(
  Buffer.from(String(publishingWidgetBuilderOutput.encodedWidget || ''), 'base64').toString('utf8')
) as {
  defaultState?: Record<string, unknown>;
  id?: string;
  name?: string;
  view?: string;
};
const requiredChatkitActions = [
  'agent.start_workflow',
  'agent.publish_article',
  'agent.fill_test_payload',
  'agent.reset',
];
const requiredPublishingFields = ['articleIdea', 'title', 'slug', 'markdown', 'overwrite'];
const actionMatches = [
  ...(publishingWidgetConfig.view?.matchAll(/type:\s*["'](agent\.[^"']+)["']/g) ?? []),
  ...(publishingWidgetBuilderOutput.template?.matchAll(/"type":"(agent\.[^"]+)"/g) ?? []),
];
const configuredWidgetActions = [...new Set(actionMatches.map((match) => match[1]))];
const configuredWidgetFields = [
  ...new Set([
    ...Object.keys(publishingWidgetConfig.defaultState ?? {}),
    ...Object.keys(publishingWidgetBuilderOutput.jsonSchema?.properties ?? {}),
  ]),
];
const chatkitWidgetBootstrap = {
  actions: configuredWidgetActions,
  defaultState: publishingWidgetConfig.defaultState,
  endpoint: String(publishingWidgetConfig.defaultState?.endpoint || '/.netlify/functions/run-publisher-agent'),
  fields: configuredWidgetFields,
  missingActions: requiredChatkitActions.filter((action) => !configuredWidgetActions.includes(action)),
  missingFields: requiredPublishingFields.filter((field) => !configuredWidgetFields.includes(field)),
  requiredActions: requiredChatkitActions,
  requiredFields: requiredPublishingFields,
  widgetId: publishingWidgetConfig.id,
  widgetName: publishingWidgetConfig.name || 'AI Publishing Workflow',
};
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="agent-admin-page mx-auto max-w-[980px] px-4 py-10 sm:px-6 sm:py-14"
    data-clerk-publishable-key={import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? ''}
  >
    <header class="agent-header">
      <div>
        <p class="agent-kicker">OpenAI Agent Builder</p>
        <h1>{pageTitle}</h1>
        <p class="agent-intro">
          Use the existing Widget Builder output as the ChatKit interface for the AI publishing workflow.
        </p>
      </div>
    </header>

    <section class="agent-card chatkit-panel" aria-labelledby="chatkit-heading" data-auth-gated>
      <div class="chatkit-panel-header">
        <div>
          <p class="agent-kicker">Widget Builder output</p>
          <h2 id="chatkit-heading">AI Publishing Workflow ChatKit</h2>
          <p class="hint">
            Loaded from <code>src/chatkit/widgets/AI Publishing Workflow.widget</code>. No OpenAI API keys or publish
            secrets are exposed in the browser.
          </p>
        </div>
        <span id="chatkit-config-status" class="pill-status" aria-live="polite">Validating widget config…</span>
      </div>

      <openai-chatkit
        id="publishing-chatkit"
        class="publishing-chatkit"
        data-widget-id={chatkitWidgetBootstrap.widgetId}></openai-chatkit>

      <details class="widget-config-details">
        <summary>Widget/action MVP config</summary>
        <dl class="widget-config-grid">
          <div>
            <dt>Required actions</dt>
            <dd>{requiredChatkitActions.join(', ')}</dd>
          </div>
          <div>
            <dt>Publishing fields</dt>
            <dd>{requiredPublishingFields.join(', ')}</dd>
          </div>
        </dl>
      </details>

      <p id="agent-status" class="agent-status" aria-live="polite"></p>
      <p id="agent-debug" class="agent-debug" aria-live="polite"></p>
      <script
        id="chatkit-widget-bootstrap"
        type="application/json"
        set:html={JSON.stringify(chatkitWidgetBootstrap)}></script>
    </section>
  </section>
</Layout>

<style>
  .agent-admin-page {
    color: var(--aw-color-text-default);
  }

  .agent-header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding-bottom: 1.5rem;
  }

  :global(.dark) .agent-header {
    border-color: rgb(30 41 59);
  }

  .agent-kicker {
    margin: 0;
    color: var(--aw-color-accent);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0.35rem 0 0;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
  }

  h2 {
    font-size: clamp(1.6rem, 3vw, 2.15rem);
  }

  .agent-intro,
  .hint {
    margin: 0.55rem 0 0;
    color: var(--aw-color-text-muted);
  }

  .agent-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 84%);
    box-shadow: 0 1.5rem 4rem rgb(15 23 42 / 6%);
    padding: 1.5rem;
  }

  :global(.dark) .agent-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
    box-shadow: none;
  }

  .chatkit-panel-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .chatkit-panel {
    display: grid;
    gap: 1rem;
  }

  .chatkit-panel[hidden] {
    display: none;
  }

  .publishing-chatkit {
    display: block;
    width: 100%;
    min-height: 680px;
    overflow: hidden;
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: var(--aw-color-bg-page);
  }

  :global(.dark) .publishing-chatkit {
    border-color: rgb(30 41 59);
  }

  .pill-status {
    border: 1px solid rgb(229 231 235);
    border-radius: 999px;
    padding: 0.55rem 0.8rem;
    background: var(--aw-color-bg-surface);
    color: var(--aw-color-text-muted);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .pill-status[data-state='valid'] {
    border-color: rgb(22 163 74 / 30%);
    color: rgb(22 101 52);
    background: rgb(220 252 231 / 78%);
  }

  .pill-status[data-state='invalid'] {
    border-color: rgb(220 38 38 / 25%);
    color: rgb(153 27 27);
    background: rgb(254 226 226 / 72%);
  }

  .widget-config-details {
    color: var(--aw-color-text-muted);
    font-size: 0.92rem;
  }

  .widget-config-details summary {
    cursor: pointer;
    color: var(--aw-color-text-heading);
    font-weight: 800;
  }

  .widget-config-grid {
    display: grid;
    gap: 0.75rem;
    margin: 0.9rem 0 0;
  }

  .widget-config-grid dt {
    color: var(--aw-color-text-heading);
    font-weight: 800;
  }

  .widget-config-grid dd {
    margin: 0.2rem 0 0;
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  .agent-status {
    min-height: 1.3em;
    margin: 0;
    color: var(--aw-color-accent);
    font-weight: 800;
  }

  .agent-debug {
    margin-top: 0.5rem;
    color: rgb(71 85 105);
    font-size: 0.85rem;
    line-height: 1.4;
    white-space: pre-line;
  }

  @media (min-width: 640px) {
    .agent-header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (max-width: 640px) {
    .agent-admin-page {
      padding-top: 1.5rem;
      padding-bottom: 2.5rem;
    }

    .agent-card {
      border-radius: 1.1rem;
      padding: 1rem;
    }

    .pill-status {
      width: 100%;
    }

    .pill-status {
      text-align: center;
    }
  }
</style>

<script is:inline>
  (() => {
    const fields = {
      chatkit: document.querySelector('#publishing-chatkit'),
      chatkitConfig: document.querySelector('#chatkit-widget-bootstrap'),
      chatkitConfigStatus: document.querySelector('#chatkit-config-status'),
      agentStatus: document.querySelector('#agent-status'),
      agentDebug: document.querySelector('#agent-debug'),
    };
    const debugState = {
      sessionRequestStatus: 'not-started',
      sessionHasClientSecret: false,
      sessionWorkflowId: 'unknown',
      lastWidgetActionSent: 'none',
      lastWidgetActionStatus: 'n/a',
    };

    let isAdmin = true;
    let isPublishInFlight = false;
    let chatkitInitialized = false;
    let clerkLoadPromise;
    const clerkPublishableKey = document.querySelector('.agent-admin-page')?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';

    const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
    const chatkitWidgetConfig = fields.chatkitConfig ? JSON.parse(fields.chatkitConfig.textContent || '{}') : {};

    const setStatus = (message, isSuccess = true) => {
      fields.agentStatus.textContent = message;
      fields.agentStatus.style.color = isSuccess ? 'var(--aw-color-accent)' : 'rgb(220 38 38)';
    };
    const setDebugLine = () => {
      if (!fields.agentDebug) return;
      fields.agentDebug.textContent =
        `session request: ${debugState.sessionRequestStatus}\n` +
        `session response has client_secret: ${String(debugState.sessionHasClientSecret)}\n` +
        `session workflow id: ${debugState.sessionWorkflowId}\n` +
        `last widget action sent: ${debugState.lastWidgetActionSent}\n` +
        `last widget action status: ${debugState.lastWidgetActionStatus}`;
    };
    const appendDebugJson = (label, payload) => {
      if (!fields.agentDebug) return;
      const serialized = (() => {
        try {
          return JSON.stringify(payload, null, 2);
        } catch {
          return String(payload);
        }
      })();
      fields.agentDebug.textContent = `${fields.agentDebug.textContent || ''}\n${label}\n${serialized}`;
    };

    const setChatkitConfigStatus = () => {
      const missingActions = chatkitWidgetConfig.missingActions || [];
      const missingFields = chatkitWidgetConfig.missingFields || [];
      const isValid = missingActions.length === 0 && missingFields.length === 0;

      fields.chatkitConfigStatus.dataset.state = isValid ? 'valid' : 'invalid';
      fields.chatkitConfigStatus.textContent = isValid
        ? 'MVP widget config confirmed'
        : `Missing ${[...missingActions, ...missingFields].join(', ')}`;
    };

    const setGatedContentVisible = (visible) => {
      gatedContent.forEach((element) => {
        element.hidden = !visible;
      });
    };

    setGatedContentVisible(isAdmin);

    const loadClerkScript = () =>
      new Promise((resolve, reject) => {
        if (window.Clerk) {
          resolve();
          return;
        }

        const existingScript = document.querySelector(
          `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
        );
        if (existingScript) {
          existingScript.addEventListener('load', () => resolve(), { once: true });
          existingScript.addEventListener(
            'error',
            () => reject(new Error('Clerk authentication could not be loaded.')),
            { once: true }
          );
          return;
        }

        const script = document.createElement('script');
        script.src = clerkJsScriptSrc;
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.type = 'text/javascript';
        script.dataset.drLurieClerkjs = 'true';
        script.dataset.clerkPublishableKey = clerkPublishableKey;
        script.addEventListener('load', () => resolve(), { once: true });
        script.addEventListener('error', () => reject(new Error('Clerk authentication could not be loaded.')), {
          once: true,
        });
        document.head.append(script);
      });

    const getClerk = async () => {
      if (!clerkPublishableKey) {
        throw new Error('Admin authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.');
      }

      clerkLoadPromise ||= (async () => {
        await loadClerkScript();

        if (!window.Clerk) {
          throw new Error('Clerk authentication could not be initialized.');
        }

        const clerk = window.Clerk;
        await clerk.load();
        return clerk;
      })();

      return clerkLoadPromise;
    };

    const waitForChatkitElement = async () => {
      if (customElements.get('openai-chatkit')) return;

      if (typeof customElements.whenDefined === 'function') {
        await customElements.whenDefined('openai-chatkit');
      }
    };

    const sendChatkitStatusMessage = async (message) => {
      if (typeof fields.chatkit?.sendUserMessage !== 'function') return;

      await fields.chatkit.sendUserMessage({ text: message });
    };

    const normalizeActionPayload = (payload) => {
      if (payload && typeof payload === 'object') return payload;
      if (typeof payload === 'string') {
        try {
          const parsed = JSON.parse(payload);
          return parsed && typeof parsed === 'object' ? parsed : {};
        } catch {
          return {};
        }
      }

      return {};
    };
    const isPublisherDeployPayload = (value) => {
      if (!value || typeof value !== 'object' || Array.isArray(value)) return false;

      const candidate = value;
      const hasRequiredFields =
        'slug' in candidate &&
        'title' in candidate &&
        'markdown' in candidate &&
        'publishDate' in candidate &&
        'overwrite' in candidate;

      return hasRequiredFields && Array.isArray(candidate.tags) && Array.isArray(candidate.images);
    };
    const normalizeWorkflowOutput = (raw) => {
      const seen = new Set();

      const walk = (value) => {
        if (typeof value === 'string') {
          const trimmed = value.trim();
          if (!trimmed) return null;
          try {
            return walk(JSON.parse(trimmed));
          } catch {
            return null;
          }
        }

        if (!value || typeof value !== 'object') return null;
        if (seen.has(value)) return null;
        seen.add(value);

        if (isPublisherDeployPayload(value)) {
          return value;
        }

        if (Array.isArray(value)) {
          for (const item of value) {
            const result = walk(item);
            if (result) return result;
          }
          return null;
        }

        const nestedKeys = ['output', 'finalOutput', 'content', 'text'];
        for (const key of nestedKeys) {
          if (key in value) {
            const result = walk(value[key]);
            if (result) return result;
          }
        }

        for (const nestedValue of Object.values(value)) {
          const result = walk(nestedValue);
          if (result) return result;
        }

        return null;
      };

      return walk(raw);
    };
    const slugPattern = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
    const base64Pattern = /^(?:data:[^;]+;base64,)?[A-Za-z0-9+/]+={0,2}$/;
    const toText = (value) => (typeof value === 'string' ? value.trim() : '');
    const isValidImagePath = (value) =>
      typeof value === 'string' && /^(src\/assets\/images\/|public\/|images\/|https?:\/\/)/.test(value.trim());
    const normalizePublishImages = (images) => {
      if (!Array.isArray(images)) return [];

      return images
        .map((image) => {
          if (!image || typeof image !== 'object') return null;
          const base64 = toText(image.base64 || image.content);
          const name = toText(image.name || image.fileName);
          const repoPath = toText(image.repoPath);
          const compactBase64 = base64.replace(/\s/g, '');
          if (!compactBase64 || compactBase64.length < 16 || !base64Pattern.test(compactBase64)) return null;
          if (!name) return null;
          if (repoPath && !isValidImagePath(repoPath)) return null;

          return {
            content: compactBase64,
            name,
            ...(repoPath ? { repoPath } : {}),
          };
        })
        .filter(Boolean);
    };

    const handleChatkitAction = async (action) => {
      const actionType = action?.type;
      const payload = normalizeActionPayload(action?.payload);
      debugState.lastWidgetActionSent = String(actionType || 'unknown');
      setDebugLine();

      if (!chatkitWidgetConfig.requiredActions?.includes(actionType)) {
        return;
      }

      if (actionType === 'agent.fill_test_payload') {
        await sendChatkitStatusMessage(
          [
            'Fill the AI Publishing Workflow widget with a smoke-test article idea, title, slug,',
            'markdown draft, and overwrite=false.',
          ].join(' ')
        );
        return;
      }

      if (actionType === 'agent.reset') {
        await sendChatkitStatusMessage('Reset the AI Publishing Workflow widget to its initial idle state.');
        setStatus('Agent workflow reset requested.');
        return;
      }

      if (actionType === 'agent.start_workflow') {
        const articleIdea = String(payload.articleIdea || '').trim();
        const slug = String(payload.slug || '').trim();
        const overwrite = Boolean(payload.overwrite);

        if (!articleIdea) {
          setStatus('Enter an article idea before starting the AI workflow.', false);
          return;
        }

        await sendChatkitStatusMessage(
          [
            'Start the AI Publishing Workflow using the configured Widget Builder card.',
            `Article idea: ${articleIdea}`,
            slug ? `Requested slug: ${slug}` : 'Requested slug: generate from the title',
            `Overwrite existing article: ${overwrite ? 'yes' : 'no'}`,
          ].join('\n')
        );
        setStatus('AI publishing workflow started.');
        debugState.lastWidgetActionStatus = 'local-only';
        setDebugLine();
        return;
      }

      if (actionType === 'agent.publish_article') {
        if (isPublishInFlight) {
          setStatus('Publish already in progress. Please wait for completion.');
          return;
        }

        const title = toText(payload.title);
        const slug = toText(payload.slug);
        const markdown = toText(payload.markdown || payload.content);
        const overwrite = Boolean(payload.overwrite);
        const commitMessage = toText(payload.commitMessage);
        const images = normalizePublishImages(payload.images);
        const rawImages = Array.isArray(payload.images) ? payload.images : [];
        const invalidImageCount = rawImages.length - images.length;

        if (!slug || !slugPattern.test(slug)) {
          setStatus('Publish blocked: slug must be non-empty and slug-like (lowercase letters, numbers, hyphens).', false);
          return;
        }
        if (!markdown) {
          setStatus('Publish blocked: markdown content is required.', false);
          return;
        }
        if (invalidImageCount > 0) {
          setStatus('Publish blocked: one or more images are invalid base64 entries or contain unsupported paths.', false);
          return;
        }

        const publishPayload = {
          slug,
          title: title || undefined,
          markdown,
          articlePath: `src/data/post/${slug}.md`,
          overwrite,
          ...(commitMessage ? { commitMessage } : {}),
          ...(images.length ? { images } : {}),
        };

        setStatus('Workflow complete. Publishing article via /.netlify/functions/publish-article…');
        isPublishInFlight = true;
        try {
          const response = await fetch('/.netlify/functions/publish-article', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            credentials: 'same-origin',
            body: JSON.stringify(publishPayload),
          });
          debugState.lastWidgetActionStatus = String(response.status);
          setDebugLine();
          const result = await response.json().catch(() => ({}));

          if (response.status === 409) {
            const message =
              result.error ||
              result.message ||
              'Article already exists. Retry with overwrite=true to replace the existing file.';
            setStatus(message, false);
            await sendChatkitStatusMessage(`${message} You can retry now with overwrite=true.`);
            return;
          }

          if (!response.ok || result.success === false) {
            const message = result.error || result.message || `Publish failed with status ${response.status}.`;
            setStatus(message, false);
            await sendChatkitStatusMessage(`Publishing failed: ${message}`);
            return;
          }

          const articlePath = toText(result.articlePath) || `src/data/post/${slug}.md`;
          const commit = toText(result.commit);
          const deployStatus = toText(result.deployStatus) || 'unknown';
          const imagePaths = Array.isArray(result.imagePaths) ? result.imagePaths.filter((path) => typeof path === 'string') : [];
          const verifyLink = `/blog/${slug}`;
          const summary = `Published ${articlePath}. Deploy: ${deployStatus}.`;
          setStatus(summary);
          await sendChatkitStatusMessage(
            [
              `Publishing succeeded.`,
              `articlePath: ${articlePath}`,
              `commit: ${commit || 'n/a'}`,
              `deployStatus: ${deployStatus}`,
              `imagePaths: ${imagePaths.length ? imagePaths.join(', ') : 'none'}`,
              `Verify: ${verifyLink}`,
            ].join('\n')
          );
        } finally {
          isPublishInFlight = false;
        }
      }
    };
    const inspectAndHandleWorkflowOutput = async (rawOutput) => {
      console.debug('Raw ChatKit output:', rawOutput);
      const publishPayload = normalizeWorkflowOutput(rawOutput);
      console.debug('Normalized publish payload:', publishPayload);

      if (!publishPayload) return false;

      console.debug('Detected publisher payload:', publishPayload);
      await handleChatkitAction({
        type: 'agent.publish_article',
        payload: publishPayload,
      });
      return true;
    };

    const initializeChatKit = async () => {
      if (chatkitInitialized || !fields.chatkit) return;

      const clerk = await getClerk();
      if (!clerk) {
        setStatus('Clerk failed to load. Admin authentication is unavailable in this environment.', false);
        debugState.lastWidgetActionStatus = 'clerk-not-loaded';
        setDebugLine();
        return;
      }
      if (!clerk.isSignedIn || !clerk.session) {
        isAdmin = false;
        setGatedContentVisible(false);
        setStatus('Sign in with an active admin session to use the AI publishing workflow.', false);
        debugState.lastWidgetActionStatus = 'not-signed-in';
        setDebugLine();
        return;
      }

      setChatkitConfigStatus();
      await waitForChatkitElement();

      chatkitInitialized = true;

      fields.chatkit.setOptions({
        api: {
          async getClientSecret() {
            const token = await clerk.session?.getToken();
            if (!token) {
              debugState.sessionRequestStatus = 'missing-token';
              debugState.sessionHasClientSecret = false;
              debugState.sessionWorkflowId = 'missing';
              debugState.lastWidgetActionStatus = 'missing-clerk-token';
              setDebugLine();
              setStatus('Sign-in required: your admin session token is missing. Please sign in again.', false);
              throw new Error('Admin session token is required before creating a ChatKit session.');
            }

            const response = await fetch('/.netlify/functions/create-chatkit-session', {
              method: 'POST',
              headers: {
                Authorization: `Bearer ${token}`,
                'Content-Type': 'application/json',
              },
              credentials: 'same-origin',
            });
            debugState.sessionRequestStatus = String(response.status);
            const body = await response.json().catch(() => ({}));
            debugState.sessionHasClientSecret = typeof body.client_secret === 'string';
            debugState.sessionWorkflowId = typeof body.workflow_id === 'string' ? body.workflow_id : 'missing';
            setDebugLine();

            if (!response.ok || typeof body.client_secret !== 'string') {
              if (response.status === 401) {
                debugState.lastWidgetActionStatus = 'session-401';
                setStatus('ChatKit session failed (401 Unauthorized). Your admin session may be expired; sign in again.', false);
              } else if (response.status === 403) {
                debugState.lastWidgetActionStatus = 'session-403';
                setStatus('ChatKit session failed (403 Forbidden). Your account is not allowed to use this admin workflow.', false);
              } else if (response.status >= 500) {
                debugState.lastWidgetActionStatus = 'session-500';
                setStatus('ChatKit session failed (server error). Deploy preview backend could not create a session.', false);
              } else {
                debugState.lastWidgetActionStatus = `session-${String(response.status || 'error')}`;
              }
              appendDebugJson('Session endpoint response', body);
              setDebugLine();
              throw new Error(body.error || 'ChatKit session could not be created.');
            }

            return body.client_secret;
          },
        },
        composer: {
          placeholder: 'Ask the OpenAI workflow to draft, revise, or publish an article…',
        },
        widgets: {
          onAction: handleChatkitAction,
        },
      });

      const processChatkitEvent = async (event) => {
        const rawOutput = event?.detail?.data ?? event?.detail ?? event;
        await inspectAndHandleWorkflowOutput(rawOutput);
      };
      const logChatkitEvent = (eventName) => (event) => {
        console.debug(`[ChatKit event] ${eventName}`, event?.detail);
      };

      const chatkitEventsToLog = [
        'chatkit.error',
        'chatkit.response.start',
        'chatkit.response.end',
        'chatkit.thread.change',
        'chatkit.log',
      ];

      chatkitEventsToLog.forEach((eventName) => {
        fields.chatkit.addEventListener(eventName, logChatkitEvent(eventName));
      });

      fields.chatkit.addEventListener('chatkit.response.end', processChatkitEvent);
      fields.chatkit.addEventListener('chatkit.log', processChatkitEvent);
      fields.chatkit.addEventListener('chatkit.error', (event) => {
        debugState.lastWidgetActionStatus = 'error';
        setDebugLine();
        setStatus('ChatKit runtime/widget error. See debug details below for full event payload.', false);
        appendDebugJson('chatkit.error detail', event?.detail ?? null);
      });
    };

    setChatkitConfigStatus();
    initializeChatKit().catch((error) => {
      console.error('ChatKit initialization failed.', error);
      if (String(error?.message || '').toLowerCase().includes('clerk')) {
        debugState.lastWidgetActionStatus = 'clerk-not-loaded';
        setStatus('Clerk not loaded. Authentication script failed to initialize in this deploy preview.', false);
      } else {
        debugState.lastWidgetActionStatus = 'chatkit-runtime-error';
        setStatus(error instanceof Error ? error.message : 'ChatKit could not be initialized.', false);
      }
      setDebugLine();
      appendDebugJson('ChatKit initialization error', {
        message: error?.message || String(error),
        name: error?.name || 'Error',
      });
    });
  })();
</script>
