---
import Layout from '~/layouts/PageLayout.astro';
import publishingWidgetBuilderOutputRaw from '~/chatkit/widgets/AI Publishing Workflow.widget?raw';

const pageTitle = 'Dr. Lurié Agent Admin';
const publishingWidgetBuilderOutput = JSON.parse(publishingWidgetBuilderOutputRaw) as {
  encodedWidget?: string;
  jsonSchema?: { properties?: Record<string, unknown> };
  template?: string;
};
const publishingWidgetConfig = JSON.parse(
  Buffer.from(String(publishingWidgetBuilderOutput.encodedWidget || ''), 'base64').toString('utf8')
) as {
  defaultState?: Record<string, unknown>;
  id?: string;
  name?: string;
  view?: string;
};
const requiredChatkitActions = [
  'agent.start_workflow',
  'agent.publish_article',
  'agent.fill_test_payload',
  'agent.reset',
];
const requiredPublishingFields = ['articleIdea', 'title', 'slug', 'markdown', 'overwrite'];
const actionMatches = [
  ...(publishingWidgetConfig.view?.matchAll(/type:\s*["'](agent\.[^"']+)["']/g) ?? []),
  ...(publishingWidgetBuilderOutput.template?.matchAll(/"type":"(agent\.[^"]+)"/g) ?? []),
];
const configuredWidgetActions = [...new Set(actionMatches.map((match) => match[1]))];
const configuredWidgetFields = [
  ...new Set([
    ...Object.keys(publishingWidgetConfig.defaultState ?? {}),
    ...Object.keys(publishingWidgetBuilderOutput.jsonSchema?.properties ?? {}),
  ]),
];
const chatkitWidgetBootstrap = {
  actions: configuredWidgetActions,
  defaultState: publishingWidgetConfig.defaultState,
  endpoint: String(publishingWidgetConfig.defaultState?.endpoint || '/.netlify/functions/run-publisher-agent'),
  fields: configuredWidgetFields,
  missingActions: requiredChatkitActions.filter((action) => !configuredWidgetActions.includes(action)),
  missingFields: requiredPublishingFields.filter((field) => !configuredWidgetFields.includes(field)),
  requiredActions: requiredChatkitActions,
  requiredFields: requiredPublishingFields,
  widgetId: publishingWidgetConfig.id,
  widgetName: publishingWidgetConfig.name || 'AI Publishing Workflow',
};
const metadata = {
  title: pageTitle,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section
    class="agent-admin-page mx-auto max-w-[980px] px-4 py-10 sm:px-6 sm:py-14"
    data-clerk-publishable-key={import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? ''}
  >
    <header class="agent-header">
      <div>
        <p class="agent-kicker">OpenAI Agent Builder</p>
        <h1>{pageTitle}</h1>
        <p class="agent-intro">
          Use the existing Widget Builder output as the ChatKit interface for the AI publishing workflow.
        </p>
      </div>
    </header>

    <section class="agent-card chatkit-panel" aria-labelledby="chatkit-heading" data-auth-gated>
      <div class="chatkit-panel-header">
        <div>
          <p class="agent-kicker">Widget Builder output</p>
          <h2 id="chatkit-heading">AI Publishing Workflow ChatKit</h2>
          <p class="hint">
            Loaded from <code>src/chatkit/widgets/AI Publishing Workflow.widget</code>. No OpenAI API keys or publish
            secrets are exposed in the browser.
          </p>
        </div>
        <span id="chatkit-config-status" class="pill-status" aria-live="polite">Validating widget config…</span>
      </div>

      <openai-chatkit
        id="publishing-chatkit"
        class="publishing-chatkit"
        data-widget-id={chatkitWidgetBootstrap.widgetId}></openai-chatkit>

      <details class="widget-config-details">
        <summary>Widget/action MVP config</summary>
        <dl class="widget-config-grid">
          <div>
            <dt>Required actions</dt>
            <dd>{requiredChatkitActions.join(', ')}</dd>
          </div>
          <div>
            <dt>Publishing fields</dt>
            <dd>{requiredPublishingFields.join(', ')}</dd>
          </div>
        </dl>
      </details>

      <p id="agent-status" class="agent-status" aria-live="polite"></p>
      <p id="agent-debug" class="agent-debug" aria-live="polite"></p>
      <section class="publish-output-panel" aria-labelledby="publish-output-heading">
        <div class="publish-output-header">
          <h3 id="publish-output-heading">End node payload</h3>
          <button id="publish-explicit-button" class="publish-button" type="button" disabled>Publish payload</button>
        </div>
        <label class="auto-publish-toggle" for="auto-publish-toggle">
          <input id="auto-publish-toggle" type="checkbox" checked />
          <span>Auto-publish when valid payload is captured</span>
        </label>
        <p id="publish-output-meta" class="publish-output-meta">Waiting for workflow output…</p>
        <pre id="publish-output-preview" class="publish-output-preview">No parsed output captured yet.</pre>
      </section>
      <script id="chatkit-widget-bootstrap" type="application/json" set:html={JSON.stringify(chatkitWidgetBootstrap)} />
    </section>
  </section>
</Layout>

<style>
  .agent-admin-page {
    color: var(--aw-color-text-default);
  }

  .agent-header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding-bottom: 1.5rem;
  }

  :global(.dark) .agent-header {
    border-color: rgb(30 41 59);
  }

  .agent-kicker {
    margin: 0;
    color: var(--aw-color-accent);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0.35rem 0 0;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
  }

  h2 {
    font-size: clamp(1.6rem, 3vw, 2.15rem);
  }

  .agent-intro,
  .hint {
    margin: 0.55rem 0 0;
    color: var(--aw-color-text-muted);
  }

  .agent-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 84%);
    box-shadow: 0 1.5rem 4rem rgb(15 23 42 / 6%);
    padding: 1.5rem;
  }

  :global(.dark) .agent-card {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42 / 72%);
    box-shadow: none;
  }

  .chatkit-panel-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .chatkit-panel {
    display: grid;
    gap: 1rem;
  }

  .chatkit-panel[hidden] {
    display: none;
  }

  .publishing-chatkit {
    display: block;
    width: 100%;
    min-height: 680px;
    overflow: hidden;
    border: 1px solid rgb(229 231 235);
    border-radius: 1.25rem;
    background: var(--aw-color-bg-page);
  }

  :global(.dark) .publishing-chatkit {
    border-color: rgb(30 41 59);
  }

  .pill-status {
    border: 1px solid rgb(229 231 235);
    border-radius: 999px;
    padding: 0.55rem 0.8rem;
    background: var(--aw-color-bg-surface);
    color: var(--aw-color-text-muted);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .pill-status[data-state='valid'] {
    border-color: rgb(22 163 74 / 30%);
    color: rgb(22 101 52);
    background: rgb(220 252 231 / 78%);
  }

  .pill-status[data-state='invalid'] {
    border-color: rgb(220 38 38 / 25%);
    color: rgb(153 27 27);
    background: rgb(254 226 226 / 72%);
  }

  .widget-config-details {
    color: var(--aw-color-text-muted);
    font-size: 0.92rem;
  }

  .widget-config-details summary {
    cursor: pointer;
    color: var(--aw-color-text-heading);
    font-weight: 800;
  }

  .widget-config-grid {
    display: grid;
    gap: 0.75rem;
    margin: 0.9rem 0 0;
  }

  .widget-config-grid dt {
    color: var(--aw-color-text-heading);
    font-weight: 800;
  }

  .widget-config-grid dd {
    margin: 0.2rem 0 0;
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  }

  .agent-status {
    min-height: 1.3em;
    margin: 0;
    color: var(--aw-color-accent);
    font-weight: 800;
  }

  .agent-debug {
    margin-top: 0.5rem;
    color: rgb(71 85 105);
    font-size: 0.85rem;
    line-height: 1.4;
    white-space: pre-line;
  }
  .publish-output-panel {
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 1rem;
    background: var(--aw-color-bg-surface);
  }
  .publish-output-header {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .publish-output-header h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--aw-color-text-heading);
  }
  .publish-button {
    border: 1px solid rgb(22 163 74 / 40%);
    background: rgb(22 163 74 / 12%);
    color: rgb(22 101 52);
    padding: 0.45rem 0.75rem;
    border-radius: 0.65rem;
    font-weight: 700;
  }
  .publish-button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .publish-output-meta {
    margin: 0.75rem 0 0;
    color: var(--aw-color-text-muted);
    font-size: 0.88rem;
  }
  .auto-publish-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.88rem;
    color: var(--aw-color-text-muted);
  }
  .auto-publish-toggle input {
    margin: 0;
  }
  .publish-output-preview {
    margin: 0.75rem 0 0;
    max-height: 280px;
    overflow: auto;
    border-radius: 0.75rem;
    padding: 0.8rem;
    background: rgb(15 23 42 / 4%);
    font-size: 0.82rem;
  }

  @media (min-width: 640px) {
    .agent-header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (max-width: 640px) {
    .agent-admin-page {
      padding-top: 1.5rem;
      padding-bottom: 2.5rem;
    }

    .agent-card {
      border-radius: 1.1rem;
      padding: 1rem;
    }

    .pill-status {
      width: 100%;
    }

    .pill-status {
      text-align: center;
    }
  }
</style>

<script>
  import { publishArticleFromPayload } from '../../lib/publishArticleFromPayload';

  window.publishArticleFromPayload = publishArticleFromPayload;
</script>

<script is:inline>
  (() => {
    const fields = {
      chatkit: document.querySelector('#publishing-chatkit'),
      chatkitConfig: document.querySelector('#chatkit-widget-bootstrap'),
      chatkitConfigStatus: document.querySelector('#chatkit-config-status'),
      agentStatus: document.querySelector('#agent-status'),
      agentDebug: document.querySelector('#agent-debug'),
      publishButton: document.querySelector('#publish-explicit-button'),
      autoPublishToggle: document.querySelector('#auto-publish-toggle'),
      publishOutputMeta: document.querySelector('#publish-output-meta'),
      publishOutputPreview: document.querySelector('#publish-output-preview'),
    };
    const debugState = {
      sessionRequestStatus: 'not-started',
      sessionHasClientSecret: false,
      sessionWorkflowId: 'unknown',
      lastWidgetActionSent: 'none',
      lastWidgetActionStatus: 'n/a',
      lastEventType: 'none',
      lastEventDetailKeys: 'n/a',
      publishPayloadDetected: 'false',
      eventLog: [],
    };

    let isAdmin = true;
    let isPublishInFlight = false;
    let chatkitInitialized = false;
    let capturedParsedPayload = null;
    let autoPublishOnOutput = fields.autoPublishToggle?.checked ?? true;
    const autoPublishedPayloadKeys = new Set();
    let clerkLoadPromise;
    const clerkPublishableKey = document.querySelector('.agent-admin-page')?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';

    const gatedContent = Array.from(document.querySelectorAll('[data-auth-gated]'));
    const chatkitWidgetConfig = fields.chatkitConfig ? JSON.parse(fields.chatkitConfig.textContent || '{}') : {};

    const setStatus = (message, isSuccess = true) => {
      fields.agentStatus.textContent = message;
      fields.agentStatus.style.color = isSuccess ? 'var(--aw-color-accent)' : 'rgb(220 38 38)';
    };
    const setDebugLine = () => {
      if (!fields.agentDebug) return;
      const recentEvents = debugState.eventLog.slice(-6).join('\n');
      fields.agentDebug.textContent =
        `session request: ${debugState.sessionRequestStatus}\n` +
        `session response has client_secret: ${String(debugState.sessionHasClientSecret)}\n` +
        `session workflow id: ${debugState.sessionWorkflowId}\n` +
        `last chatkit event: ${debugState.lastEventType}\n` +
        `last event detail keys: ${debugState.lastEventDetailKeys}\n` +
        `publish-looking payload detected: ${debugState.publishPayloadDetected}\n` +
        `last widget action sent: ${debugState.lastWidgetActionSent}\n` +
        `last widget action status: ${debugState.lastWidgetActionStatus}\n` +
        `recent chatkit events:\n${recentEvents || 'none'}`;
    };

    const setChatkitConfigStatus = () => {
      const missingActions = chatkitWidgetConfig.missingActions || [];
      const missingFields = chatkitWidgetConfig.missingFields || [];
      const isValid = missingActions.length === 0 && missingFields.length === 0;

      fields.chatkitConfigStatus.dataset.state = isValid ? 'valid' : 'invalid';
      fields.chatkitConfigStatus.textContent = isValid
        ? 'MVP widget config confirmed'
        : `Missing ${[...missingActions, ...missingFields].join(', ')}`;
    };

    const setGatedContentVisible = (visible) => {
      gatedContent.forEach((element) => {
        element.hidden = !visible;
      });
    };

    setGatedContentVisible(isAdmin);

    const loadClerkScript = () =>
      new Promise((resolve, reject) => {
        if (window.Clerk) {
          resolve();
          return;
        }

        const existingScript = document.querySelector(
          `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
        );
        if (existingScript) {
          existingScript.addEventListener('load', () => resolve(), { once: true });
          existingScript.addEventListener(
            'error',
            () => reject(new Error('Clerk authentication could not be loaded.')),
            { once: true }
          );
          return;
        }

        const script = document.createElement('script');
        script.src = clerkJsScriptSrc;
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.type = 'text/javascript';
        script.dataset.drLurieClerkjs = 'true';
        script.dataset.clerkPublishableKey = clerkPublishableKey;
        script.addEventListener('load', () => resolve(), { once: true });
        script.addEventListener('error', () => reject(new Error('Clerk authentication could not be loaded.')), {
          once: true,
        });
        document.head.append(script);
      });

    const getClerk = async () => {
      if (!clerkPublishableKey) {
        throw new Error('Admin authentication is not configured. Set PUBLIC_CLERK_PUBLISHABLE_KEY in Netlify.');
      }

      clerkLoadPromise ||= (async () => {
        await loadClerkScript();

        if (!window.Clerk) {
          throw new Error('Clerk authentication could not be initialized.');
        }

        const clerk = window.Clerk;
        await clerk.load();
        return clerk;
      })();

      return clerkLoadPromise;
    };

    const waitForChatkitElement = async () => {
      if (customElements.get('openai-chatkit')) return;

      if (typeof customElements.whenDefined === 'function') {
        await customElements.whenDefined('openai-chatkit');
      }
    };

    const sendChatkitStatusMessage = async (message) => {
      if (typeof fields.chatkit?.sendUserMessage !== 'function') return;

      await fields.chatkit.sendUserMessage({ text: message });
    };

    const normalizeActionPayload = (payload) => {
      if (payload && typeof payload === 'object') return payload;
      if (typeof payload === 'string') {
        try {
          const parsed = JSON.parse(payload);
          return parsed && typeof parsed === 'object' ? parsed : {};
        } catch {
          return {};
        }
      }

      return {};
    };
    const updatePublishPreview = (payload, message) => {
      if (fields.publishOutputMeta) fields.publishOutputMeta.textContent = message;
      if (fields.publishOutputPreview) {
        fields.publishOutputPreview.textContent = payload
          ? JSON.stringify(payload, null, 2)
          : 'No parsed output captured yet.';
      }
      if (fields.publishButton) fields.publishButton.disabled = !payload || isPublishInFlight;
    };
    const parseOutputObject = (value) => {
      if (value && typeof value === 'object') return value;
      if (typeof value === 'string') {
        try {
          const parsed = JSON.parse(value);
          return parsed && typeof parsed === 'object' ? parsed : null;
        } catch {
          throw new Error('End node parsed_output is a string, but JSON.parse failed.');
        }
      }
      return null;
    };
    const extractPossibleOutput = (payload) => {
      if (!payload || typeof payload !== 'object') return undefined;
      return (
        payload.parsed_output ??
        payload.parsedOutput ??
        payload.output ??
        payload.final_output ??
        payload.finalOutput ??
        payload.payload ??
        payload.data ??
        payload.result
      );
    };
    const slugPattern = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
    const base64Pattern = /^(?:data:[^;]+;base64,)?[A-Za-z0-9+/]+={0,2}$/;
    const toText = (value) => (typeof value === 'string' ? value.trim() : '');
    const getPayloadFingerprint = (payload) => {
      const slug = toText(payload?.slug);
      const commitMessage = toText(payload?.commitMessage);
      const markdown = toText(payload?.markdown);
      const content = toText(payload?.content);
      const bodySignature = markdown ? `md:${markdown.length}` : `ct:${content.length}`;
      return `${slug}|${commitMessage || 'none'}|${bodySignature}`;
    };
    const isValidImagePath = (value) =>
      typeof value === 'string' && /^(src\/assets\/images\/|public\/|images\/|https?:\/\/)/.test(value.trim());
    const normalizePublishImages = (images) => {
      if (!Array.isArray(images)) return [];

      return images
        .map((image) => {
          if (!image || typeof image !== 'object') return null;
          const base64 = toText(image.base64 || image.content);
          const name = toText(image.name || image.fileName);
          const repoPath = toText(image.repoPath);
          const compactBase64 = base64.replace(/\s/g, '');
          if (!compactBase64 || compactBase64.length < 16 || !base64Pattern.test(compactBase64)) return null;
          if (!name) return null;
          if (repoPath && !isValidImagePath(repoPath)) return null;

          return {
            content: compactBase64,
            name,
            ...(repoPath ? { repoPath } : {}),
          };
        })
        .filter(Boolean);
    };

    const runPublishFromPayload = async (sourcePayload, origin = 'widget action') => {
      if (isPublishInFlight) {
        setStatus('Publish already in progress. Please wait for completion.');
        return;
      }
      const payload = normalizeActionPayload(sourcePayload);
      const slug = toText(payload.slug);
      const markdown = toText(payload.markdown);
      const content = toText(payload.content);
      const images = normalizePublishImages(payload.images);
      const rawImages = Array.isArray(payload.images) ? payload.images : [];
      const invalidImageCount = rawImages.length - images.length;

      if (!slug || !slugPattern.test(slug)) {
        setStatus(
          'missing required field: slug must be non-empty and slug-like (lowercase letters, numbers, hyphens).',
          false
        );
        return;
      }
      if (!markdown && !content) {
        setStatus('missing required field: markdown or content is required.', false);
        return;
      }
      if (invalidImageCount > 0) {
        setStatus(
          'Publish blocked: one or more images are invalid base64 entries or contain unsupported paths.',
          false
        );
        return;
      }

      const publishPayload = {
        slug,
        title: toText(payload.title) || undefined,
        markdown: markdown || undefined,
        content: content || undefined,
        publishDate: toText(payload.publishDate) || undefined,
        draft: payload.draft === true,
        author: toText(payload.author) || undefined,
        category: toText(payload.category) || undefined,
        tags: Array.isArray(payload.tags)
          ? payload.tags.map((tag) => toText(tag)).filter(Boolean)
          : toText(payload.tags) || undefined,
        excerpt: toText(payload.excerpt) || undefined,
        overwrite: Boolean(payload.overwrite),
        images,
        featuredImage: toText(payload.featuredImage) || undefined,
        videoLink: toText(payload.videoLink) || undefined,
        ctaLink: toText(payload.ctaLink) || undefined,
        ctaText: toText(payload.ctaText) || undefined,
        seoDescription: toText(payload.seoDescription) || undefined,
        commitMessage: toText(payload.commitMessage) || undefined,
      };
      const payloadKey = getPayloadFingerprint(payload);
      updatePublishPreview(payload, `Payload ready from ${origin}. key=${payloadKey}`);
      setStatus('Workflow complete. Publishing article via /.netlify/functions/publish-article…');
      isPublishInFlight = true;
      if (fields.publishButton) fields.publishButton.disabled = true;
      try {
        const publishResult = await window.publishArticleFromPayload(publishPayload);
        debugState.lastWidgetActionStatus = String(publishResult.status);
        setDebugLine();
        const result = publishResult.body || {};
        if (publishResult.status === 409) {
          const message =
            result.error ||
            result.message ||
            'Article already exists. Retry with overwrite=true to replace the existing file.';
          setStatus(message, false);
          return;
        }
        if (!publishResult.ok || result.success === false) {
          const message = result.error || result.message || `Publish failed with status ${publishResult.status}.`;
          setStatus(message, false);
          return;
        }
        const articlePath = toText(result.articlePath) || `src/data/post/${slug}.md`;
        const commit = toText(result.commit);
        const deployStatus = toText(result.deployStatus) || 'unknown';
        const message = toText(result.message) || 'Publish request completed.';
        autoPublishedPayloadKeys.add(payloadKey);
        setStatus(`Published ${articlePath}. commit=${commit || 'n/a'} deploy=${deployStatus}. ${message}`);
      } finally {
        isPublishInFlight = false;
        if (fields.publishButton) fields.publishButton.disabled = !capturedParsedPayload;
      }
    };

    const capturePayloadCandidate = async (candidate, sourceLabel) => {
      const normalized = normalizeActionPayload(candidate);
      const possibleOutput = extractPossibleOutput(normalized);
      const rawCandidate = typeof possibleOutput !== 'undefined' ? possibleOutput : normalized;
      try {
        const parsed = parseOutputObject(rawCandidate);
        capturedParsedPayload = parsed;
        const publishLooking = Boolean(
          parsed && toText(parsed.slug) && (toText(parsed.markdown) || toText(parsed.content))
        );
        debugState.publishPayloadDetected = String(publishLooking);
        if (!parsed) {
          updatePublishPreview(null, `Event ${sourceLabel} captured but payload is not an object.`);
          setDebugLine();
          return;
        }
        if (!publishLooking) {
          updatePublishPreview(parsed, `Event ${sourceLabel} captured output, but required fields are missing.`);
          setStatus('missing required field: output must include slug and either markdown or content.', false);
          setDebugLine();
          return;
        }
        const payloadKey = getPayloadFingerprint(parsed);
        updatePublishPreview(parsed, `Captured from ${sourceLabel}. Key=${payloadKey}. Ready to publish.`);
        setDebugLine();
        if (autoPublishOnOutput) {
          if (autoPublishedPayloadKeys.has(payloadKey)) {
            setStatus(
              'Auto-publish skipped: this payload was already published. Use Publish payload to retry manually.'
            );
          } else {
            await runPublishFromPayload(parsed, `${sourceLabel} (auto)`);
          }
        }
      } catch (error) {
        debugState.publishPayloadDetected = 'false';
        capturedParsedPayload = null;
        updatePublishPreview(null, error instanceof Error ? error.message : 'Failed to parse workflow output.');
        setStatus(error instanceof Error ? error.message : 'Failed to parse workflow output.', false);
        setDebugLine();
      }
    };

    const trackEvent = async (eventName, rawData) => {
      const detailKeys =
        rawData && typeof rawData === 'object'
          ? Object.keys(rawData).slice(0, 12).join(', ') || '(no-keys)'
          : '(non-object)';
      debugState.lastEventType = eventName;
      debugState.lastEventDetailKeys = detailKeys;
      const payloadLike =
        rawData &&
        typeof rawData === 'object' &&
        (rawData.slug ||
          rawData.parsed_output ||
          rawData.parsedOutput ||
          rawData.output ||
          rawData.final_output ||
          rawData.finalOutput ||
          rawData.payload);
      debugState.eventLog.push(
        `${new Date().toISOString()} | ${eventName} | keys: ${detailKeys} | payload: ${payloadLike ? 'yes' : 'no'}`
      );
      if (debugState.eventLog.length > 20) debugState.eventLog.shift();
      setDebugLine();
      if (payloadLike) {
        const sourceLabel = eventName.startsWith('widget.onAction:agent.publish_article')
          ? 'widget action'
          : eventName.startsWith('element:') || eventName.startsWith('window:')
            ? 'End output'
            : 'Manual console/test payload';
        await capturePayloadCandidate(rawData, sourceLabel);
      }
    };

    const handleChatkitAction = async (action) => {
      const actionType = action?.type;
      const payload = normalizeActionPayload(action?.payload);
      debugState.lastWidgetActionSent = String(actionType || 'unknown');
      setDebugLine();

      if (!chatkitWidgetConfig.requiredActions?.includes(actionType)) {
        // no-op; still allow parsed output capture below.
      }
      await trackEvent(`widget.onAction:${String(actionType || 'unknown')}`, payload);
      if (actionType === 'agent.publish_article') {
        await capturePayloadCandidate(payload, 'widget action');
      }

      if (actionType === 'agent.fill_test_payload') {
        await sendChatkitStatusMessage(
          [
            'Fill the AI Publishing Workflow widget with a smoke-test article idea, title, slug,',
            'markdown draft, and overwrite=false.',
          ].join(' ')
        );
        return;
      }

      if (actionType === 'agent.reset') {
        await sendChatkitStatusMessage('Reset the AI Publishing Workflow widget to its initial idle state.');
        setStatus('Agent workflow reset requested.');
        return;
      }

      if (actionType === 'agent.start_workflow') {
        const articleIdea = String(payload.articleIdea || '').trim();
        const slug = String(payload.slug || '').trim();
        const overwrite = Boolean(payload.overwrite);

        if (!articleIdea) {
          setStatus('Enter an article idea before starting the AI workflow.', false);
          return;
        }

        await sendChatkitStatusMessage(
          [
            'Start the AI Publishing Workflow using the configured Widget Builder card.',
            `Article idea: ${articleIdea}`,
            slug ? `Requested slug: ${slug}` : 'Requested slug: generate from the title',
            `Overwrite existing article: ${overwrite ? 'yes' : 'no'}`,
          ].join('\n')
        );
        setStatus('AI publishing workflow started.');
        debugState.lastWidgetActionStatus = 'local-only';
        setDebugLine();
        return;
      }

      if (actionType === 'agent.publish_article') {
        await runPublishFromPayload(capturedParsedPayload || payload, 'Captured from widget action');
      }
    };

    const initializeChatKit = async () => {
      if (chatkitInitialized || !fields.chatkit) return;

      const clerk = await getClerk();
      if (!clerk.isSignedIn || !clerk.session) {
        isAdmin = false;
        setGatedContentVisible(false);
        setStatus('Sign in with an active admin session to use the AI publishing workflow.', false);
        return;
      }

      setChatkitConfigStatus();
      await waitForChatkitElement();

      chatkitInitialized = true;

      fields.chatkit.setOptions({
        api: {
          async getClientSecret() {
            const token = await clerk.session?.getToken();
            if (!token) {
              debugState.sessionRequestStatus = 'missing-token';
              debugState.sessionHasClientSecret = false;
              debugState.sessionWorkflowId = 'missing';
              setDebugLine();
              setStatus('Sign-in required: your admin session token is missing. Please sign in again.', false);
              throw new Error('Admin session token is required before creating a ChatKit session.');
            }

            const response = await fetch('/.netlify/functions/create-chatkit-session', {
              method: 'POST',
              headers: {
                Authorization: `Bearer ${token}`,
                'Content-Type': 'application/json',
              },
              credentials: 'same-origin',
            });
            debugState.sessionRequestStatus = String(response.status);
            const body = await response.json().catch(() => ({}));
            debugState.sessionHasClientSecret = typeof body.client_secret === 'string';
            debugState.sessionWorkflowId = typeof body.workflow_id === 'string' ? body.workflow_id : 'missing';
            setDebugLine();

            if (!response.ok || typeof body.client_secret !== 'string') {
              throw new Error(body.error || 'ChatKit session could not be created.');
            }

            return body.client_secret;
          },
        },
        composer: {
          placeholder: 'Ask the OpenAI workflow to draft, revise, or publish an article…',
        },
        widgets: {
          onAction: handleChatkitAction,
        },
      });

      const eventNames = [
        'message',
        'chatkit:message',
        'chatkit:event',
        'chatkit:action',
        'action',
        'workflow:output',
        'output',
      ];
      eventNames.forEach((eventName) => {
        fields.chatkit?.addEventListener(eventName, async (event) => {
          await trackEvent(`element:${eventName}`, event?.detail ?? event);
        });
      });

      window.addEventListener('message', async (event) => {
        const data = event?.data;
        const looksChatkit =
          data &&
          typeof data === 'object' &&
          (String(data.type || '')
            .toLowerCase()
            .includes('chatkit') ||
            String(data.event || '')
              .toLowerCase()
              .includes('chatkit') ||
            data.parsed_output ||
            data.parsedOutput ||
            data.final_output ||
            data.finalOutput);
        if (looksChatkit) {
          await trackEvent('window:message', data);
        }
      });
    };

    setChatkitConfigStatus();
    fields.autoPublishToggle?.addEventListener('change', (event) => {
      autoPublishOnOutput = Boolean(event?.target?.checked);
      if (capturedParsedPayload) {
        updatePublishPreview(
          capturedParsedPayload,
          autoPublishOnOutput
            ? 'Auto-publish enabled for next valid captured payload.'
            : 'Auto-publish disabled. Manual publish only.'
        );
      }
    });
    fields.publishButton?.addEventListener('click', () => {
      if (!capturedParsedPayload) {
        setStatus('Publish blocked: no parsed End node payload captured yet.', false);
        return;
      }
      runPublishFromPayload(capturedParsedPayload, 'Manual console/test payload');
    });
    initializeChatKit().catch((error) => {
      console.error('ChatKit initialization failed.', error);
      setStatus(error instanceof Error ? error.message : 'ChatKit could not be initialized.', false);
    });
  })();
</script>
<script src="https://cdn.platform.openai.com/deployments/chatkit/chatkit.js" async></script>
