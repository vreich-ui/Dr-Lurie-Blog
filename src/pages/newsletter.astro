---
import Layout from '~/layouts/PageLayout.astro';
import { getBlogPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Newsletter',
  description: 'Join the Dr. Lurié newsletter for skin science notes and launch updates.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Newsletter</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-heading sm:text-5xl">Skin science notes in your inbox.</h1>
    <p class="mt-5 text-lg leading-8 text-muted">
      Newsletter sign-up will share practical education, research notes, and early access announcements from Dr. Lurié.
    </p>
    <div class="mt-8">
      <a class="btn-primary" href={getBlogPermalink()}>Read the library</a>
    </div>
  </section>
</Layout>
