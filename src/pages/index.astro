---
import Layout from '~/layouts/PageLayout.astro';
import Footer from '~/components/widgets/Footer.astro';
import { getAsset, getBlogPermalink, getPermalink } from '~/utils/permalinks';

const homeFooterData = {
  brand: 'Dr. Lurié Skin Care',
  descriptor: 'Healthy Skin for Skincare Newcomers',
  links: [
    {
      title: 'Start learning',
      links: [
        { text: 'Start Here', href: getPermalink('/#start-here') },
        { text: 'Beginner Guides', href: getBlogPermalink() },
        { text: 'Healthy Aging', href: getPermalink('/topics') },
        { text: 'Skin Barrier Health', href: getPermalink('/topics') },
      ],
    },
    {
      title: 'Connect',
      links: [
        { text: 'About', href: getPermalink('/about') },
        { text: 'Newsletter', href: getPermalink('/#newsletter') },
      ],
    },
  ],
  secondaryLinks: [
    { text: 'Terms', href: getPermalink('/terms') },
    { text: 'Privacy', href: getPermalink('/privacy') },
  ],
  socialLinks: [{ ariaLabel: 'RSS', icon: 'tabler:rss', href: getAsset('/rss.xml') }],
  footNote: `
    Educational content only — not medical advice. © Dr. Lurié.
  `,
};

const metadata = {
  title: 'Dr. Lurié Skin Care | Healthy Skin for Skincare Newcomers',
  ignoreTitleTemplate: true,
  openGraph: {
    images: [
      {
        url: 'https://kugelmedia.netlify.app/drlurieblog/dr-lurie-home-social-preview.jpg',
        width: 1200,
        height: 630,
      },
    ],
  },
};

const audienceNotes = [
  'You are new to skincare and want a calm place to begin.',
  'You want to understand what your skin needs before buying more products.',
  'You prefer physician-led education over trend-driven routines.',
  'You want simple explanations that respect both science and everyday life.',
];

const startHereArticles = [
  {
    title: 'What Healthy Skin Means',
    description: 'A plain-language starting point for understanding comfort, resilience, and consistency in your skin.',
  },
  {
    title: 'How to Build a Simple Skincare Routine',
    description: 'The essential steps to begin with, what each one is meant to do, and why more is not always better.',
  },
  {
    title: 'How to Choose Products Without Feeling Overwhelmed',
    description: 'A practical way to read claims, compare options, and focus on what your skin actually needs.',
  },
  {
    title: 'What to Do When Your Skin Feels Sensitive',
    description: 'How to slow down, simplify your routine, and notice the patterns that may be affecting your skin.',
  },
  {
    title: 'When to Ask a Dermatology Professional',
    description: 'A guide to knowing when education is enough and when a skin concern deserves medical attention.',
  },
];

const trustNotes = [
  'Physician-led perspective on skin health education.',
  'MD, PhD in Biophysics with decades of pharmaceutical research and development experience.',
  'Clear explanations designed for people who are just beginning to care for their skin intentionally.',
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="mb-4 text-sm font-medium uppercase tracking-[0.16em] text-accent">
      Physician-led skin health education
    </p>
    <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-heading sm:text-5xl">
      Healthy Skin for Skincare Newcomers
    </h1>
    <p class="mt-6 max-w-2xl text-xl leading-8 text-default">
      A calmer, clearer way to begin caring for your skin — without complicated routines, product pressure, or trend-led
      advice.
    </p>
    <p class="mt-5 max-w-2xl text-base leading-7 text-muted">
      Dr. Lurié Skin Care helps newcomers understand the basics of healthy skin, choose simple next steps, and build
      confidence through physician-led education.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a class="btn-primary" href="#start-here">Start Here</a>
      <a class="btn-secondary" href="#newsletter">Join Newsletter</a>
    </div>
  </section>

  <section id="audience" class="mx-auto max-w-5xl border-t border-gray-200 px-4 py-14 sm:px-6 dark:border-gray-800">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-accent">This is for you if…</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-heading sm:text-3xl">
        You want skincare to feel understandable.
      </h2>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        audienceNotes.map((note) => (
          <article class="rounded-2xl border border-gray-200 bg-white p-5 text-default dark:border-gray-800 dark:bg-slate-900">
            <p>{note}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="start-here" class="mx-auto max-w-5xl border-t border-gray-200 px-4 py-14 sm:px-6 dark:border-gray-800">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-accent">Start here</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-heading sm:text-3xl">
        Five simple places to begin.
      </h2>
      <p class="mt-4 text-muted">
        Read these in order or choose the question that feels most useful today.
      </p>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        startHereArticles.map((article, index) => (
          <article class="rounded-2xl border border-gray-200 bg-gray-50 p-6 dark:border-gray-800 dark:bg-slate-900">
            <p class="text-sm font-medium text-accent">Article {index + 1}</p>
            <h3 class="mt-3 text-xl font-semibold text-heading">{article.title}</h3>
            <p class="mt-3 text-muted">{article.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="about" class="mx-auto max-w-5xl border-t border-gray-200 px-4 py-14 sm:px-6 dark:border-gray-800">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-accent">About</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-heading sm:text-3xl">Meet Dr. Lurié</h2>
      </div>
      <div>
        <p class="text-lg leading-8 text-default">
          Dr. Lurié brings a physician and scientist’s lens to skin health education, translating complex ideas into
          steady guidance for people who are beginning their skincare journey.
        </p>
        <ul class="mt-6 space-y-3 text-muted">
          {trustNotes.map((note) => <li class="border-l-2 border-accent/40 pl-4">{note}</li>)}
        </ul>
        <p class="mt-6 text-sm text-muted">Educational content only. Not medical advice.</p>
      </div>
    </div>
  </section>

  <section id="newsletter" class="mx-auto max-w-5xl border-t border-gray-200 px-4 py-14 sm:px-6 dark:border-gray-800">
    <div class="rounded-3xl border border-gray-200 bg-white p-6 sm:p-8 dark:border-gray-800 dark:bg-slate-900">
      <div class="max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-accent">Newsletter</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-heading sm:text-3xl">
          Learn about healthy skin one clear step at a time.
        </h2>
        <p class="mt-4 text-muted">
          Join the Dr. Lurié newsletter for concise skin health education, beginner-friendly explanations, and calm
          guidance you can return to when you need it.
        </p>
      </div>
      <form
        name="newsletter"
        method="post"
        action="/thank-you?form=newsletter"
        data-netlify="true"
        class="mt-6 max-w-xl"
        aria-label="Newsletter signup form"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <label for="newsletter-email" class="block text-sm font-medium">Email address</label>
        <div class="mt-2 flex flex-col gap-3 sm:flex-row">
          <input
            id="newsletter-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="min-w-0 flex-1 rounded-lg border border-gray-300 bg-white px-4 py-3 text-md dark:border-gray-700 dark:bg-slate-950"
            placeholder="you@example.com"
          />
          <button type="submit" class="btn-primary">Join Newsletter</button>
        </div>
      </form>
      <p class="mt-4 text-sm text-muted">No overwhelm, no trend chasing — just clear education for healthier skin.</p>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer {...homeFooterData} descriptor="Healthy Skin for Skincare Newcomers" />
  </Fragment>
</Layout>
