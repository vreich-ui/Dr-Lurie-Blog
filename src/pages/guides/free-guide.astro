---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Free Guide',
  description: 'Request the Dr. Lurié free guide to aging skin and practical skincare decisions.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Free guide</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-heading sm:text-5xl">A clearer guide to changing skin.</h1>
    <p class="mt-5 text-lg leading-8 text-muted">
      This guide will collect the essentials: barrier comfort, lipid shifts, age-related scent changes, and practical
      questions to ask before adding products.
    </p>
    <div class="mt-8">
      <a class="btn-primary" href={getPermalink('/newsletter')}>Join the newsletter</a>
    </div>
  </section>
</Layout>
