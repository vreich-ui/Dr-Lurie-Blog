---
import PageLayout from '~/layouts/PageLayout.astro';

export const prerender = false;

const { userId, redirectToSignIn } = Astro.locals.auth();

if (!userId) {
  return redirectToSignIn();
}

const metadata = {
  title: 'Members',
  description: 'Protected Dr. Lurié member area for research notes, product previews, and account resources.',
  robots: {
    index: false,
    follow: false,
  },
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:py-16">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary">Protected member area</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Welcome to Dr. Lurié Members</h1>
      <p class="mt-5 text-lg text-muted">
        This page is rendered only after Clerk validates the server-side request session. Future research notes, early
        previews, and paid-member resources can be organized from here.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      <article
        class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
      >
        <h2 class="text-xl font-semibold">Research notes</h2>
        <p class="mt-3 text-muted">Member-only education and launch updates can be listed here.</p>
      </article>
      <article
        class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
      >
        <h2 class="text-xl font-semibold">Product previews</h2>
        <p class="mt-3 text-muted">
          Preview content can be shown after authentication and upgraded with entitlements later.
        </p>
      </article>
      <article
        class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
      >
        <h2 class="text-xl font-semibold">Account access</h2>
        <p class="mt-3 text-muted">Manage your Clerk profile, security, and sessions from the account page.</p>
        <a class="btn-secondary mt-5" href="/account">Open account</a>
      </article>
    </div>

    <div
      class="mt-10 rounded-2xl border border-amber-200 bg-amber-50 p-6 text-amber-950 dark:border-amber-800 dark:bg-amber-950/40 dark:text-amber-100"
    >
      <h2 class="text-xl font-semibold">Future paid content boundary</h2>
      <p class="mt-3">
        Do not serve premium/private articles by placing full content in frontend-only JavaScript and hiding it with
        CSS. Paid content should be returned by a Netlify Function or Edge Function only after that server-side code
        validates the Clerk session and, later, the Stripe subscription or entitlement.
      </p>
    </div>
  </section>
</PageLayout>
