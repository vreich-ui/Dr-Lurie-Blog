---
import { UserProfile } from '@clerk/astro/components';
import PageLayout from '~/layouts/PageLayout.astro';

export const prerender = false;

const { userId, redirectToSignIn } = Astro.locals.auth();

if (!userId) {
  return redirectToSignIn();
}

const metadata = {
  title: 'Account',
  description: 'Manage your Dr. Lurié member profile and security settings.',
  robots: {
    index: false,
    follow: false,
  },
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:py-16">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary">Account</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Manage your profile</h1>
      <p class="mt-3 text-muted">Update account details, email addresses, security settings, and active sessions.</p>
    </div>

    <div class="mt-8 flex justify-center">
      <UserProfile routing="path" path="/account" />
    </div>
  </section>
</PageLayout>
