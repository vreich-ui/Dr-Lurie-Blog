---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import GridItem from '~/components/blog/GridItem.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

export const getStaticPaths = (async () => {
  const posts = await fetchPosts();
  const topics = new Map<string, { title: string; slug: string }>();

  posts.forEach((post) => {
    post.tags?.forEach((tag) => topics.set(tag.slug, tag));
  });

  return Array.from(topics.values()).map((topic) => ({
    params: { topic: topic.slug },
    props: {
      topic,
      posts: posts.filter((post) => post.tags?.some((tag) => tag.slug === topic.slug)),
    },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { topic, posts } = Astro.props as Props;

const metadata = {
  title: `${topic.title} articles`,
  description: `Science-led Dr. Lurié articles about ${topic.title}.`,
};
---

<Layout metadata={metadata}>
  <section class="dl-section">
    <a class="text-sm font-semibold text-primary hover:text-secondary" href={getPermalink('/topics')}>← All topics</a>
    <div class="mt-4 rounded-3xl bg-gradient-to-br from-sky-50 via-amber-50 to-transparent p-6 sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Topic</p>
      <h1 class="mt-3 text-4xl font-bold capitalize sm:text-5xl">{topic.title}</h1>
      <p class="mt-5 max-w-2xl text-lg text-muted">
        A focused collection of Dr. Lurié education for understanding this part of age-aware skin biology and product
        decision-making.
      </p>
    </div>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {posts.map((post) => <GridItem post={post} />)}
    </div>
  </section>
</Layout>
