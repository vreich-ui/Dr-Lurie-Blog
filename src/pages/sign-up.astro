---
import { SignUp } from '@clerk/astro/components';
import PageLayout from '~/layouts/PageLayout.astro';

export const prerender = false;

const metadata = {
  title: 'Create account',
  description: 'Create your Dr. Lurié member account.',
  robots: {
    index: false,
    follow: false,
  },
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:py-16">
    <div class="mx-auto max-w-md text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary">Join the member area</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Create your Dr. Lurié account</h1>
      <p class="mt-3 text-muted">Sign up for saved access now and future paid-member features later.</p>
    </div>

    <div class="mt-8 flex justify-center">
      <SignUp routing="path" path="/sign-up" signInUrl="/sign-in" fallbackRedirectUrl="/members" />
    </div>
  </section>
</PageLayout>
