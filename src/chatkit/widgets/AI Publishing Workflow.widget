{
  "version": "1.0",
  "name": "AI Publishing Workflow",
  "template": "{\"type\":\"Card\",\"size\":\"md\",\"padding\":0,\"children\":[{\"type\":\"Col\",\"gap\":0,\"children\":[{\"type\":\"Col\",\"padding\":4,\"gap\":2,\"children\":[{\"type\":\"Row\",\"align\":\"center\",\"children\":[{\"type\":\"Title\",\"value\":\"AI Publishing Workflow\",\"size\":\"md\"},{\"type\":\"Spacer\"},{\"type\":\"Badge\",\"label\":{{ (status) | tojson }},\"variant\":\"soft\",\"color\":\"secondary\"}]},{\"type\":\"Text\",\"value\":\"Generate, review, and publish AI-assisted articles through Netlify.\",\"color\":\"secondary\",\"size\":\"sm\"},{\"type\":\"Row\",\"gap\":1,\"children\":[{\"type\":\"Badge\",\"label\":\"ChatKit\",\"variant\":\"soft\",\"color\":\"secondary\"},{\"type\":\"Badge\",\"label\":\"OpenAI\",\"variant\":\"soft\",\"color\":\"secondary\"},{\"type\":\"Badge\",\"label\":\"Netlify\",\"variant\":\"soft\",\"color\":\"secondary\"},{\"type\":\"Badge\",\"label\":\"Protected\",\"variant\":\"outline\",\"color\":\"secondary\"}]}]},{\"type\":\"Divider\",\"flush\":true},{\"type\":\"Col\",\"padding\":4,\"gap\":3,\"children\":[{\"type\":\"Transition\",\"children\":[{%- set _c -%}{%-if status == \"idle\" -%},{\"type\":\"Col\",\"key\":\"idle\",\"gap\":3,\"children\":[{\"type\":\"Form\",\"onSubmitAction\":{\"type\":\"agent.start_workflow\",\"payload\":{\"endpoint\":{{ (endpoint) | tojson }}}},\"children\":[{\"type\":\"Col\",\"gap\":3,\"children\":[{\"type\":\"Col\",\"gap\":1,\"children\":[{\"type\":\"Label\",\"value\":\"Article idea\",\"fieldName\":\"articleIdea\"},{\"type\":\"Textarea\",\"name\":\"articleIdea\",\"defaultValue\":{{ (articleIdea) | tojson }},\"required\":true,\"rows\":5,\"placeholder\":\"e.g., Why a room can feel clean before it looks clean\"}]},{\"type\":\"Row\",\"gap\":3,\"align\":\"center\",\"children\":[{\"type\":\"Col\",\"flex\":\"auto\",\"gap\":1,\"children\":[{\"type\":\"Label\",\"value\":\"Optional slug\",\"fieldName\":\"slug\"},{\"type\":\"Input\",\"name\":\"slug\",\"defaultValue\":{{ (slug) | tojson }},\"placeholder\":\"e.g., why-clean-has-a-smell\"}]},{\"type\":\"Checkbox\",\"name\":\"overwrite\",\"label\":\"Overwrite existing article\",\"defaultChecked\":{{ (overwrite) | tojson }}}]},{\"type\":\"Row\",\"gap\":2,\"children\":[{\"type\":\"Button\",\"submit\":true,\"style\":\"primary\",\"label\":\"Start AI workflow\",\"iconStart\":\"sparkle\"},{\"type\":\"Button\",\"label\":\"Fill smoke test\",\"variant\":\"outline\",\"iconStart\":\"reload\",\"onClickAction\":{\"type\":\"agent.fill_test_payload\",\"payload\":{\"endpoint\":{{ (endpoint) | tojson }}}}}]}]}]},{\"type\":\"Caption\",\"value\":{{ ((\"Posts to \" ~ endpoint)) | tojson }}},{\"type\":\"Row\",\"gap\":2,\"align\":\"center\",\"children\":[{\"type\":\"Icon\",\"name\":\"info\",\"color\":\"warning\"},{\"type\":\"Text\",\"value\":\"No OpenAI API keys or publish secrets are exposed in the browser.\",\"color\":\"warning\",\"size\":\"sm\"}]}]}{%-else-%}{%-endif-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}]}]}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": [
          "idle",
          "researching",
          "angle_review",
          "draft_ready",
          "publishing",
          "published",
          "error"
        ]
      },
      "articleIdea": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "slug": {
        "type": "string"
      },
      "markdown": {
        "type": "string"
      },
      "overwrite": {
        "type": "boolean"
      },
      "recommendedAngle": {
        "type": "string"
      },
      "hook": {
        "type": "string"
      },
      "editorialPromise": {
        "type": "string"
      },
      "risks": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "imageBrief": {
        "type": "string"
      },
      "endpoint": {
        "type": "string"
      },
      "result": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "articlePath": {
                "type": "string"
              },
              "commit": {
                "type": "string"
              },
              "deployStatus": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "articlePath",
              "commit",
              "deployStatus",
              "message"
            ],
            "additionalProperties": false
          },
          {
            "type": "null"
          }
        ]
      },
      "error": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "stack": {
                "type": "string"
              }
            },
            "required": [
              "message"
            ],
            "additionalProperties": false
          },
          {
            "type": "null"
          }
        ]
      },
      "errorJson": {
        "type": "string"
      },
      "states": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "enum": [
                "idle",
                "researching",
                "angle_review",
                "draft_ready",
                "publishing",
                "published",
                "error"
              ]
            },
            "label": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "label"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "status",
      "articleIdea",
      "title",
      "slug",
      "markdown",
      "overwrite",
      "recommendedAngle",
      "hook",
      "editorialPromise",
      "risks",
      "imageBrief",
      "endpoint",
      "result",
      "error",
      "states"
    ],
    "additionalProperties": false
  },
  "outputJsonPreview": {
    "type": "Card",
    "size": "md",
    "padding": 0,
    "children": [
      {
        "type": "Col",
        "gap": 0,
        "children": [
          {
            "type": "Col",
            "padding": 4,
            "gap": 2,
            "children": [
              {
                "type": "Row",
                "align": "center",
                "children": [
                  {
                    "type": "Title",
                    "value": "AI Publishing Workflow",
                    "size": "md"
                  },
                  {
                    "type": "Spacer"
                  },
                  {
                    "type": "Badge",
                    "label": "idle",
                    "variant": "soft",
                    "color": "secondary"
                  }
                ]
              },
              {
                "type": "Text",
                "value": "Generate, review, and publish AI-assisted articles through Netlify.",
                "color": "secondary",
                "size": "sm"
              },
              {
                "type": "Row",
                "gap": 1,
                "children": [
                  {
                    "type": "Badge",
                    "label": "ChatKit",
                    "variant": "soft",
                    "color": "secondary"
                  },
                  {
                    "type": "Badge",
                    "label": "OpenAI",
                    "variant": "soft",
                    "color": "secondary"
                  },
                  {
                    "type": "Badge",
                    "label": "Netlify",
                    "variant": "soft",
                    "color": "secondary"
                  },
                  {
                    "type": "Badge",
                    "label": "Protected",
                    "variant": "outline",
                    "color": "secondary"
                  }
                ]
              }
            ]
          },
          {
            "type": "Divider",
            "flush": true
          },
          {
            "type": "Col",
            "padding": 4,
            "gap": 3,
            "children": [
              {
                "type": "Transition",
                "children": {
                  "type": "Col",
                  "key": "idle",
                  "gap": 3,
                  "children": [
                    {
                      "type": "Form",
                      "onSubmitAction": {
                        "type": "agent.start_workflow",
                        "payload": {
                          "endpoint": "/.netlify/functions/run-publisher-agent"
                        }
                      },
                      "children": [
                        {
                          "type": "Col",
                          "gap": 3,
                          "children": [
                            {
                              "type": "Col",
                              "gap": 1,
                              "children": [
                                {
                                  "type": "Label",
                                  "value": "Article idea",
                                  "fieldName": "articleIdea"
                                },
                                {
                                  "type": "Textarea",
                                  "name": "articleIdea",
                                  "defaultValue": "",
                                  "required": true,
                                  "rows": 5,
                                  "placeholder": "e.g., Why a room can feel clean before it looks clean"
                                }
                              ]
                            },
                            {
                              "type": "Row",
                              "gap": 3,
                              "align": "center",
                              "children": [
                                {
                                  "type": "Col",
                                  "flex": "auto",
                                  "gap": 1,
                                  "children": [
                                    {
                                      "type": "Label",
                                      "value": "Optional slug",
                                      "fieldName": "slug"
                                    },
                                    {
                                      "type": "Input",
                                      "name": "slug",
                                      "defaultValue": "",
                                      "placeholder": "e.g., why-clean-has-a-smell"
                                    }
                                  ]
                                },
                                {
                                  "type": "Checkbox",
                                  "name": "overwrite",
                                  "label": "Overwrite existing article",
                                  "defaultChecked": false
                                }
                              ]
                            },
                            {
                              "type": "Row",
                              "gap": 2,
                              "children": [
                                {
                                  "type": "Button",
                                  "submit": true,
                                  "style": "primary",
                                  "label": "Start AI workflow",
                                  "iconStart": "sparkle"
                                },
                                {
                                  "type": "Button",
                                  "label": "Fill smoke test",
                                  "variant": "outline",
                                  "iconStart": "reload",
                                  "onClickAction": {
                                    "type": "agent.fill_test_payload",
                                    "payload": {
                                      "endpoint": "/.netlify/functions/run-publisher-agent"
                                    }
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Caption",
                      "value": "Posts to /.netlify/functions/run-publisher-agent"
                    },
                    {
                      "type": "Row",
                      "gap": 2,
                      "align": "center",
                      "children": [
                        {
                          "type": "Icon",
                          "name": "info",
                          "color": "warning"
                        },
                        {
                          "type": "Text",
                          "value": "No OpenAI API keys or publish secrets are exposed in the browser.",
                          "color": "warning",
                          "size": "sm"
                        }
                      ]
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "encodedWidget": "eyJpZCI6ImViYmE4Y2NiLWY4MzgtNDM2ZC04OTQzLTRkZmQ2YmMzMmRhNCIsIm5hbWUiOiJBSSBQdWJsaXNoaW5nIFdvcmtmbG93IiwidmlldyI6IjxDYXJkIHNpemU9XCJtZFwiIHBhZGRpbmc9ezB9PlxuICA8Q29sIGdhcD17MH0-XG4gICAgPENvbCBwYWRkaW5nPXs0fSBnYXA9ezJ9PlxuICAgICAgPFJvdyBhbGlnbj1cImNlbnRlclwiPlxuICAgICAgICA8VGl0bGUgdmFsdWU9XCJBSSBQdWJsaXNoaW5nIFdvcmtmbG93XCIgc2l6ZT1cIm1kXCIgLz5cbiAgICAgICAgPFNwYWNlciAvPlxuICAgICAgICA8QmFkZ2UgbGFiZWw9e3N0YXR1c30gdmFyaWFudD1cInNvZnRcIiBjb2xvcj1cInNlY29uZGFyeVwiIC8--XG4gICAgICAgIDxCYWRnZSBsYWJlbD1cIk9wZW5BSVwiIHZhcmlhbnQ9XCJzb2Z0XCIgY29sb3I9XCJzZWNvbmRhcnlcIiAvPlxuICAgICAgICA8QmFkZ2UgbGFiZWw9XCJOZXRsaWZ5XCIgdmFyaWFudD1cInNvZnRcIiBjb2xvcj1cInNlY29uZGFyeVwiIC8-XG4gICAgICAgIDxCYWRnZSBsYWJlbD1cIlByb3RlY3RlZFwiIHZhcmlhbnQ9XCJvdXRsaW5lXCIgY29sb3I9XCJzZWNvbmRhcnlcIiAvPlxuICAgICAgPC9Sb3c-XG4gICAgPC9Db2w-XG5cbiAgICA8RGl2aWRlciBmbHVzaCAvPlxuXG4gICAgPENvbCBwYWRkaW5nPXs0fSBnYXA9ezN9PlxuICAgICAgPFRyYW5zaXRpb24-XG4gICAgICAgIHtzdGF0dXMgPT09IFwiaWRsZVwiID8gKFxuICAgICAgICAgIDxDb2wga2V5PVwiaWRsZVwiIGdhcD17M30-XG4gICAgICAgICAgICA8Rm9ybVxuICAgICAgICAgICAgICBvblN1Ym1pdEFjdGlvbj17e1xuICAgICAgICAgICAgICAgIHR5cGU6IFwiYWdlbnQuc3RhcnRfd29ya2Zsb3dcIixcbiAgICAgICAgICAgICAgICBwYXlsb2FkOiB7IGVuZHBvaW50IH0sXG4gICAgICAgICAgICAgIH19XG4gICAgICAgICAgICA-XG4gICAgICAgICAgICAgIDxDb2wgZ2FwPXszfT5cbiAgICAgICAgICAgICAgICA8Q29sIGdhcD17MX0-XG4gICAgICAgICAgICAgICAgICA8TGFiZWwgdmFsdWU9XCJBcnRpY2xlIGlkZWFcIiBmaWVsZE5hbWU9XCJhcnRpY2xlSWRlYVwiIC8----XG4gICAgICAgICAgICA8L0Zvcm0---XG4gICAgICAgICAgPC9Db2w-XG4gICAgICAgICkgOiBzdGF0dXMgPT09IFwiYW5nbGVfcmV2aWV3XCIgPyAoXG4gICAgICAgICAgPENvbCBrZXk9XCJhbmdsZV9yZXZpZXdcIiBnYXA9ezN9PlxuICAgICAgICAgICAgPEJveCBib3JkZXI9ezF9IHJhZGl1cz1cIm1kXCIgcGFkZGluZz17M30gYmFja2dyb3VuZD1cInN1cmZhY2VcIj5cbiAgICAgICAgICAgICAgPENhcHRpb24gdmFsdWU9XCJSZWNvbW1lbmRlZCBhbmdsZVwiIC8-XG4gICAgICAgICAgICAgIDxUZXh0IHZhbHVlPXtyZWNvbW1lbmRlZEFuZ2xlIHx8IFwiTm8gYW5nbGUgcHJvdmlkZWQgeWV0LlwifSAvPlxuICAgICAgICAgICAgPC9Cb3g-XG5cbiAgICAgICAgICAgIDxSb3cgZ2FwPXszfT5cbiAgICAgICAgICAgICAgPEJveCBib3JkZX