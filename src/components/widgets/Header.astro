---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import HeaderAuthButton from '~/components/common/HeaderAuthButton.astro';
import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash, getAsset, getPermalink } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
  description?: string;
  authAction?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
  logoText?: string;
}

const {
  id = 'header',
  links = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
  logoText,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-50/0 transition-[transform,opacity] duration-300 ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full',
      {
        'md:flex md:justify-between': position !== 'center',
      },
      {
        'md:grid md:grid-cols-3 md:items-center': position === 'center',
      },
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo text={logoText} />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="items-center w-full md:w-auto hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-y-visible md:overflow-x-auto md:justify-self-center"
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-[0.9375rem] tracking-[0.01rem] font-medium md:justify-center"
      >
        {
          links.map(({ text, href, links }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button
                    type="button"
                    class="flex w-full items-center justify-between whitespace-nowrap border-b border-gray-200/70 px-1 py-4 text-left hover:text-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:border-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-950 md:w-auto md:justify-start md:border-b-0 md:px-4 md:py-3"
                    aria-expanded="false"
                    data-mobile-accordion-trigger
                  >
                    <span>{text}</span>
                    <span class="flex items-center">
                      <Icon
                        name="tabler:plus"
                        class="h-4 w-4 md:hidden"
                        data-mobile-accordion-icon-closed
                        aria-hidden="true"
                      />
                      <Icon
                        name="tabler:minus"
                        class="hidden h-4 w-4 md:hidden"
                        data-mobile-accordion-icon-open
                        aria-hidden="true"
                      />
                      <Icon
                        name="tabler:chevron-down"
                        class="ml-0.5 hidden h-3.5 w-3.5 rtl:ml-0 rtl:mr-0.5 md:inline"
                      />
                    </span>
                  </button>
                  <div class="dropdown-menu mega-menu rounded-2xl pl-4 font-medium md:absolute md:left-1/2 md:top-full md:mt-3 md:min-w-[520px] md:max-w-[min(680px,calc(100vw-2rem))] md:rounded-3xl md:border md:border-gray-200/75 md:bg-white/95 md:p-4 md:shadow-2xl md:shadow-slate-900/10 md:ring-1 md:ring-slate-900/5 md:backdrop-blur-xl dark:md:border-slate-700/70 dark:md:bg-slate-950/95 dark:md:shadow-black/30 dark:md:ring-white/10">
                    <ul class="grid gap-2 md:grid-cols-2">
                      {links.map(({ text: text2, href: href2, description, authAction }) => (
                        <li>
                          {authAction ? (
                            <button
                              type="button"
                              class="group block w-full rounded-2xl border border-transparent bg-white/70 px-4 py-3 text-left whitespace-normal transition-colors hover:border-gray-200 hover:bg-gray-50 hover:text-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:bg-slate-900/60 dark:hover:border-slate-700 dark:hover:bg-slate-800/90 dark:hover:text-white dark:focus-visible:ring-offset-slate-950"
                              {...(authAction === 'profile'
                                ? { 'data-auth-profile': true }
                                : { 'data-auth-sign-out': true })}
                            >
                              <span class="block font-semibold">{text2}</span>
                              {description && (
                                <span
                                  class="mt-1 block text-sm font-normal leading-5 text-slate-600 group-hover:text-slate-700 dark:text-slate-300 dark:group-hover:text-slate-200"
                                  data-menu-description
                                >
                                  {description}
                                </span>
                              )}
                            </button>
                          ) : (
                            <a
                              class:list={[
                                'group block rounded-2xl border border-transparent bg-white/70 px-4 py-3 whitespace-normal transition-colors hover:border-gray-200 hover:bg-gray-50 hover:text-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:bg-slate-900/60 dark:hover:border-slate-700 dark:hover:bg-slate-800/90 dark:hover:text-white dark:focus-visible:ring-offset-slate-950',
                                { 'aw-link-active': href2 === currentPath },
                              ]}
                              href={href2}
                            >
                              <span class="block font-semibold">{text2}</span>
                              {description && (
                                <span
                                  class="mt-1 block text-sm font-normal leading-5 text-slate-600 group-hover:text-slate-700 dark:text-slate-300 dark:group-hover:text-slate-200"
                                  data-menu-description
                                >
                                  {description}
                                </span>
                              )}
                            </a>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-link dark:hover:text-white px-4 py-3 flex items-center whitespace-nowrap',
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
        <HeaderAuthButton variant="mobile-menu" />
      </ul>
      <div
        class="mx-auto mt-6 flex w-full max-w-md flex-col gap-4 border-t border-gray-200/80 px-4 py-5 dark:border-slate-800 md:hidden"
        data-mobile-menu-utilities
      >
        <div class="space-y-2" data-mobile-menu-search>
          <label class="sr-only" for="mobile-menu-search-input">Search the site</label>
          <div
            class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 shadow-sm dark:border-slate-700 dark:bg-slate-900"
          >
            <Icon name="tabler:search" class="h-5 w-5 shrink-0 text-muted" />
            <input
              id="mobile-menu-search-input"
              class="w-full border-0 bg-transparent p-0 text-base text-default placeholder:text-muted focus-visible:ring-0 focus-visible:ring-offset-0"
              type="search"
              placeholder="Search the site"
              autocomplete="off"
              aria-label="Search the site"
            />
          </div>
          <div
            id="mobile-search-results"
            class="hidden max-h-[40vh] overflow-y-auto rounded-2xl bg-surface p-2 shadow-inner"
            data-mobile-search-results
          >
          </div>
        </div>
        <a
          class="inline-flex w-full justify-center rounded-full bg-primary px-5 py-3 text-base font-semibold text-white shadow-sm shadow-slate-900/10 transition-colors hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-950"
          href={getPermalink('/newsletter')}
          data-mobile-newsletter-cta
        >
          Join Newsletter
        </a>
      </div>
    </nav>
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex md:items-center md:mb-0 md:w-auto md:static md:justify-end md:p-0 md:justify-self-end md:flex-nowrap',
      ]}
      data-desktop-header-utilities
    >
      <div
        class="flex w-full flex-wrap items-center justify-between gap-2 border-t border-gray-200/80 bg-page pt-4 dark:border-slate-800 md:w-auto md:flex-nowrap md:justify-end md:border-t-0 md:bg-transparent md:pt-0"
      >
        <div class="flex shrink-0 flex-nowrap items-center gap-1">
          <button
            type="button"
            class="inline-flex items-center rounded-lg p-2.5 text-sm text-muted transition-colors hover:bg-gray-100 hover:text-link focus:outline-none focus:ring-4 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white dark:focus:ring-gray-700"
            aria-label="Open search"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls="header-search-overlay"
            data-header-search-trigger
          >
            <Icon name="tabler:search" class="h-5 w-5" />
          </button>
          {
            showRssFeed && (
              <a
                class="text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center"
                aria-label="RSS Feed"
                href={getAsset('/rss.xml')}
              >
                <Icon name="tabler:rss" class="w-5 h-5" />
              </a>
            )
          }
          {showToggleTheme && <ToggleTheme iconClass="w-6 h-6 md:w-5 md:h-5 md:inline-block" />}
        </div>
        <span class="flex shrink-0 flex-wrap items-center justify-end gap-2 whitespace-nowrap">
          <HeaderAuthButton />
        </span>
      </div>
    </div>
  </div>
</header>

<div
  id="header-search-overlay"
  class="fixed inset-0 z-50 hidden bg-slate-950/35 px-4 py-6 backdrop-blur-sm sm:px-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="header-search-title"
  data-header-search-overlay
>
  <div
    class="mx-auto mt-16 max-w-2xl rounded-3xl border border-gray-200/80 bg-white p-4 shadow-2xl shadow-slate-900/20 dark:border-slate-700/80 dark:bg-slate-950 dark:shadow-black/40 sm:p-5"
  >
    <div class="mb-4 flex items-center justify-between gap-4">
      <div>
        <h2 id="header-search-title" class="text-lg font-semibold text-default">Search Dr. Lurié</h2>
        <p class="mt-1 text-sm text-muted" data-header-search-description>Quickly find articles, topics, and guides.</p>
      </div>
      <button
        type="button"
        class="inline-flex rounded-full p-2 text-muted transition-colors hover:bg-gray-100 hover:text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:bg-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-950"
        aria-label="Close search"
        data-header-search-close
      >
        <Icon name="tabler:x" class="h-5 w-5" />
      </button>
    </div>
    <form data-header-search-form>
      <label class="sr-only" for="header-search-input">Search query</label>
      <div
        class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-surface px-4 py-3 dark:border-slate-700 dark:bg-slate-900"
      >
        <Icon name="tabler:search" class="h-5 w-5 shrink-0 text-muted" />
        <input
          id="header-search-input"
          class="w-full border-0 bg-transparent p-0 text-base text-default placeholder:text-muted focus-visible:ring-0 focus-visible:ring-offset-0"
          type="search"
          placeholder="Search articles, topics, and solutions"
          autocomplete="off"
          data-header-search-input
        />
      </div>
      <p class="mt-3 text-sm text-muted" aria-live="polite" data-header-search-status></p>
    </form>
    <div id="header-search-results" class="mt-4 max-h-[50vh] overflow-y-auto pr-2" data-header-search-results></div>
  </div>
</div>

<script>
  const headerDropdownCloseDelay = 180;
  const headerDropdownDesktopQuery = window.matchMedia('(min-width: 768px)');

  function initHeaderDropdownHoverIntent() {
    const header = document.getElementById('header') as
      | (HTMLElement & { awDropdownHoverIntentController?: AbortController })
      | null;

    if (!header) return;

    header.awDropdownHoverIntentController?.abort();

    const controller = new AbortController();
    header.awDropdownHoverIntentController = controller;

    const dropdowns = Array.from(header.querySelectorAll<HTMLElement>('.dropdown'));
    const closeTimers = new WeakMap<HTMLElement, number>();

    const clearPendingClose = (dropdown: HTMLElement) => {
      const timer = closeTimers.get(dropdown);

      if (timer) {
        window.clearTimeout(timer);
        closeTimers.delete(dropdown);
      }
    };

    const closeDropdown = (dropdown: HTMLElement) => {
      clearPendingClose(dropdown);
      dropdown.classList.remove('dropdown-open');
    };

    const openDropdown = (dropdown: HTMLElement) => {
      if (!headerDropdownDesktopQuery.matches) return;

      dropdowns.forEach((item) => {
        if (item !== dropdown) closeDropdown(item);
      });
      clearPendingClose(dropdown);
      dropdown.classList.add('dropdown-open');
    };

    const scheduleClose = (dropdown: HTMLElement) => {
      clearPendingClose(dropdown);

      const timer = window.setTimeout(() => {
        closeDropdown(dropdown);
      }, headerDropdownCloseDelay);

      closeTimers.set(dropdown, timer);
    };

    dropdowns.forEach((dropdown) => {
      const menu = dropdown.querySelector<HTMLElement>('.dropdown-menu');

      dropdown.addEventListener('mouseenter', () => openDropdown(dropdown), { signal: controller.signal });
      dropdown.addEventListener('mouseleave', () => scheduleClose(dropdown), { signal: controller.signal });
      dropdown.addEventListener('focusin', () => openDropdown(dropdown), { signal: controller.signal });
      dropdown.addEventListener(
        'focusout',
        (event) => {
          const nextFocusedElement = event.relatedTarget;

          if (nextFocusedElement instanceof Node && dropdown.contains(nextFocusedElement)) return;

          scheduleClose(dropdown);
        },
        { signal: controller.signal }
      );

      menu?.addEventListener('mouseenter', () => openDropdown(dropdown), { signal: controller.signal });
      menu?.addEventListener('mouseleave', () => scheduleClose(dropdown), { signal: controller.signal });
    });

    headerDropdownDesktopQuery.addEventListener(
      'change',
      (event) => {
        if (event.matches) return;

        dropdowns.forEach(closeDropdown);
      },
      { signal: controller.signal }
    );
  }

  function initHeaderSearchOverlay() {
    const searchWindow = window as Window & { awHeaderSearchController?: AbortController };
    searchWindow.awHeaderSearchController?.abort();

    const overlay = document.querySelector<HTMLElement>('[data-header-search-overlay]');
    const input = document.querySelector<HTMLInputElement>('[data-header-search-input]');
    const status = document.querySelector<HTMLElement>('[data-header-search-status]');
    const form = document.querySelector<HTMLFormElement>('[data-header-search-form]');
    const triggers = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-header-search-trigger]'));
    const closeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-header-search-close]'));
    let previousFocus: Element | null = null;

    if (!overlay || !input) return;

    const controller = new AbortController();
    searchWindow.awHeaderSearchController = controller;

    interface SearchItem {
      title: string;
      excerpt?: string;
      permalink: string;
      category?: string;
      tags?: string[];
      publishDate: string;
    }

    let searchIndex: SearchItem[] | null = null;
    const desktopResults = document.querySelector<HTMLElement>('[data-header-search-results]');
    const mobileInput = document.querySelector<HTMLInputElement>('#mobile-menu-search-input');
    const mobileResults = document.querySelector<HTMLElement>('[data-mobile-search-results]');

    const fetchIndex = async () => {
      if (searchIndex) return;
      try {
        const response = await fetch('/search.json');
        searchIndex = (await response.json()) as SearchItem[];
      } catch (e) {
        console.error('Failed to load search index', e);
      }
    };

    const performSearch = (query: string, resultsContainer: HTMLElement | null, statusElement: HTMLElement | null) => {
      if (!searchIndex || !resultsContainer) return;

      const normalizedQuery = query.toLowerCase().trim();
      if (!normalizedQuery) {
        resultsContainer.innerHTML = '';
        resultsContainer.classList.add('hidden');
        if (statusElement) statusElement.textContent = '';
        return;
      }

      const results = searchIndex.filter(
        (item) =>
          item.title.toLowerCase().includes(normalizedQuery) ||
          item.excerpt?.toLowerCase().includes(normalizedQuery) ||
          item.category?.toLowerCase().includes(normalizedQuery) ||
          item.tags?.some((tag) => tag.toLowerCase().includes(normalizedQuery))
      );

      if (results.length === 0) {
        resultsContainer.innerHTML = `
          <div class="py-8 text-center">
            <p class="text-default font-semibold">No results found for “${query}”</p>
            <p class="text-sm text-muted mt-1">Try a different keyword or topic.</p>
          </div>
        `;
        resultsContainer.classList.remove('hidden');
        if (statusElement) statusElement.textContent = `No results for “${query}”.`;
        return;
      }

      resultsContainer.innerHTML = results
        .map(
          (result) => `
        <a href="/${result.permalink}" class="block p-3 rounded-2xl hover:bg-gray-100 dark:hover:bg-slate-900 transition-colors group mb-1">
          <span class="block text-sm font-bold text-default group-hover:text-primary transition-colors">${result.title}</span>
          ${result.excerpt ? `<span class="block text-xs text-muted mt-1 line-clamp-2">${result.excerpt}</span>` : ''}
          <span class="flex items-center gap-2 mt-2">
            ${result.category ? `<span class="text-[10px] uppercase tracking-wider font-extrabold text-accent bg-accent/10 px-1.5 py-0.5 rounded-md">${result.category}</span>` : ''}
            <span class="text-[10px] text-muted font-medium">${new Intl.DateTimeFormat(undefined, { month: 'short', day: 'numeric', year: 'numeric' }).format(new Date(result.publishDate))}</span>
          </span>
        </a>
      `
        )
        .join('');

      resultsContainer.classList.remove('hidden');
      if (statusElement)
        statusElement.textContent = `Found ${results.length} result${results.length === 1 ? '' : 's'} for “${query}”.`;
    };

    const handleInput = () => {
      const query = input.value;
      performSearch(query, desktopResults, status);
    };

    const handleMobileInput = () => {
      if (!mobileInput) return;
      const query = mobileInput.value;
      performSearch(query, mobileResults, null);
    };

    const closeSearch = () => {
      overlay.classList.add('hidden');
      triggers.forEach((trigger) => trigger.setAttribute('aria-expanded', 'false'));

      if (previousFocus instanceof HTMLElement) previousFocus.focus();
    };

    const openSearch = () => {
      previousFocus = document.activeElement;
      overlay.classList.remove('hidden');
      triggers.forEach((trigger) => trigger.setAttribute('aria-expanded', 'true'));
      window.requestAnimationFrame(() => input.focus());
      handleInput();
    };

    triggers.forEach((trigger) =>
      trigger.addEventListener(
        'click',
        async () => {
          await fetchIndex();
          openSearch();
        },
        { signal: controller.signal }
      )
    );
    closeButtons.forEach((button) => button.addEventListener('click', closeSearch, { signal: controller.signal }));
    input.addEventListener('input', handleInput, { signal: controller.signal });
    mobileInput?.addEventListener(
      'input',
      async () => {
        await fetchIndex();
        handleMobileInput();
      },
      { signal: controller.signal }
    );
    form?.addEventListener(
      'submit',
      (event) => {
        event.preventDefault();
        handleInput();
      },
      { signal: controller.signal }
    );
    overlay.addEventListener(
      'click',
      (event) => {
        if (event.target === overlay) closeSearch();
      },
      { signal: controller.signal }
    );
    document.addEventListener(
      'keydown',
      (event) => {
        if (event.key === 'Escape' && !overlay.classList.contains('hidden')) closeSearch();
      },
      { signal: controller.signal }
    );
  }

  initHeaderDropdownHoverIntent();
  initHeaderSearchOverlay();
  document.addEventListener('astro:after-swap', () => {
    initHeaderDropdownHoverIntent();
    initHeaderSearchOverlay();
  });
</script>
