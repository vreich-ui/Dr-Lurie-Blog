---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const {
  inputs,
  textarea,
  disclaimer,
  button = 'Contact us',
  description = '',
  formName,
  thankYouKey,
  thankYouMessage,
  action,
  ariaLabel,
  formClass,
  inputClass = 'py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900',
  inputWrapperClass = 'mb-6',
  buttonWrapperClass = 'mt-10 grid',
} = Astro.props as Props;

if (!formName || !thankYouKey || !thankYouMessage) {
  throw new Error('Form.astro requires formName, thankYouKey, and thankYouMessage for Netlify form submissions.');
}

const formAction =
  action || `/thank-you/?form=${encodeURIComponent(thankYouKey)}&message=${encodeURIComponent(thankYouMessage)}`;
---

<!-- All Netlify forms must use this component so future forms inherit the thank-you redirect. -->
<form name={formName} method="post" action={formAction} data-netlify="true" class={formClass} aria-label={ariaLabel}>
  <input type="hidden" name="form-name" value={formName} />
  <input type="hidden" name="thankYouKey" value={thankYouKey} />
  <input type="hidden" name="thankYouMessage" value={thankYouMessage} />
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', id = name, autocomplete = 'on', placeholder = '', required = false }) =>
          name && (
            <div class={inputWrapperClass}>
              {label && (
                <label for={id} class="block text-sm font-medium">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={id}
                autocomplete={autocomplete}
                placeholder={placeholder}
                required={required}
                class={inputClass}
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-sm font-medium">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class={inputClass}
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class={buttonWrapperClass}>
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>
