---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400..800&display=swap"
  rel="stylesheet"
/>

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Source Serif 4', Georgia, serif;
    --aw-font-heading: 'Playfair Display', 'Times New Roman', serif;

    --aw-color-primary: rgb(46 111 149);
    --aw-color-secondary: rgb(37 90 120);
    --aw-color-accent: rgb(94 140 138);
    --aw-color-gold: rgb(194 168 120);

    --aw-color-text-heading: rgb(22 26 29);
    --aw-color-text-default: rgb(36 41 46);
    --aw-color-text-muted: rgb(58 65 73 / 76%);
    --aw-color-bg-page: rgb(252 251 248);
    --aw-color-bg-surface: rgb(247 245 240);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Source Serif 4', Georgia, serif;
    --aw-font-heading: 'Playfair Display', 'Times New Roman', serif;

    --aw-color-primary: rgb(46 111 149);
    --aw-color-secondary: rgb(37 90 120);
    --aw-color-accent: rgb(94 140 138);
    --aw-color-gold: rgb(194 168 120);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);
    --aw-color-bg-surface: rgb(19 24 46);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
