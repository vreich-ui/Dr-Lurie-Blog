---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';

import { getFormattedMonthYear } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const adminEditHref = `/admin/publish?edit=${encodeURIComponent(post.slug)}`;
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const heroImageAspect = (() => {
  if (post.image && typeof post.image === 'object' && 'width' in post.image && 'height' in post.image) {
    const ratio = post.image.width / post.image.height;

    return Math.abs(ratio - 3 / 2) < Math.abs(ratio - 16 / 9) ? 'aspect-[3/2]' : 'aspect-[16/9]';
  }

  return 'aspect-[16/9]';
})();
---

<section class="dl-pt-s dl-pb-l sm:py-8 lg:py-10 mx-auto">
  <article
    data-print-article
    data-clerk-publishable-key={clerkPublishableKey}
    data-post-unpublished={String(Boolean(post.draft))}
  >
    <header
      class={post.image
        ? 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
        : 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'}
    >
      <h1
        class="px-4 sm:px-6 max-w-[720px] mx-auto font-serif text-4xl md:text-5xl font-bold leading-tighter tracking-tighter"
      >
        {post.title}
      </h1>
      <p
        class="line-clamp-3 max-w-[720px] mx-auto dl-mt-s dl-mb-s px-4 sm:px-6 text-[0.7875rem] sm:text-sm leading-normal italic text-muted dark:text-slate-400"
      >
        {post.excerpt}
      </p>

      <div class="max-w-[720px] mx-auto dl-mb-s flex items-center gap-3 px-4 sm:px-6">
        <p class="inline-flex flex-wrap items-center gap-2 text-xs text-muted dark:text-slate-400">
          {post.readingTime && <span>{post.readingTime} min read</span>}
          {post.readingTime && <span aria-hidden="true">·</span>}
          <time datetime={String(post.publishDate)}>{getFormattedMonthYear(post.publishDate)}</time>
        </p>
        <div class="ml-auto inline-flex shrink-0 items-center gap-2">
          <span
            class="hidden rounded-full border border-amber-300 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800 dark:border-amber-700 dark:bg-amber-950/50 dark:text-amber-200"
            data-admin-publish-badge
          >
            Unpublished / Draft
          </span>
          <button
            type="button"
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-wait disabled:opacity-60 dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
            data-admin-publish-toggle
            data-post-slug={post.slug}
            data-post-draft={String(Boolean(post.draft))}
            hidden
            aria-pressed={!post.draft}
            aria-label={post.draft ? 'Publish article' : 'Unpublish article'}
            title={post.draft ? 'Publish article' : 'Unpublish article'}
          >
            <Icon
              name="tabler:cloud-upload"
              class={`h-5 w-5 ${post.draft ? '' : 'hidden'}`}
              data-admin-publish-icon="publish"
              aria-hidden="true"
            />
            <Icon
              name="tabler:cloud-off"
              class={`h-5 w-5 ${post.draft ? 'hidden' : ''}`}
              data-admin-publish-icon="unpublish"
              aria-hidden="true"
            />
            <span class="sr-only" data-admin-publish-status>
              {post.draft ? 'Publish article' : 'Unpublish article'}
            </span>
          </button>
          <a
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
            href={adminEditHref}
            data-admin-edit
            hidden
            aria-label="Edit article"
          >
            <Icon name="tabler:pencil" class="h-5 w-5" aria-hidden="true" />
            <span class="sr-only">Edit article</span>
          </a>
        </div>
      </div>

      {
        post.image ? (
          <Image
            src={post.image}
            class={`w-full max-w-[720px] ${heroImageAspect} object-cover mx-auto dl-mb-s sm:rounded-md bg-gray-400 dark:bg-slate-700`}
            widths={[400, 720]}
            sizes="(max-width: 720px) 100vw, 720px"
            alt={post?.excerpt || ''}
            width={720}
            height={405}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-[720px] mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
      {
        post.video && (
          <div class="mx-auto dl-mt-m max-w-[720px] px-4 sm:px-6">
            <div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <iframe
                class="aspect-video w-full"
                src={post.video}
                title={`${post.title} video`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
          </div>
        )
      }
      {
        post.ctaLink && (
          <div class="mx-auto dl-mt-m max-w-[720px] px-4 sm:px-6">
            <a class="btn-primary" href={post.ctaLink}>
              {post.ctaText || 'Learn more'}
            </a>
          </div>
        )
      }
    </header>
    <div class="editorial-prose px-6 sm:px-6 dl-mt-s dl-gap-m">
      <slot />
    </div>
    <div class="post-actions mx-auto flex max-w-[720px] items-center gap-3 px-6 sm:px-6 dl-mt-m">
      <button
        type="button"
        data-immersive-share
        data-share-url={String(url)}
        data-share-title={post.title}
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
        aria-label="Share article"
      >
        <Icon name="tabler:share" class="h-5 w-5" aria-hidden="true" />
        <span class="sr-only" data-share-status>Share article</span>
      </button>
      <button
        type="button"
        data-immersive-print
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
        aria-label="Print article"
      >
        <Icon name="tabler:printer" class="h-5 w-5" aria-hidden="true" />
        <span class="sr-only">Print article</span>
      </button>
      <a
        class="ml-auto inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
        href={adminEditHref}
        data-admin-edit
        hidden
        aria-label="Edit article"
      >
        <Icon name="tabler:pencil" class="h-5 w-5" aria-hidden="true" />
        <span class="sr-only">Edit article</span>
      </a>
    </div>
  </article>
  <dialog
    class="w-[min(92vw,32rem)] rounded-2xl border border-gray-200 bg-white p-0 text-default shadow-2xl backdrop:bg-slate-950/50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
    data-admin-publish-confirm
    aria-labelledby="admin-publish-confirm-title"
  >
    <form method="dialog" class="p-6">
      <div class="flex items-start gap-3">
        <div
          class="mt-1 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-100 text-amber-700 dark:bg-amber-950 dark:text-amber-300"
        >
          <Icon name="tabler:alert-triangle" class="h-5 w-5" aria-hidden="true" />
        </div>
        <div>
          <h2 id="admin-publish-confirm-title" class="font-heading text-xl font-bold">Confirm article status change</h2>
          <p class="mt-2 text-sm leading-6 text-muted dark:text-slate-300" data-admin-publish-confirm-message>
            Unpublishing saves this article as a draft and removes it from public library pages after the site
            refreshes.
          </p>
        </div>
      </div>
      <div class="mt-6 flex flex-wrap justify-end gap-3">
        <button class="btn-secondary" type="submit" value="cancel">Cancel</button>
        <button class="btn-primary" type="submit" value="confirm">Confirm</button>
      </div>
    </form>
  </dialog>
</section>

<style>
  [data-admin-edit][hidden],
  [data-admin-publish-toggle][hidden] {
    display: none !important;
  }

  [data-print-article][data-post-unpublished='true'] {
    opacity: 0.72;
    filter: grayscale(0.35);
  }

  [data-print-article][data-post-unpublished='true'] [data-admin-publish-badge] {
    display: inline-flex;
  }

  @media print {
    body > * {
      display: none !important;
    }

    body > *:has([data-print-article]) {
      display: block !important;
      visibility: visible !important;
    }

    [data-print-article],
    [data-print-article] * {
      visibility: visible !important;
    }

    [data-print-article] {
      position: static !important;
      display: block !important;
      width: auto !important;
      max-width: none !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .post-actions,
    [data-admin-edit],
    [data-admin-publish-toggle],
    [data-admin-publish-badge] {
      display: none !important;
    }
  }
</style>

<script is:inline>
  const registerAdminEditControls = () => {
    const article = document.querySelector('[data-print-article]');
    const adminEditControls = Array.from(document.querySelectorAll('[data-admin-edit]'));
    const adminPublishControls = Array.from(document.querySelectorAll('[data-admin-publish-toggle]'));
    const adminControls = [...adminEditControls, ...adminPublishControls];
    const clerkPublishableKey = article?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';

    if (!adminControls.length || !clerkPublishableKey) return;

    let clerkLoadPromise;

    const setAdminControlsVisible = (visible) => {
      adminControls.forEach((control) => {
        control.hidden = !visible;
      });
    };

    const loadClerkScript = () =>
      new Promise((resolve, reject) => {
        if (window.Clerk) {
          resolve();
          return;
        }

        const resolveWhenClerkExists = () => {
          if (!window.Clerk) {
            reject(new Error('Clerk authentication could not be initialized.'));
            return;
          }

          resolve();
        };

        const existingScript = document.querySelector(
          `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
        );
        if (existingScript) {
          existingScript.addEventListener('load', resolveWhenClerkExists, { once: true });
          existingScript.addEventListener(
            'error',
            () => reject(new Error('Clerk authentication could not be loaded.')),
            {
              once: true,
            }
          );
          return;
        }

        const script = document.createElement('script');
        script.src = clerkJsScriptSrc;
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.type = 'text/javascript';
        script.dataset.drLurieClerkjs = 'true';
        script.dataset.clerkPublishableKey = clerkPublishableKey;
        script.addEventListener('load', resolveWhenClerkExists, { once: true });
        script.addEventListener('error', () => reject(new Error('Clerk authentication could not be loaded.')), {
          once: true,
        });
        document.head.append(script);
      });

    const getClerk = async () => {
      clerkLoadPromise ||= (async () => {
        await loadClerkScript();

        if (!window.Clerk) {
          throw new Error('Clerk authentication could not be initialized.');
        }

        const clerk = window.Clerk;
        await clerk.load();
        return clerk;
      })();

      return clerkLoadPromise;
    };

    const getClerkSessionToken = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return '';

      const token = await clerk.session.getToken();
      return typeof token === 'string' ? token : '';
    };

    const getAdminStateForClerk = async (clerk) => {
      const token = await getClerkSessionToken(clerk);
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };
      if (!token) return { authenticated: true, isAdmin: false };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response.json().catch(() => ({ authenticated: true, isAdmin: false }));
    };

    const setPublishControlState = (control, draft, statusText) => {
      control.dataset.postDraft = String(Boolean(draft));
      control.setAttribute('aria-pressed', String(!draft));
      control.setAttribute('aria-label', draft ? 'Publish article' : 'Unpublish article');
      control.setAttribute('title', draft ? 'Publish article' : 'Unpublish article');

      const publishIcon = control.querySelector('[data-admin-publish-icon="publish"]');
      const unpublishIcon = control.querySelector('[data-admin-publish-icon="unpublish"]');
      if (publishIcon) publishIcon.classList.toggle('hidden', !draft);
      if (unpublishIcon) unpublishIcon.classList.toggle('hidden', draft);
      [publishIcon, unpublishIcon].forEach((icon) => {
        if (!icon) return;
        icon.classList.toggle('text-amber-600', draft);
        icon.classList.toggle('dark:text-amber-300', draft);
      });

      const status = control.querySelector('[data-admin-publish-status]');
      if (status) status.textContent = statusText || (draft ? 'Article is unpublished draft' : 'Article is published');
    };

    const applyArticleDraftState = (draft) => {
      if (article) article.dataset.postUnpublished = String(Boolean(draft));
      adminPublishControls.forEach((control) => setPublishControlState(control, draft));
    };

    const confirmPublishChange = async (willDraft) => {
      const dialog = document.querySelector('[data-admin-publish-confirm]');
      const message = dialog?.querySelector('[data-admin-publish-confirm-message]');
      const warning = willDraft
        ? 'Unpublishing saves this article as a draft and removes it from public library pages after the site refreshes.'
        : 'Publishing makes this article visible on public article and library pages after the site refreshes.';

      if (message) message.textContent = warning;

      if (!(dialog instanceof HTMLDialogElement) || typeof dialog.showModal !== 'function') {
        return window.confirm(warning);
      }

      return new Promise((resolve) => {
        const handleClose = () => {
          dialog.removeEventListener('close', handleClose);
          resolve(dialog.returnValue === 'confirm');
        };

        dialog.addEventListener('close', handleClose);
        dialog.showModal();
      });
    };

    const togglePublishState = async (control) => {
      const slug = control.dataset.postSlug || '';
      const willDraft = control.dataset.postDraft !== 'true';
      const confirmed = await confirmPublishChange(willDraft);

      if (!confirmed) return;

      control.disabled = true;
      setPublishControlState(control, !willDraft, willDraft ? 'Unpublishing article…' : 'Publishing article…');

      try {
        const clerk = await getClerk();
        const token = await getClerkSessionToken(clerk);

        if (!token) throw new Error('A valid Clerk session token is required.');

        const response = await fetch('/.netlify/functions/toggle-article-publish', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ slug, draft: willDraft }),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || `Publish status update failed with status ${response.status}.`);
        }

        applyArticleDraftState(Boolean(result.draft));
        setPublishControlState(
          control,
          Boolean(result.draft),
          result.draft ? 'Article unpublished and saved as draft' : 'Article published'
        );
      } catch (error) {
        const isDraft = control.dataset.postDraft === 'true';
        setPublishControlState(
          control,
          isDraft,
          error instanceof Error ? error.message : 'Article publish status could not be updated'
        );
        window.alert(error instanceof Error ? error.message : 'Article publish status could not be updated.');
      } finally {
        control.disabled = false;
      }
    };

    adminPublishControls.forEach((control) => {
      setPublishControlState(control, control.dataset.postDraft === 'true');
      control.addEventListener('click', () => {
        togglePublishState(control);
      });
    });

    const renderAdminEditState = async (clerk) => {
      const adminState = await getAdminStateForClerk(clerk);
      setAdminControlsVisible(Boolean(adminState.isAdmin));
    };

    getClerk()
      .then(async (clerk) => {
        await renderAdminEditState(clerk);

        if (typeof clerk.addListener === 'function') {
          clerk.addListener(() => {
            renderAdminEditState(clerk).catch(() => setAdminControlsVisible(false));
          });
        }
      })
      .catch(() => setAdminControlsVisible(false));
  };

  const registerArticleActions = () => {
    const shareButton = document.querySelector('[data-immersive-share]');
    const printButton = document.querySelector('[data-immersive-print]');

    if (printButton instanceof HTMLButtonElement) {
      printButton.addEventListener('click', () => {
        window.print();
      });
    }

    if (!(shareButton instanceof HTMLButtonElement)) return;

    shareButton.addEventListener('click', async () => {
      const shareUrl = shareButton.dataset.shareUrl || window.location.href;
      const shareTitle = shareButton.dataset.shareTitle || document.title;

      if (navigator.share) {
        try {
          await navigator.share({ title: shareTitle, url: shareUrl });
          return;
        } catch {
          // Fall through to clipboard on dismiss/error.
        }
      }

      try {
        await navigator.clipboard.writeText(shareUrl);
        const shareStatus = shareButton.querySelector('[data-share-status]');
        const originalText = shareStatus?.textContent || 'Share article';
        if (shareStatus) shareStatus.textContent = 'Link copied';
        shareButton.setAttribute('aria-label', 'Link copied');
        window.setTimeout(() => {
          if (shareStatus) shareStatus.textContent = originalText;
          shareButton.setAttribute('aria-label', originalText);
        }, 1400);
      } catch {
        window.prompt('Copy this link:', shareUrl);
      }
    });
  };

  const registerPostEnhancements = () => {
    registerAdminEditControls();
    registerArticleActions();
  };

  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(registerPostEnhancements);
  } else {
    window.setTimeout(registerPostEnhancements, 1);
  }
</script>
