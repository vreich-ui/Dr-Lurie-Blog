---
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { getFormattedMonthYear } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const heroImageAspect = (() => {
  if (post.image && typeof post.image === 'object' && 'width' in post.image && 'height' in post.image) {
    const ratio = post.image.width / post.image.height;

    return Math.abs(ratio - 3 / 2) < Math.abs(ratio - 16 / 9) ? 'aspect-[3/2]' : 'aspect-[16/9]';
  }

  return 'aspect-[16/9]';
})();
---

<section class="py-5 sm:py-8 lg:py-10 mx-auto">
  <article>
    <header
      class={post.image
        ? 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
        : 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'}
    >
      <h1
        class="px-4 sm:px-6 max-w-[720px] mx-auto font-serif text-4xl md:text-5xl font-bold leading-tighter tracking-tighter"
      >
        {post.title}
      </h1>
      <p
        class="line-clamp-2 max-w-[720px] mx-auto mt-3 mb-3 px-4 sm:px-6 text-lg md:text-xl leading-snug text-muted dark:text-slate-400"
      >
        {post.excerpt}
      </p>

      <div class="max-w-[720px] mx-auto mt-0 mb-4 px-4 sm:px-6">
        <p class="inline-flex flex-wrap items-center gap-2 text-xs text-muted dark:text-slate-400">
          {post.readingTime && <span>{post.readingTime} min read</span>}
          {post.readingTime && <span aria-hidden="true">·</span>}
          <time datetime={String(post.publishDate)}>{getFormattedMonthYear(post.publishDate)}</time>
        </p>
      </div>

      {
        post.image ? (
          <Image
            src={post.image}
            class={`w-full max-w-[720px] ${heroImageAspect} object-cover mx-auto mb-4 sm:rounded-md bg-gray-400 dark:bg-slate-700`}
            widths={[400, 720]}
            sizes="(max-width: 720px) 100vw, 720px"
            alt={post?.excerpt || ''}
            width={720}
            height={405}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-[720px] mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
      {
        post.video && (
          <div class="mx-auto mt-6 max-w-[720px] px-4 sm:px-6">
            <div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <iframe
                class="aspect-video w-full"
                src={post.video}
                title={`${post.title} video`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
          </div>
        )
      }
      {
        post.ctaLink && (
          <div class="mx-auto mt-6 max-w-[720px] px-4 sm:px-6">
            <a class="btn-primary" href={post.ctaLink}>
              {post.ctaText || 'Learn more'}
            </a>
          </div>
        )
      }
    </header>
    <div class="editorial-prose px-6 sm:px-6 mt-5 prose-headings:scroll-mt-[80px]">
      <slot />
    </div>
    <div class="mx-auto px-6 sm:px-6 max-w-[720px] mt-8 flex justify-between flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-500 dark:text-slate-600" />
    </div>
  </article>
</section>
