---
import Image from '~/components/common/Image.astro';

import { getFormattedMonthYear } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const heroImageAspect = (() => {
  if (post.image && typeof post.image === 'object' && 'width' in post.image && 'height' in post.image) {
    const ratio = post.image.width / post.image.height;

    return Math.abs(ratio - 3 / 2) < Math.abs(ratio - 16 / 9) ? 'aspect-[3/2]' : 'aspect-[16/9]';
  }

  return 'aspect-[16/9]';
})();
---

<section class="dl-pt-s dl-pb-l sm:py-8 lg:py-10 mx-auto">
  <article>
    <header
      class={post.image
        ? 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
        : 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'}
    >
      <h1
        class="px-4 sm:px-6 max-w-[720px] mx-auto font-serif text-4xl md:text-5xl font-bold leading-tighter tracking-tighter"
      >
        {post.title}
      </h1>
      <p
        class="line-clamp-2 max-w-[760px] mx-auto dl-mt-s dl-mb-s px-4 sm:px-6 text-base sm:text-lg leading-normal text-muted dark:text-slate-400"
      >
        {post.excerpt}
      </p>

      <div class="max-w-[720px] mx-auto dl-mb-s px-4 sm:px-6">
        <p class="inline-flex flex-wrap items-center gap-2 text-xs text-muted dark:text-slate-400">
          {post.readingTime && <span>{post.readingTime} min read</span>}
          {post.readingTime && <span aria-hidden="true">·</span>}
          <time datetime={String(post.publishDate)}>{getFormattedMonthYear(post.publishDate)}</time>
        </p>
      </div>

      {
        post.image ? (
          <Image
            src={post.image}
            class={`w-full max-w-[720px] ${heroImageAspect} object-cover mx-auto dl-mb-s sm:rounded-md bg-gray-400 dark:bg-slate-700`}
            widths={[400, 720]}
            sizes="(max-width: 720px) 100vw, 720px"
            alt={post?.excerpt || ''}
            width={720}
            height={405}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-[720px] mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
      {
        post.video && (
          <div class="mx-auto dl-mt-m max-w-[720px] px-4 sm:px-6">
            <div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <iframe
                class="aspect-video w-full"
                src={post.video}
                title={`${post.title} video`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
          </div>
        )
      }
      {
        post.ctaLink && (
          <div class="mx-auto dl-mt-m max-w-[720px] px-4 sm:px-6">
            <a class="btn-primary" href={post.ctaLink}>
              {post.ctaText || 'Learn more'}
            </a>
          </div>
        )
      }
    </header>
    <div class="editorial-prose px-6 sm:px-6 dl-mt-s dl-gap-m">
      <slot />
    </div>
    <div class="mx-auto max-w-[720px] px-6 sm:px-6 dl-mt-m">
      <button
        type="button"
        data-immersive-share
        data-share-url={String(url)}
        data-share-title={post.title}
        class="text-sm text-muted underline decoration-gray-300 underline-offset-4 transition hover:text-default dark:text-slate-500 dark:hover:text-slate-300"
      >
        Share
      </button>
    </div>
  </article>
</section>

<script is:inline>
  const registerShareHandler = () => {
    const shareButton = document.querySelector('[data-immersive-share]');
    if (!(shareButton instanceof HTMLButtonElement)) return;

    shareButton.addEventListener('click', async () => {
      const shareUrl = shareButton.dataset.shareUrl || window.location.href;
      const shareTitle = shareButton.dataset.shareTitle || document.title;

      if (navigator.share) {
        try {
          await navigator.share({ title: shareTitle, url: shareUrl });
          return;
        } catch {
          // Fall through to clipboard on dismiss/error.
        }
      }

      try {
        await navigator.clipboard.writeText(shareUrl);
        const originalText = shareButton.textContent;
        shareButton.textContent = 'Link copied';
        window.setTimeout(() => {
          shareButton.textContent = originalText;
        }, 1400);
      } catch {
        window.prompt('Copy this link:', shareUrl);
      }
    });
  };

  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(registerShareHandler);
  } else {
    window.setTimeout(registerShareHandler, 1);
  }
</script>
