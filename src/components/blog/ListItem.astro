---
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = (await findImage(post.image)) as ImageMetadata | undefined;

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
const adminEditHref = `/admin/publish?edit=${encodeURIComponent(post.slug)}`;
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
---

<article
  class={`max-w-md mx-auto md:max-w-none grid gap-6 md:gap-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade ${image ? 'md:grid-cols-2' : ''}`}
  data-post-preview
  data-post-unpublished={String(Boolean(post.draft))}
  data-clerk-publishable-key={clerkPublishableKey}
>
  {
    image &&
      (link ? (
        <a class="relative block group" href={link ?? 'javascript:void(0)'}>
          <div class="relative h-0 pb-[56.25%] md:pb-[75%] md:h-72 lg:pb-[56.25%] overflow-hidden bg-gray-400 dark:bg-slate-700 rounded shadow-lg">
            {image && (
              <Image
                src={image}
                class="absolute inset-0 object-cover w-full h-full mb-6 rounded shadow-lg bg-gray-400 dark:bg-slate-700"
                widths={[400, 900]}
                width={900}
                sizes="(max-width: 900px) 400px, 900px"
                alt={post.title}
                aspectRatio="16:9"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        </a>
      ) : (
        <div class="relative h-0 pb-[56.25%] md:pb-[75%] md:h-72 lg:pb-[56.25%] overflow-hidden bg-gray-400 dark:bg-slate-700 rounded shadow-lg">
          {image && (
            <Image
              src={image}
              class="absolute inset-0 object-cover w-full h-full mb-6 rounded shadow-lg bg-gray-400 dark:bg-slate-700"
              widths={[400, 900]}
              width={900}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              aspectRatio="16:9"
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      ))
  }
  <div class="mt-2">
    <header>
      <div class="mb-1 flex items-start gap-3">
        <span class="text-sm">
          <Icon name="tabler:clock" class="w-3.5 h-3.5 inline-block -mt-0.5 dark:text-gray-400" />
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {
            post.author && (
              <>
                {' '}
                · <Icon name="tabler:user" class="w-3.5 h-3.5 inline-block -mt-0.5 dark:text-gray-400" />
                <span>{post.author.replaceAll('-', ' ')}</span>
              </>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a class="hover:underline" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </>
            )
          }
        </span>
        <div class="ml-auto inline-flex shrink-0 items-center gap-1" data-admin-preview-actions>
          <span
            class="hidden rounded-full border border-amber-300 bg-amber-50 px-2 py-1 text-[0.6875rem] font-semibold leading-none text-amber-800 dark:border-amber-700 dark:bg-amber-950/50 dark:text-amber-200"
            data-admin-publish-badge
          >
            Draft
          </span>
          <button
            type="button"
            class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-wait disabled:opacity-60 dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
            data-admin-publish-toggle
            data-post-slug={post.slug}
            data-post-draft={String(Boolean(post.draft))}
            hidden
            aria-pressed={!post.draft}
            aria-label={post.draft ? 'Publish article' : 'Unpublish article'}
            title={post.draft ? 'Publish article' : 'Unpublish article'}
          >
            <Icon
              name="tabler:cloud-upload"
              class={`h-4 w-4 ${post.draft ? '' : 'hidden'}`}
              data-admin-publish-icon="publish"
              aria-hidden="true"
            />
            <Icon
              name="tabler:cloud-off"
              class={`h-4 w-4 ${post.draft ? 'hidden' : ''}`}
              data-admin-publish-icon="unpublish"
              aria-hidden="true"
            />
            <span class="sr-only" data-admin-publish-status>
              {post.draft ? 'Publish article' : 'Unpublish article'}
            </span>
          </button>
          <a
            class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300"
            href={adminEditHref}
            data-admin-edit
            hidden
            aria-label="Edit article"
          >
            <Icon name="tabler:pencil" class="h-4 w-4" aria-hidden="true" />
            <span class="sr-only">Edit article</span>
          </a>
        </div>
      </div>
      <h2 class="text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading dark:text-slate-300">
        {
          link ? (
            <a
              class="inline-block hover:text-primary dark:hover:text-blue-700 transition ease-in duration-200"
              href={link}
            >
              {post.title}
            </a>
          ) : (
            post.title
          )
        }
      </h2>
    </header>

    {
      post.excerpt && (
        <p class="line-clamp-4 flex-grow text-[0.7875rem] leading-normal italic text-muted dark:text-slate-400">
          {post.excerpt}
        </p>
      )
    }
    {
      post.tags && Array.isArray(post.tags) ? (
        <footer class="mt-5">
          <PostTags tags={post.tags} />
        </footer>
      ) : (
        <Fragment />
      )
    }
  </div>
</article>

<style>
  [data-admin-edit][hidden],
  [data-admin-publish-toggle][hidden] {
    display: none !important;
  }

  [data-post-preview][data-post-unpublished='true'] {
    opacity: 0.62;
    filter: grayscale(0.45);
  }

  [data-post-preview][data-post-unpublished='true'] [data-admin-publish-badge] {
    display: inline-flex;
  }
</style>
