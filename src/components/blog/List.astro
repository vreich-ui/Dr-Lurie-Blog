---
import Item from '~/components/blog/ListItem.astro';
import type { Post } from '~/types';

export interface Props {
  posts: Array<Post>;
}

const { posts } = Astro.props;
const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
---

<div
  class="mb-8 flex flex-wrap items-center justify-end gap-3"
  data-admin-library-mode-controls
  data-clerk-publishable-key={clerkPublishableKey}
  hidden
>
  <a class="btn-secondary text-sm" href="?unpublished=1" data-admin-drafts-link>View unpublished drafts</a>
  <a class="btn-secondary text-sm" href="." data-admin-published-link hidden>Back to published Library</a>
  <p class="w-full text-right text-xs text-muted dark:text-slate-400" data-admin-unpublished-status></p>
</div>

<ul data-blog-list>
  {
    posts.map((post) => (
      <li class="mb-12 md:mb-20">
        <Item post={post} />
      </li>
    ))
  }
</ul>

<script is:inline>
  const registerBlogPreviewAdminControls = () => {
    const list = document.querySelector('[data-blog-list]');
    const modeControls = document.querySelector('[data-admin-library-mode-controls]');
    const draftsLink = document.querySelector('[data-admin-drafts-link]');
    const publishedLink = document.querySelector('[data-admin-published-link]');
    const modeStatus = document.querySelector('[data-admin-unpublished-status]');
    const firstPreview = document.querySelector('[data-post-preview]');
    const clerkPublishableKey =
      modeControls?.dataset.clerkPublishableKey || firstPreview?.dataset.clerkPublishableKey || '';
    const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
    const isUnpublishedMode = new URLSearchParams(window.location.search).get('unpublished') === '1';

    if (!list || !clerkPublishableKey) return;

    let clerkLoadPromise;
    let activeClerk;

    const setModeStatus = (message) => {
      if (modeStatus) modeStatus.textContent = message || '';
    };

    const getAdminControls = () => [
      ...Array.from(document.querySelectorAll('[data-post-preview] [data-admin-edit]')),
      ...Array.from(document.querySelectorAll('[data-post-preview] [data-admin-publish-toggle]')),
    ];

    const getAdminPublishControls = () =>
      Array.from(document.querySelectorAll('[data-post-preview] [data-admin-publish-toggle]'));

    const setAdminControlsVisible = (visible) => {
      getAdminControls().forEach((control) => {
        control.hidden = !visible;
      });
      if (modeControls) modeControls.hidden = !visible;
    };

    const configureModeLinks = () => {
      const draftUrl = new URL(window.location.href);
      draftUrl.searchParams.set('unpublished', '1');

      const publishedUrl = new URL(window.location.href);
      publishedUrl.searchParams.delete('unpublished');

      if (draftsLink) draftsLink.href = `${draftUrl.pathname}${draftUrl.search}${draftUrl.hash}`;
      if (publishedLink) publishedLink.href = `${publishedUrl.pathname}${publishedUrl.search}${publishedUrl.hash}`;
      if (draftsLink) draftsLink.hidden = isUnpublishedMode;
      if (publishedLink) publishedLink.hidden = !isUnpublishedMode;
    };

    const escapeHtml = (value) =>
      String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatDate = (value) => {
      const date = new Date(value);
      if (Number.isNaN(date.valueOf())) return '';
      return new Intl.DateTimeFormat(undefined, { month: 'short', day: 'numeric', year: 'numeric' }).format(date);
    };

    const renderDraftPreview = (post) => {
      const title = escapeHtml(post.title || post.slug || 'Untitled draft');
      const slug = escapeHtml(post.slug || '');
      const author = post.author ? ` · ${escapeHtml(String(post.author).replaceAll('-', ' '))}` : '';
      const category = post.category ? ` · ${escapeHtml(post.category)}` : '';
      const publishDate = escapeHtml(formatDate(post.publishDate));
      const excerpt = post.excerpt
        ? `<p class="line-clamp-4 flex-grow text-[0.7875rem] leading-normal italic text-muted dark:text-slate-400">${escapeHtml(post.excerpt)}</p>`
        : '';
      const tags = Array.isArray(post.tags)
        ? post.tags
            .map((tag) => `<span class="text-xs text-muted dark:text-slate-400">#${escapeHtml(tag)}</span>`)
            .join(' ')
        : '';

      return `
        <li class="mb-12 md:mb-20">
          <article class="max-w-md mx-auto md:max-w-none grid gap-6 md:gap-8" data-post-preview data-post-unpublished="true">
            <div class="mt-2 md:col-span-2">
              <header>
                <div class="mb-1 flex items-start gap-3">
                  <span class="text-sm text-muted dark:text-slate-400">
                    <time>${publishDate}</time>${author}${category}
                  </span>
                  <div class="ml-auto inline-flex shrink-0 items-center gap-1" data-admin-preview-actions>
                    <span class="inline-flex rounded-full border border-amber-300 bg-amber-50 px-2 py-1 text-[0.6875rem] font-semibold leading-none text-amber-800 dark:border-amber-700 dark:bg-amber-950/50 dark:text-amber-200" data-admin-publish-badge>Draft</span>
                    <button type="button" class="inline-flex h-9 shrink-0 items-center justify-center rounded-full px-3 text-xs font-semibold text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-wait disabled:opacity-60 dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300" data-admin-publish-toggle data-post-slug="${slug}" data-post-draft="true" aria-pressed="false" aria-label="Publish article" title="Publish article">
                      <span data-admin-publish-status>Publish</span>
                    </button>
                    <a class="inline-flex h-9 shrink-0 items-center justify-center rounded-full px-3 text-xs font-semibold text-muted transition hover:bg-gray-100 hover:text-default focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-300" href="/admin/publish?edit=${encodeURIComponent(post.slug || '')}" data-admin-edit aria-label="Edit article">
                      Edit
                    </a>
                  </div>
                </div>
                <h2 class="text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading dark:text-slate-300">${title}</h2>
              </header>
              ${excerpt}
              ${tags ? `<footer class="mt-5 flex flex-wrap gap-2">${tags}</footer>` : ''}
            </div>
          </article>
        </li>`;
    };

    const renderDrafts = (drafts) => {
      if (!Array.isArray(drafts) || !drafts.length) {
        list.innerHTML =
          '<li class="rounded-2xl border border-dashed border-gray-300 p-6 text-sm text-muted dark:border-slate-700 dark:text-slate-400">No unpublished drafts found.</li>';
        return;
      }

      list.innerHTML = drafts.map((post) => renderDraftPreview(post)).join('');
    };

    const loadClerkScript = () =>
      new Promise((resolve, reject) => {
        if (window.Clerk) {
          resolve();
          return;
        }

        const resolveWhenClerkExists = () => {
          if (!window.Clerk) {
            reject(new Error('Clerk authentication could not be initialized.'));
            return;
          }

          resolve();
        };

        const existingScript = document.querySelector(
          `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
        );
        if (existingScript) {
          existingScript.addEventListener('load', resolveWhenClerkExists, { once: true });
          existingScript.addEventListener(
            'error',
            () => reject(new Error('Clerk authentication could not be loaded.')),
            {
              once: true,
            }
          );
          return;
        }

        const script = document.createElement('script');
        script.src = clerkJsScriptSrc;
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.type = 'text/javascript';
        script.dataset.drLurieClerkjs = 'true';
        script.dataset.clerkPublishableKey = clerkPublishableKey;
        script.addEventListener('load', resolveWhenClerkExists, { once: true });
        script.addEventListener('error', () => reject(new Error('Clerk authentication could not be loaded.')), {
          once: true,
        });
        document.head.append(script);
      });

    const getClerk = async () => {
      clerkLoadPromise ||= (async () => {
        await loadClerkScript();

        if (!window.Clerk) {
          throw new Error('Clerk authentication could not be initialized.');
        }

        const clerk = window.Clerk;
        await clerk.load();
        activeClerk = clerk;
        return clerk;
      })();

      return clerkLoadPromise;
    };

    const getClerkSessionToken = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return '';

      const token = await clerk.session.getToken();
      return typeof token === 'string' ? token : '';
    };

    const getAdminStateForClerk = async (clerk) => {
      const token = await getClerkSessionToken(clerk);
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };
      if (!token) return { authenticated: true, isAdmin: false };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response.json().catch(() => ({ authenticated: true, isAdmin: false }));
    };

    const setPublishControlState = (control, draft, statusText) => {
      control.dataset.postDraft = String(Boolean(draft));
      control.setAttribute('aria-pressed', String(!draft));
      control.setAttribute('aria-label', draft ? 'Publish article' : 'Unpublish article');
      control.setAttribute('title', draft ? 'Publish article' : 'Unpublish article');

      const publishIcon = control.querySelector('[data-admin-publish-icon="publish"]');
      const unpublishIcon = control.querySelector('[data-admin-publish-icon="unpublish"]');
      if (publishIcon) publishIcon.classList.toggle('hidden', !draft);
      if (unpublishIcon) unpublishIcon.classList.toggle('hidden', draft);
      [publishIcon, unpublishIcon].forEach((icon) => {
        if (!icon) return;
        icon.classList.toggle('text-amber-600', draft);
        icon.classList.toggle('dark:text-amber-300', draft);
      });

      const status = control.querySelector('[data-admin-publish-status]');
      if (status) status.textContent = statusText || (draft ? 'Article is unpublished draft' : 'Article is published');
    };

    const applyPreviewDraftState = (control, draft) => {
      const preview = control.closest('[data-post-preview]');
      if (preview) preview.dataset.postUnpublished = String(Boolean(draft));
      setPublishControlState(control, draft);
    };

    const confirmPublishChange = (willDraft) => {
      const warning = willDraft
        ? 'Unpublishing saves this article as a draft and removes it from public library pages after the site refreshes.'
        : 'Publishing makes this article visible on public article and library pages after the site refreshes.';

      return window.confirm(warning);
    };

    const togglePublishState = async (control) => {
      const slug = control.dataset.postSlug || '';
      const willDraft = control.dataset.postDraft !== 'true';
      const confirmed = confirmPublishChange(willDraft);

      if (!confirmed) return;

      control.disabled = true;
      setPublishControlState(control, !willDraft, willDraft ? 'Unpublishing article…' : 'Publishing article…');

      try {
        const clerk = activeClerk || (await getClerk());
        const token = await getClerkSessionToken(clerk);

        if (!token) throw new Error('A valid Clerk session token is required.');

        const response = await fetch('/.netlify/functions/toggle-article-publish', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ slug, draft: willDraft }),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || `Publish status update failed with status ${response.status}.`);
        }

        applyPreviewDraftState(control, Boolean(result.draft));
        setPublishControlState(
          control,
          Boolean(result.draft),
          result.draft ? 'Article unpublished and saved as draft' : 'Article published'
        );
      } catch (error) {
        const isDraft = control.dataset.postDraft === 'true';
        setPublishControlState(
          control,
          isDraft,
          error instanceof Error ? error.message : 'Article publish status could not be updated'
        );
        window.alert(error instanceof Error ? error.message : 'Article publish status could not be updated.');
      } finally {
        control.disabled = false;
      }
    };

    const bindPreviewToggleControls = () => {
      getAdminPublishControls().forEach((control) => {
        setPublishControlState(control, control.dataset.postDraft === 'true');
        if (control.dataset.adminPublishBound === 'true') return;

        control.dataset.adminPublishBound = 'true';
        control.addEventListener('click', () => {
          togglePublishState(control);
        });
      });
    };

    const loadUnpublishedDrafts = async (clerk) => {
      if (!isUnpublishedMode) return;

      const token = await getClerkSessionToken(clerk);
      if (!token) {
        setModeStatus('Sign in as an admin to view unpublished drafts.');
        return;
      }

      setModeStatus('Loading unpublished drafts…');

      try {
        const response = await fetch('/.netlify/functions/list-draft-articles', {
          method: 'GET',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || `Draft articles could not be loaded with status ${response.status}.`);
        }

        renderDrafts(result.posts || []);
        bindPreviewToggleControls();
        setAdminControlsVisible(true);
        setModeStatus(
          `${(result.posts || []).length} unpublished draft${(result.posts || []).length === 1 ? '' : 's'} loaded.`
        );
      } catch (error) {
        setModeStatus(error instanceof Error ? error.message : 'Unpublished drafts could not be loaded.');
      }
    };

    bindPreviewToggleControls();
    configureModeLinks();

    const renderAdminEditState = async (clerk) => {
      const adminState = await getAdminStateForClerk(clerk);
      const isAdmin = Boolean(adminState.isAdmin);
      setAdminControlsVisible(isAdmin);

      if (isAdmin) {
        await loadUnpublishedDrafts(clerk);
      } else if (isUnpublishedMode) {
        setModeStatus('Sign in as an admin to view unpublished drafts.');
      }
    };

    getClerk()
      .then(async (clerk) => {
        await renderAdminEditState(clerk);

        if (typeof clerk.addListener === 'function') {
          clerk.addListener(() => {
            renderAdminEditState(clerk).catch(() => setAdminControlsVisible(false));
          });
        }
      })
      .catch(() => setAdminControlsVisible(false));
  };

  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(registerBlogPreviewAdminControls);
  } else {
    window.setTimeout(registerBlogPreviewAdminControls, 1);
  }
</script>
