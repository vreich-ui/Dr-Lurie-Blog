---
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  variant?: 'desktop' | 'mobile-menu';
}

const { variant = 'desktop' } = Astro.props;
const netlifyIdentityUrl = import.meta.env.PUBLIC_NETLIFY_IDENTITY_URL ?? '';
const authRootAttributes = {
  'data-header-auth': true,
  'data-netlify-identity-url': netlifyIdentityUrl,
};
---

{
  variant === 'mobile-menu' ? (
    <li class="dropdown md:hidden" {...authRootAttributes} data-mobile-auth-menu>
      <button
        type="button"
        class="flex w-full items-center justify-between whitespace-nowrap border-b border-gray-200/70 px-1 py-4 text-left hover:text-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:border-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-950"
        data-auth-trigger
        aria-haspopup="menu"
        aria-expanded="false"
      >
        <span data-auth-trigger-label>Login</span>
        <span class="hidden flex items-center" data-auth-trigger-chevron aria-hidden="true">
          <svg
            class="h-4 w-4"
            data-auth-mobile-icon-closed
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
          >
            <path d="M12 5v14" />
            <path d="M5 12h14" />
          </svg>
          <svg
            class="hidden h-4 w-4"
            data-auth-mobile-icon-open
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
          >
            <path d="M5 12h14" />
          </svg>
        </span>
      </button>
      <div class="dropdown-menu rounded-2xl pl-4 font-medium" data-auth-menu role="menu" hidden>
        <div data-auth-signed-out>
          <label class="flex items-center gap-2 py-2 text-sm text-muted" data-keep-signed-in-label>
            <input type="checkbox" data-keep-signed-in checked class="rounded" />
            <span>Keep me signed in</span>
          </label>
          <button type="button" data-auth-sign-in role="menuitem">
            Sign in
          </button>
        </div>
        <div data-auth-signed-in hidden>
          <button type="button" data-auth-profile role="menuitem">
            Account settings
          </button>
          <a href={getPermalink('/member-updates')} role="menuitem">
            Member updates
          </a>
          <div data-auth-admin-links hidden />
          <button type="button" data-auth-sign-out role="menuitem">
            Sign out
          </button>
        </div>
      </div>
    </li>
  ) : (
    <div class="header-auth relative ml-1" {...authRootAttributes}>
      <button
        type="button"
        class="flex items-center whitespace-nowrap px-2 py-3 text-base font-medium tracking-[0.01rem] text-default transition-colors hover:text-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-white dark:focus-visible:ring-offset-slate-950 md:text-[0.9375rem]"
        data-auth-trigger
        aria-haspopup="menu"
        aria-expanded="false"
      >
        <span data-auth-trigger-label>Login</span>
        <svg
          class="ml-0.5 hidden h-3.5 w-3.5 transition-transform rtl:ml-0 rtl:mr-0.5"
          data-auth-trigger-chevron
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </button>
      <div
        class="absolute right-0 z-50 mt-2 w-[min(14.5rem,calc(100vw-2rem))] max-w-[calc(100vw-2rem)] origin-top-right rounded-2xl border border-gray-200/80 bg-white p-2.5 text-sm shadow-xl shadow-slate-900/10 transition duration-200 dark:border-slate-700/80 dark:bg-slate-900 dark:shadow-black/30"
        data-auth-menu
        role="menu"
        hidden
      >
        <div
          class="mb-1.5 truncate border-b border-gray-200/70 px-2 pb-1.5 text-xs font-medium leading-4 text-muted dark:border-slate-700/70"
          data-auth-label
        >
          Account
        </div>

        <div class="py-1" data-auth-signed-out>
          <label class="flex cursor-pointer items-center gap-2 rounded-lg px-2.5 py-1.5 text-slate-700 transition-colors hover:bg-gray-50 dark:text-slate-300 dark:hover:bg-slate-800/60">
            <input type="checkbox" data-keep-signed-in checked class="h-3.5 w-3.5 rounded accent-[var(--aw-color-accent,#4f46e5)]" />
            <span class="text-xs font-medium">Keep me signed in</span>
          </label>
          <button
            type="button"
            class="mt-1 w-full rounded-lg bg-[var(--aw-color-accent,#4f46e5)] px-2.5 py-1.5 text-left text-xs font-semibold text-white transition-colors hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--aw-color-accent,#4f46e5)] focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-900"
            data-auth-sign-in
            role="menuitem"
          >
            Sign in
          </button>
        </div>

        <div class="space-y-0.5" data-auth-signed-in hidden>
          <button
            type="button"
            class="w-full rounded-lg px-2.5 py-1.5 text-left font-medium leading-5 text-slate-800 transition-colors hover:bg-gray-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-100 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-900"
            data-auth-profile
            role="menuitem"
          >
            Account settings
          </button>
          <a
            class="block rounded-lg px-2.5 py-1.5 font-medium leading-5 text-slate-800 transition-colors hover:bg-gray-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-100 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-900"
            href={getPermalink('/member-updates')}
            role="menuitem"
          >
            Member updates
          </a>
          <div data-auth-admin-links hidden />
          <div class="my-1 border-t border-gray-200/70 dark:border-slate-700/70" />
          <button
            type="button"
            class="w-full rounded-lg px-2.5 py-1.5 text-left font-medium leading-5 text-slate-600 transition-colors hover:bg-gray-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-900"
            data-auth-sign-out
            role="menuitem"
          >
            Sign out
          </button>
        </div>
      </div>
    </div>
  )
}

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  import { loadNetlifyIdentity } from '~/utils/netlifyIdentityLoader';

  (() => {
    if (!window.__drLurieHeaderAuth) {
      window.__drLurieHeaderAuth = {
        identityLoadPromise: undefined,
        initialized: false,
      };
    }

    const headerAuthState = window.__drLurieHeaderAuth;
    const getAuthRoots = () => Array.from(document.querySelectorAll('[data-header-auth]'));

    const getIdentityUrl = () => {
      const firstRoot = getAuthRoots()[0];
      return firstRoot?.dataset.netlifyIdentityUrl || undefined;
    };

    const SESSION_ACTIVE_KEY = 'dr-lurie-session-active';
    const KEEP_SIGNED_IN_KEY = 'dr-lurie-keep-signed-in';

    const isKeepSignedIn = () => localStorage.getItem(KEEP_SIGNED_IN_KEY) === '1';
    const hasActiveSession = () => sessionStorage.getItem(SESSION_ACTIVE_KEY) === '1';

    const getKeepSignedInCheckbox = () => {
      const root = getAuthRoots().find((r) => !r.hasAttribute('data-mobile-auth-menu'));
      return root?.querySelector('[data-keep-signed-in]');
    };

    const setMenuOpen = (root, open) => {
      const trigger = root.querySelector('[data-auth-trigger]');
      const menu = root.querySelector('[data-auth-menu]');
      if (!trigger || !menu) return;

      menu.hidden = !open;
      trigger.setAttribute('aria-expanded', String(open));
      root.classList.toggle('mobile-open', root.hasAttribute('data-mobile-auth-menu') && open);
      root.querySelector('[data-auth-trigger-chevron]')?.classList.toggle('rotate-180', open);
      root.querySelector('[data-auth-mobile-icon-closed]')?.classList.toggle('hidden', open);
      root.querySelector('[data-auth-mobile-icon-open]')?.classList.toggle('hidden', !open);
    };

    const closeMobileNavigationAccordions = (exceptRoot = undefined) => {
      document.querySelectorAll('#header .dropdown.mobile-open').forEach((dropdown) => {
        if (dropdown === exceptRoot) return;

        if (dropdown.hasAttribute('data-mobile-auth-menu')) {
          setMenuOpen(dropdown, false);
          return;
        }

        dropdown.classList.remove('mobile-open');
        dropdown.querySelector('[data-mobile-accordion-trigger]')?.setAttribute('aria-expanded', 'false');
      });
    };

    let authMenuCloseTimer;

    const clearAuthMenuCloseTimer = () => {
      if (!authMenuCloseTimer) return;
      window.clearTimeout(authMenuCloseTimer);
      authMenuCloseTimer = undefined;
    };

    const closeAllMenus = () => {
      clearAuthMenuCloseTimer();
      getAuthRoots().forEach((root) => setMenuOpen(root, false));
    };

    const scheduleAuthMenuClose = (root) => {
      clearAuthMenuCloseTimer();
      authMenuCloseTimer = window.setTimeout(() => setMenuOpen(root, false), 180);
    };

    const getIdentity = async () => {
      const identityUrl = getIdentityUrl();
      headerAuthState.identityLoadPromise ||= loadNetlifyIdentity(
        identityUrl ? { APIUrl: identityUrl } : undefined
      );
      return headerAuthState.identityLoadPromise;
    };

    const getAdminState = async (token) => {
      if (!token) return { authenticated: false, isAdmin: false };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response.json().catch(() => ({ authenticated: true, isAdmin: false }));
    };

    const adminMenuItems = [
      { href: '/admin', text: 'Admin Dashboard' },
      { href: '/admin/publish', text: 'Publish Article' },
      { href: '/admin/agent-admin', text: 'AI Publisher' },
    ];

    const getSignedInLabel = (user, adminState) => {
      const email = adminState?.email || user?.email;
      const name = user?.user_metadata?.full_name;

      if (email) return email.split('@')[0] || email;
      return name || 'Account';
    };

    const renderAdminLinks = (container, isAdmin) => {
      container.hidden = !isAdmin;
      container.replaceChildren();

      if (!isAdmin) return;

      const divider = document.createElement('div');
      divider.className = 'my-1 border-t border-gray-200/70 dark:border-slate-700/70';
      container.append(divider);

      adminMenuItems.forEach((item) => {
        const link = document.createElement('a');
        link.className =
          'block rounded-lg px-2.5 py-1.5 font-medium leading-5 text-slate-600 transition-colors hover:bg-gray-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-900';
        link.href = item.href;
        link.role = 'menuitem';
        link.textContent = item.text;
        container.append(link);
      });
    };

    const renderAuthState = async (identity = undefined) => {
      const activeIdentity = identity ?? (await getIdentity());
      const user = activeIdentity.currentUser();
      const signedIn = Boolean(user && (isKeepSignedIn() || hasActiveSession()));

      if (user && !signedIn) {
        await activeIdentity.logout();
      }

      const token = signedIn ? user?.token?.access_token : undefined;
      const adminState = signedIn ? await getAdminState(token) : { authenticated: false, isAdmin: false };

      getAuthRoots().forEach((root) => {
        const trigger = root.querySelector('[data-auth-trigger]');
        const triggerLabel = root.querySelector('[data-auth-trigger-label]');
        const triggerChevron = root.querySelector('[data-auth-trigger-chevron]');
        const label = root.querySelector('[data-auth-label]');
        const signedOutPanel = root.querySelector('[data-auth-signed-out]');
        const signedInPanel = root.querySelector('[data-auth-signed-in]');
        const adminLinks = root.querySelector('[data-auth-admin-links]');

        root.dataset.authSignedIn = String(signedIn);
        root.dataset.authAdmin = String(Boolean(adminState.isAdmin));

        if (triggerLabel) triggerLabel.textContent = signedIn ? 'Account' : 'Login';
        if (triggerChevron) {
          triggerChevron.classList.toggle('hidden', false);
          triggerChevron.classList.toggle('rotate-180', trigger?.getAttribute('aria-expanded') === 'true');
        }
        if (!signedIn) setMenuOpen(root, false);
        if (label) label.textContent = signedIn ? getSignedInLabel(user, adminState) : 'Account';
        if (signedOutPanel) signedOutPanel.hidden = signedIn;
        if (signedInPanel) signedInPanel.hidden = !signedIn;
        if (adminLinks) renderAdminLinks(adminLinks, Boolean(adminState.isAdmin));

        document.querySelectorAll('[data-mobile-newsletter-cta]').forEach((cta) => {
          cta.hidden = signedIn;
        });

        const menu = root.querySelector('[data-auth-menu]');
        if (menu) menu.style.width = adminState.isAdmin ? 'min(15.5rem, calc(100vw - 2rem))' : '';
      });

      // Sync checkbox state
      const checkbox = getKeepSignedInCheckbox();
      if (checkbox) checkbox.checked = isKeepSignedIn();
    };

    const readKeepSignedIn = () => {
      const checkbox = getKeepSignedInCheckbox();
      return checkbox ? checkbox.checked : true;
    };

    const openSignIn = async () => {
      const identity = await getIdentity();

      // Store keep-signed-in preference before opening modal (survives OAuth redirects)
      const keep = readKeepSignedIn();
      sessionStorage.setItem('dr-lurie-login-keep-preference', keep ? '1' : '0');

      identity.open('login');
    };

    const openUserProfile = async () => {
      const identity = await getIdentity();
      identity.open('login');
    };

    const signOut = async () => {
      const identity = await getIdentity();
      localStorage.removeItem(KEEP_SIGNED_IN_KEY);
      sessionStorage.removeItem(SESSION_ACTIVE_KEY);
      sessionStorage.removeItem('dr-lurie-login-keep-preference');
      await identity.logout();
      await renderAuthState(identity);
      closeAllMenus();
    };

    const onLogin = async (identity, _user) => {
      const keepPref = sessionStorage.getItem('dr-lurie-login-keep-preference');
      const keep = keepPref === null ? true : keepPref === '1';

      if (keep) {
        localStorage.setItem(KEEP_SIGNED_IN_KEY, '1');
      } else {
        localStorage.removeItem(KEEP_SIGNED_IN_KEY);
      }
      sessionStorage.setItem(SESSION_ACTIVE_KEY, '1');
      sessionStorage.removeItem('dr-lurie-login-keep-preference');

      await renderAuthState(identity);
      closeAllMenus();
    };

    const initializeHeaderAuthState = () => {
      getIdentity()
        .then(async (identity) => {
          await renderAuthState(identity);

          if (!headerAuthState.identityListenersAttached) {
            headerAuthState.identityListenersAttached = true;

            identity.on('login', (user) => {
              onLogin(identity, user).catch((error) => {
                console.error('Header authentication login handler failed.', error);
              });
            });

            identity.on('logout', () => {
              renderAuthState(identity).catch((error) => {
                console.error('Header authentication refresh failed.', error);
              });
            });
          }
        })
        .catch((error) => {
          console.error('Header authentication initialization failed.', error);
        });
    };

    initializeHeaderAuthState();

    if (!headerAuthState.initialized) {
      headerAuthState.initialized = true;

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : undefined;
        const root = target?.closest('[data-header-auth]');
        const trigger = target?.closest('[data-auth-trigger]');
        const signInButton = target?.closest('[data-auth-sign-in]');
        const profileButton = target?.closest('[data-auth-profile]');
        const signOutButton = target?.closest('[data-auth-sign-out]');

        if (trigger && root) {
          event.preventDefault();
          event.stopPropagation();

          if (root.hasAttribute('data-mobile-auth-menu') && window.matchMedia('(max-width: 767px)').matches) {
            const willOpen = trigger.getAttribute('aria-expanded') !== 'true';
            closeAllMenus();
            closeMobileNavigationAccordions(root);
            setMenuOpen(root, willOpen);
            return;
          }

          const willOpen = trigger.getAttribute('aria-expanded') !== 'true';
          closeAllMenus();
          setMenuOpen(root, willOpen);
          return;
        }

        if (signInButton) {
          event.preventDefault();
          event.stopPropagation();
          openSignIn().catch((error) => {
            console.error('Header sign-in failed.', error);
          });
          return;
        }

        if (profileButton) {
          event.preventDefault();
          event.stopPropagation();
          openUserProfile().catch((error) => {
            console.error('Account settings failed.', error);
          });
          return;
        }

        if (signOutButton) {
          event.preventDefault();
          event.stopPropagation();
          signOut().catch((error) => {
            console.error('Header sign-out failed.', error);
          });
          return;
        }

        if (!root) closeAllMenus();
      });

      const handleAuthPointerEnter = (event) => {
        const target = event.target instanceof Element ? event.target : undefined;
        const root = target?.closest('[data-header-auth]');
        const trigger = target?.closest('[data-auth-trigger]');
        const menu = target?.closest('[data-auth-menu]');

        if (!root || (!trigger && !menu)) return;

        clearAuthMenuCloseTimer();
        setMenuOpen(root, true);
      };

      const handleAuthPointerLeave = (event) => {
        const target = event.target instanceof Element ? event.target : undefined;
        const root = target?.closest('[data-header-auth]');
        const nextTarget = event.relatedTarget;

        if (!root) return;
        if (nextTarget instanceof Node && root.contains(nextTarget)) return;

        scheduleAuthMenuClose(root);
      };

      document.addEventListener('pointerover', handleAuthPointerEnter);
      document.addEventListener('pointerout', handleAuthPointerLeave);

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeAllMenus();
      });

      document.addEventListener('astro:page-load', initializeHeaderAuthState);
    }
  })();
</script>
