---
import { getPermalink } from '~/utils/permalinks';

const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';
const clerkJsScriptSrc = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js';
---

<div
  class="header-auth relative ml-1"
  data-header-auth
  data-clerk-publishable-key={clerkPublishableKey}
  data-clerk-js-src={clerkJsScriptSrc}
>
  <button
    type="button"
    class="flex items-center whitespace-nowrap px-2 py-3 text-base font-medium tracking-[0.01rem] text-default transition-colors hover:text-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-white dark:focus-visible:ring-offset-slate-950 md:text-[0.9375rem]"
    data-auth-trigger
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <span data-auth-trigger-label>Login</span>
    <svg
      class="ml-0.5 hidden h-3.5 w-3.5 transition-transform rtl:ml-0 rtl:mr-0.5"
      data-auth-trigger-chevron
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>
  <div
    class="absolute right-0 z-50 mt-2 w-[min(21.5rem,calc(100vw-1rem))] origin-top-right rounded-2xl border border-gray-200/80 bg-white p-3 text-sm shadow-xl shadow-slate-900/10 transition duration-200 dark:border-slate-700/80 dark:bg-slate-900 dark:shadow-black/30"
    data-auth-menu
    role="menu"
    hidden
  >
    <div
      class="mb-2 truncate border-b border-gray-200/80 px-2 pb-2 text-[0.6875rem] font-medium uppercase leading-4 tracking-[0.1em] text-muted dark:border-slate-700/80"
      data-auth-label
    >
      Account
    </div>

    <div class="space-y-1" data-auth-signed-in hidden>
      <button
        type="button"
        class="w-full rounded-xl px-3 py-2 text-left font-semibold leading-5 text-slate-800 transition-colors hover:bg-gray-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-100 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-900"
        data-auth-profile
        role="menuitem"
      >
        Account settings
      </button>
      <a
        class="block rounded-xl px-3 py-2 font-semibold leading-5 text-slate-800 transition-colors hover:bg-gray-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-100 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-900"
        href={getPermalink('/member-updates')}
        role="menuitem"
      >
        Member updates
      </a>
      <div data-auth-admin-links hidden></div>
      <div class="my-1.5 border-t border-gray-200/80 dark:border-slate-700/80"></div>
      <button
        type="button"
        class="w-full rounded-xl px-3 py-2 text-left font-medium leading-5 text-slate-600 transition-colors hover:bg-gray-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-900"
        data-auth-sign-out
        role="menuitem"
      >
        Sign out
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    if (!window.__drLurieHeaderAuth) {
      window.__drLurieHeaderAuth = {
        clerkLoadPromise: undefined,
        initialized: false,
      };
    }

    const headerAuthState = window.__drLurieHeaderAuth;
    const getAuthRoots = () => Array.from(document.querySelectorAll('[data-header-auth]'));

    const getHeaderAuthConfig = () => {
      const firstRoot = getAuthRoots()[0];
      return {
        clerkPublishableKey: firstRoot?.dataset.clerkPublishableKey || '',
        clerkJsScriptSrc: firstRoot?.dataset.clerkJsSrc || '',
      };
    };

    const setMenuOpen = (root, open) => {
      const trigger = root.querySelector('[data-auth-trigger]');
      const menu = root.querySelector('[data-auth-menu]');
      if (!trigger || !menu) return;

      menu.hidden = !open;
      trigger.setAttribute('aria-expanded', String(open));
      root.querySelector('[data-auth-trigger-chevron]')?.classList.toggle('rotate-180', open);
    };

    let authMenuCloseTimer;

    const clearAuthMenuCloseTimer = () => {
      if (!authMenuCloseTimer) return;

      window.clearTimeout(authMenuCloseTimer);
      authMenuCloseTimer = undefined;
    };

    const closeAllMenus = () => {
      clearAuthMenuCloseTimer();
      getAuthRoots().forEach((root) => setMenuOpen(root, false));
    };

    const scheduleAuthMenuClose = (root) => {
      clearAuthMenuCloseTimer();
      authMenuCloseTimer = window.setTimeout(() => setMenuOpen(root, false), 180);
    };

    const loadClerkScript = () =>
      new Promise((resolve, reject) => {
        const { clerkPublishableKey, clerkJsScriptSrc } = getHeaderAuthConfig();

        if (window.Clerk) {
          resolve();
          return;
        }

        const existingScript = document.querySelector(
          `script[data-dr-lurie-clerkjs="true"], script[src="${clerkJsScriptSrc}"]`
        );

        if (existingScript) {
          existingScript.addEventListener('load', () => resolve(), { once: true });
          existingScript.addEventListener(
            'error',
            () => reject(new Error('Clerk authentication could not be loaded.')),
            {
              once: true,
            }
          );
          return;
        }

        const script = document.createElement('script');
        script.src = clerkJsScriptSrc;
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.dataset.drLurieClerkjs = 'true';
        script.dataset.clerkPublishableKey = clerkPublishableKey;
        script.addEventListener('load', () => resolve(), { once: true });
        script.addEventListener('error', () => reject(new Error('Clerk authentication could not be loaded.')), {
          once: true,
        });
        document.head.append(script);
      });

    const getClerk = async () => {
      const { clerkPublishableKey } = getHeaderAuthConfig();

      if (!clerkPublishableKey) {
        throw new Error('Header authentication is not configured.');
      }

      headerAuthState.clerkLoadPromise ||= (async () => {
        await loadClerkScript();

        let clerk = window.Clerk;
        if (typeof clerk === 'function') {
          clerk = new clerk(clerkPublishableKey);
          window.Clerk = clerk;
        }

        if (!clerk || typeof clerk.load !== 'function') {
          throw new Error('Clerk authentication could not be initialized.');
        }

        await clerk.load();
        return clerk;
      })();

      return headerAuthState.clerkLoadPromise;
    };

    const getAdminState = async (clerk) => {
      if (!clerk.isSignedIn || !clerk.session) return { authenticated: false, isAdmin: false };

      const token = await clerk.session.getToken();
      if (!token) return { authenticated: true, isAdmin: false };

      const response = await fetch('/.netlify/functions/admin-auth-state', {
        method: 'GET',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      return response.json().catch(() => ({ authenticated: true, isAdmin: false }));
    };

    const adminMenuItems = [
      { href: '/admin', text: 'Admin Dashboard' },
      { href: '/admin/publish', text: 'Publish Article' },
      { href: '/admin/agent-admin', text: 'AI Publisher' },
    ];

    const getSignedInLabel = (clerk, adminState) => {
      const email = adminState?.email || clerk.user?.primaryEmailAddress?.emailAddress;
      const name = clerk.user?.fullName || clerk.user?.firstName;
      return email || name || 'Account';
    };

    const renderAdminLinks = (container, isAdmin) => {
      container.hidden = !isAdmin;
      container.replaceChildren();

      if (!isAdmin) return;

      const divider = document.createElement('div');
      divider.className = 'my-1.5 border-t border-gray-200/80 dark:border-slate-700/80';
      container.append(divider);

      adminMenuItems.forEach((item) => {
        const link = document.createElement('a');
        link.className =
          'block rounded-xl px-3 py-2 font-medium leading-5 text-slate-600 transition-colors hover:bg-gray-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white dark:focus-visible:ring-offset-slate-900';
        link.href = item.href;
        link.role = 'menuitem';
        link.textContent = item.text;
        container.append(link);
      });
    };

    const renderAuthState = async (clerk = undefined) => {
      const activeClerk = clerk ?? (await getClerk());
      const signedIn = Boolean(activeClerk.isSignedIn && activeClerk.session);
      const adminState = signedIn ? await getAdminState(activeClerk) : { authenticated: false, isAdmin: false };

      getAuthRoots().forEach((root) => {
        const trigger = root.querySelector('[data-auth-trigger]');
        const triggerLabel = root.querySelector('[data-auth-trigger-label]');
        const triggerChevron = root.querySelector('[data-auth-trigger-chevron]');
        const label = root.querySelector('[data-auth-label]');
        const signedInPanel = root.querySelector('[data-auth-signed-in]');
        const adminLinks = root.querySelector('[data-auth-admin-links]');

        root.dataset.authSignedIn = String(signedIn);
        if (trigger) {
          trigger.setAttribute('aria-haspopup', signedIn ? 'menu' : 'dialog');
        }
        if (triggerLabel) triggerLabel.textContent = signedIn ? 'Account' : 'Login';
        if (triggerChevron) {
          triggerChevron.classList.toggle('hidden', !signedIn);
          triggerChevron.classList.toggle('rotate-180', signedIn && trigger?.getAttribute('aria-expanded') === 'true');
        }
        if (!signedIn) setMenuOpen(root, false);
        if (label) label.textContent = signedIn ? getSignedInLabel(activeClerk, adminState) : 'Welcome';
        if (signedInPanel) signedInPanel.hidden = !signedIn;
        if (adminLinks) renderAdminLinks(adminLinks, Boolean(adminState.isAdmin));
      });
    };

    const redirectToHostedSignIn = async (clerk) => {
      if (typeof clerk.redirectToSignIn !== 'function') {
        throw new Error('Clerk hosted sign-in redirect is unavailable.');
      }

      await clerk.redirectToSignIn({ redirectUrl: window.location.href });
    };

    const openSignIn = async () => {
      const clerk = await getClerk();

      if (typeof clerk.openSignIn === 'function') {
        try {
          await clerk.openSignIn();
          await renderAuthState(clerk);
          return;
        } catch (error) {
          console.error('Clerk modal sign-in failed. Falling back to hosted sign-in redirect.', error);
        }
      } else {
        console.error('Clerk modal sign-in is unavailable. Falling back to hosted sign-in redirect.');
      }

      await redirectToHostedSignIn(clerk);
    };

    const openUserProfile = async () => {
      const clerk = await getClerk();
      if (typeof clerk.openUserProfile === 'function') {
        await clerk.openUserProfile();
      }
    };

    const signOut = async () => {
      const clerk = await getClerk();
      await clerk.signOut();
      await renderAuthState(clerk);
      closeAllMenus();
    };

    if (!headerAuthState.initialized) {
      headerAuthState.initialized = true;

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : undefined;
        const root = target?.closest('[data-header-auth]');
        const trigger = target?.closest('[data-auth-trigger]');
        const signInButton = target?.closest('[data-auth-sign-in]');
        const profileButton = target?.closest('[data-auth-profile]');
        const signOutButton = target?.closest('[data-auth-sign-out]');

        if (trigger && root) {
          event.preventDefault();
          event.stopPropagation();

          if (root.dataset.authSignedIn !== 'true') {
            openSignIn().catch((error) => {
              console.error('Header sign-in failed.', error);
            });
            return;
          }

          closeAllMenus();
          setMenuOpen(root, true);
          renderAuthState().catch((error) => {
            console.error('Header authentication refresh failed.', error);
          });

          return;
        }

        if (signInButton) {
          event.preventDefault();
          event.stopPropagation();
          openSignIn().catch((error) => {
            console.error('Header sign-in failed.', error);
          });
          return;
        }

        if (profileButton) {
          event.preventDefault();
          event.stopPropagation();
          openUserProfile().catch((error) => {
            console.error('Clerk account settings failed.', error);
          });
          return;
        }

        if (signOutButton) {
          event.preventDefault();
          event.stopPropagation();
          signOut().catch((error) => {
            console.error('Header sign-out failed.', error);
          });
          return;
        }

        if (!root) closeAllMenus();
      });

      document.addEventListener('mouseover', (event) => {
        const target = event.target instanceof Element ? event.target : undefined;
        const root = target?.closest('[data-header-auth]');
        const trigger = target?.closest('[data-auth-trigger]');
        const menu = target?.closest('[data-auth-menu]');

        if (!root || root.dataset.authSignedIn !== 'true' || (!trigger && !menu)) return;

        clearAuthMenuCloseTimer();
        setMenuOpen(root, true);
      });

      document.addEventListener('mouseout', (event) => {
        const target = event.target instanceof Element ? event.target : undefined;
        const root = target?.closest('[data-header-auth]');
        const nextTarget = event.relatedTarget;

        if (!root || root.dataset.authSignedIn !== 'true') return;
        if (nextTarget instanceof Node && root.contains(nextTarget)) return;

        scheduleAuthMenuClose(root);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeAllMenus();
      });

      document.addEventListener('astro:page-load', () => {
        renderAuthState().catch((error) => {
          console.error('Header authentication refresh failed.', error);
        });
      });
    }

    getClerk()
      .then(async (clerk) => {
        await renderAuthState(clerk);
        if (typeof clerk.addListener === 'function' && !headerAuthState.clerkListenerAttached) {
          headerAuthState.clerkListenerAttached = true;
          clerk.addListener(() => {
            renderAuthState(clerk).catch((error) => {
              console.error('Header authentication refresh failed.', error);
            });
          });
        }
      })
      .catch((error) => {
        console.error('Header authentication initialization failed.', error);
      });
  })();
</script>
