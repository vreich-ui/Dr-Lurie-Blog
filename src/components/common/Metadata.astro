---
import merge from 'lodash.merge';

import { SITE, METADATA, I18N } from 'astrowind:config';
import type { MetaData, MetaDataImage } from '~/types';
import { getCanonical } from '~/utils/permalinks';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const FALLBACK_TITLE = METADATA?.title?.default || SITE?.name || 'Dr. Lurié';
const FALLBACK_DESCRIPTION =
  METADATA?.description ||
  'Science-led education on aging skin, age-related scent changes, and future age-aware skincare solutions.';
const FALLBACK_IMAGE: MetaDataImage = {
  url: '/social-preview.png',
  width: 1200,
  height: 630,
};

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

const siteUrl = Astro.site ?? new URL(SITE?.site || 'https://drluriescience.netlify.app');
const resolvedTitle = title || FALLBACK_TITLE;
const resolvedDescription = description || FALLBACK_DESCRIPTION;
const titleTemplate = ignoreTitleTemplate ? '%s' : METADATA?.title?.template || '%s';
const pageTitle = titleTemplate.includes('%s') ? titleTemplate.replace('%s', resolvedTitle) : resolvedTitle;
const noindex = typeof robots?.index !== 'undefined' ? !robots.index : METADATA?.robots?.index === false;
const nofollow = typeof robots?.follow !== 'undefined' ? !robots.follow : METADATA?.robots?.follow === false;

const mergedOpenGraph = merge(
  {
    url: canonical,
    site_name: SITE?.name,
    title: pageTitle,
    description: resolvedDescription,
    images: [FALLBACK_IMAGE],
    locale: I18N?.language || 'en',
    type: 'website',
  },
  METADATA?.openGraph || {},
  {
    url: canonical,
    title: pageTitle,
    description: resolvedDescription,
  },
  openGraph || {}
);

const adaptedOpenGraph = await adaptOpenGraphImages(mergedOpenGraph, siteUrl);
const primaryImage = adaptedOpenGraph?.images?.find((image) => image?.url) || FALLBACK_IMAGE;
const absoluteImageUrl = String(new URL(primaryImage.url, siteUrl));
const imageWidth = primaryImage.width || FALLBACK_IMAGE.width;
const imageHeight = primaryImage.height || FALLBACK_IMAGE.height;
const ogType = adaptedOpenGraph?.type || 'website';
const ogSiteName = adaptedOpenGraph?.site_name || adaptedOpenGraph?.siteName || SITE?.name;
const ogLocale = adaptedOpenGraph?.locale || I18N?.language || 'en';

const mergedTwitter = merge(
  {
    cardType: 'summary_large_image',
    title: pageTitle,
    description: resolvedDescription,
    image: absoluteImageUrl,
  },
  METADATA?.twitter || {},
  twitter || {},
  {
    title: twitter?.title || pageTitle,
    description: twitter?.description || resolvedDescription,
    image: twitter?.image || absoluteImageUrl,
  }
);

const robotsContent = [noindex ? 'noindex' : 'index', nofollow ? 'nofollow' : 'follow'].join(', ');
---

<title>{pageTitle}</title>
<meta name="description" content={resolvedDescription} />
<meta name="robots" content={robotsContent} />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={adaptedOpenGraph?.title || pageTitle} />
<meta property="og:description" content={adaptedOpenGraph?.description || resolvedDescription} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={adaptedOpenGraph?.url || canonical} />
<meta property="og:image" content={absoluteImageUrl} />
<meta property="og:image:width" content={String(imageWidth)} />
<meta property="og:image:height" content={String(imageHeight)} />
{ogSiteName && <meta property="og:site_name" content={ogSiteName} />}
{ogLocale && <meta property="og:locale" content={ogLocale} />}

<meta name="twitter:card" content={mergedTwitter.cardType || 'summary_large_image'} />
<meta name="twitter:title" content={mergedTwitter.title || pageTitle} />
<meta name="twitter:description" content={mergedTwitter.description || resolvedDescription} />
<meta name="twitter:image" content={mergedTwitter.image || absoluteImageUrl} />
{mergedTwitter.site && <meta name="twitter:site" content={mergedTwitter.site} />}
{mergedTwitter.handle && <meta name="twitter:creator" content={mergedTwitter.handle} />}
